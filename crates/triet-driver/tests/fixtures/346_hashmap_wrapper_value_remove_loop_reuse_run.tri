// EXPECT: 1
// ADR-0082 B-α Slice D-2 — LOOP-REUSE teeth for the present-tag write, T9
// 8B path analog of 345 (`Wrapper{v:Vector<String>}`, total_size==8).
// Same deterministic slot-reuse hazard as 345: iter0 (not-found) writes
// `NULL_SENTINEL`@tag(slot+0) via the T9 empty branch; iter1 (found) must
// overwrite it with the present marker, or `hits` stays 0 instead of 1.
struct Wrapper { v: Vector<String> }

function main() -> Integer {
    let mutable m: HashMap<Integer, Wrapper> = hashmap_new();
    let mutable i: Integer = 0;
    let mutable hits: Integer = 0;
    while i < 2 {
        let out = remove(m, 1);
        hits = match out {
            ~0 => {
                let mutable inner: Vector<String> = vector_new();
                inner = push(inner, "x");
                m = insert(m, 1, Wrapper { v: inner });
                hits
            },
            ~+ w => { hits + 1 },
        };
        i = i + 1;
    }
    return hits;
}
