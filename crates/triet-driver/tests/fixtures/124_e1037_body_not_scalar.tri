// ERROR: E1037
// APP.2b-1: ~+> body must be Bậc A scalar — String (heap) rejected.

function succeed() -> Integer~Integer =
    ~+ 42

// Body returns String — heap type cannot fit in i64 payload slot.
function bad_map() -> Integer~Integer =
    succeed() ~+> |a| "not a scalar"

function main() -> Integer = 0
