// EXPECT: 129
// ADR-0064: match on an Integer-typed scrutinee (value-keyed SwitchInt, mirror
// Trit-path). classify(1)=10 (case), classify(2)=20 (case), classify(9)=99
// (wildcard catch-all). 10 + 20 + 99 = 129 — a wrong case→arm mapping, a missing
// wildcard fallthrough, or a broken switch changes the total.
// NOTE: the scrutinee must be Integer-typed (here a param) — a bare `let x = 2`
// infers MirType::Unknown and is out of scope for this lát (type-inference gap).
function classify(x: Integer) -> Integer = match x {
    1 => 10,
    2 => 20,
    _ => 99,
}

function main() -> Integer = classify(1) + classify(2) + classify(9)
