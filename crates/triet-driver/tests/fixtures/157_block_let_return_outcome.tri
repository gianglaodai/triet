// EXPECT: 5
// ADR-0055 Bug A: same dead-block hazard via a let-bound Outcome then return.
// ADR-0072 Slice 3: the binding is annotated `Integer~String` — after the §2.5
// fallback removal, `~+ 5` reads its expected type from the annotation, not the
// (now-severed) c.sig.return_type proxy. Untyped `let r = ~+ 5` is rejected (309).
function f() -> Integer~String { let r: Integer~String = ~+ 5; return r; }
function main() -> Integer = match f() { ~+ x => x  ~- e => -1 }
