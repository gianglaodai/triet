// EXPECT: 2
// ADR-0062 Heap-Nullable Lát 4: Elvis `?:` on a non-null `String?`. f()
// returns "hi" (non-null) → ptr@0 != NULL_SENTINEL → Elvis yields the object
// ("hi"), NOT the default "abc" (len 3). len(r) = 2 confirms the present value
// was chosen (2, not 3).
function f() -> String? = "hi"

function main() -> Integer {
    let r = f() ?: "abc";
    return len(r);
}
