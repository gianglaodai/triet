// EXPECT: 99
// Pin: qualified payload variant with disc≠0 (NoneInt = disc 1).
enum OptionA { SomeInt(Integer), NoneInt }
enum OptionB { SomeInt(Integer), NoneInt }

function main() -> Integer = {
    let a = OptionA.NoneInt;
    return match a {
        SomeInt(x) => x,
        NoneInt => 99,
    };
}
