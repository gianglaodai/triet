// EXPECT: 99
// Pin: qualified payload variant with discâ‰ 0 (NoneInt = disc 1). `SomeInt`/
// `NoneInt` are shared by OptionA and OptionB â€” ADR-0071 `::` disambiguates.
enum OptionA { SomeInt(Integer), NoneInt }
enum OptionB { SomeInt(Integer), NoneInt }

function main() -> Integer = {
    let a = OptionA::NoneInt;
    return match a {
        OptionA::SomeInt(x) => x,
        OptionA::NoneInt => 99,
    };
}
