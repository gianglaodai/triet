// ERROR: E1039
// APP.2c: ~-> with T ≡ E — body auto-wrap is ambiguous.
// inner() ~-> |e| e with Integer~Integer: both slots are Integer,
// the compiler cannot distinguish intent.  Fix: explicit ~- or match.

function fail() -> Integer~Integer =
    ~- -99

function propagate() -> Integer~Integer =
    fail() ~-> |e| e  // T≡E, auto-wrap ambiguous → E1039

function main() -> Integer = 0
