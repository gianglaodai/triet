// EXPECT: 3
// ADR-0062 Heap-Nullable Lát 4: Elvis `?:` on a null `String?`. f() returns
// `~0` → ptr@0 == NULL_SENTINEL → Elvis evaluates the default expression
// "abc" (len 3). len(r) = 3 confirms the null branch took the default.
function f() -> String? = ~0

function main() -> Integer {
    let r = f() ?: "abc";
    return len(r);
}
