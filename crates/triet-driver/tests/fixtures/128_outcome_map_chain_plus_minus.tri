// EXPECT: 45
// APP.2c: chain ~+> (map success Integerâ†’Integer) then ~-> (map error Trileanâ†’Trit).
// Tests 3 merge_bb in one CFG (1 ~+> + 1 ~->).

function start() -> Integer~Trilean =
    ~+ 42

function chain() -> Integer~Trit =
    (start() ~+> |a| a + 3) ~-> |e| 1_trit

function main() -> Integer =
    match chain() {
        ~+ x => x
        ~- t => -999
    }
