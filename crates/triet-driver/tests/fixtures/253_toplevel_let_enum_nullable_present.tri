// EXPECT: 5
// ADR-0065 §12.8: top-level `let x: Color? = ~+ Color::Green`. The redirect lowers the
// inner enum literal `Color::Green` as a PLAIN enum; the widening block retypes it
// Nullable(Color) in-place (niche disc@0: a valid variant disc != MIN, so the
// present arm fires — mirror of fixture 229/225). Without the redirect `~+` →
// OutcomeAlloc on main's non-Outcome return type (Bug B). Poison (P1) → red.
enum Color {
    Red,
    Green,
}

function main() -> Integer = {
    let x: Color? = ~+ Color::Green;
    return match x {
        ~+ v => match v {
            Color::Red => 1,
            Color::Green => 5,
        },
        ~0 => -1,
    };
}
