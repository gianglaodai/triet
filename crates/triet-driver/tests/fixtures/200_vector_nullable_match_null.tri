// EXPECT: 99
// ADR-0062 Heap-Nullable Lát 4.8: match on a null `Vector<Integer>?`. f()
// returns `~0` → the handle = NULL_SENTINEL → the null-check routes to the
// `~0` arm → 99. No dereference of the handle on the null path.
function f() -> Vector<Integer>? = ~0

function main() -> Integer {
    let x = f();
    return match x {
        ~+ v => len(v),
        ~0 => 99,
    };
}
