// EXPECT: 2
// ADR-0055 regression-lock: tail-`match` producing a binary Outcome (T~E).
// h(Color::Green) → ~+ 2; caller match-unwraps the success payload. Color::Green WITHOUT
// lát-2 Bước A.
enum Color { Red, Green, Blue }

function h(c: Color) -> Integer~String {
    match c {
        Color::Red => ~+ 1,
        Color::Green => ~+ 2,
        Color::Blue => ~- "e",
    }
}

function main() -> Integer =
    match h(Color::Green) {
        ~+ x => x
        ~- e => -1
    }
