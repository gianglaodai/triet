// EXPECT: 0
// Phase 2 (ADR-0070 read-side) — a single-level heap-STRUCT field move-out is
// now ALLOWED. `h.inner` is a struct-typed field whose struct owns a String;
// moving it out into `m` is sound: borrowck records the partial move and the JIT
// tombstones the moved struct's heap leaf at its absolute offset in the base
// slot (collect_heap_leaves with base_offset=field_off), so the base's scope-end
// Drop frees nothing already moved (no double-free). The ADR-0067
// construction-into-field double-free that previously blocked this is fixed.
struct Inner {
    name: String,
}

struct Holder {
    inner: Inner,
    tag: Integer,
}

function main() -> Integer {
    let n = "hi";
    let i = Inner { name: n };
    let h = Holder { inner: i, tag: 5 };
    let m = h.inner;         // single-level heap-STRUCT field move-out → E2423
    return 0;
}
