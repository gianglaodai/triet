// EXPECT: 129
// ADR-0064 §A1.2: match on a Tryte-typed scrutinee (value-keyed SwitchInt,
// same i64 key extraction as Integer via lower_value_keyed_match). Tryte's
// domain is impractically large (19_683 values), so exhaustiveness REQUIRES a
// `_` wildcard. classify(1_tryte)=10 (case), classify(2_tryte)=20 (case),
// classify(9_tryte)=99 (wildcard catch-all). 10 + 20 + 99 = 129 — a wrong
// case→arm mapping, a missing wildcard fallthrough, or a broken switch changes
// the total.
function classify(x: Tryte) -> Integer = match x {
    1_tryte => 10,
    2_tryte => 20,
    _ => 99,
}

function main() -> Integer = classify(1_tryte) + classify(2_tryte) + classify(9_tryte)
