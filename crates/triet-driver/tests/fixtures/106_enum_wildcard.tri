// EXPECT: 0
// C2: enum match with wildcard fallback.
// Color::Red‚Üí1, Color::Blue‚Üí2, _‚Üí0. Scrutinee is Color::Green ‚Üí wildcard arm ‚Üí 0.
enum Color { Red, Blue, Green }

function main() -> Integer = {
    let c = Color::Green;
    return match c {
        Color::Red => 1,
        Color::Blue => 2,
        _ => 0,
    };
}
