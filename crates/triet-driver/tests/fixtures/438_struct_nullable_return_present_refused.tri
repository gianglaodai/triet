// ERROR: nullable struct return
// WO-StructReturnRefuse T2 (O+G mandate, 2026-07-19): `Struct?` in RETURN
// position, PRESENT arm, field read (`v.x + v.y`). Pre-guard measured on
// 768fc8e: reading one field returned garbage address-shaped bits; reading
// both fields traps SIGILL 132 (garbage + garbage overflow, ADR-0044). This
// fixture pins the POLICY GATE refuse shut for the present-value shape.
struct P { x: Integer, y: Integer }

function make() -> P? {
    return ~+ P { x: 40, y: 2 };
}

function main() -> Integer {
    return match make() {
        ~+ v => v.x + v.y,
        ~0 => -1,
    };
}
