// EXPECT: 10
// String return through user-function boundary + concat observable.
// Phase 4.3c: concat wired through typechecker — no more constant return.
function make() -> String {
    let s = "hello";
    return s;
}
function main() -> Integer {
    let t = make();
    let u = concat(t, "world");
    return len(u);
}
