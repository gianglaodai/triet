// EXPECT: 10
// LATENT E2450 guard: `r = &0 x` creates a read-only borrow.
// The lowerer does not emit explicit Drop for parameters at function
// exit, so E2450 (DropWhileBorrowed) is not reachable through the
// real pipeline. When the lowerer starts emitting Drop statements,
// change to: // ERROR: E2450
function demo(x: Integer) -> Integer {
    let r = &0 x;
    return x;
}
function main() -> Integer {
    return demo(10);
}
