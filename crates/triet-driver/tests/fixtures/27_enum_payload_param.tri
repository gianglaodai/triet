// EXPECT: 52
// C1: Enum payload by-pointer — payload survives crossing function boundary.
enum OptionInt { SomeInt(Integer), NoneInt }

function unwrap_or_default(opt: OptionInt, default_val: Integer) -> Integer =
    match opt {
        SomeInt(x) => x,
        NoneInt => default_val,
    }

function main() -> Integer = {
    let a = SomeInt(52);
    return unwrap_or_default(a, 0);
}
