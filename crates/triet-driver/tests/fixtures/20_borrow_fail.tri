// ERROR: E2440
// Double exclusive borrow where at least one is actually used —
// NLL live ranges overlap → E2440 NllExclusivityViolation.
// (Same pattern as examples/test_borrow.tri.)
function demo(vga: Integer) -> Integer {
    let a = &0 mutable vga;
    let b = &0 mutable vga;
    return a;
}
function main() -> Integer {
    return demo(42);
}
