// EXPECT: 3
// ADR-0065 §12.7: a `Struct?` FIELD set to a plain `Point{...}` (implicit
// widening). The field Assign hits case 2 WIDEN: set tag=present(1)@field+0,
// copy Point fields → field+8. The match present-arm binds `pt` (case 3
// DOWNCAST, fields src+8 → dest+0) and reads `pt.x` = 3. NOT pass-by-luck: the
// tag is set explicitly (poison case 2 — drop the set-tag — turns this red).
struct Point { x: Integer, y: Integer }
struct Holder { p: Point? }

function main() -> Integer = {
    let h = Holder { p: Point { x: 3, y: 4 } };
    return match h.p {
        ~+ pt => pt.x,
        ~0 => -1,
    };
}
