// EXPECT: 10
// GAP: E2450 (DropWhileBorrowed) is dead end-to-end.
//
// The borrowck crate implements E2450, but it never fires through
// the real pipeline because the lowerer does not emit Drop statements
// for locals at function exit. Without a Drop in the MIR, the
// borrowck's Drop handler is never reached.
//
// This fixture will become a negative test (// ERROR: E2450) when
// the lowerer starts emitting Drop. Until then, it documents the gap.
function demo(x: Integer) -> Integer {
    let r = &0 x;
    return x;
}
function main() -> Integer {
    return demo(10);
}
