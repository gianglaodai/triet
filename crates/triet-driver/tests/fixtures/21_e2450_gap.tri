// ERROR: E2450
// Returning a borrowed value: `r = &0 x` creates a shared borrow on `x`,
// then `return x` tries to move `x` out of the function while the borrow
// is still active. E2450 fires because `x` still has active loans when
// its storage ends.
function demo(x: Integer) -> Integer {
    let r = &0 x;
    return x;
}
function main() -> Integer {
    return demo(10);
}
