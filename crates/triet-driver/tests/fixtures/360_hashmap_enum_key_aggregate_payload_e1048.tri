// EXPECT: 42007
// SUPERSEDED by ADR-0067 §AMEND (Enum-Payload-Aggregate Sizing) — this
// fixture used to assert `// ERROR: E1048`: an enum key whose variant
// carries an AGGREGATE payload (a Struct/Enum > 8B) was refused because the
// lowerer sized every enum payload at a fixed 8B (no aggregate-payload
// fixup), so a nested `Point{x,y}` (16B) was under-sized and would truncate
// on the key marshal → silent MISS. ADR-0067 §AMEND closed that gap with a
// struct+enum co-fixpoint (`triet-lower/src/lib.rs`) and lifted the
// `is_hashable_enum_payload` typecheck refuse + the JIT walker's defence-in-
// depth guard — this exact scenario is now sound. insert `Dot(Point{3,4})`
// =42; a FRESH `Dot(Point{3,4})` (same content, different construction) must
// HIT (42); a different-content key must MISS (~0 → 7). See fixture
// 370_hashmap_enum_aggregate_key_roundtrip.tri for the companion test using
// distinct type names.
struct Point { x: Integer, y: Integer }
enum Shape { Dot(Point), None }
function main() -> Integer = {
    let m: HashMap<Shape, Integer> = hashmap_new();
    let k = Shape::Dot(Point { x: 3, y: 4 });
    let m2 = insert(m, k, 42);
    let hit = get(&0 m2, Shape::Dot(Point { x: 3, y: 4 }));
    let miss = get(&0 m2, Shape::Dot(Point { x: 9, y: 9 }));
    let a = match hit { ~+ v => v, ~0 => -1 };
    let b = match miss { ~+ v => v, ~0 => 7 };
    return a * 1000 + b;
}
