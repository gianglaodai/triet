// ERROR: E1049
// ADR-0082 §AMEND-3.1/3.3 — `get(m,k)` on `HashMap<Integer, Tagged>` where
// `Tagged` has a `String` leaf must REFUSE (E1049). Same predicate as the
// Vector case (364), exercised through the HashMap scalar-key arm instead —
// proves the refuse isn't accidentally Vector-only. Non-vacuous: a plain
// `HashMap<Integer, Point>` (Copy struct value) compiles fine (fixture 362).
struct Tagged { name: String }

function main() -> Integer {
    let mutable m: HashMap<Integer, Tagged> = hashmap_new();
    m = insert(m, 1, Tagged { name: "x" });
    let r = get(m, 1);
    return 0;
}
