// EXPECT: 5
// ADR-0062 Heap-Nullable LĂˇt 5 (Bug B): `?+>` map heapâ†’scalar. Input String?,
// body returns Integer (len) â†’ result must be Integer?. Before the fix the
// result was typed from the INPUT (String?), so Drop ran string_free on a
// scalar value â€” latent UB. Retyping from the body fixes it. f()="hello",
// len 5 â†’ Elvis â†’ 5.
function f() -> String? = "hello"

function main() -> Integer {
    let r = (f() ?+> |s| len(s)) ?: 0;
    return r;
}
