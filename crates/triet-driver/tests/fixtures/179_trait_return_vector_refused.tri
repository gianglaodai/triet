// ERROR: Vector/HashMap/Enum/Reference returns deferred
// Nợ #2 §2 (refuse NARROW): a trait method returning Vector still needs its
// own ABI. The lowerer must REFUSE cleanly, NOT fall through to the scalar
// branch and miscompile the fat pointer into a single i64 (silent soundness
// hole). Poison check: delete the narrow refuse arm → the call falls into the
// scalar branch and miscompiles instead of producing this clean Err.
//
// `v` is bound but not consumed: `length(v)` would trip an unrelated typecheck
// overload error first, masking the lower-side refuse we want to exercise.
trait Producer {
    function items(self) -> Vector<Integer>
}

implement Producer for Integer {
    function items(self) -> Vector<Integer> = vector_new()
}

function main() -> Integer = {
    let v = (1).items();
    return 0;
}
