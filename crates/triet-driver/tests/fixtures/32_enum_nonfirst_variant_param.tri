// EXPECT: 2
// Pin: non-first discriminant via param — was silently miscompiled
// (callee always received 0 because caller arg-prep ignored enum_slots).

enum Color { Red, Green, Blue }

function map_color(c: Color) -> Integer =
    match c {
        Color::Red => 1,
        Color::Green => 2,
        Color::Blue => 3,
    }

function main() -> Integer = {
    let c = Color::Green;
    return map_color(c);
}
