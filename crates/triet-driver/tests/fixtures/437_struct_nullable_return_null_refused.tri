// ERROR: nullable struct return
// WO-StructReturnRefuse T1 (O+G mandate, 2026-07-19): `Struct?` in RETURN
// position, NULL arm. Pre-guard measured on 768fc8e: the `~0` return read
// back as the WRONG present value (silent, exit 0, match hit the `~+` arm
// instead of `~0` — câm). This fixture pins the POLICY GATE refuse
// (`nullable_struct_return_unsupported`) shut.
struct P { x: Integer, y: Integer }

function make() -> P? {
    return ~0;
}

function main() -> Integer {
    return match make() {
        ~+ v => 1,
        ~0 => 0,
    };
}
