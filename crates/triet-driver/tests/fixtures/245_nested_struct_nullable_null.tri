// EXPECT: 99
// ADR-0065 §12.7: a `Struct?` FIELD set to `~0`. Construction materializes
// NULL_SENTINEL into the field's tag@0; the field Assign (case 1 WHOLE-COPY,
// tag-first) preserves it; the match null-check `tag@0 == i64::MIN` routes to
// `~0` → 99. This is the bug the rejected Lát 5 returned garbage on (base-
// downcast nuốt the tag in whole-slot move). Poison case 1 (force +8 downcast) →
// tag lost → present-arm → red.
struct Point { x: Integer, y: Integer }
struct Holder { p: Point? }

function main() -> Integer = {
    let h = Holder { p: ~0 };
    return match h.p {
        ~+ pt => pt.x,
        ~0 => 99,
    };
}
