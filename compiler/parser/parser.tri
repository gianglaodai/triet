// Triết-in-Triết parser port — bootstrap source for the self-hosting
// compiler ([ADR-0019][adr-0019] §A7.5 v0.7.5 umbrella).
//
// v0.7.5.1 — AST + Arena scaffolding. Mirrors crates/triet-syntax/'s
// arena pattern (Vec<Spanned<T>> + u32 index handle) using Triết's
// Vector<T> + Integer index. Minimal Expr/Pattern/TypeExpr/Stmt
// surface for the scaffolding smoke; subsequent sub-tasks expand
// each enum as parser features land.
//
// v0.7.5.2 — Pratt expressions + atoms. Wires up compiler/lexer.tri
// via `module lexer;` + `from khi.lexer import …` and grows the
// parser surface to cover: literals (Integer / Ternary / Trilean /
// String / NullLiteral / Identifier), parenthesised expressions,
// unary `Negate`, the full 17-variant `BinaryOperator` Pratt
// precedence ladder, force-unwrap `!!`, the Outcome operator trio
// (`~+` / `~0` / `~-` constructors and the `~?` / `~:` postfix
// operators), Elvis `?:`, range `..` / `..=`, and the dotted
// postfix family (Call / FieldAccess / MethodCall). Block / If /
// Match / StructLiteral / FString / Lambda / Tuple / safe-access
// stay deferred to v0.7.5.3+ since they require the statement
// layer or item-level context. ParserState threads `(tokens, cursor,
// arena)` functionally and parse helpers return `ParseStep~ParseError`
// (wrapper struct, not a tuple — IR tuple returns defer post-v1.0).
//
// v0.7.5.3 — Statements + bindings. Brings the parser up to
// crates/triet-parser/src/stmt.rs: `Block`, the `Stmt` enum
// (`Let` / `Constant` / `Return` / `Break` / `Continue` / `For` /
// `While` / `While?` / `Loop` / `Assign` / `ExpressionStmt`),
// plus the brace-delimited `parse_block` driver that flips an
// element between `Statement` and the block's `FinalExpression`
// via `parse_statement_or_final_expr`. `parse_pattern` lands in
// minimal form (`Identifier` / `_`) — just enough for `let x = …`,
// `let _ = …` and `for i in …`. Tuple destructuring, the full
// type grammar, items, and parser-level error recovery stay
// deferred to v0.7.5.{4, 5, 6}.
//
// v0.7.5.4a — Items: top-level driver + functions + constant +
// type alias + visibility. Ports the upper half of
// crates/triet-parser/src/item.rs. Adds the `Item` enum (all 8
// variants scaffolded so the AST + Arena shape stays stable for
// .4b), `Visibility` / `ParameterPassing` / `FunctionBody` /
// `FunctionParam` / `FunctionDef` / `ConstantItemPayload` /
// `TypeAliasPayload`, a fifth `items` sub-arena keyed by Integer
// (mirroring the existing expr/pattern/type/stmt arenas), and
// `Program { arena, item_ids }` as the root container.
// Parser surface: `parse_program` (loops over items till EOF),
// `parse_item` dispatcher (visibility prefix + keyword dispatch),
// `parse_visibility` (PrivateVis / PublicVis / PackageVis),
// `parse_function` (+ `parse_parameter_list` / `parse_parameter`
// / `parse_generic_params` / `parse_function_body`),
// `parse_constant_item`, `parse_type_alias`, `parse_ident`,
// `parse_item_name` (+ ADR-0005 reserved-name check for `std` /
// `sys` / `dev` / `usr` / `core` via `ReservedItemNameErr`).
// `parse_function_body` consumes either `{ … }` (via the v0.7.5.3
// `parse_block`) or `= expr` (via the v0.7.5.2 `parse_expression`).
// Struct / Enum / Module / Import / ImportFrom parsers stub-fail
// at `parse_item` dispatch — implementation lands in v0.7.5.4b.
//
// v0.7.5.6a — Error recovery. `parse_program`'s return type
// changes from `ParseProgramStep~ParseError` to plain
// `ParseProgramStep { program, errors }` because the program itself
// is always producible (each failed item just contributes nothing
// to `item_ids`); `errors` is a `Vector<ParseError>` accumulator.
// New `synchronize` skips tokens until the next item / statement
// boundary (or after a `;`), so a single malformed item doesn't
// poison the rest of the file. Defensive force-advance guards
// against `parse_item` failing at a sync token without consuming
// anything — without it the driver would spin forever at top
// level on a malformed corpus. Mirrors
// triet-parser::parser::synchronize + triet-parser::parse_tokens.
// Smoke `main()` adds 4 multi-error recovery assertions covering:
// broken middle item, leading broken item, 3-error case, error at
// EOF.
//
// v0.7.5.5b — Full pattern grammar. Expands the v0.7.5.3 minimal
// `Pattern` (Wildcard / Identifier) into the full grammar per
// crates/triet-parser/src/pattern.rs. New variants: `LiteralPat`
// (Integer / Ternary / String / Trilean — each in `LiteralPattern`
// sub-enum), `TuplePat` (`(p1, p2, …)` with singleton `(p,)` vs
// grouping `(p)` distinction matching the type grammar in .5a),
// `OrPat` (top-level `a | b | c` — `parse_pattern_no_or` keeps `|`
// from binding across structural boundaries), `RangePat` (`..`
// exclusive / `..=` inclusive — supports negative range bounds
// `-5..=5`), `NullPat` (the bare `null` keyword), `EnumVariantPat`
// (`Variant(payload)` — bare identifier `Variant` falls back to
// IdentifierPattern; the enum/variable distinction is resolved at
// lowering time, mirroring the Rust impl), and `OutcomeArmPat`
// (`~+ binding` / `~- binding` / `~0` per ADR-0020 §5). Negative
// integer literals (`-N`) handled via dedicated
// `parse_negative_literal_pattern` and as range bounds via
// `parse_literal_pattern_payload`.
//
// v0.7.5.5a — Full type grammar. Expands the v0.7.5.3 placeholder
// `parse_type_minimal` (single-Identifier `NamedType` only) into
// the full ADR-0020 + ADR-0021 grammar in place: `NamedType` is
// joined by `GenericType` (`Option<T>` / `HashMap<K, V>` with
// trailing-comma support), `TupleType` (`(T1, T2 [, …])` —
// singleton tuple `(T,)` distinguished from grouping `(T)` via the
// trailing comma), `NullableType` (chained `T?…?`), `FunctionType`
// (`(T1, T2) -> R`), `OutcomeType` (`T~E` binary outcome + `T?~E`
// ternary outcome with `Trit::Zero` null arm), and the
// `RefinedTrileanType` marker for `Trilean!` per ADR-0021 §2.7.
// Postfix dispatch (`apply_type_postfix`) follows ADR-0020 §1.3
// precedence: `Trilean!` (only after a bare `Trilean` atom) →
// `T?~E` (compound `?~`) → `T~E` (bare `~`) → chained `T?…?`.
// `parse_type_minimal` keeps its v0.7.5.3 name as the public
// entrypoint so every existing call site (let / constant / param
// annotation / return type / struct field / enum variant payload
// / type alias body) inherits the full grammar without touching
// its signature.
//
// v0.7.5.4b — Items: struct + enum + module + imports. Fills in
// the remaining Item variants .4a scaffolded. New parsers:
// `parse_struct` (+ `parse_struct_field` / `parse_struct_fields`),
// `parse_enum` (+ `parse_enum_variant` / `parse_enum_variants` —
// optional tuple-style payload `Some(T)`), `parse_module`
// (file-bound `module foo` + inline `module foo { items… }` via
// `parse_inline_module_body` recursing through `parse_item`; per
// ADR-0005 §"File resolution" rejects `module foo.bar` dotted
// declarations), `parse_import_item` (`import a.b.c`),
// `parse_from_import` (`from a.b import x, y as z` per ADR-0005
// §"Imports — Python style"), `parse_import_name_list` /
// `parse_import_name` (+ ADR-0005 glob `*` rejection + optional
// `as alias`), and the `parse_dot_path` family (root accepts
// `crate` / `self` / `super` per ADR-0005 §"Path syntax";
// subsequent segments must be regular identifiers). Visibility
// on `import` / `from` is explicitly rejected via
// `reject_visibility_on_import` (re-exports of imported names are
// a post-v0.2.x feature). 15 new program-level smoke assertions
// exercise every shape. Closes the item layer; v0.7.5.5 grows
// the placeholder `parse_type_minimal` into the full type grammar
// (generics, `T?`, `T~E`, function types).
//
// AllocResult / ParseStep wrap (arena, id) / (state, expr_id) because
// IR tuple returns are deferred post-v1.0 per SPEC §95 — without
// tuple returns, the alloc helpers can't expose Rust's
// `&mut Arena -> ExprId` shape directly.
//
// Variant names carry an `Expr` / `Pattern` / `Type` / `Stmt`
// suffix to avoid collisions with the Token enum's variants once
// `khi.lexer` is in scope — Triết binds enum variants into a
// single global namespace (last-write-wins). Confirmed via the
// E1003 typecheck error a bare `Add` raises when both `FooKind`
// and `BarKind` declare it.
//
// [adr-0019]: ../docs/decisions/0019-self-hosting-compiler-bootstrap.md

module lexer;

from std.io import println
from std.collections.vector import new, push, length, get
from std.text import from_integer, concat, len
from std.string import substring
from std.assert import assert

from self.lexer import NumericSuffix, IntLiteral, Token, SpannedToken
from self.lexer import StringPayload, IntPayload, LexError, lex

// ─────────────────────────────────────────────────────────────────
// Trilean AST value — not in the lexer (the lexer emits the
// `TrueKw`/`FalseKw`/`UnknownKw` tokens; the parser maps those to
// this 3-state enum so the AST stores the resolved value, not the
// raw token).
// ─────────────────────────────────────────────────────────────────

public enum TrileanValue {
    TrueValue,
    FalseValue,
    UnknownValue,
}

// ─────────────────────────────────────────────────────────────────
// Operator enums (1:1 with triet-syntax::expr::{BinaryOperator,
// UnaryOperator})
// ─────────────────────────────────────────────────────────────────

public enum BinaryOperator {
    Add,
    Subtract,
    Multiply,
    Divide,
    Modulo,
    Power,
    Equal,
    NotEqual,
    LessThan,
    LessEqual,
    GreaterThan,
    GreaterEqual,
    And,
    Or,
    Xor,
    Iff,
    Implies,
    KleeneXor,
    KleeneIff,
    KleeneImplies,
}

public enum UnaryOperator {
    Negate,
}

// ─────────────────────────────────────────────────────────────────
// OutcomeArm — which arm of a `T~E` / `T?~E` outcome the AST node
// constructs or matches. Trit-shaped per ADR-0020 §2.
// ─────────────────────────────────────────────────────────────────

public enum OutcomeArm {
    PositiveArm,
    ZeroArm,
    NegativeArm,
}

// ─────────────────────────────────────────────────────────────────
// Expr payload structs — Triết enum variants take a single payload,
// so every Rust struct-style variant becomes its own tagged record.
// ─────────────────────────────────────────────────────────────────

public struct BinaryOpPayload {
    operator: BinaryOperator,
    left: Integer,
    right: Integer,
}

public struct UnaryOpPayload {
    operator: UnaryOperator,
    operand: Integer,
}

public struct CallPayload {
    callee: Integer,
    arguments: Vector<Integer>,
}

public struct FieldAccessPayload {
    object: Integer,
    field: String,
}

public struct MethodCallPayload {
    receiver: Integer,
    method: String,
    arguments: Vector<Integer>,
}

public struct OutcomeConstructorPayload {
    arm: OutcomeArm,
    payload: Integer?,
}

public struct OutcomePropagatePayload {
    inner: Integer,
    capture_name: String?,
    early_return: Integer,
}

public struct OutcomeDefaultPayload {
    inner: Integer,
    default_expr: Integer,
}

public struct ElvisOpPayload {
    object: Integer,
    default_expr: Integer,
}

public struct RangePayload {
    range_start: Integer,
    range_end: Integer,
    inclusive: Trilean!,
}

// ─────────────────────────────────────────────────────────────────
// Expr — v0.7.5.2 surface. Block / If / Match / Lambda / Tuple /
// FStringLiteral / StructLiteral / EnumLiteral / Safe* operators /
// TupleIndex defer to subsequent sub-tasks per the umbrella plan.
// ─────────────────────────────────────────────────────────────────

public enum Expr {
    IntegerLiteralExpr(IntLiteral),
    TernaryLiteralExpr(IntLiteral),
    TrileanLiteralExpr(TrileanValue),
    StringLiteralExpr(StringPayload),
    NullLiteralExpr,
    IdentifierExpr(StringPayload),
    UnaryOpExpr(UnaryOpPayload),
    BinaryOpExpr(BinaryOpPayload),
    ForceUnwrapExpr(Integer),
    CallExpr(CallPayload),
    FieldAccessExpr(FieldAccessPayload),
    MethodCallExpr(MethodCallPayload),
    OutcomeConstructorExpr(OutcomeConstructorPayload),
    OutcomePropagateExpr(OutcomePropagatePayload),
    OutcomeDefaultExpr(OutcomeDefaultPayload),
    ElvisOpExpr(ElvisOpPayload),
    RangeExpr(RangePayload),
}

// ─────────────────────────────────────────────────────────────────
// Pattern — v0.7.5.5b expands the v0.7.5.3 minimal surface
// (Wildcard / Identifier) into the full grammar per
// crates/triet-parser/src/pattern.rs. Mirrors triet-syntax::Pattern.
// `Identifier` doubles as `Variable` in the Rust shape — the
// distinction between "bind name" and "tag-check on enum variant"
// is resolved at lowering time, not parse time.
// ─────────────────────────────────────────────────────────────────

// Pattern-position literals — distinct from Expr literals because
// only Integer / Ternary / String / Trilean are valid pattern
// scalars (no f-string, no `null` — null has its own variant).
public struct LiteralIntegerPattern {
    value: Integer,
    suffix: NumericSuffix?,
}

public enum LiteralPattern {
    IntegerLit(LiteralIntegerPattern),
    TernaryLit(Integer),
    StringLit(StringPayload),
    TrileanLit(TrileanValue),
}

public struct RangePatternPayload {
    range_start: LiteralPattern,
    range_end: LiteralPattern,
    inclusive: Trilean!,
}

public struct EnumVariantPatternPayload {
    variant_name: String,
    payload: Integer?,
}

public struct OutcomeArmPatternPayload {
    arm: OutcomeArm,
    payload: Integer?,
}

public enum Pattern {
    WildcardPattern,
    IdentifierPattern(StringPayload),
    LiteralPat(LiteralPattern),
    TuplePat(Vector<Integer>),
    OrPat(Vector<Integer>),
    RangePat(RangePatternPayload),
    NullPat,
    EnumVariantPat(EnumVariantPatternPayload),
    OutcomeArmPat(OutcomeArmPatternPayload),
}

// ─────────────────────────────────────────────────────────────────
// TypeExpr — v0.7.5.5a grows the surface from a single
// `NamedType` placeholder to the full ADR-0020 + ADR-0021 grammar:
// generics, tuples, nullables, function types, outcome types (`T~E`
// + `T?~E`), and the `Trilean!` refinement marker.
// ─────────────────────────────────────────────────────────────────

public struct NamedTypePayload {
    name: String,
}

public struct GenericTypePayload {
    name: String,
    arguments: Vector<Integer>,
}

public struct FunctionTypePayload {
    parameters: Vector<Integer>,
    return_type: Integer,
}

public struct OutcomeTypePayload {
    value_type: Integer,
    error_type: Integer,
    allow_null_state: Trilean!,
}

public enum TypeExpr {
    NamedType(NamedTypePayload),
    GenericType(GenericTypePayload),
    TupleType(Vector<Integer>),
    NullableType(Integer),
    FunctionType(FunctionTypePayload),
    OutcomeType(OutcomeTypePayload),
    RefinedTrileanType,
}

// ─────────────────────────────────────────────────────────────────
// Block — brace-delimited body shared by `for` / `while` / `loop`
// and (later, when block expressions land) Expr::BlockExpr. Mirrors
// triet-syntax::stmt::Block: a list of statement IDs plus an
// optional trailing expression that produces the block's value.
// ─────────────────────────────────────────────────────────────────

public struct Block {
    block_statements: Vector<Integer>,
    block_final: Integer?,
}

// ─────────────────────────────────────────────────────────────────
// Stmt — v0.7.5.3 brings the parser up to the full Rust shape:
// Let / Constant / Return / Break / Continue / For / While / Loop /
// Assign / ExpressionStmt. Each multi-field variant carries its own
// payload struct because Triết enum variants take a single payload.
// ─────────────────────────────────────────────────────────────────

public struct LetStmtPayload {
    name: String,
    is_mutable: Trilean!,
    type_annotation: Integer?,
    value: Integer,
}

public struct ConstantStmtPayload {
    name: String,
    type_annotation: Integer?,
    value: Integer,
}

public struct ReturnStmtPayload {
    value: Integer?,
}

public struct BreakStmtPayload {
    value: Integer?,
}

public struct ForStmtPayload {
    variable: Integer,
    iterable: Integer,
    body: Block,
}

public struct WhileStmtPayload {
    condition: Integer,
    body: Block,
    treat_unknown_as_false: Trilean!,
}

public struct LoopStmtPayload {
    body: Block,
}

public struct AssignStmtPayload {
    target: String,
    value: Integer,
}

public struct ExpressionStmtPayload {
    expression: Integer,
}

public enum Stmt {
    LetStmt(LetStmtPayload),
    ConstantStmt(ConstantStmtPayload),
    ReturnStmt(ReturnStmtPayload),
    BreakStmt(BreakStmtPayload),
    ContinueStmt,
    ForStmt(ForStmtPayload),
    WhileStmt(WhileStmtPayload),
    LoopStmt(LoopStmtPayload),
    AssignStmt(AssignStmtPayload),
    ExpressionStmt(ExpressionStmtPayload),
}

// ─────────────────────────────────────────────────────────────────
// Item AST — top-level declarations (v0.7.5.4a scaffolds the enum
// + all payload structs; .4a parses Function / Constant / TypeAlias,
// .4b adds Struct / Enum / Module / Import / ImportFrom).
// Mirrors triet-syntax::item.
// ─────────────────────────────────────────────────────────────────

// Per ADR-0005 §"Visibility": three states. The `Vis` suffix avoids
// collision with the `PublicKw` token name in the global namespace.
public enum Visibility {
    PrivateVis,
    PublicVis,
    PackageVis,
}

// SPEC §10.3 — Mojo-aligned parameter passing.
public enum ParameterPassing {
    BorrowedParam,
    MutableParam,
    OwnedParam,
}

public struct FunctionParam {
    name: String,
    type_annotation: Integer,
    passing: ParameterPassing,
}

// `function foo() -> T { ... }` vs `function foo() -> T = expr`.
public enum FunctionBody {
    BlockBody(Block),
    ExpressionBody(Integer),
}

public struct FunctionDef {
    visibility: Visibility,
    name: String,
    type_params: Vector<String>,
    parameters: Vector<FunctionParam>,
    return_type: Integer?,
    body: FunctionBody,
}

public struct ConstantItemPayload {
    visibility: Visibility,
    name: String,
    type_annotation: Integer?,
    value: Integer,
}

public struct TypeAliasPayload {
    visibility: Visibility,
    name: String,
    target: Integer,
}

// .4b will populate these — defined now so the Item enum + Arena
// shape stay stable across the .4a → .4b split.
public struct StructField {
    name: String,
    type_annotation: Integer,
}

public struct StructDef {
    visibility: Visibility,
    name: String,
    type_params: Vector<String>,
    fields: Vector<StructField>,
}

public struct EnumVariant {
    name: String,
    payload: Integer?,
}

public struct EnumDef {
    visibility: Visibility,
    name: String,
    type_params: Vector<String>,
    variants: Vector<EnumVariant>,
}

public struct ImportPath {
    segments: Vector<String>,
}

public struct ImportName {
    name: String,
    alias: String?,
}

public struct ImportFromPayload {
    source: Vector<String>,
    names: Vector<ImportName>,
}

// `module foo` (file-bound) vs `module foo { items… }` (inline).
// Inline items reference into the Arena's 5th sub-arena by ID.
public enum ModuleContent {
    ExternalContent,
    InlineContent(Vector<Integer>),
}

public struct ModuleDecl {
    visibility: Visibility,
    name: String,
    content: ModuleContent,
}

public enum Item {
    FunctionItem(FunctionDef),
    ConstantItem(ConstantItemPayload),
    TypeAliasItem(TypeAliasPayload),
    StructItem(StructDef),
    EnumItem(EnumDef),
    ImportItem(ImportPath),
    ImportFromItem(ImportFromPayload),
    ModuleItem(ModuleDecl),
}

// ─────────────────────────────────────────────────────────────────
// Spanned wrappers — every AST node carries its source byte range
// ─────────────────────────────────────────────────────────────────

public struct SpannedExpr {
    node: Expr,
    span_start: Integer,
    span_end: Integer,
}

public struct SpannedPattern {
    node: Pattern,
    span_start: Integer,
    span_end: Integer,
}

public struct SpannedTypeExpr {
    node: TypeExpr,
    span_start: Integer,
    span_end: Integer,
}

public struct SpannedStmt {
    node: Stmt,
    span_start: Integer,
    span_end: Integer,
}

public struct SpannedItem {
    node: Item,
    span_start: Integer,
    span_end: Integer,
}

// ─────────────────────────────────────────────────────────────────
// Arena — 5 typed sub-arenas indexed by Integer.
// v0.7.5.4a adds the items sub-arena; inline `module foo { … }`
// content references items by ID, and `Program` stores top-level
// item IDs in source order.
// ─────────────────────────────────────────────────────────────────

public struct Arena {
    expressions: Vector<SpannedExpr>,
    patterns: Vector<SpannedPattern>,
    types: Vector<SpannedTypeExpr>,
    statements: Vector<SpannedStmt>,
    items: Vector<SpannedItem>,
}

public struct AllocResult {
    arena: Arena,
    id: Integer,
}

public function arena_new() -> Arena =
    Arena {
        expressions: new(),
        patterns: new(),
        types: new(),
        statements: new(),
        items: new(),
    }

public function alloc_expression(arena: Arena, node: SpannedExpr) -> AllocResult = {
    let next_id: Integer = length(arena.expressions)
    AllocResult {
        arena: Arena {
            expressions: push(arena.expressions, node),
            patterns: arena.patterns,
            types: arena.types,
            statements: arena.statements,
            items: arena.items,
        },
        id: next_id,
    }
}

public function alloc_pattern(arena: Arena, node: SpannedPattern) -> AllocResult = {
    let next_id: Integer = length(arena.patterns)
    AllocResult {
        arena: Arena {
            expressions: arena.expressions,
            patterns: push(arena.patterns, node),
            types: arena.types,
            statements: arena.statements,
            items: arena.items,
        },
        id: next_id,
    }
}

public function alloc_type(arena: Arena, node: SpannedTypeExpr) -> AllocResult = {
    let next_id: Integer = length(arena.types)
    AllocResult {
        arena: Arena {
            expressions: arena.expressions,
            patterns: arena.patterns,
            types: push(arena.types, node),
            statements: arena.statements,
            items: arena.items,
        },
        id: next_id,
    }
}

public function alloc_statement(arena: Arena, node: SpannedStmt) -> AllocResult = {
    let next_id: Integer = length(arena.statements)
    AllocResult {
        arena: Arena {
            expressions: arena.expressions,
            patterns: arena.patterns,
            types: arena.types,
            statements: push(arena.statements, node),
            items: arena.items,
        },
        id: next_id,
    }
}

public function alloc_item(arena: Arena, node: SpannedItem) -> AllocResult = {
    let next_id: Integer = length(arena.items)
    AllocResult {
        arena: Arena {
            expressions: arena.expressions,
            patterns: arena.patterns,
            types: arena.types,
            statements: arena.statements,
            items: push(arena.items, node),
        },
        id: next_id,
    }
}

public function get_expression(arena: Arena, id: Integer) -> SpannedExpr =
    get(arena.expressions, id)!!

public function get_pattern(arena: Arena, id: Integer) -> SpannedPattern =
    get(arena.patterns, id)!!

public function get_type(arena: Arena, id: Integer) -> SpannedTypeExpr =
    get(arena.types, id)!!

public function get_statement(arena: Arena, id: Integer) -> SpannedStmt =
    get(arena.statements, id)!!

public function get_item(arena: Arena, id: Integer) -> SpannedItem =
    get(arena.items, id)!!

public function expression_count(arena: Arena) -> Integer =
    length(arena.expressions)

public function pattern_count(arena: Arena) -> Integer =
    length(arena.patterns)

public function type_count(arena: Arena) -> Integer =
    length(arena.types)

public function statement_count(arena: Arena) -> Integer =
    length(arena.statements)

public function item_count(arena: Arena) -> Integer =
    length(arena.items)

// `Program` — root of a parsed `.tri` source file. Mirrors
// triet-syntax::item::Program: owns the Arena so all `*Id` handles
// remain valid, plus an ordered list of top-level item IDs.
public struct Program {
    arena: Arena,
    item_ids: Vector<Integer>,
}

// ─────────────────────────────────────────────────────────────────
// Convenience constructors — make smoke construction readable.
// ─────────────────────────────────────────────────────────────────

public function spanned_expr(node: Expr, start: Integer, end: Integer) -> SpannedExpr =
    SpannedExpr { node: node, span_start: start, span_end: end }

public function int_literal(value: Integer) -> Expr =
    IntegerLiteralExpr(IntLiteral { value: value, suffix: ~0 })

public function binary_op(op: BinaryOperator, l_id: Integer, r_id: Integer) -> Expr =
    BinaryOpExpr(BinaryOpPayload { operator: op, left: l_id, right: r_id })

// ─────────────────────────────────────────────────────────────────
// ParseError — only the variants the v0.7.5.2 surface can raise.
// Recovery + multi-error reporting land in v0.7.5.6.
// ─────────────────────────────────────────────────────────────────

public struct ParseErrorDetail {
    expected: String,
    found: String,
    span_start: Integer,
    span_end: Integer,
}

public struct ReservedNameDetail {
    name: String,
    span_start: Integer,
    span_end: Integer,
}

public enum ParseError {
    UnexpectedTokenErr(ParseErrorDetail),
    UnexpectedEofErr(ParseErrorDetail),
    LexerFailedErr(ParseErrorDetail),
    ReservedItemNameErr(ReservedNameDetail),
}

// ─────────────────────────────────────────────────────────────────
// ParserState — token cursor + arena. Threaded functionally through
// every parse_* helper. ParseStep wraps the (state, expr_id) pair.
// ─────────────────────────────────────────────────────────────────

public struct ParserState {
    tokens: Vector<SpannedToken>,
    cursor: Integer,
    arena: Arena,
}

public struct ParseStep {
    state: ParserState,
    expr_id: Integer,
}

// ── v0.7.5.3 step wrappers ──────────────────────────────────────

public struct ParseStmtStep {
    state: ParserState,
    stmt_id: Integer,
}

public struct ParsePatternStep {
    state: ParserState,
    pattern_id: Integer,
}

public struct ParseBlockStep {
    state: ParserState,
    block: Block,
}

// `parse_statement_or_final_expr` may return either a finished
// statement (allocated into the arena) or an expression that turned
// out to be the block's final value (no trailing `;`). Triết's
// enum-with-payload models the tagged union; `BlockElementStep`
// wraps the (state, BlockElement) pair so the loop in `parse_block`
// can advance the cursor regardless of which branch fired.
public enum BlockElement {
    StatementElem(Integer),
    FinalExprElem(Integer),
}

public struct BlockElementStep {
    state: ParserState,
    element: BlockElement,
}

// ── v0.7.5.4a item / program / visibility step wrappers ─────────

public struct ParseItemStep {
    state: ParserState,
    item_id: Integer,
}

public struct ParseProgramStep {
    program: Program,
    errors: Vector<ParseError>,
}

public struct ParseVisibilityStep {
    state: ParserState,
    visibility: Visibility,
}

public struct ParseIdentStep {
    state: ParserState,
    text: String,
    span_start: Integer,
    span_end: Integer,
}

public struct ParseParamsStep {
    state: ParserState,
    parameters: Vector<FunctionParam>,
}

public struct ParseGenericsStep {
    state: ParserState,
    type_params: Vector<String>,
}

public function parser_new(tokens: Vector<SpannedToken>) -> ParserState =
    ParserState { tokens: tokens, cursor: 0, arena: arena_new() }

// ── Token consumer helpers ──────────────────────────────────────

public function peek(state: ParserState) -> SpannedToken? =
    get(state.tokens, state.cursor)

public function advance(state: ParserState) -> ParserState =
    ParserState { tokens: state.tokens, cursor: state.cursor + 1, arena: state.arena }

public function at_end(state: ParserState) -> Trilean! =
    state.cursor >= length(state.tokens)

public function eof_position(state: ParserState) -> Integer = {
    let tlen: Integer = length(state.tokens)
    if tlen == 0 {
        0
    } else {
        let last: SpannedToken = get(state.tokens, tlen - 1)!!
        last.span_end
    }
}

function token_kind_label(token: Token) -> String =
    match token {
        FunctionKw => "function",
        LetKw => "let",
        MutableKw => "mutable",
        ConstantKw => "constant",
        TypeKw => "type",
        IfKw => "if",
        IfQKw => "if?",
        ElseKw => "else",
        MatchKw => "match",
        ReturnKw => "return",
        ForKw => "for",
        WhileKw => "while",
        WhileQKw => "while?",
        LoopKw => "loop",
        BreakKw => "break",
        ContinueKw => "continue",
        InKw => "in",
        TrueKw => "true",
        FalseKw => "false",
        UnknownKw => "unknown",
        NullKw => "null",
        NotKw => "not",
        AndKw => "and",
        OrKw => "or",
        XorKw => "xor",
        IffKw => "iff",
        ImpliesKw => "implies",
        KleeneImpliesKw => "kleene_implies",
        KleeneXorKw => "kleene_xor",
        KleeneIffKw => "kleene_iff",
        ImportKw => "import",
        FromKw => "from",
        AsKw => "as",
        ModuleKw => "module",
        PublicKw => "public",
        OwnedKw => "owned",
        StructKw => "struct",
        EnumKw => "enum",
        KhiKw => "khi",
        SelfKw => "self",
        SuperKw => "super",
        LtEqGt => "<=>",
        LtTildeGt => "<~>",
        DotDotEq => "..=",
        DotDot => "..",
        EqEq => "==",
        NotEq => "!=",
        LtEq => "<=",
        GtEq => ">=",
        AndAnd => "&&",
        OrOr => "||",
        FatArrow => "=>",
        TildeArrow => "~>",
        TildeCaret => "~^",
        QuestionTilde => "?~",
        TildePlus => "~+",
        TildeMinus => "~-",
        TildeZero => "~0",
        TildeQuestion => "~?",
        TildeColon => "~:",
        Tilde => "~",
        ThinArrow => "->",
        QuestionDot => "?.",
        QuestionColon => "?:",
        BangBang => "!!",
        StarStar => "**",
        Plus => "+",
        Minus => "-",
        Star => "*",
        Slash => "/",
        PercentPercent => "%%",
        Assign => "=",
        Lt => "<",
        Gt => ">",
        Bang => "!",
        Caret => "^",
        Question => "?",
        Colon => ":",
        Semi => ";",
        Comma => ",",
        Dot => ".",
        LBrace => "{",
        RBrace => "}",
        LBracket => "[",
        RBracket => "]",
        LParen => "(",
        RParen => ")",
        Pipe => "|",
        Underscore => "_",
        IntegerLiteral(_) => "<int>",
        TernaryLiteral(_) => "<ternary>",
        StringLiteral(_) => "<string>",
        Identifier(_) => "<ident>",
        FStringStart => "f\"",
        FStringText(_) => "<fstr-text>",
        InterpolationStart => "${",
        InterpolationEnd => "}",
        FStringEnd => "\"",
    }

public function current_kind_label(state: ParserState) -> String = {
    let sp: SpannedToken? = peek(state)
    match sp {
        ~0 => "<eof>",
        _ => token_kind_label(sp!!.token),
    }
}

public function current_span_start(state: ParserState) -> Integer = {
    let sp: SpannedToken? = peek(state)
    match sp {
        ~0 => eof_position(state),
        _ => sp!!.span_start,
    }
}

public function current_span_end(state: ParserState) -> Integer = {
    let sp: SpannedToken? = peek(state)
    match sp {
        ~0 => eof_position(state),
        _ => sp!!.span_end,
    }
}

function make_unexpected_token_err(state: ParserState, expected: String) -> ParseError = {
    let detail: ParseErrorDetail = ParseErrorDetail {
        expected: expected,
        found: current_kind_label(state),
        span_start: current_span_start(state),
        span_end: current_span_end(state),
    }
    UnexpectedTokenErr(detail)
}

function make_unexpected_eof_err(state: ParserState, expected: String) -> ParseError = {
    let pos: Integer = eof_position(state)
    let detail: ParseErrorDetail = ParseErrorDetail {
        expected: expected,
        found: "<eof>",
        span_start: pos,
        span_end: pos,
    }
    UnexpectedEofErr(detail)
}

// ─────────────────────────────────────────────────────────────────
// Token predicates / expect helpers — v0.7.5.3.
//
// Triết doesn't expose a structural-equality compare over the
// `Token` enum (variants carry distinct payloads), so each
// kind-check is its own match arm. `expect_*` helpers consume the
// token if its kind matches, otherwise propagate a `ParseError`
// outcome — matching the Rust impl's `Parser::expect`. `eat_*`
// returns the advanced state if the token matched and the input
// state otherwise, so callers can express the "optional `;`" /
// "optional `mutable`" patterns idiomatically.
// ─────────────────────────────────────────────────────────────────

function is_semi(token: Token) -> Trilean! =
    match token {
        Semi => true,
        _ => false,
    }

function is_rbrace(token: Token) -> Trilean! =
    match token {
        RBrace => true,
        _ => false,
    }

function is_assign_token(token: Token) -> Trilean! =
    match token {
        Assign => true,
        _ => false,
    }

function is_comma(token: Token) -> Trilean! =
    match token {
        Comma => true,
        _ => false,
    }

function is_mutable_kw(token: Token) -> Trilean! =
    match token {
        MutableKw => true,
        _ => false,
    }

function is_while_q_kw(token: Token) -> Trilean! =
    match token {
        WhileQKw => true,
        _ => false,
    }

// `return` / `break` look ahead to decide whether a value follows;
// the value is absent when the next token is `;`, `}`, `,`, or EOF.
// (Mirrors the Rust `matches!(peek_token(), None | Some(Token::Semi
// | Token::RBrace | Token::Comma))` guard.)
function is_value_terminator(token: Token) -> Trilean! =
    match token {
        Semi => true,
        RBrace => true,
        Comma => true,
        _ => false,
    }

function eat_semi(state: ParserState) -> ParserState = {
    let nx: SpannedToken? = peek(state)
    match nx {
        ~0 => state,
        _ => if is_semi(nx!!.token) { advance(state) } else { state },
    }
}

public struct EatFlagStep {
    state: ParserState,
    was_present: Trilean!,
}

function eat_mutable(state: ParserState) -> EatFlagStep = {
    let nx: SpannedToken? = peek(state)
    match nx {
        ~0 => EatFlagStep { state: state, was_present: false },
        _ => if is_mutable_kw(nx!!.token) {
            EatFlagStep { state: advance(state), was_present: true }
        } else {
            EatFlagStep { state: state, was_present: false }
        },
    }
}

function expect_assign(state: ParserState) -> ParserState~ParseError = {
    let nx: SpannedToken? = peek(state)
    match nx {
        ~0 => ~- make_unexpected_eof_err(state, "`=`"),
        _ => if is_assign_token(nx!!.token) {
            ~+ advance(state)
        } else {
            ~- make_unexpected_token_err(state, "`=`")
        },
    }
}

function expect_lbrace(state: ParserState) -> ParserState~ParseError = {
    let nx: SpannedToken? = peek(state)
    match nx {
        ~0 => ~- make_unexpected_eof_err(state, "`{`"),
        _ => match nx!!.token {
            LBrace => ~+ advance(state),
            _ => ~- make_unexpected_token_err(state, "`{`"),
        },
    }
}

function expect_rbrace(state: ParserState) -> ParserState~ParseError = {
    let nx: SpannedToken? = peek(state)
    match nx {
        ~0 => ~- make_unexpected_eof_err(state, "`}`"),
        _ => if is_rbrace(nx!!.token) {
            ~+ advance(state)
        } else {
            ~- make_unexpected_token_err(state, "`}`")
        },
    }
}

function expect_in_kw(state: ParserState) -> ParserState~ParseError = {
    let nx: SpannedToken? = peek(state)
    match nx {
        ~0 => ~- make_unexpected_eof_err(state, "`in`"),
        _ => match nx!!.token {
            InKw => ~+ advance(state),
            _ => ~- make_unexpected_token_err(state, "`in`"),
        },
    }
}

function expect_colon(state: ParserState) -> ParserState~ParseError = {
    let nx: SpannedToken? = peek(state)
    match nx {
        ~0 => ~- make_unexpected_eof_err(state, "`:`"),
        _ => match nx!!.token {
            Colon => ~+ advance(state),
            _ => ~- make_unexpected_token_err(state, "`:`"),
        },
    }
}

// ─────────────────────────────────────────────────────────────────
// Token classification — Pratt precedence tables. Mirrors
// crates/triet-parser/src/expr.rs binding-power layout.
// ─────────────────────────────────────────────────────────────────

public struct BindingPowerPair {
    bp_left: Integer,
    bp_right: Integer,
}

function binding_power(op: BinaryOperator) -> BindingPowerPair =
    match op {
        Implies => BindingPowerPair { bp_left: 1, bp_right: 0 },
        KleeneImplies => BindingPowerPair { bp_left: 1, bp_right: 0 },
        Iff => BindingPowerPair { bp_left: 2, bp_right: 3 },
        KleeneIff => BindingPowerPair { bp_left: 2, bp_right: 3 },
        Or => BindingPowerPair { bp_left: 4, bp_right: 5 },
        Xor => BindingPowerPair { bp_left: 6, bp_right: 7 },
        KleeneXor => BindingPowerPair { bp_left: 6, bp_right: 7 },
        And => BindingPowerPair { bp_left: 8, bp_right: 9 },
        Equal => BindingPowerPair { bp_left: 10, bp_right: 11 },
        NotEqual => BindingPowerPair { bp_left: 10, bp_right: 11 },
        LessThan => BindingPowerPair { bp_left: 12, bp_right: 13 },
        LessEqual => BindingPowerPair { bp_left: 12, bp_right: 13 },
        GreaterThan => BindingPowerPair { bp_left: 12, bp_right: 13 },
        GreaterEqual => BindingPowerPair { bp_left: 12, bp_right: 13 },
        Add => BindingPowerPair { bp_left: 18, bp_right: 19 },
        Subtract => BindingPowerPair { bp_left: 18, bp_right: 19 },
        Multiply => BindingPowerPair { bp_left: 20, bp_right: 21 },
        Divide => BindingPowerPair { bp_left: 20, bp_right: 21 },
        Modulo => BindingPowerPair { bp_left: 20, bp_right: 21 },
        Power => BindingPowerPair { bp_left: 26, bp_right: 25 },
    }

function elvis_binding_power() -> BindingPowerPair =
    BindingPowerPair { bp_left: 15, bp_right: 14 }

function range_binding_power() -> BindingPowerPair =
    BindingPowerPair { bp_left: 16, bp_right: 17 }

function unary_right_bp() -> Integer = 23
function postfix_left_bp() -> Integer = 28

function classify_binary(token: Token) -> BinaryOperator? =
    match token {
        Plus => Add,
        Minus => Subtract,
        Star => Multiply,
        Slash => Divide,
        PercentPercent => Modulo,
        StarStar => Power,
        EqEq => Equal,
        NotEq => NotEqual,
        Lt => LessThan,
        LtEq => LessEqual,
        Gt => GreaterThan,
        GtEq => GreaterEqual,
        AndAnd => And,
        AndKw => And,
        OrOr => Or,
        OrKw => Or,
        Caret => Xor,
        XorKw => Xor,
        TildeCaret => KleeneXor,
        KleeneXorKw => KleeneXor,
        LtEqGt => Iff,
        IffKw => Iff,
        LtTildeGt => KleeneIff,
        KleeneIffKw => KleeneIff,
        FatArrow => Implies,
        ImpliesKw => Implies,
        TildeArrow => KleeneImplies,
        KleeneImpliesKw => KleeneImplies,
        _ => ~0,
    }

function is_postfix_token(token: Token) -> Trilean! =
    match token {
        Dot => true,
        QuestionDot => true,
        LParen => true,
        BangBang => true,
        TildeQuestion => true,
        TildeColon => true,
        _ => false,
    }

function is_elvis_token(token: Token) -> Trilean! =
    match token {
        QuestionColon => true,
        _ => false,
    }

function is_range_token(token: Token) -> Trilean! =
    match token {
        DotDot => true,
        DotDotEq => true,
        _ => false,
    }

// ─────────────────────────────────────────────────────────────────
// Pratt parser — entry + recursive driver
// ─────────────────────────────────────────────────────────────────

public function parse_expression(state: ParserState) -> ParseStep~ParseError =
    parse_expression_bp(state, 0)

function parse_expression_bp(state: ParserState, min_bp: Integer) -> ParseStep~ParseError = {
    let prefix_step: ParseStep = parse_prefix(state) ~? |err| ~- err
    parse_infix_chain(prefix_step.state, prefix_step.expr_id, min_bp)
}

function parse_infix_chain(state: ParserState, lhs: Integer, min_bp: Integer) -> ParseStep~ParseError = {
    let next_opt: SpannedToken? = peek(state)
    match next_opt {
        ~0 => ~+ ParseStep { state: state, expr_id: lhs },
        _ => {
            let next: SpannedToken = next_opt!!
            // Postfix has highest binding power; try it first.
            if is_postfix_token(next.token) {
                let pf_bp: Integer = postfix_left_bp()
                if pf_bp < min_bp {
                    ~+ ParseStep { state: state, expr_id: lhs }
                } else {
                    let post_step: ParseStep = parse_postfix(state, lhs) ~? |err| ~- err
                    parse_infix_chain(post_step.state, post_step.expr_id, min_bp)
                }
            } else {
                if is_elvis_token(next.token) {
                    parse_elvis_infix(state, lhs, min_bp)
                } else {
                    if is_range_token(next.token) {
                        parse_range_infix(state, lhs, min_bp)
                    } else {
                        let bin_opt: BinaryOperator? = classify_binary(next.token)
                        match bin_opt {
                            ~0 => ~+ ParseStep { state: state, expr_id: lhs },
                            _ => {
                                let op: BinaryOperator = bin_opt!!
                                let bps: BindingPowerPair = binding_power(op)
                                if bps.bp_left < min_bp {
                                    ~+ ParseStep { state: state, expr_id: lhs }
                                } else {
                                    let advanced: ParserState = advance(state)
                                    let rhs_step: ParseStep = parse_expression_bp(advanced, bps.bp_right) ~? |err| ~- err
                                    let lhs_sp: SpannedExpr = get_expression(rhs_step.state.arena, lhs)
                                    let rhs_sp: SpannedExpr = get_expression(rhs_step.state.arena, rhs_step.expr_id)
                                    let bin_node: Expr = binary_op(op, lhs, rhs_step.expr_id)
                                    let alloc_res: AllocResult = alloc_expression(
                                        rhs_step.state.arena,
                                        spanned_expr(bin_node, lhs_sp.span_start, rhs_sp.span_end),
                                    )
                                    let new_state: ParserState = ParserState {
                                        tokens: rhs_step.state.tokens,
                                        cursor: rhs_step.state.cursor,
                                        arena: alloc_res.arena,
                                    }
                                    parse_infix_chain(new_state, alloc_res.id, min_bp)
                                }
                            },
                        }
                    }
                }
            }
        },
    }
}

function parse_elvis_infix(state: ParserState, lhs: Integer, min_bp: Integer) -> ParseStep~ParseError = {
    let bps: BindingPowerPair = elvis_binding_power()
    if bps.bp_left < min_bp {
        ~+ ParseStep { state: state, expr_id: lhs }
    } else {
        let advanced: ParserState = advance(state)
        let rhs_step: ParseStep = parse_expression_bp(advanced, bps.bp_right) ~? |err| ~- err
        let lhs_sp: SpannedExpr = get_expression(rhs_step.state.arena, lhs)
        let rhs_sp: SpannedExpr = get_expression(rhs_step.state.arena, rhs_step.expr_id)
        let payload: ElvisOpPayload = ElvisOpPayload { object: lhs, default_expr: rhs_step.expr_id }
        let alloc_res: AllocResult = alloc_expression(
            rhs_step.state.arena,
            spanned_expr(ElvisOpExpr(payload), lhs_sp.span_start, rhs_sp.span_end),
        )
        let new_state: ParserState = ParserState {
            tokens: rhs_step.state.tokens,
            cursor: rhs_step.state.cursor,
            arena: alloc_res.arena,
        }
        parse_infix_chain(new_state, alloc_res.id, min_bp)
    }
}

function parse_range_infix(state: ParserState, lhs: Integer, min_bp: Integer) -> ParseStep~ParseError = {
    let bps: BindingPowerPair = range_binding_power()
    if bps.bp_left < min_bp {
        ~+ ParseStep { state: state, expr_id: lhs }
    } else {
        let next: SpannedToken = peek(state)!!
        let inclusive: Trilean! = match next.token {
            DotDotEq => true,
            _ => false,
        }
        let advanced: ParserState = advance(state)
        let rhs_step: ParseStep = parse_expression_bp(advanced, bps.bp_right) ~? |err| ~- err
        let lhs_sp: SpannedExpr = get_expression(rhs_step.state.arena, lhs)
        let rhs_sp: SpannedExpr = get_expression(rhs_step.state.arena, rhs_step.expr_id)
        let payload: RangePayload = RangePayload {
            range_start: lhs,
            range_end: rhs_step.expr_id,
            inclusive: inclusive,
        }
        let alloc_res: AllocResult = alloc_expression(
            rhs_step.state.arena,
            spanned_expr(RangeExpr(payload), lhs_sp.span_start, rhs_sp.span_end),
        )
        let new_state: ParserState = ParserState {
            tokens: rhs_step.state.tokens,
            cursor: rhs_step.state.cursor,
            arena: alloc_res.arena,
        }
        parse_infix_chain(new_state, alloc_res.id, min_bp)
    }
}

// ─────────────────────────────────────────────────────────────────
// Prefix parsing — atoms + unary + outcome constructors
// ─────────────────────────────────────────────────────────────────

function parse_prefix(state: ParserState) -> ParseStep~ParseError = {
    let next_opt: SpannedToken? = peek(state)
    match next_opt {
        ~0 => ~- make_unexpected_eof_err(state, "expression"),
        ~+ next => {
            match next.token {
                IntegerLiteral(p) => {
                    let advanced: ParserState = advance(state)
                    let node: Expr = IntegerLiteralExpr(p.literal)
                    let res: AllocResult = alloc_expression(
                        advanced.arena,
                        spanned_expr(node, next.span_start, next.span_end),
                    )
                    ~+ ParseStep {
                        state: ParserState { tokens: advanced.tokens, cursor: advanced.cursor, arena: res.arena },
                        expr_id: res.id,
                    }
                },
                TernaryLiteral(p) => {
                    let advanced: ParserState = advance(state)
                    let node: Expr = TernaryLiteralExpr(p.literal)
                    let res: AllocResult = alloc_expression(
                        advanced.arena,
                        spanned_expr(node, next.span_start, next.span_end),
                    )
                    ~+ ParseStep {
                        state: ParserState { tokens: advanced.tokens, cursor: advanced.cursor, arena: res.arena },
                        expr_id: res.id,
                    }
                },
                StringLiteral(p) => {
                    let advanced: ParserState = advance(state)
                    let node: Expr = StringLiteralExpr(p)
                    let res: AllocResult = alloc_expression(
                        advanced.arena,
                        spanned_expr(node, next.span_start, next.span_end),
                    )
                    ~+ ParseStep {
                        state: ParserState { tokens: advanced.tokens, cursor: advanced.cursor, arena: res.arena },
                        expr_id: res.id,
                    }
                },
                TrueKw => parse_trilean_atom(state, next, TrueValue),
                FalseKw => parse_trilean_atom(state, next, FalseValue),
                UnknownKw => parse_trilean_atom(state, next, UnknownValue),
                NullKw => {
                    let advanced: ParserState = advance(state)
                    let res: AllocResult = alloc_expression(
                        advanced.arena,
                        spanned_expr(NullLiteralExpr, next.span_start, next.span_end),
                    )
                    ~+ ParseStep {
                        state: ParserState { tokens: advanced.tokens, cursor: advanced.cursor, arena: res.arena },
                        expr_id: res.id,
                    }
                },
                Identifier(p) => {
                    let advanced: ParserState = advance(state)
                    let node: Expr = IdentifierExpr(p)
                    let res: AllocResult = alloc_expression(
                        advanced.arena,
                        spanned_expr(node, next.span_start, next.span_end),
                    )
                    ~+ ParseStep {
                        state: ParserState { tokens: advanced.tokens, cursor: advanced.cursor, arena: res.arena },
                        expr_id: res.id,
                    }
                },
                LParen => parse_paren_atom(state),
                Minus => parse_unary_prefix(state),
                Bang => parse_unary_prefix(state),
                NotKw => parse_unary_prefix(state),
                TildePlus => parse_outcome_ctor_payloaded(state, PositiveArm),
                TildeMinus => parse_outcome_ctor_payloaded(state, NegativeArm),
                TildeZero => parse_outcome_ctor_zero(state),
                _ => ~- make_unexpected_token_err(state, "expression"),
            }
        },
    }
}

function parse_trilean_atom(state: ParserState, tok: SpannedToken, value: TrileanValue) -> ParseStep~ParseError = {
    let advanced: ParserState = advance(state)
    let res: AllocResult = alloc_expression(
        advanced.arena,
        spanned_expr(TrileanLiteralExpr(value), tok.span_start, tok.span_end),
    )
    ~+ ParseStep {
        state: ParserState { tokens: advanced.tokens, cursor: advanced.cursor, arena: res.arena },
        expr_id: res.id,
    }
}

function parse_paren_atom(state: ParserState) -> ParseStep~ParseError = {
    // consume `(`
    let after_open: ParserState = advance(state)
    let inner_step: ParseStep = parse_expression_bp(after_open, 0) ~? |err| ~- err
    // expect `)`
    let next_opt: SpannedToken? = peek(inner_step.state)
    match next_opt {
        ~0 => ~- make_unexpected_eof_err(inner_step.state, "`)`"),
        _ => {
            let next: SpannedToken = next_opt!!
            match next.token {
                RParen => {
                    let after_close: ParserState = advance(inner_step.state)
                    // Paren just groups — no AST wrapper, return inner expr_id.
                    ~+ ParseStep { state: after_close, expr_id: inner_step.expr_id }
                },
                _ => ~- make_unexpected_token_err(inner_step.state, "`)`"),
            }
        },
    }
}

function parse_unary_prefix(state: ParserState) -> ParseStep~ParseError = {
    let op_tok: SpannedToken = peek(state)!!
    let advanced: ParserState = advance(state)
    let operand_step: ParseStep = parse_expression_bp(advanced, unary_right_bp()) ~? |err| ~- err
    let operand_sp: SpannedExpr = get_expression(operand_step.state.arena, operand_step.expr_id)
    let payload: UnaryOpPayload = UnaryOpPayload { operator: Negate, operand: operand_step.expr_id }
    let res: AllocResult = alloc_expression(
        operand_step.state.arena,
        spanned_expr(UnaryOpExpr(payload), op_tok.span_start, operand_sp.span_end),
    )
    ~+ ParseStep {
        state: ParserState {
            tokens: operand_step.state.tokens,
            cursor: operand_step.state.cursor,
            arena: res.arena,
        },
        expr_id: res.id,
    }
}

function parse_outcome_ctor_payloaded(state: ParserState, arm: OutcomeArm) -> ParseStep~ParseError = {
    let op_tok: SpannedToken = peek(state)!!
    let advanced: ParserState = advance(state)
    let payload_step: ParseStep = parse_expression_bp(advanced, unary_right_bp()) ~? |err| ~- err
    let payload_sp: SpannedExpr = get_expression(payload_step.state.arena, payload_step.expr_id)
    let ctor_payload: OutcomeConstructorPayload = OutcomeConstructorPayload {
        arm: arm,
        payload: payload_step.expr_id,
    }
    let res: AllocResult = alloc_expression(
        payload_step.state.arena,
        spanned_expr(OutcomeConstructorExpr(ctor_payload), op_tok.span_start, payload_sp.span_end),
    )
    ~+ ParseStep {
        state: ParserState {
            tokens: payload_step.state.tokens,
            cursor: payload_step.state.cursor,
            arena: res.arena,
        },
        expr_id: res.id,
    }
}

function parse_outcome_ctor_zero(state: ParserState) -> ParseStep~ParseError = {
    let op_tok: SpannedToken = peek(state)!!
    let advanced: ParserState = advance(state)
    let ctor_payload: OutcomeConstructorPayload = OutcomeConstructorPayload {
        arm: ZeroArm,
        payload: ~0,
    }
    let res: AllocResult = alloc_expression(
        advanced.arena,
        spanned_expr(OutcomeConstructorExpr(ctor_payload), op_tok.span_start, op_tok.span_end),
    )
    ~+ ParseStep {
        state: ParserState { tokens: advanced.tokens, cursor: advanced.cursor, arena: res.arena },
        expr_id: res.id,
    }
}

// ─────────────────────────────────────────────────────────────────
// Postfix parsing — `(args)` / `.field` / `.method(args)` / `!!` /
// `~?` / `~:`
// ─────────────────────────────────────────────────────────────────

function parse_postfix(state: ParserState, lhs: Integer) -> ParseStep~ParseError = {
    let next: SpannedToken = peek(state)!!
    match next.token {
        Dot => parse_dot_postfix(state, lhs),
        LParen => parse_call_postfix(state, lhs),
        BangBang => parse_bangbang_postfix(state, lhs, next),
        TildeQuestion => parse_outcome_propagate_postfix(state, lhs),
        TildeColon => parse_outcome_default_postfix(state, lhs),
        QuestionDot => ~- make_unexpected_token_err(state, "operator (safe access `?.` deferred to v0.7.5.4)"),
        _ => ~- make_unexpected_token_err(state, "postfix operator"),
    }
}

function parse_bangbang_postfix(state: ParserState, lhs: Integer, op_tok: SpannedToken) -> ParseStep~ParseError = {
    let advanced: ParserState = advance(state)
    let lhs_sp: SpannedExpr = get_expression(advanced.arena, lhs)
    let res: AllocResult = alloc_expression(
        advanced.arena,
        spanned_expr(ForceUnwrapExpr(lhs), lhs_sp.span_start, op_tok.span_end),
    )
    ~+ ParseStep {
        state: ParserState { tokens: advanced.tokens, cursor: advanced.cursor, arena: res.arena },
        expr_id: res.id,
    }
}

function parse_call_postfix(state: ParserState, lhs: Integer) -> ParseStep~ParseError = {
    let args_step: CallArgsStep = parse_call_args(state) ~? |err| ~- err
    let lhs_sp: SpannedExpr = get_expression(args_step.state.arena, lhs)
    let payload: CallPayload = CallPayload { callee: lhs, arguments: args_step.arguments }
    let res: AllocResult = alloc_expression(
        args_step.state.arena,
        spanned_expr(CallExpr(payload), lhs_sp.span_start, args_step.close_end),
    )
    ~+ ParseStep {
        state: ParserState {
            tokens: args_step.state.tokens,
            cursor: args_step.state.cursor,
            arena: res.arena,
        },
        expr_id: res.id,
    }
}

public struct CallArgsStep {
    state: ParserState,
    arguments: Vector<Integer>,
    close_end: Integer,
}

function parse_call_args(state: ParserState) -> CallArgsStep~ParseError = {
    // peek already saw LParen; consume it
    let after_open: ParserState = advance(state)
    let mutable state: ParserState = after_open
    let mutable args: Vector<Integer> = new()
    let mutable should_continue: Trilean! = true
    let mutable maybe_err: ParseError? = ~0
    let mutable close_end: Integer = 0

    // Empty arg list short-circuit
    let first_peek: SpannedToken? = peek(state)
    match first_peek {
        ~0 => {
            maybe_err = make_unexpected_eof_err(state, "`)` or argument")
            should_continue = false
        },
        _ => {
            let first: SpannedToken = first_peek!!
            match first.token {
                RParen => {
                    close_end = first.span_end
                    state = advance(state)
                    should_continue = false
                },
                _ => {},
            }
        },
    }

    while should_continue {
        let arg_outcome: ParseStep~ParseError = parse_expression(state)
        match arg_outcome {
            ~+ astep => {
                args = push(args, astep.expr_id)
                state = astep.state
                let after_arg: SpannedToken? = peek(state)
                match after_arg {
                    ~0 => {
                        maybe_err = make_unexpected_eof_err(state, "`,` or `)`")
                        should_continue = false
                    },
                    _ => {
                        let token: SpannedToken = after_arg!!
                        match token.token {
                            Comma => {
                                state = advance(state)
                                let after_comma: SpannedToken? = peek(state)
                                match after_comma {
                                    ~0 => {
                                        maybe_err = make_unexpected_eof_err(state, "argument or `)`")
                                        should_continue = false
                                    },
                                    _ => {
                                        let t2: SpannedToken = after_comma!!
                                        match t2.token {
                                            RParen => {
                                                close_end = t2.span_end
                                                state = advance(state)
                                                should_continue = false
                                            },
                                            _ => {},
                                        }
                                    },
                                }
                            },
                            RParen => {
                                close_end = token.span_end
                                state = advance(state)
                                should_continue = false
                            },
                            _ => {
                                maybe_err = make_unexpected_token_err(state, "`,` or `)`")
                                should_continue = false
                            },
                        }
                    },
                }
            },
            ~- e => {
                maybe_err = e
                should_continue = false
            },
        }
    }

    match maybe_err {
        ~0 => ~+ CallArgsStep { state: state, arguments: args, close_end: close_end },
        _ => ~- maybe_err!!,
    }
}

function parse_dot_postfix(state: ParserState, lhs: Integer) -> ParseStep~ParseError = {
    // consume `.`
    let after_dot: ParserState = advance(state)
    let name_tok_opt: SpannedToken? = peek(after_dot)
    match name_tok_opt {
        ~0 => ~- make_unexpected_eof_err(after_dot, "field name or method name"),
        _ => {
            let name_tok: SpannedToken = name_tok_opt!!
            match name_tok.token {
                Identifier(p) => {
                    let after_name: ParserState = advance(after_dot)
                    // Method call iff next is `(`
                    let lookahead: SpannedToken? = peek(after_name)
                    let is_call: Trilean! = match lookahead {
                        ~0 => false,
                        _ => match lookahead!!.token {
                            LParen => true,
                            _ => false,
                        },
                    }
                    if is_call {
                        let args_step: CallArgsStep = parse_call_args(after_name) ~? |err| ~- err
                        let lhs_sp: SpannedExpr = get_expression(args_step.state.arena, lhs)
                        let payload: MethodCallPayload = MethodCallPayload {
                            receiver: lhs,
                            method: p.text,
                            arguments: args_step.arguments,
                        }
                        let res: AllocResult = alloc_expression(
                            args_step.state.arena,
                            spanned_expr(MethodCallExpr(payload), lhs_sp.span_start, args_step.close_end),
                        )
                        ~+ ParseStep {
                            state: ParserState {
                                tokens: args_step.state.tokens,
                                cursor: args_step.state.cursor,
                                arena: res.arena,
                            },
                            expr_id: res.id,
                        }
                    } else {
                        let lhs_sp: SpannedExpr = get_expression(after_name.arena, lhs)
                        let payload: FieldAccessPayload = FieldAccessPayload {
                            object: lhs,
                            field: p.text,
                        }
                        let res: AllocResult = alloc_expression(
                            after_name.arena,
                            spanned_expr(FieldAccessExpr(payload), lhs_sp.span_start, name_tok.span_end),
                        )
                        ~+ ParseStep {
                            state: ParserState {
                                tokens: after_name.tokens,
                                cursor: after_name.cursor,
                                arena: res.arena,
                            },
                            expr_id: res.id,
                        }
                    }
                },
                _ => ~- make_unexpected_token_err(after_dot, "field name or method name"),
            }
        },
    }
}

function parse_outcome_propagate_postfix(state: ParserState, lhs: Integer) -> ParseStep~ParseError = {
    // consume `~?`
    let after_op: ParserState = advance(state)
    // expect `|`
    let pipe_opt: SpannedToken? = peek(after_op)
    let after_pipe: ParserState = match pipe_opt {
        ~0 => ~- make_unexpected_eof_err(after_op, "`|` (closure capture for ~?)"),
        _ => {
            let pipe: SpannedToken = pipe_opt!!
            match pipe.token {
                Pipe => advance(after_op),
                _ => ~- make_unexpected_token_err(after_op, "`|` (closure capture for ~?)"),
            }
        },
    }
    // capture name (Identifier or `_`)
    let name_opt: SpannedToken? = peek(after_pipe)
    let capture: String? = match name_opt {
        ~0 => ~- make_unexpected_eof_err(after_pipe, "binding name or `_`"),
        _ => {
            let nt: SpannedToken = name_opt!!
            match nt.token {
                Identifier(p) => p.text,
                Underscore => ~0,
                _ => ~- make_unexpected_token_err(after_pipe, "binding name or `_`"),
            }
        },
    }
    let after_name: ParserState = advance(after_pipe)
    // expect closing `|`
    let close_opt: SpannedToken? = peek(after_name)
    let after_close: ParserState = match close_opt {
        ~0 => ~- make_unexpected_eof_err(after_name, "closing `|`"),
        _ => {
            let close: SpannedToken = close_opt!!
            match close.token {
                Pipe => advance(after_name),
                _ => ~- make_unexpected_token_err(after_name, "closing `|`"),
            }
        },
    }
    // parse early-return expression at bp 0
    let early_step: ParseStep = parse_expression_bp(after_close, 0) ~? |err| ~- err
    let lhs_sp: SpannedExpr = get_expression(early_step.state.arena, lhs)
    let early_sp: SpannedExpr = get_expression(early_step.state.arena, early_step.expr_id)
    let payload: OutcomePropagatePayload = OutcomePropagatePayload {
        inner: lhs,
        capture_name: capture,
        early_return: early_step.expr_id,
    }
    let res: AllocResult = alloc_expression(
        early_step.state.arena,
        spanned_expr(OutcomePropagateExpr(payload), lhs_sp.span_start, early_sp.span_end),
    )
    ~+ ParseStep {
        state: ParserState {
            tokens: early_step.state.tokens,
            cursor: early_step.state.cursor,
            arena: res.arena,
        },
        expr_id: res.id,
    }
}

function parse_outcome_default_postfix(state: ParserState, lhs: Integer) -> ParseStep~ParseError = {
    let after_op: ParserState = advance(state)
    let default_step: ParseStep = parse_expression_bp(after_op, 0) ~? |err| ~- err
    let lhs_sp: SpannedExpr = get_expression(default_step.state.arena, lhs)
    let def_sp: SpannedExpr = get_expression(default_step.state.arena, default_step.expr_id)
    let payload: OutcomeDefaultPayload = OutcomeDefaultPayload {
        inner: lhs,
        default_expr: default_step.expr_id,
    }
    let res: AllocResult = alloc_expression(
        default_step.state.arena,
        spanned_expr(OutcomeDefaultExpr(payload), lhs_sp.span_start, def_sp.span_end),
    )
    ~+ ParseStep {
        state: ParserState {
            tokens: default_step.state.tokens,
            cursor: default_step.state.cursor,
            arena: res.arena,
        },
        expr_id: res.id,
    }
}

// ─────────────────────────────────────────────────────────────────
// Pattern parsing — v0.7.5.5b full grammar. Mirrors
// crates/triet-parser/src/pattern.rs.
//
// Or-patterns (`a | b | c`) parse at the top level only;
// sub-patterns (tuple elements, enum variant payloads, outcome arm
// payloads) call `parse_pattern_no_or` so `|` stops at structural
// boundaries.
// ─────────────────────────────────────────────────────────────────

function spanned_pattern(node: Pattern, start: Integer, end: Integer) -> SpannedPattern =
    SpannedPattern { node: node, span_start: start, span_end: end }

// ── Step wrappers + literal helpers for .5b ──────────────────────

public struct ParseLiteralPatternStep {
    state: ParserState,
    literal: LiteralPattern,
    span_start: Integer,
    span_end: Integer,
}

function is_pipe(token: Token) -> Trilean! =
    match token {
        Pipe => true,
        _ => false,
    }

function is_dotdot(token: Token) -> Trilean! =
    match token {
        DotDot => true,
        _ => false,
    }

function is_dotdoteq(token: Token) -> Trilean! =
    match token {
        DotDotEq => true,
        _ => false,
    }

function is_underscore(token: Token) -> Trilean! =
    match token {
        Underscore => true,
        _ => false,
    }

function is_null_kw(token: Token) -> Trilean! =
    match token {
        NullKw => true,
        _ => false,
    }

function is_minus(token: Token) -> Trilean! =
    match token {
        Minus => true,
        _ => false,
    }

// Top-level pattern parse — handles or-patterns.
public function parse_pattern(state: ParserState) -> ParsePatternStep~ParseError = {
    let first: ParsePatternStep = parse_pattern_no_or(state) ~? |err| ~- err

    // Peek for `|` — if absent, return as-is.
    let nx: SpannedToken? = peek(first.state)
    let has_pipe: Trilean! = match nx {
        ~0 => false,
        _ => is_pipe(nx!!.token),
    }
    if has_pipe {
        let first_sp: SpannedPattern = get_pattern(first.state.arena, first.pattern_id)
        let mutable state: ParserState = first.state
        let mutable alts: Vector<Integer> = push(new(), first.pattern_id)
        let mutable should_continue: Trilean! = true
        let mutable err_slot: ParseError? = ~0
        let mutable last_end: Integer = first_sp.span_end

        while should_continue {
            let nx2: SpannedToken? = peek(state)
            match nx2 {
                ~0 => {
                    should_continue = false
                },
                _ => {
                    if is_pipe(nx2!!.token) {
                        let after_pipe: ParserState = advance(state)
                        let alt_outcome: ParsePatternStep~ParseError = parse_pattern_no_or(after_pipe)
                        match alt_outcome {
                            ~+ alt_step => {
                                alts = push(alts, alt_step.pattern_id)
                                state = alt_step.state
                                let alt_sp: SpannedPattern = get_pattern(state.arena, alt_step.pattern_id)
                                last_end = alt_sp.span_end
                            },
                            ~- e => {
                                err_slot = e
                                should_continue = false
                            },
                        }
                    } else {
                        should_continue = false
                    }
                },
            }
        }

        match err_slot {
            ~+ e => ~- e,
            ~0 => {
                let res: AllocResult = alloc_pattern(
                    state.arena,
                    spanned_pattern(OrPat(alts), first_sp.span_start, last_end),
                )
                ~+ ParsePatternStep {
                    state: ParserState { tokens: state.tokens, cursor: state.cursor, arena: res.arena },
                    pattern_id: res.id,
                }
            },
        }
    } else {
        ~+ first
    }
}

// Parse a single pattern that does NOT consume top-level `|`.
// Mirrors Rust's parse_pattern_no_or.
function parse_pattern_no_or(state: ParserState) -> ParsePatternStep~ParseError = {
    let nx_opt: SpannedToken? = peek(state)
    match nx_opt {
        ~0 => ~- make_unexpected_eof_err(state, "pattern"),
        ~+ nx => {
            match nx.token {
                Underscore => {
                    let advanced: ParserState = advance(state)
                    let res: AllocResult = alloc_pattern(
                        advanced.arena,
                        spanned_pattern(WildcardPattern, nx.span_start, nx.span_end),
                    )
                    ~+ ParsePatternStep {
                        state: ParserState { tokens: advanced.tokens, cursor: advanced.cursor, arena: res.arena },
                        pattern_id: res.id,
                    }
                },
                NullKw => {
                    let advanced: ParserState = advance(state)
                    let res: AllocResult = alloc_pattern(
                        advanced.arena,
                        spanned_pattern(NullPat, nx.span_start, nx.span_end),
                    )
                    ~+ ParsePatternStep {
                        state: ParserState { tokens: advanced.tokens, cursor: advanced.cursor, arena: res.arena },
                        pattern_id: res.id,
                    }
                },
                Identifier(p) => parse_identifier_or_enum_variant_pattern(state, p, nx.span_start, nx.span_end),
                LParen => parse_tuple_pattern(state, nx.span_start),
                TrueKw => parse_trilean_pattern_atom(state, TrueValue, nx.span_start, nx.span_end),
                FalseKw => parse_trilean_pattern_atom(state, FalseValue, nx.span_start, nx.span_end),
                UnknownKw => parse_trilean_pattern_atom(state, UnknownValue, nx.span_start, nx.span_end),
                IntegerLiteral(_) => parse_literal_or_range_pattern(state),
                TernaryLiteral(_) => parse_literal_or_range_pattern(state),
                StringLiteral(_) => parse_literal_or_range_pattern(state),
                Minus => parse_negative_literal_pattern(state),
                TildePlus => parse_outcome_arm_pattern_with_payload(state, PositiveArm),
                TildeMinus => parse_outcome_arm_pattern_with_payload(state, NegativeArm),
                TildeZero => {
                    let advanced: ParserState = advance(state)
                    let res: AllocResult = alloc_pattern(
                        advanced.arena,
                        spanned_pattern(
                            OutcomeArmPat(OutcomeArmPatternPayload { arm: ZeroArm, payload: ~0 }),
                            nx.span_start,
                            nx.span_end,
                        ),
                    )
                    ~+ ParsePatternStep {
                        state: ParserState { tokens: advanced.tokens, cursor: advanced.cursor, arena: res.arena },
                        pattern_id: res.id,
                    }
                },
                _ => ~- make_unexpected_token_err(state, "pattern"),
            }
        },
    }
}

// `Variant(subpattern)` vs bare `Variable` — disambiguated by
// looking ahead for `(` after the identifier.
function parse_identifier_or_enum_variant_pattern(
    state: ParserState,
    p: StringPayload,
    span_start: Integer,
    span_end: Integer,
) -> ParsePatternStep~ParseError = {
    let advanced: ParserState = advance(state)
    let nx2: SpannedToken? = peek(advanced)
    let is_variant: Trilean! = match nx2 {
        ~0 => false,
        _ => is_lparen(nx2!!.token),
    }
    if is_variant {
        let after_open: ParserState = advance(advanced)
        let payload_step: ParsePatternStep = parse_pattern(after_open) ~? |err| ~- err
        let nx3: SpannedToken? = peek(payload_step.state)
        match nx3 {
            ~0 => ~- make_unexpected_eof_err(payload_step.state, "`)`"),
            _ => {
                let nt3: SpannedToken = nx3!!
                if is_rparen(nt3.token) {
                    let after_close: ParserState = advance(payload_step.state)
                    let res: AllocResult = alloc_pattern(
                        after_close.arena,
                        spanned_pattern(
                            EnumVariantPat(EnumVariantPatternPayload {
                                variant_name: p.text,
                                payload: payload_step.pattern_id,
                            }),
                            span_start,
                            nt3.span_end,
                        ),
                    )
                    ~+ ParsePatternStep {
                        state: ParserState { tokens: after_close.tokens, cursor: after_close.cursor, arena: res.arena },
                        pattern_id: res.id,
                    }
                } else {
                    ~- make_unexpected_token_err(payload_step.state, "`)`")
                }
            },
        }
    } else {
        let res: AllocResult = alloc_pattern(
            advanced.arena,
            spanned_pattern(IdentifierPattern(p), span_start, span_end),
        )
        ~+ ParsePatternStep {
            state: ParserState { tokens: advanced.tokens, cursor: advanced.cursor, arena: res.arena },
            pattern_id: res.id,
        }
    }
}

// `(p1, p2, ...)` tuple pattern. Single-element parens without
// trailing comma are grouping (returns inner pattern unchanged).
function parse_tuple_pattern(state: ParserState, open_start: Integer) -> ParsePatternStep~ParseError = {
    let after_open: ParserState = advance(state)
    // Empty tuple `()` — valid pattern (matches Unit).
    let nx: SpannedToken? = peek(after_open)
    match nx {
        ~0 => ~- make_unexpected_eof_err(after_open, "pattern or `)`"),
        _ => {
            if is_rparen(nx!!.token) {
                let close_end: Integer = nx!!.span_end
                let after_close: ParserState = advance(after_open)
                let res: AllocResult = alloc_pattern(
                    after_close.arena,
                    spanned_pattern(TuplePat(new()), open_start, close_end),
                )
                ~+ ParsePatternStep {
                    state: ParserState { tokens: after_close.tokens, cursor: after_close.cursor, arena: res.arena },
                    pattern_id: res.id,
                }
            } else {
                let first_step: ParsePatternStep = parse_pattern(after_open) ~? |err| ~- err
                let mutable state: ParserState = first_step.state
                let mutable elems: Vector<Integer> = push(new(), first_step.pattern_id)
                let mutable had_comma: Trilean! = false
                let mutable should_continue: Trilean! = true
                let mutable err_slot: ParseError? = ~0

                while should_continue {
                    let nx2: SpannedToken? = peek(state)
                    match nx2 {
                        ~0 => {
                            err_slot = make_unexpected_eof_err(state, "`,` or `)`")
                            should_continue = false
                        },
                        _ => {
                            let nt: SpannedToken = nx2!!
                            if is_comma(nt.token) {
                                had_comma = true
                                state = advance(state)
                                let after_comma: SpannedToken? = peek(state)
                                match after_comma {
                                    ~0 => {
                                        err_slot = make_unexpected_eof_err(state, "pattern or `)`")
                                        should_continue = false
                                    },
                                    _ => {
                                        if is_rparen(after_comma!!.token) {
                                            should_continue = false
                                        } else {
                                            let next_outcome: ParsePatternStep~ParseError = parse_pattern(state)
                                            match next_outcome {
                                                ~+ next_step => {
                                                    elems = push(elems, next_step.pattern_id)
                                                    state = next_step.state
                                                },
                                                ~- e => {
                                                    err_slot = e
                                                    should_continue = false
                                                },
                                            }
                                        }
                                    },
                                }
                            } else {
                                should_continue = false
                            }
                        },
                    }
                }

                match err_slot {
                    ~+ e => ~- e,
                    ~0 => {
                        let close_peek: SpannedToken? = peek(state)
                        match close_peek {
                            ~0 => ~- make_unexpected_eof_err(state, "`)`"),
                            _ => {
                                let nt: SpannedToken = close_peek!!
                                if is_rparen(nt.token) {
                                    let after_close: ParserState = advance(state)
                                    // Single element without trailing comma → grouping.
                                    if length(elems) == 1 {
                                        if had_comma {
                                            let res: AllocResult = alloc_pattern(
                                                after_close.arena,
                                                spanned_pattern(TuplePat(elems), open_start, nt.span_end),
                                            )
                                            ~+ ParsePatternStep {
                                                state: ParserState { tokens: after_close.tokens, cursor: after_close.cursor, arena: res.arena },
                                                pattern_id: res.id,
                                            }
                                        } else {
                                            // Grouping — return inner pattern.
                                            let inner: Integer = get(elems, 0)!!
                                            ~+ ParsePatternStep {
                                                state: ParserState { tokens: after_close.tokens, cursor: after_close.cursor, arena: after_close.arena },
                                                pattern_id: inner,
                                            }
                                        }
                                    } else {
                                        let res: AllocResult = alloc_pattern(
                                            after_close.arena,
                                            spanned_pattern(TuplePat(elems), open_start, nt.span_end),
                                        )
                                        ~+ ParsePatternStep {
                                            state: ParserState { tokens: after_close.tokens, cursor: after_close.cursor, arena: res.arena },
                                            pattern_id: res.id,
                                        }
                                    }
                                } else {
                                    ~- make_unexpected_token_err(state, "`)`")
                                }
                            },
                        }
                    },
                }
            }
        },
    }
}

// Atom Trilean literal pattern (`true` / `false` / `unknown`).
function parse_trilean_pattern_atom(
    state: ParserState,
    value: TrileanValue,
    span_start: Integer,
    span_end: Integer,
) -> ParsePatternStep~ParseError = {
    let advanced: ParserState = advance(state)
    let res: AllocResult = alloc_pattern(
        advanced.arena,
        spanned_pattern(LiteralPat(TrileanLit(value)), span_start, span_end),
    )
    ~+ ParsePatternStep {
        state: ParserState { tokens: advanced.tokens, cursor: advanced.cursor, arena: res.arena },
        pattern_id: res.id,
    }
}

// Parse a literal pattern, optionally followed by `..` or `..=`
// to form a range pattern.
function parse_literal_or_range_pattern(state: ParserState) -> ParsePatternStep~ParseError = {
    let start_step: ParseLiteralPatternStep = parse_literal_pattern_payload(state) ~? |err| ~- err
    let nx: SpannedToken? = peek(start_step.state)
    let range_kind: Integer = match nx {
        ~0 => 0,
        _ => {
            let nt: SpannedToken = nx!!
            if is_dotdoteq(nt.token) {
                2
            } else {
                if is_dotdot(nt.token) {
                    1
                } else {
                    0
                }
            }
        },
    }
    if range_kind == 0 {
        let res: AllocResult = alloc_pattern(
            start_step.state.arena,
            spanned_pattern(LiteralPat(start_step.literal), start_step.span_start, start_step.span_end),
        )
        ~+ ParsePatternStep {
            state: ParserState { tokens: start_step.state.tokens, cursor: start_step.state.cursor, arena: res.arena },
            pattern_id: res.id,
        }
    } else {
        let inclusive: Trilean! = range_kind == 2
        let after_op: ParserState = advance(start_step.state)
        let end_step: ParseLiteralPatternStep = parse_literal_pattern_payload(after_op) ~? |err| ~- err
        let res: AllocResult = alloc_pattern(
            end_step.state.arena,
            spanned_pattern(
                RangePat(RangePatternPayload {
                    range_start: start_step.literal,
                    range_end: end_step.literal,
                    inclusive: inclusive,
                }),
                start_step.span_start,
                end_step.span_end,
            ),
        )
        ~+ ParsePatternStep {
            state: ParserState { tokens: end_step.state.tokens, cursor: end_step.state.cursor, arena: res.arena },
            pattern_id: res.id,
        }
    }
}

// `-N` negative integer literal pattern, optionally followed by
// range continuation.
function parse_negative_literal_pattern(state: ParserState) -> ParsePatternStep~ParseError = {
    let minus_tok: SpannedToken = peek(state)!!
    let after_minus: ParserState = advance(state)
    let nx: SpannedToken? = peek(after_minus)
    let lit_step: ParseLiteralPatternStep = match nx {
        ~0 => ~- make_unexpected_eof_err(after_minus, "integer literal after `-`"),
        ~+ nt => {
            match nt.token {
                IntegerLiteral(int_p) => {
                    let advanced: ParserState = advance(after_minus)
                    ParseLiteralPatternStep {
                        state: advanced,
                        literal: IntegerLit(LiteralIntegerPattern {
                            value: -int_p.literal.value,
                            suffix: int_p.literal.suffix,
                        }),
                        span_start: minus_tok.span_start,
                        span_end: nt.span_end,
                    }
                },
                TernaryLiteral(int_p) => {
                    let advanced: ParserState = advance(after_minus)
                    ParseLiteralPatternStep {
                        state: advanced,
                        literal: TernaryLit(-int_p.literal.value),
                        span_start: minus_tok.span_start,
                        span_end: nt.span_end,
                    }
                },
                _ => ~- make_unexpected_token_err(after_minus, "integer literal after `-`"),
            }
        },
    }

    // Optional range continuation.
    let nx_range: SpannedToken? = peek(lit_step.state)
    let range_kind: Integer = match nx_range {
        ~0 => 0,
        _ => {
            let nt: SpannedToken = nx_range!!
            if is_dotdoteq(nt.token) {
                2
            } else {
                if is_dotdot(nt.token) {
                    1
                } else {
                    0
                }
            }
        },
    }
    if range_kind == 0 {
        let res: AllocResult = alloc_pattern(
            lit_step.state.arena,
            spanned_pattern(LiteralPat(lit_step.literal), lit_step.span_start, lit_step.span_end),
        )
        ~+ ParsePatternStep {
            state: ParserState { tokens: lit_step.state.tokens, cursor: lit_step.state.cursor, arena: res.arena },
            pattern_id: res.id,
        }
    } else {
        let inclusive: Trilean! = range_kind == 2
        let after_op: ParserState = advance(lit_step.state)
        let end_step: ParseLiteralPatternStep = parse_literal_pattern_payload(after_op) ~? |err| ~- err
        let res: AllocResult = alloc_pattern(
            end_step.state.arena,
            spanned_pattern(
                RangePat(RangePatternPayload {
                    range_start: lit_step.literal,
                    range_end: end_step.literal,
                    inclusive: inclusive,
                }),
                lit_step.span_start,
                end_step.span_end,
            ),
        )
        ~+ ParsePatternStep {
            state: ParserState { tokens: end_step.state.tokens, cursor: end_step.state.cursor, arena: res.arena },
            pattern_id: res.id,
        }
    }
}

// Pull a literal value (with optional leading `-`) and its span.
// Used by both `parse_literal_or_range_pattern` and as the range-
// end parser.
function parse_literal_pattern_payload(state: ParserState) -> ParseLiteralPatternStep~ParseError = {
    let nx: SpannedToken? = peek(state)
    match nx {
        ~0 => ~- make_unexpected_eof_err(state, "literal"),
        ~+ nt => {
            // Leading `-` allowed (e.g. range `-5..=5`).
            if is_minus(nt.token) {
                let after_minus: ParserState = advance(state)
                let nx2: SpannedToken? = peek(after_minus)
                match nx2 {
                    ~0 => ~- make_unexpected_eof_err(after_minus, "literal after `-`"),
                    ~+ nt2 => {
                        match nt2.token {
                            IntegerLiteral(int_p) => {
                                let advanced: ParserState = advance(after_minus)
                                ~+ ParseLiteralPatternStep {
                                    state: advanced,
                                    literal: IntegerLit(LiteralIntegerPattern {
                                        value: -int_p.literal.value,
                                        suffix: int_p.literal.suffix,
                                    }),
                                    span_start: nt.span_start,
                                    span_end: nt2.span_end,
                                }
                            },
                            TernaryLiteral(int_p) => {
                                let advanced: ParserState = advance(after_minus)
                                ~+ ParseLiteralPatternStep {
                                    state: advanced,
                                    literal: TernaryLit(-int_p.literal.value),
                                    span_start: nt.span_start,
                                    span_end: nt2.span_end,
                                }
                            },
                            _ => ~- make_unexpected_token_err(after_minus, "integer literal"),
                        }
                    },
                }
            } else {
                match nt.token {
                    IntegerLiteral(int_p) => {
                        let advanced: ParserState = advance(state)
                        ~+ ParseLiteralPatternStep {
                            state: advanced,
                            literal: IntegerLit(LiteralIntegerPattern {
                                value: int_p.literal.value,
                                suffix: int_p.literal.suffix,
                            }),
                            span_start: nt.span_start,
                            span_end: nt.span_end,
                        }
                    },
                    TernaryLiteral(int_p) => {
                        let advanced: ParserState = advance(state)
                        ~+ ParseLiteralPatternStep {
                            state: advanced,
                            literal: TernaryLit(int_p.literal.value),
                            span_start: nt.span_start,
                            span_end: nt.span_end,
                        }
                    },
                    StringLiteral(p) => {
                        let advanced: ParserState = advance(state)
                        ~+ ParseLiteralPatternStep {
                            state: advanced,
                            literal: StringLit(p),
                            span_start: nt.span_start,
                            span_end: nt.span_end,
                        }
                    },
                    TrueKw => {
                        let advanced: ParserState = advance(state)
                        ~+ ParseLiteralPatternStep {
                            state: advanced,
                            literal: TrileanLit(TrueValue),
                            span_start: nt.span_start,
                            span_end: nt.span_end,
                        }
                    },
                    FalseKw => {
                        let advanced: ParserState = advance(state)
                        ~+ ParseLiteralPatternStep {
                            state: advanced,
                            literal: TrileanLit(FalseValue),
                            span_start: nt.span_start,
                            span_end: nt.span_end,
                        }
                    },
                    UnknownKw => {
                        let advanced: ParserState = advance(state)
                        ~+ ParseLiteralPatternStep {
                            state: advanced,
                            literal: TrileanLit(UnknownValue),
                            span_start: nt.span_start,
                            span_end: nt.span_end,
                        }
                    },
                    _ => ~- make_unexpected_token_err(state, "literal"),
                }
            }
        },
    }
}

// `~+ subpattern` or `~- subpattern` outcome arm pattern with payload.
function parse_outcome_arm_pattern_with_payload(
    state: ParserState,
    arm: OutcomeArm,
) -> ParsePatternStep~ParseError = {
    let op_tok: SpannedToken = peek(state)!!
    let advanced: ParserState = advance(state)
    let payload_step: ParsePatternStep = parse_pattern_no_or(advanced) ~? |err| ~- err
    let payload_sp: SpannedPattern = get_pattern(payload_step.state.arena, payload_step.pattern_id)
    let res: AllocResult = alloc_pattern(
        payload_step.state.arena,
        spanned_pattern(
            OutcomeArmPat(OutcomeArmPatternPayload { arm: arm, payload: payload_step.pattern_id }),
            op_tok.span_start,
            payload_sp.span_end,
        ),
    )
    ~+ ParsePatternStep {
        state: ParserState { tokens: payload_step.state.tokens, cursor: payload_step.state.cursor, arena: res.arena },
        pattern_id: res.id,
    }
}

// ─────────────────────────────────────────────────────────────────
// Statement parsing — `let`, `constant`, `return`, `break`,
// `continue`, `for`, `while` / `while?`, `loop`, plus the assign
// vs expr-stmt vs final-expression dispatch handled by
// `parse_statement_or_final_expr`. Mirrors
// crates/triet-parser/src/stmt.rs.
// ─────────────────────────────────────────────────────────────────

function spanned_stmt(node: Stmt, start: Integer, end: Integer) -> SpannedStmt =
    SpannedStmt { node: node, span_start: start, span_end: end }

// `let [mutable] name (: T)? = expr ;?`
function parse_let(state: ParserState) -> ParseStmtStep~ParseError = {
    let head_tok: SpannedToken = peek(state)!!
    let head_start: Integer = head_tok.span_start
    let after_let: ParserState = advance(state)

    let mut_step: EatFlagStep = eat_mutable(after_let)
    let after_mut: ParserState = mut_step.state
    let is_mut: Trilean! = mut_step.was_present

    let name_opt: SpannedToken? = peek(after_mut)
    let parsed_name: StringPayload = match name_opt {
        ~0 => ~- make_unexpected_eof_err(after_mut, "identifier after `let`"),
        _ => {
            let nt: SpannedToken = name_opt!!
            match nt.token {
                Identifier(p) => p,
                _ => ~- make_unexpected_token_err(after_mut, "identifier"),
            }
        },
    }
    let after_name: ParserState = advance(after_mut)

    // Optional `: TypeExpr`. v0.7.5.3 parses the annotation as a
    // bare identifier and allocates a NamedType node — full type
    // grammar lands in v0.7.5.5.
    let ann_step: ParseLetAnnotation = parse_optional_type_annotation(after_name) ~? |err| ~- err
    let after_ann: ParserState = ann_step.state
    let type_annotation: Integer? = ann_step.annotation_id

    let after_eq: ParserState = expect_assign(after_ann) ~? |err| ~- err
    let val_step: ParseStep = parse_expression(after_eq) ~? |err| ~- err
    let after_semi: ParserState = eat_semi(val_step.state)

    let val_sp: SpannedExpr = get_expression(after_semi.arena, val_step.expr_id)
    let payload: LetStmtPayload = LetStmtPayload {
        name: parsed_name.text,
        is_mutable: is_mut,
        type_annotation: type_annotation,
        value: val_step.expr_id,
    }
    let res: AllocResult = alloc_statement(
        after_semi.arena,
        spanned_stmt(LetStmt(payload), head_start, val_sp.span_end),
    )
    ~+ ParseStmtStep {
        state: ParserState { tokens: after_semi.tokens, cursor: after_semi.cursor, arena: res.arena },
        stmt_id: res.id,
    }
}

// `constant NAME (: T)? = expr ;?`
function parse_constant(state: ParserState) -> ParseStmtStep~ParseError = {
    let head_tok: SpannedToken = peek(state)!!
    let head_start: Integer = head_tok.span_start
    let after_kw: ParserState = advance(state)

    let name_opt: SpannedToken? = peek(after_kw)
    let parsed_name: StringPayload = match name_opt {
        ~0 => ~- make_unexpected_eof_err(after_kw, "identifier after `constant`"),
        _ => {
            let nt: SpannedToken = name_opt!!
            match nt.token {
                Identifier(p) => p,
                _ => ~- make_unexpected_token_err(after_kw, "identifier"),
            }
        },
    }
    let after_name: ParserState = advance(after_kw)

    let ann_step: ParseLetAnnotation = parse_optional_type_annotation(after_name) ~? |err| ~- err
    let after_ann: ParserState = ann_step.state
    let type_annotation: Integer? = ann_step.annotation_id

    let after_eq: ParserState = expect_assign(after_ann) ~? |err| ~- err
    let val_step: ParseStep = parse_expression(after_eq) ~? |err| ~- err
    let after_semi: ParserState = eat_semi(val_step.state)

    let val_sp: SpannedExpr = get_expression(after_semi.arena, val_step.expr_id)
    let payload: ConstantStmtPayload = ConstantStmtPayload {
        name: parsed_name.text,
        type_annotation: type_annotation,
        value: val_step.expr_id,
    }
    let res: AllocResult = alloc_statement(
        after_semi.arena,
        spanned_stmt(ConstantStmt(payload), head_start, val_sp.span_end),
    )
    ~+ ParseStmtStep {
        state: ParserState { tokens: after_semi.tokens, cursor: after_semi.cursor, arena: res.arena },
        stmt_id: res.id,
    }
}

// Helper for the shared `let` / `constant` annotation slot.
public struct ParseLetAnnotation {
    state: ParserState,
    annotation_id: Integer?,
}

function parse_optional_type_annotation(state: ParserState) -> ParseLetAnnotation~ParseError = {
    let nx: SpannedToken? = peek(state)
    match nx {
        ~0 => ~+ ParseLetAnnotation { state: state, annotation_id: ~0 },
        _ => {
            let nt: SpannedToken = nx!!
            match nt.token {
                Colon => {
                    let after_colon: ParserState = advance(state)
                    let ty_step: ParseTypeStep = parse_type_minimal(after_colon) ~? |err| ~- err
                    ~+ ParseLetAnnotation { state: ty_step.state, annotation_id: ty_step.type_id }
                },
                _ => ~+ ParseLetAnnotation { state: state, annotation_id: ~0 },
            }
        },
    }
}

public struct ParseTypeStep {
    state: ParserState,
    type_id: Integer,
}

// ─────────────────────────────────────────────────────────────────
// Type parsing — v0.7.5.5a full grammar. Mirrors
// crates/triet-parser/src/type_expr.rs. The atom + postfix split
// is preserved so we can apply ADR-0020 §1.3 precedence:
// 1. `Trilean!` (only after a bare `Trilean` atom)
// 2. `T?~E` (compound `?~`)
// 3. `T~E`  (bare `~`)
// 4. `T?...?` (one or more bare `?`s — chained nullable)
//
// `parse_type_minimal` is kept as the public name for backward
// compat with v0.7.5.3+ call sites (let / constant / param / return
// type annotations + struct fields + enum variant payloads). It is
// just `parse_type` under the hood now.
// ─────────────────────────────────────────────────────────────────

// Helper: alloc a typed node with span.
function spanned_type(node: TypeExpr, start: Integer, end: Integer) -> SpannedTypeExpr =
    SpannedTypeExpr { node: node, span_start: start, span_end: end }

// ── Token predicates for type-level tokens ───────────────────────

function is_question(token: Token) -> Trilean! =
    match token {
        Question => true,
        _ => false,
    }

function is_question_tilde(token: Token) -> Trilean! =
    match token {
        QuestionTilde => true,
        _ => false,
    }

function is_tilde(token: Token) -> Trilean! =
    match token {
        Tilde => true,
        _ => false,
    }

function is_bang(token: Token) -> Trilean! =
    match token {
        Bang => true,
        _ => false,
    }

// Step wrapper for parse_type_list (used by tuple + generic args + function params).
public struct ParseTypeListStep {
    state: ParserState,
    types: Vector<Integer>,
    had_comma: Trilean!,
    close_end: Integer,
}

// Public entrypoint — kept named `parse_type_minimal` so the v0.7.5.3+
// call sites compile unchanged. Returns a `ParseTypeStep` containing
// the root TypeExpr ID.
public function parse_type_minimal(state: ParserState) -> ParseTypeStep~ParseError = {
    let head: ParseTypeStep = parse_type_atom(state) ~? |err| ~- err
    apply_type_postfix(head.state, head.type_id)
}

// Atom: NamedType (+ optional generic args), or paren-form (which
// resolves to grouping, tuple type, or function type).
function parse_type_atom(state: ParserState) -> ParseTypeStep~ParseError = {
    let nx_opt: SpannedToken? = peek(state)
    match nx_opt {
        ~0 => ~- make_unexpected_eof_err(state, "type expression"),
        ~+ nx => {
            match nx.token {
                Identifier(p) => {
                    let advanced: ParserState = advance(state)
                    // Optional generic instantiation `Name<T1, T2>`.
                    let nx2: SpannedToken? = peek(advanced)
                    let is_gen: Trilean! = match nx2 {
                        ~0 => false,
                        _ => is_lt(nx2!!.token),
                    }
                    if is_gen {
                        parse_generic_args(advanced, p.text, nx.span_start)
                    } else {
                        let res: AllocResult = alloc_type(
                            advanced.arena,
                            spanned_type(
                                NamedType(NamedTypePayload { name: p.text }),
                                nx.span_start,
                                nx.span_end,
                            ),
                        )
                        ~+ ParseTypeStep {
                            state: ParserState { tokens: advanced.tokens, cursor: advanced.cursor, arena: res.arena },
                            type_id: res.id,
                        }
                    }
                },
                LParen => parse_paren_type(state, nx.span_start),
                _ => ~- make_unexpected_token_err(state, "type expression"),
            }
        },
    }
}

// `Name<T1, T2, ...>` after the name has been consumed.
function parse_generic_args(state: ParserState, name: String, name_start: Integer) -> ParseTypeStep~ParseError = {
    let after_lt: ParserState = advance(state) // consume `<`
    let mutable state: ParserState = after_lt
    let mutable args: Vector<Integer> = new()
    let mutable should_continue: Trilean! = true
    let mutable err_slot: ParseError? = ~0

    // Empty generic list `<>` short-circuit (parser_minimal rejects, but
    // mirror the Rust impl: walk normally and let `>` close it).
    let first_peek: SpannedToken? = peek(state)
    match first_peek {
        ~0 => {
            err_slot = make_unexpected_eof_err(state, "type argument or `>`")
            should_continue = false
        },
        _ => {
            if is_gt(first_peek!!.token) {
                should_continue = false
            }
        },
    }

    while should_continue {
        let arg_outcome: ParseTypeStep~ParseError = parse_type_minimal(state)
        match arg_outcome {
            ~+ arg_step => {
                args = push(args, arg_step.type_id)
                state = arg_step.state
                let after_arg: SpannedToken? = peek(state)
                match after_arg {
                    ~0 => {
                        err_slot = make_unexpected_eof_err(state, "`,` or `>`")
                        should_continue = false
                    },
                    _ => {
                        let nt: SpannedToken = after_arg!!
                        if is_comma(nt.token) {
                            state = advance(state)
                            // Trailing comma allowed.
                            let after_comma: SpannedToken? = peek(state)
                            match after_comma {
                                ~0 => {
                                    err_slot = make_unexpected_eof_err(state, "type argument or `>`")
                                    should_continue = false
                                },
                                _ => {
                                    if is_gt(after_comma!!.token) {
                                        should_continue = false
                                    }
                                },
                            }
                        } else {
                            should_continue = false
                        }
                    },
                }
            },
            ~- e => {
                err_slot = e
                should_continue = false
            },
        }
    }

    match err_slot {
        ~+ e => ~- e,
        ~0 => {
            // expect `>`
            let close_peek: SpannedToken? = peek(state)
            match close_peek {
                ~0 => ~- make_unexpected_eof_err(state, "`>`"),
                _ => {
                    let nt: SpannedToken = close_peek!!
                    if is_gt(nt.token) {
                        let after_close: ParserState = advance(state)
                        let res: AllocResult = alloc_type(
                            after_close.arena,
                            spanned_type(
                                GenericType(GenericTypePayload { name: name, arguments: args }),
                                name_start,
                                nt.span_end,
                            ),
                        )
                        ~+ ParseTypeStep {
                            state: ParserState { tokens: after_close.tokens, cursor: after_close.cursor, arena: res.arena },
                            type_id: res.id,
                        }
                    } else {
                        ~- make_unexpected_token_err(state, "`>`")
                    }
                },
            }
        },
    }
}

// `(...)` form. Three outcomes:
//   1. `(T)` — grouping, returns inner T unchanged.
//   2. `(T1, T2 [, ...])` — tuple type.
//   3. `(T1, T2 [, ...]) -> R` — function type.
function parse_paren_type(state: ParserState, open_start: Integer) -> ParseTypeStep~ParseError = {
    let after_open: ParserState = advance(state) // consume `(`
    // Reject empty `()` for consistency with Rust impl (no Unit syntax sugar).
    let nx: SpannedToken? = peek(after_open)
    match nx {
        ~0 => ~- make_unexpected_eof_err(after_open, "at least one type before `)`"),
        _ => {
            if is_rparen(nx!!.token) {
                ~- make_unexpected_token_err(after_open, "at least one type before `)`")
            } else {
                let elems_step: ParseTypeListStep = parse_type_list_until_rparen(after_open) ~? |err| ~- err
                // We're now past `)`. Check for `->` (function type).
                let nx_arrow: SpannedToken? = peek(elems_step.state)
                let is_arrow: Trilean! = match nx_arrow {
                    ~0 => false,
                    _ => is_thin_arrow(nx_arrow!!.token),
                }
                if is_arrow {
                    let after_arrow: ParserState = advance(elems_step.state)
                    let ret_step: ParseTypeStep = parse_type_minimal(after_arrow) ~? |err| ~- err
                    let ret_sp: SpannedTypeExpr = get_type(ret_step.state.arena, ret_step.type_id)
                    let res: AllocResult = alloc_type(
                        ret_step.state.arena,
                        spanned_type(
                            FunctionType(FunctionTypePayload {
                                parameters: elems_step.types,
                                return_type: ret_step.type_id,
                            }),
                            open_start,
                            ret_sp.span_end,
                        ),
                    )
                    ~+ ParseTypeStep {
                        state: ParserState {
                            tokens: ret_step.state.tokens,
                            cursor: ret_step.state.cursor,
                            arena: res.arena,
                        },
                        type_id: res.id,
                    }
                } else {
                    // Grouping vs tuple decided by length + comma presence.
                    let elem_count: Integer = length(elems_step.types)
                    if elem_count == 1 {
                        if elems_step.had_comma {
                            // `(T,)` — singleton tuple. Span includes
                            // the closing `)` to match Rust.
                            let res: AllocResult = alloc_type(
                                elems_step.state.arena,
                                spanned_type(TupleType(elems_step.types), open_start, elems_step.close_end),
                            )
                            ~+ ParseTypeStep {
                                state: ParserState {
                                    tokens: elems_step.state.tokens,
                                    cursor: elems_step.state.cursor,
                                    arena: res.arena,
                                },
                                type_id: res.id,
                            }
                        } else {
                            // `(T)` — grouping, return inner unchanged.
                            let inner_id: Integer = get(elems_step.types, 0)!!
                            ~+ ParseTypeStep { state: elems_step.state, type_id: inner_id }
                        }
                    } else {
                        // 2+ elements — tuple. Span includes the
                        // closing `)`.
                        let res: AllocResult = alloc_type(
                            elems_step.state.arena,
                            spanned_type(TupleType(elems_step.types), open_start, elems_step.close_end),
                        )
                        ~+ ParseTypeStep {
                            state: ParserState {
                                tokens: elems_step.state.tokens,
                                cursor: elems_step.state.cursor,
                                arena: res.arena,
                            },
                            type_id: res.id,
                        }
                    }
                }
            }
        },
    }
}

// Parse comma-separated types until `)`. Returns the list + a
// trailing flag so the caller can disambiguate `(T)` grouping from
// `(T,)` singleton tuple. Consumes the closing `)`.
function parse_type_list_until_rparen(state: ParserState) -> ParseTypeListStep~ParseError = {
    let first_step: ParseTypeStep = parse_type_minimal(state) ~? |err| ~- err
    let mutable state: ParserState = first_step.state
    let mutable types: Vector<Integer> = push(new(), first_step.type_id)
    let mutable had_comma: Trilean! = false
    let mutable should_continue: Trilean! = true
    let mutable err_slot: ParseError? = ~0

    while should_continue {
        let nx: SpannedToken? = peek(state)
        match nx {
            ~0 => {
                err_slot = make_unexpected_eof_err(state, "`,` or `)`")
                should_continue = false
            },
            _ => {
                let nt: SpannedToken = nx!!
                if is_comma(nt.token) {
                    had_comma = true
                    state = advance(state)
                    // Trailing comma before `)` allowed.
                    let after_comma: SpannedToken? = peek(state)
                    match after_comma {
                        ~0 => {
                            err_slot = make_unexpected_eof_err(state, "type or `)`")
                            should_continue = false
                        },
                        _ => {
                            if is_rparen(after_comma!!.token) {
                                should_continue = false
                            } else {
                                let next_outcome: ParseTypeStep~ParseError = parse_type_minimal(state)
                                match next_outcome {
                                    ~+ next_step => {
                                        types = push(types, next_step.type_id)
                                        state = next_step.state
                                    },
                                    ~- e => {
                                        err_slot = e
                                        should_continue = false
                                    },
                                }
                            }
                        },
                    }
                } else {
                    should_continue = false
                }
            },
        }
    }

    match err_slot {
        ~+ e => ~- e,
        ~0 => {
            // consume `)`
            let close_peek: SpannedToken? = peek(state)
            match close_peek {
                ~0 => ~- make_unexpected_eof_err(state, "`)`"),
                _ => {
                    let close_tok: SpannedToken = close_peek!!
                    if is_rparen(close_tok.token) {
                        ~+ ParseTypeListStep {
                            state: advance(state),
                            types: types,
                            had_comma: had_comma,
                            close_end: close_tok.span_end,
                        }
                    } else {
                        ~- make_unexpected_token_err(state, "`)`")
                    }
                },
            }
        },
    }
}

// Postfix operators: precedence per ADR-0020 §1.3.
function apply_type_postfix(state: ParserState, id: Integer) -> ParseTypeStep~ParseError = {
    // 1. `Trilean!` refinement — only valid right after a bare
    //    `Trilean` atom per ADR-0021 §2.7. If the bang sits after
    //    a non-Trilean atom, fall through and let the surrounding
    //    context decide (typically the caller treats it as an
    //    error).
    let nx: SpannedToken? = peek(state)
    match nx {
        ~0 => ~+ ParseTypeStep { state: state, type_id: id },
        _ => {
            let nt: SpannedToken = nx!!
            if is_bang(nt.token) {
                let inner_sp: SpannedTypeExpr = get_type(state.arena, id)
                let is_bare_trilean: Trilean! = match inner_sp.node {
                    NamedType(p) => p.name == "Trilean",
                    _ => false,
                }
                if is_bare_trilean {
                    let after_bang: ParserState = advance(state)
                    let res: AllocResult = alloc_type(
                        after_bang.arena,
                        spanned_type(RefinedTrileanType, inner_sp.span_start, nt.span_end),
                    )
                    apply_type_postfix(
                        ParserState { tokens: after_bang.tokens, cursor: after_bang.cursor, arena: res.arena },
                        res.id,
                    )
                } else {
                    // Bang after a non-Trilean atom — let the caller surface.
                    apply_outcome_or_nullable(state, id)
                }
            } else {
                apply_outcome_or_nullable(state, id)
            }
        },
    }
}

// 2. + 3. + 4. — `T?~E` / `T~E` / chained `T?`s.
function apply_outcome_or_nullable(state: ParserState, id: Integer) -> ParseTypeStep~ParseError = {
    let nx: SpannedToken? = peek(state)
    match nx {
        ~0 => ~+ ParseTypeStep { state: state, type_id: id },
        _ => {
            let nt: SpannedToken = nx!!
            if is_question_tilde(nt.token) {
                let after_op: ParserState = advance(state)
                let err_step: ParseTypeStep = parse_type_atom(after_op) ~? |err| ~- err
                let val_sp: SpannedTypeExpr = get_type(err_step.state.arena, id)
                let err_sp: SpannedTypeExpr = get_type(err_step.state.arena, err_step.type_id)
                let res: AllocResult = alloc_type(
                    err_step.state.arena,
                    spanned_type(
                        OutcomeType(OutcomeTypePayload {
                            value_type: id,
                            error_type: err_step.type_id,
                            allow_null_state: true,
                        }),
                        val_sp.span_start,
                        err_sp.span_end,
                    ),
                )
                ~+ ParseTypeStep {
                    state: ParserState {
                        tokens: err_step.state.tokens,
                        cursor: err_step.state.cursor,
                        arena: res.arena,
                    },
                    type_id: res.id,
                }
            } else {
                if is_tilde(nt.token) {
                    let after_op: ParserState = advance(state)
                    let err_step: ParseTypeStep = parse_type_atom(after_op) ~? |err| ~- err
                    let val_sp: SpannedTypeExpr = get_type(err_step.state.arena, id)
                    let err_sp: SpannedTypeExpr = get_type(err_step.state.arena, err_step.type_id)
                    let res: AllocResult = alloc_type(
                        err_step.state.arena,
                        spanned_type(
                            OutcomeType(OutcomeTypePayload {
                                value_type: id,
                                error_type: err_step.type_id,
                                allow_null_state: false,
                            }),
                            val_sp.span_start,
                            err_sp.span_end,
                        ),
                    )
                    ~+ ParseTypeStep {
                        state: ParserState {
                            tokens: err_step.state.tokens,
                            cursor: err_step.state.cursor,
                            arena: res.arena,
                        },
                        type_id: res.id,
                    }
                } else {
                    if is_question(nt.token) {
                        apply_chained_nullable(state, id)
                    } else {
                        ~+ ParseTypeStep { state: state, type_id: id }
                    }
                }
            }
        },
    }
}

// 4. Chained `T?` / `T??` / `T???` — one or more bare `?` tokens.
function apply_chained_nullable(state: ParserState, start_id: Integer) -> ParseTypeStep~ParseError = {
    let mutable state: ParserState = state
    let mutable id: Integer = start_id
    let mutable should_continue: Trilean! = true

    while should_continue {
        let nx: SpannedToken? = peek(state)
        match nx {
            ~0 => {
                should_continue = false
            },
            _ => {
                let nt: SpannedToken = nx!!
                if is_question(nt.token) {
                    let after_q: ParserState = advance(state)
                    let inner_sp: SpannedTypeExpr = get_type(after_q.arena, id)
                    let res: AllocResult = alloc_type(
                        after_q.arena,
                        spanned_type(NullableType(id), inner_sp.span_start, nt.span_end),
                    )
                    state = ParserState { tokens: after_q.tokens, cursor: after_q.cursor, arena: res.arena }
                    id = res.id
                } else {
                    should_continue = false
                }
            },
        }
    }
    ~+ ParseTypeStep { state: state, type_id: id }
}

// `return [expr] ;?` — value absent when next is `;`, `}`, `,`, or EOF.
function parse_return(state: ParserState) -> ParseStmtStep~ParseError = {
    let head_tok: SpannedToken = peek(state)!!
    let head_start: Integer = head_tok.span_start
    let head_end: Integer = head_tok.span_end
    let after_kw: ParserState = advance(state)

    let has_value: Trilean! = {
        let nx: SpannedToken? = peek(after_kw)
        match nx {
            ~0 => false,
            _ => if is_value_terminator(nx!!.token) { false } else { true },
        }
    }

    if has_value {
        let val_step: ParseStep = parse_expression(after_kw) ~? |err| ~- err
        let after_semi: ParserState = eat_semi(val_step.state)
        let val_sp: SpannedExpr = get_expression(after_semi.arena, val_step.expr_id)
        let payload: ReturnStmtPayload = ReturnStmtPayload { value: val_step.expr_id }
        let res: AllocResult = alloc_statement(
            after_semi.arena,
            spanned_stmt(ReturnStmt(payload), head_start, val_sp.span_end),
        )
        ~+ ParseStmtStep {
            state: ParserState { tokens: after_semi.tokens, cursor: after_semi.cursor, arena: res.arena },
            stmt_id: res.id,
        }
    } else {
        let after_semi: ParserState = eat_semi(after_kw)
        let payload: ReturnStmtPayload = ReturnStmtPayload { value: ~0 }
        let res: AllocResult = alloc_statement(
            after_semi.arena,
            spanned_stmt(ReturnStmt(payload), head_start, head_end),
        )
        ~+ ParseStmtStep {
            state: ParserState { tokens: after_semi.tokens, cursor: after_semi.cursor, arena: res.arena },
            stmt_id: res.id,
        }
    }
}

// `break [expr] ;?` — same value-absence rule as `return`.
function parse_break(state: ParserState) -> ParseStmtStep~ParseError = {
    let head_tok: SpannedToken = peek(state)!!
    let head_start: Integer = head_tok.span_start
    let head_end: Integer = head_tok.span_end
    let after_kw: ParserState = advance(state)

    let has_value: Trilean! = {
        let nx: SpannedToken? = peek(after_kw)
        match nx {
            ~0 => false,
            _ => if is_value_terminator(nx!!.token) { false } else { true },
        }
    }

    if has_value {
        let val_step: ParseStep = parse_expression(after_kw) ~? |err| ~- err
        let after_semi: ParserState = eat_semi(val_step.state)
        let val_sp: SpannedExpr = get_expression(after_semi.arena, val_step.expr_id)
        let payload: BreakStmtPayload = BreakStmtPayload { value: val_step.expr_id }
        let res: AllocResult = alloc_statement(
            after_semi.arena,
            spanned_stmt(BreakStmt(payload), head_start, val_sp.span_end),
        )
        ~+ ParseStmtStep {
            state: ParserState { tokens: after_semi.tokens, cursor: after_semi.cursor, arena: res.arena },
            stmt_id: res.id,
        }
    } else {
        let after_semi: ParserState = eat_semi(after_kw)
        let payload: BreakStmtPayload = BreakStmtPayload { value: ~0 }
        let res: AllocResult = alloc_statement(
            after_semi.arena,
            spanned_stmt(BreakStmt(payload), head_start, head_end),
        )
        ~+ ParseStmtStep {
            state: ParserState { tokens: after_semi.tokens, cursor: after_semi.cursor, arena: res.arena },
            stmt_id: res.id,
        }
    }
}

function parse_continue(state: ParserState) -> ParseStmtStep~ParseError = {
    let head_tok: SpannedToken = peek(state)!!
    let after_kw: ParserState = advance(state)
    let after_semi: ParserState = eat_semi(after_kw)
    let res: AllocResult = alloc_statement(
        after_semi.arena,
        spanned_stmt(ContinueStmt, head_tok.span_start, head_tok.span_end),
    )
    ~+ ParseStmtStep {
        state: ParserState { tokens: after_semi.tokens, cursor: after_semi.cursor, arena: res.arena },
        stmt_id: res.id,
    }
}

// `for pattern in expr { ... }`.
function parse_for(state: ParserState) -> ParseStmtStep~ParseError = {
    let head_tok: SpannedToken = peek(state)!!
    let head_start: Integer = head_tok.span_start
    let after_kw: ParserState = advance(state)

    let pat_step: ParsePatternStep = parse_pattern(after_kw) ~? |err| ~- err
    let after_in: ParserState = expect_in_kw(pat_step.state) ~? |err| ~- err
    let iter_step: ParseStep = parse_expression(after_in) ~? |err| ~- err
    let body_step: ParseBlockStep = parse_block(iter_step.state) ~? |err| ~- err

    // span end = previous-token-end after parse_block consumed `}`
    let prev_end: Integer = previous_token_end(body_step.state, head_tok.span_end)
    let payload: ForStmtPayload = ForStmtPayload {
        variable: pat_step.pattern_id,
        iterable: iter_step.expr_id,
        body: body_step.block,
    }
    let res: AllocResult = alloc_statement(
        body_step.state.arena,
        spanned_stmt(ForStmt(payload), head_start, prev_end),
    )
    ~+ ParseStmtStep {
        state: ParserState {
            tokens: body_step.state.tokens,
            cursor: body_step.state.cursor,
            arena: res.arena,
        },
        stmt_id: res.id,
    }
}

// `while expr { ... }` / `while? expr { ... }`.
function parse_while(state: ParserState) -> ParseStmtStep~ParseError = {
    let head_tok: SpannedToken = peek(state)!!
    let head_start: Integer = head_tok.span_start
    let unknown_as_false: Trilean! = is_while_q_kw(head_tok.token)
    let after_kw: ParserState = advance(state)

    let cond_step: ParseStep = parse_expression(after_kw) ~? |err| ~- err
    let body_step: ParseBlockStep = parse_block(cond_step.state) ~? |err| ~- err

    let prev_end: Integer = previous_token_end(body_step.state, head_tok.span_end)
    let payload: WhileStmtPayload = WhileStmtPayload {
        condition: cond_step.expr_id,
        body: body_step.block,
        treat_unknown_as_false: unknown_as_false,
    }
    let res: AllocResult = alloc_statement(
        body_step.state.arena,
        spanned_stmt(WhileStmt(payload), head_start, prev_end),
    )
    ~+ ParseStmtStep {
        state: ParserState {
            tokens: body_step.state.tokens,
            cursor: body_step.state.cursor,
            arena: res.arena,
        },
        stmt_id: res.id,
    }
}

// `loop { ... }`.
function parse_loop_stmt(state: ParserState) -> ParseStmtStep~ParseError = {
    let head_tok: SpannedToken = peek(state)!!
    let head_start: Integer = head_tok.span_start
    let after_kw: ParserState = advance(state)
    let body_step: ParseBlockStep = parse_block(after_kw) ~? |err| ~- err
    let prev_end: Integer = previous_token_end(body_step.state, head_tok.span_end)
    let payload: LoopStmtPayload = LoopStmtPayload { body: body_step.block }
    let res: AllocResult = alloc_statement(
        body_step.state.arena,
        spanned_stmt(LoopStmt(payload), head_start, prev_end),
    )
    ~+ ParseStmtStep {
        state: ParserState {
            tokens: body_step.state.tokens,
            cursor: body_step.state.cursor,
            arena: res.arena,
        },
        stmt_id: res.id,
    }
}

// `previous_token_end` mirrors Parser::previous_token_end — returns
// the `span_end` of the token immediately before the current
// cursor, falling back to `default_end` when we're at the start.
function previous_token_end(state: ParserState, default_end: Integer) -> Integer = {
    if state.cursor == 0 {
        default_end
    } else {
        let prev: SpannedToken = get(state.tokens, state.cursor - 1)!!
        prev.span_end
    }
}

// ─────────────────────────────────────────────────────────────────
// Block parser — `{ stmts* final-expr? }`. Mirrors
// triet-parser::expr::parse_block. Each iteration calls
// `parse_statement_or_final_expr`; a `FinalExprElem` terminates
// the loop before the closing brace.
// ─────────────────────────────────────────────────────────────────

public function parse_block(state: ParserState) -> ParseBlockStep~ParseError = {
    let after_open: ParserState = expect_lbrace(state) ~? |err| ~- err
    let mutable state: ParserState = after_open
    let mutable stmts: Vector<Integer> = new()
    let mutable final_expr: Integer? = ~0
    let mutable should_continue: Trilean! = true
    let mutable err_slot: ParseError? = ~0

    while should_continue {
        let nx: SpannedToken? = peek(state)
        match nx {
            ~0 => {
                err_slot = make_unexpected_eof_err(state, "`}`")
                should_continue = false
            },
            _ => {
                if is_rbrace(nx!!.token) {
                    should_continue = false
                } else {
                    let outcome: BlockElementStep~ParseError = parse_statement_or_final_expr(state)
                    match outcome {
                        ~+ step => {
                            state = step.state
                            match step.element {
                                StatementElem(sid) => {
                                    stmts = push(stmts, sid)
                                },
                                FinalExprElem(eid) => {
                                    final_expr = eid
                                    should_continue = false
                                },
                            }
                        },
                        ~- e => {
                            err_slot = e
                            should_continue = false
                        },
                    }
                }
            },
        }
    }

    match err_slot {
        ~+ e => ~- e,
        ~0 => {
            let after_close: ParserState = expect_rbrace(state) ~? |err| ~- err
            ~+ ParseBlockStep {
                state: after_close,
                block: Block { block_statements: stmts, block_final: final_expr },
            }
        },
    }
}

// Decide whether the next block element is a keyword statement
// (`let`/`return`/…), an expression-statement (`expr ;`), an
// assignment (`ident = expr ;?`), or the block's final expression
// (`expr` followed by `}`).
public function parse_statement_or_final_expr(state: ParserState) -> BlockElementStep~ParseError = {
    let nx_opt: SpannedToken? = peek(state)
    match nx_opt {
        ~0 => ~- make_unexpected_eof_err(state, "statement or expression"),
        ~+ nx => {
            match nx.token {
                LetKw => {
                    let stmt_step: ParseStmtStep = parse_let(state) ~? |err| ~- err
                    ~+ BlockElementStep { state: stmt_step.state, element: StatementElem(stmt_step.stmt_id) }
                },
                ConstantKw => {
                    let stmt_step: ParseStmtStep = parse_constant(state) ~? |err| ~- err
                    ~+ BlockElementStep { state: stmt_step.state, element: StatementElem(stmt_step.stmt_id) }
                },
                ReturnKw => {
                    let stmt_step: ParseStmtStep = parse_return(state) ~? |err| ~- err
                    ~+ BlockElementStep { state: stmt_step.state, element: StatementElem(stmt_step.stmt_id) }
                },
                BreakKw => {
                    let stmt_step: ParseStmtStep = parse_break(state) ~? |err| ~- err
                    ~+ BlockElementStep { state: stmt_step.state, element: StatementElem(stmt_step.stmt_id) }
                },
                ContinueKw => {
                    let stmt_step: ParseStmtStep = parse_continue(state) ~? |err| ~- err
                    ~+ BlockElementStep { state: stmt_step.state, element: StatementElem(stmt_step.stmt_id) }
                },
                ForKw => {
                    let stmt_step: ParseStmtStep = parse_for(state) ~? |err| ~- err
                    ~+ BlockElementStep { state: stmt_step.state, element: StatementElem(stmt_step.stmt_id) }
                },
                WhileKw => {
                    let stmt_step: ParseStmtStep = parse_while(state) ~? |err| ~- err
                    ~+ BlockElementStep { state: stmt_step.state, element: StatementElem(stmt_step.stmt_id) }
                },
                WhileQKw => {
                    let stmt_step: ParseStmtStep = parse_while(state) ~? |err| ~- err
                    ~+ BlockElementStep { state: stmt_step.state, element: StatementElem(stmt_step.stmt_id) }
                },
                LoopKw => {
                    let stmt_step: ParseStmtStep = parse_loop_stmt(state) ~? |err| ~- err
                    ~+ BlockElementStep { state: stmt_step.state, element: StatementElem(stmt_step.stmt_id) }
                },
                _ => parse_expression_or_final(state),
            }
        },
    }
}

// Expression-position dispatch: after `parse_expression`, check
// for `=` (assignment), `;` (expr-stmt), `}` / EOF (final expr),
// or fall through to expr-stmt with no semicolon.
function parse_expression_or_final(state: ParserState) -> BlockElementStep~ParseError = {
    let expr_step: ParseStep = parse_expression(state) ~? |err| ~- err
    let after_expr: ParserState = expr_step.state
    let expr_id: Integer = expr_step.expr_id

    let nx: SpannedToken? = peek(after_expr)
    match nx {
        ~0 => ~+ BlockElementStep {
            state: after_expr,
            element: FinalExprElem(expr_id),
        },
        ~+ tok => {
            if is_assign_token(tok.token) {
                parse_assignment_after_target(after_expr, expr_id)
            } else {
                if is_semi(tok.token) {
                    let after_semi: ParserState = advance(after_expr)
                    let expr_sp: SpannedExpr = get_expression(after_semi.arena, expr_id)
                    let payload: ExpressionStmtPayload = ExpressionStmtPayload { expression: expr_id }
                    let res: AllocResult = alloc_statement(
                        after_semi.arena,
                        spanned_stmt(ExpressionStmt(payload), expr_sp.span_start, expr_sp.span_end),
                    )
                    ~+ BlockElementStep {
                        state: ParserState {
                            tokens: after_semi.tokens,
                            cursor: after_semi.cursor,
                            arena: res.arena,
                        },
                        element: StatementElem(res.id),
                    }
                } else {
                    if is_rbrace(tok.token) {
                        ~+ BlockElementStep { state: after_expr, element: FinalExprElem(expr_id) }
                    } else {
                        // No semi and more content follows — treat as expr-stmt anyway.
                        let expr_sp: SpannedExpr = get_expression(after_expr.arena, expr_id)
                        let payload: ExpressionStmtPayload = ExpressionStmtPayload { expression: expr_id }
                        let res: AllocResult = alloc_statement(
                            after_expr.arena,
                            spanned_stmt(ExpressionStmt(payload), expr_sp.span_start, expr_sp.span_end),
                        )
                        ~+ BlockElementStep {
                            state: ParserState {
                                tokens: after_expr.tokens,
                                cursor: after_expr.cursor,
                                arena: res.arena,
                            },
                            element: StatementElem(res.id),
                        }
                    }
                }
            }
        },
    }
}

// `target = value ;?` — validate `target` is an identifier (SPEC §5).
// Tuple / field / index targets are reserved for future spec work.
function parse_assignment_after_target(state: ParserState, target_expr: Integer) -> BlockElementStep~ParseError = {
    let target_sp: SpannedExpr = get_expression(state.arena, target_expr)
    let target_name: String = match target_sp.node {
        IdentifierExpr(p) => p.text,
        _ => ~- make_unexpected_token_err(state, "identifier on left of `=`"),
    }
    let after_eq: ParserState = expect_assign(state) ~? |err| ~- err
    let val_step: ParseStep = parse_expression(after_eq) ~? |err| ~- err
    let after_semi: ParserState = eat_semi(val_step.state)
    let val_sp: SpannedExpr = get_expression(after_semi.arena, val_step.expr_id)
    let payload: AssignStmtPayload = AssignStmtPayload {
        target: target_name,
        value: val_step.expr_id,
    }
    let res: AllocResult = alloc_statement(
        after_semi.arena,
        spanned_stmt(AssignStmt(payload), target_sp.span_start, val_sp.span_end),
    )
    ~+ BlockElementStep {
        state: ParserState {
            tokens: after_semi.tokens,
            cursor: after_semi.cursor,
            arena: res.arena,
        },
        element: StatementElem(res.id),
    }
}

// ─────────────────────────────────────────────────────────────────
// Item parsing — top-level `function` / `constant` / `type` (.4a)
// plus stubs for `struct` / `enum` / `module` / `import` / `from`
// that surface as ParseError until .4b lands. Mirrors
// crates/triet-parser/src/item.rs.
// ─────────────────────────────────────────────────────────────────

function spanned_item(node: Item, start: Integer, end: Integer) -> SpannedItem =
    SpannedItem { node: node, span_start: start, span_end: end }

// ── Token kind predicates for item-level keywords ────────────────

function is_function_kw(token: Token) -> Trilean! =
    match token {
        FunctionKw => true,
        _ => false,
    }

function is_constant_kw(token: Token) -> Trilean! =
    match token {
        ConstantKw => true,
        _ => false,
    }

function is_type_kw(token: Token) -> Trilean! =
    match token {
        TypeKw => true,
        _ => false,
    }

function is_struct_kw(token: Token) -> Trilean! =
    match token {
        StructKw => true,
        _ => false,
    }

function is_enum_kw(token: Token) -> Trilean! =
    match token {
        EnumKw => true,
        _ => false,
    }

function is_module_kw(token: Token) -> Trilean! =
    match token {
        ModuleKw => true,
        _ => false,
    }

function is_import_kw(token: Token) -> Trilean! =
    match token {
        ImportKw => true,
        _ => false,
    }

function is_from_kw(token: Token) -> Trilean! =
    match token {
        FromKw => true,
        _ => false,
    }

function is_public_kw(token: Token) -> Trilean! =
    match token {
        PublicKw => true,
        _ => false,
    }

function is_lparen(token: Token) -> Trilean! =
    match token {
        LParen => true,
        _ => false,
    }

function is_rparen(token: Token) -> Trilean! =
    match token {
        RParen => true,
        _ => false,
    }

function is_lt(token: Token) -> Trilean! =
    match token {
        Lt => true,
        _ => false,
    }

function is_gt(token: Token) -> Trilean! =
    match token {
        Gt => true,
        _ => false,
    }

function is_thin_arrow(token: Token) -> Trilean! =
    match token {
        ThinArrow => true,
        _ => false,
    }

function is_owned_kw(token: Token) -> Trilean! =
    match token {
        OwnedKw => true,
        _ => false,
    }

// `parse_visibility` — ADR-0005 §"Visibility": three states.
// `public` alone → PublicVis, `public(package)` → PackageVis, no
// keyword → PrivateVis. Anything other than `package` inside the
// parens is an error.
public function parse_visibility(state: ParserState) -> ParseVisibilityStep~ParseError = {
    let nx: SpannedToken? = peek(state)
    match nx {
        ~0 => ~+ ParseVisibilityStep { state: state, visibility: PrivateVis },
        _ => {
            let nt: SpannedToken = nx!!
            if is_public_kw(nt.token) {
                let after_pub: ParserState = advance(state)
                let nx2: SpannedToken? = peek(after_pub)
                match nx2 {
                    ~0 => ~+ ParseVisibilityStep { state: after_pub, visibility: PublicVis },
                    _ => {
                        let nt2: SpannedToken = nx2!!
                        if is_lparen(nt2.token) {
                            let after_open: ParserState = advance(after_pub)
                            let nx3: SpannedToken? = peek(after_open)
                            match nx3 {
                                ~0 => ~- make_unexpected_eof_err(after_open, "`package` after `public(`"),
                                _ => {
                                    let nt3: SpannedToken = nx3!!
                                    match nt3.token {
                                        Identifier(p) => {
                                            if p.text == "package" {
                                                let after_name: ParserState = advance(after_open)
                                                let nx4: SpannedToken? = peek(after_name)
                                                match nx4 {
                                                    ~0 => ~- make_unexpected_eof_err(after_name, "`)`"),
                                                    _ => {
                                                        let nt4: SpannedToken = nx4!!
                                                        if is_rparen(nt4.token) {
                                                            let after_close: ParserState = advance(after_name)
                                                            ~+ ParseVisibilityStep { state: after_close, visibility: PackageVis }
                                                        } else {
                                                            ~- make_unexpected_token_err(after_name, "`)`")
                                                        }
                                                    },
                                                }
                                            } else {
                                                ~- make_unexpected_token_err(
                                                    after_open,
                                                    "`package` (the only restriction allowed in `public(...)`)",
                                                )
                                            }
                                        },
                                        _ => ~- make_unexpected_token_err(
                                            after_open,
                                            "`package` (the only restriction allowed in `public(...)`)",
                                        ),
                                    }
                                },
                            }
                        } else {
                            ~+ ParseVisibilityStep { state: after_pub, visibility: PublicVis }
                        }
                    },
                }
            } else {
                ~+ ParseVisibilityStep { state: state, visibility: PrivateVis }
            }
        },
    }
}

// `parse_ident` — consumes one Identifier token and returns its
// text + span. Errors on EOF / non-Identifier.
function parse_ident(state: ParserState, expected: String) -> ParseIdentStep~ParseError = {
    let nx: SpannedToken? = peek(state)
    match nx {
        ~0 => ~- make_unexpected_eof_err(state, expected),
        ~+ nt => {
            match nt.token {
                Identifier(p) => {
                    let advanced: ParserState = advance(state)
                    ~+ ParseIdentStep {
                        state: advanced,
                        text: p.text,
                        span_start: nt.span_start,
                        span_end: nt.span_end,
                    }
                },
                _ => ~- make_unexpected_token_err(state, expected),
            }
        },
    }
}

// Reserved namespace roots — ADR-0005 trụ cột #5. Top-level item
// names cannot collide with these (kept for stdlib + OS namespaces).
function is_reserved_item_name(name: String) -> Trilean! = {
    if name == "std" {
        true
    } else {
        if name == "sys" {
            true
        } else {
            if name == "dev" {
                true
            } else {
                if name == "usr" {
                    true
                } else {
                    if name == "core" {
                        true
                    } else {
                        false
                    }
                }
            }
        }
    }
}

// `parse_item_name` — like `parse_ident` but rejects reserved
// namespace roots with `ReservedItemNameErr`.
function parse_item_name(state: ParserState, expected: String) -> ParseIdentStep~ParseError = {
    let ident_step: ParseIdentStep = parse_ident(state, expected) ~? |err| ~- err
    if is_reserved_item_name(ident_step.text) {
        let detail: ReservedNameDetail = ReservedNameDetail {
            name: ident_step.text,
            span_start: ident_step.span_start,
            span_end: ident_step.span_end,
        }
        ~- ReservedItemNameErr(detail)
    } else {
        ~+ ident_step
    }
}

// `parse_generic_params` — optional `<T, U>` (ADR-0019 Addendum
// §A7, v0.7.4.1). Empty Vector when absent.
function parse_generic_params(state: ParserState) -> ParseGenericsStep~ParseError = {
    let nx: SpannedToken? = peek(state)
    match nx {
        ~0 => ~+ ParseGenericsStep { state: state, type_params: new() },
        _ => {
            let nt: SpannedToken = nx!!
            if is_lt(nt.token) {
                let after_lt: ParserState = advance(state)
                let mutable state: ParserState = after_lt
                let mutable params: Vector<String> = new()
                let mutable should_continue: Trilean! = true
                let mutable err_slot: ParseError? = ~0

                while should_continue {
                    let id_outcome: ParseIdentStep~ParseError = parse_ident(state, "type parameter")
                    match id_outcome {
                        ~+ id_step => {
                            params = push(params, id_step.text)
                            state = id_step.state
                            let nx2: SpannedToken? = peek(state)
                            match nx2 {
                                ~0 => {
                                    err_slot = make_unexpected_eof_err(state, "`,` or `>`")
                                    should_continue = false
                                },
                                _ => {
                                    let nt2: SpannedToken = nx2!!
                                    if is_comma(nt2.token) {
                                        state = advance(state)
                                    } else {
                                        should_continue = false
                                    }
                                },
                            }
                        },
                        ~- e => {
                            err_slot = e
                            should_continue = false
                        },
                    }
                }

                match err_slot {
                    ~+ e => ~- e,
                    ~0 => {
                        let nx3: SpannedToken? = peek(state)
                        match nx3 {
                            ~0 => ~- make_unexpected_eof_err(state, "`>`"),
                            _ => {
                                let nt3: SpannedToken = nx3!!
                                if is_gt(nt3.token) {
                                    ~+ ParseGenericsStep { state: advance(state), type_params: params }
                                } else {
                                    ~- make_unexpected_token_err(state, "`>`")
                                }
                            },
                        }
                    },
                }
            } else {
                ~+ ParseGenericsStep { state: state, type_params: new() }
            }
        },
    }
}

// `parse_parameter` — optional `mutable` / `owned` prefix +
// identifier + `: T`.
public struct ParseParamStep {
    state: ParserState,
    parameter: FunctionParam,
}

function parse_parameter(state: ParserState) -> ParseParamStep~ParseError = {
    let nx: SpannedToken? = peek(state)
    let passing_step: EatFlagStep = {
        match nx {
            ~0 => EatFlagStep { state: state, was_present: false },
            _ => {
                let nt: SpannedToken = nx!!
                if is_mutable_kw(nt.token) {
                    EatFlagStep { state: advance(state), was_present: true }
                } else {
                    EatFlagStep { state: state, was_present: false }
                }
            },
        }
    }

    let after_mut: ParserState = passing_step.state
    let is_mut: Trilean! = passing_step.was_present

    let nx_after_mut: SpannedToken? = peek(after_mut)
    let owned_step: EatFlagStep = {
        if is_mut {
            EatFlagStep { state: after_mut, was_present: false }
        } else {
            match nx_after_mut {
                ~0 => EatFlagStep { state: after_mut, was_present: false },
                _ => {
                    let nt: SpannedToken = nx_after_mut!!
                    if is_owned_kw(nt.token) {
                        EatFlagStep { state: advance(after_mut), was_present: true }
                    } else {
                        EatFlagStep { state: after_mut, was_present: false }
                    }
                },
            }
        }
    }
    let after_passing: ParserState = owned_step.state
    let is_owned: Trilean! = owned_step.was_present

    let passing: ParameterPassing = if is_mut {
        MutableParam
    } else {
        if is_owned {
            OwnedParam
        } else {
            BorrowedParam
        }
    }

    let id_step: ParseIdentStep = parse_ident(after_passing, "parameter name") ~? |err| ~- err
    let after_colon: ParserState = expect_colon(id_step.state) ~? |err| ~- err
    let ty_step: ParseTypeStep = parse_type_minimal(after_colon) ~? |err| ~- err

    let param: FunctionParam = FunctionParam {
        name: id_step.text,
        type_annotation: ty_step.type_id,
        passing: passing,
    }
    ~+ ParseParamStep { state: ty_step.state, parameter: param }
}

function parse_parameter_list(state: ParserState) -> ParseParamsStep~ParseError = {
    let mutable state: ParserState = state
    let mutable params: Vector<FunctionParam> = new()
    let mutable should_continue: Trilean! = true
    let mutable err_slot: ParseError? = ~0

    // Empty arg list short-circuit
    let first_peek: SpannedToken? = peek(state)
    match first_peek {
        ~0 => {
            err_slot = make_unexpected_eof_err(state, "`)` or parameter")
            should_continue = false
        },
        _ => {
            let first: SpannedToken = first_peek!!
            if is_rparen(first.token) {
                should_continue = false
            }
        },
    }

    while should_continue {
        let outcome: ParseParamStep~ParseError = parse_parameter(state)
        match outcome {
            ~+ pstep => {
                params = push(params, pstep.parameter)
                state = pstep.state
                let after: SpannedToken? = peek(state)
                match after {
                    ~0 => {
                        err_slot = make_unexpected_eof_err(state, "`,` or `)`")
                        should_continue = false
                    },
                    _ => {
                        let nt: SpannedToken = after!!
                        if is_comma(nt.token) {
                            state = advance(state)
                            let after_comma: SpannedToken? = peek(state)
                            match after_comma {
                                ~0 => {
                                    err_slot = make_unexpected_eof_err(state, "parameter or `)`")
                                    should_continue = false
                                },
                                _ => {
                                    let nt2: SpannedToken = after_comma!!
                                    if is_rparen(nt2.token) {
                                        should_continue = false
                                    }
                                },
                            }
                        } else {
                            should_continue = false
                        }
                    },
                }
            },
            ~- e => {
                err_slot = e
                should_continue = false
            },
        }
    }

    match err_slot {
        ~+ e => ~- e,
        ~0 => ~+ ParseParamsStep { state: state, parameters: params },
    }
}

// Wrapper for parse_function's body parse.
public struct ParseFunctionBodyStep {
    state: ParserState,
    body: FunctionBody,
}

function parse_function_body(state: ParserState) -> ParseFunctionBodyStep~ParseError = {
    let nx: SpannedToken? = peek(state)
    match nx {
        ~0 => ~- make_unexpected_eof_err(state, "function body (`{ … }` or `= expr`)"),
        ~+ nt => {
            match nt.token {
                LBrace => {
                    let block_step: ParseBlockStep = parse_block(state) ~? |err| ~- err
                    ~+ ParseFunctionBodyStep { state: block_step.state, body: BlockBody(block_step.block) }
                },
                Assign => {
                    let after_eq: ParserState = advance(state)
                    let expr_step: ParseStep = parse_expression(after_eq) ~? |err| ~- err
                    ~+ ParseFunctionBodyStep { state: expr_step.state, body: ExpressionBody(expr_step.expr_id) }
                },
                _ => ~- make_unexpected_token_err(state, "function body (`{ … }` or `= expr`)"),
            }
        },
    }
}

// `function name<G…>(params) -> R? { body | = expr }`.
function parse_function(state: ParserState, head_start: Integer, visibility: Visibility) -> ParseItemStep~ParseError = {
    let after_kw: ParserState = advance(state)
    let name_step: ParseIdentStep = parse_item_name(after_kw, "function name") ~? |err| ~- err
    let generics_step: ParseGenericsStep = parse_generic_params(name_step.state) ~? |err| ~- err

    // expect `(`
    let nx_open: SpannedToken? = peek(generics_step.state)
    let after_open: ParserState = match nx_open {
        ~0 => ~- make_unexpected_eof_err(generics_step.state, "`(`"),
        _ => if is_lparen(nx_open!!.token) {
            advance(generics_step.state)
        } else {
            ~- make_unexpected_token_err(generics_step.state, "`(`")
        },
    }

    let params_step: ParseParamsStep = parse_parameter_list(after_open) ~? |err| ~- err

    // expect `)`
    let nx_close: SpannedToken? = peek(params_step.state)
    let after_close: ParserState = match nx_close {
        ~0 => ~- make_unexpected_eof_err(params_step.state, "`)`"),
        _ => if is_rparen(nx_close!!.token) {
            advance(params_step.state)
        } else {
            ~- make_unexpected_token_err(params_step.state, "`)`")
        },
    }

    // Optional return type: `-> T`. Parsing the type may fail, so
    // each branch threads `ParseLetAnnotation~ParseError` and the
    // outer `~?` unwraps. (An earlier draft mixed `ParseLetAnnotation`
    // and `~- err` in two arms of the same `match` — that's invalid
    // because the arms must agree on result type. The propagation
    // shape mirrors `parse_optional_type_annotation` in v0.7.5.3.)
    let return_outcome: ParseLetAnnotation~ParseError = {
        let nx_ret: SpannedToken? = peek(after_close)
        match nx_ret {
            ~0 => ~+ ParseLetAnnotation { state: after_close, annotation_id: ~0 },
            _ => {
                let nt: SpannedToken = nx_ret!!
                if is_thin_arrow(nt.token) {
                    let after_arrow: ParserState = advance(after_close)
                    let ty_step: ParseTypeStep = parse_type_minimal(after_arrow) ~? |err| ~- err
                    ~+ ParseLetAnnotation { state: ty_step.state, annotation_id: ty_step.type_id }
                } else {
                    ~+ ParseLetAnnotation { state: after_close, annotation_id: ~0 }
                }
            },
        }
    }
    let return_step: ParseLetAnnotation = return_outcome ~? |err| ~- err

    let body_step: ParseFunctionBodyStep = parse_function_body(return_step.state) ~? |err| ~- err
    let prev_end: Integer = previous_token_end(body_step.state, head_start)

    let function_def: FunctionDef = FunctionDef {
        visibility: visibility,
        name: name_step.text,
        type_params: generics_step.type_params,
        parameters: params_step.parameters,
        return_type: return_step.annotation_id,
        body: body_step.body,
    }
    let res: AllocResult = alloc_item(
        body_step.state.arena,
        spanned_item(FunctionItem(function_def), head_start, prev_end),
    )
    ~+ ParseItemStep {
        state: ParserState {
            tokens: body_step.state.tokens,
            cursor: body_step.state.cursor,
            arena: res.arena,
        },
        item_id: res.id,
    }
}

// `constant NAME (: T)? = expr ;?` — module-level constant.
function parse_constant_item(state: ParserState, head_start: Integer, visibility: Visibility) -> ParseItemStep~ParseError = {
    let after_kw: ParserState = advance(state)
    let name_step: ParseIdentStep = parse_item_name(after_kw, "constant name") ~? |err| ~- err

    let ann_step: ParseLetAnnotation = parse_optional_type_annotation(name_step.state) ~? |err| ~- err
    let after_eq: ParserState = expect_assign(ann_step.state) ~? |err| ~- err
    let val_step: ParseStep = parse_expression(after_eq) ~? |err| ~- err
    let after_semi: ParserState = eat_semi(val_step.state)

    let val_sp: SpannedExpr = get_expression(after_semi.arena, val_step.expr_id)
    let payload: ConstantItemPayload = ConstantItemPayload {
        visibility: visibility,
        name: name_step.text,
        type_annotation: ann_step.annotation_id,
        value: val_step.expr_id,
    }
    let res: AllocResult = alloc_item(
        after_semi.arena,
        spanned_item(ConstantItem(payload), head_start, val_sp.span_end),
    )
    ~+ ParseItemStep {
        state: ParserState {
            tokens: after_semi.tokens,
            cursor: after_semi.cursor,
            arena: res.arena,
        },
        item_id: res.id,
    }
}

// `type Alias = T ;?` — type alias.
function parse_type_alias(state: ParserState, head_start: Integer, visibility: Visibility) -> ParseItemStep~ParseError = {
    let after_kw: ParserState = advance(state)
    let name_step: ParseIdentStep = parse_item_name(after_kw, "type alias name") ~? |err| ~- err
    let after_eq: ParserState = expect_assign(name_step.state) ~? |err| ~- err
    let ty_step: ParseTypeStep = parse_type_minimal(after_eq) ~? |err| ~- err
    let after_semi: ParserState = eat_semi(ty_step.state)

    let ty_sp: SpannedTypeExpr = get_type(after_semi.arena, ty_step.type_id)
    let payload: TypeAliasPayload = TypeAliasPayload {
        visibility: visibility,
        name: name_step.text,
        target: ty_step.type_id,
    }
    let res: AllocResult = alloc_item(
        after_semi.arena,
        spanned_item(TypeAliasItem(payload), head_start, ty_sp.span_end),
    )
    ~+ ParseItemStep {
        state: ParserState {
            tokens: after_semi.tokens,
            cursor: after_semi.cursor,
            arena: res.arena,
        },
        item_id: res.id,
    }
}

// ─────────────────────────────────────────────────────────────────
// v0.7.5.4b — struct / enum / module / import / from parsers.
// Mirrors the bottom half of crates/triet-parser/src/item.rs.
// ─────────────────────────────────────────────────────────────────

// Per-element step wrappers (mirror v0.7.5.4a's ParseParamStep).
public struct ParseStructFieldStep {
    state: ParserState,
    field: StructField,
}

public struct ParseStructFieldsStep {
    state: ParserState,
    fields: Vector<StructField>,
}

public struct ParseEnumVariantStep {
    state: ParserState,
    variant: EnumVariant,
}

public struct ParseEnumVariantsStep {
    state: ParserState,
    variants: Vector<EnumVariant>,
}

public struct ParseDotPathStep {
    state: ParserState,
    segments: Vector<String>,
}

public struct ParseImportNameStep {
    state: ParserState,
    name: ImportName,
}

public struct ParseImportNamesStep {
    state: ParserState,
    names: Vector<ImportName>,
}

// ── Token kind predicates added for .4b ──────────────────────────

function is_dot(token: Token) -> Trilean! =
    match token {
        Dot => true,
        _ => false,
    }

function is_star(token: Token) -> Trilean! =
    match token {
        Star => true,
        _ => false,
    }

function is_as_kw(token: Token) -> Trilean! =
    match token {
        AsKw => true,
        _ => false,
    }

function is_crate_kw(token: Token) -> Trilean! =
    match token {
        KhiKw => true,
        _ => false,
    }

function is_self_kw(token: Token) -> Trilean! =
    match token {
        SelfKw => true,
        _ => false,
    }

function is_super_kw(token: Token) -> Trilean! =
    match token {
        SuperKw => true,
        _ => false,
    }

// ── Struct fields ────────────────────────────────────────────────

function parse_struct_field(state: ParserState) -> ParseStructFieldStep~ParseError = {
    let id_step: ParseIdentStep = parse_ident(state, "field name") ~? |err| ~- err
    let after_colon: ParserState = expect_colon(id_step.state) ~? |err| ~- err
    let ty_step: ParseTypeStep = parse_type_minimal(after_colon) ~? |err| ~- err
    let field: StructField = StructField {
        name: id_step.text,
        type_annotation: ty_step.type_id,
    }
    ~+ ParseStructFieldStep { state: ty_step.state, field: field }
}

function parse_struct_fields(state: ParserState) -> ParseStructFieldsStep~ParseError = {
    let mutable state: ParserState = state
    let mutable fields: Vector<StructField> = new()
    let mutable should_continue: Trilean! = true
    let mutable err_slot: ParseError? = ~0

    // Empty body short-circuit
    let first_peek: SpannedToken? = peek(state)
    match first_peek {
        ~0 => {
            err_slot = make_unexpected_eof_err(state, "`}` or field name")
            should_continue = false
        },
        _ => {
            if is_rbrace(first_peek!!.token) {
                should_continue = false
            }
        },
    }

    while should_continue {
        let outcome: ParseStructFieldStep~ParseError = parse_struct_field(state)
        match outcome {
            ~+ fstep => {
                fields = push(fields, fstep.field)
                state = fstep.state
                let after: SpannedToken? = peek(state)
                match after {
                    ~0 => {
                        err_slot = make_unexpected_eof_err(state, "`,` or `}`")
                        should_continue = false
                    },
                    _ => {
                        let nt: SpannedToken = after!!
                        if is_comma(nt.token) {
                            state = advance(state)
                            // Trailing comma allowed.
                            let after_comma: SpannedToken? = peek(state)
                            match after_comma {
                                ~0 => {
                                    err_slot = make_unexpected_eof_err(state, "field name or `}`")
                                    should_continue = false
                                },
                                _ => {
                                    if is_rbrace(after_comma!!.token) {
                                        should_continue = false
                                    }
                                },
                            }
                        } else {
                            should_continue = false
                        }
                    },
                }
            },
            ~- e => {
                err_slot = e
                should_continue = false
            },
        }
    }

    match err_slot {
        ~+ e => ~- e,
        ~0 => ~+ ParseStructFieldsStep { state: state, fields: fields },
    }
}

// `struct Foo<G…> { fields }`.
function parse_struct(state: ParserState, head_start: Integer, visibility: Visibility) -> ParseItemStep~ParseError = {
    let after_kw: ParserState = advance(state)
    let name_step: ParseIdentStep = parse_item_name(after_kw, "struct name") ~? |err| ~- err
    let generics_step: ParseGenericsStep = parse_generic_params(name_step.state) ~? |err| ~- err
    let after_open: ParserState = expect_lbrace(generics_step.state) ~? |err| ~- err
    let fields_step: ParseStructFieldsStep = parse_struct_fields(after_open) ~? |err| ~- err
    let after_close: ParserState = expect_rbrace(fields_step.state) ~? |err| ~- err
    let prev_end: Integer = previous_token_end(after_close, head_start)

    let struct_def: StructDef = StructDef {
        visibility: visibility,
        name: name_step.text,
        type_params: generics_step.type_params,
        fields: fields_step.fields,
    }
    let res: AllocResult = alloc_item(
        after_close.arena,
        spanned_item(StructItem(struct_def), head_start, prev_end),
    )
    ~+ ParseItemStep {
        state: ParserState { tokens: after_close.tokens, cursor: after_close.cursor, arena: res.arena },
        item_id: res.id,
    }
}

// ── Enum variants ────────────────────────────────────────────────

function parse_enum_variant(state: ParserState) -> ParseEnumVariantStep~ParseError = {
    let id_step: ParseIdentStep = parse_ident(state, "variant name") ~? |err| ~- err
    // Optional `(PayloadType)`.
    let nx: SpannedToken? = peek(id_step.state)
    let payload_outcome: ParseLetAnnotation~ParseError = {
        match nx {
            ~0 => ~+ ParseLetAnnotation { state: id_step.state, annotation_id: ~0 },
            _ => {
                let nt: SpannedToken = nx!!
                if is_lparen(nt.token) {
                    let after_open: ParserState = advance(id_step.state)
                    let ty_step: ParseTypeStep = parse_type_minimal(after_open) ~? |err| ~- err
                    let nx2: SpannedToken? = peek(ty_step.state)
                    match nx2 {
                        ~0 => ~- make_unexpected_eof_err(ty_step.state, "`)`"),
                        _ => {
                            if is_rparen(nx2!!.token) {
                                let after_close: ParserState = advance(ty_step.state)
                                ~+ ParseLetAnnotation { state: after_close, annotation_id: ty_step.type_id }
                            } else {
                                ~- make_unexpected_token_err(ty_step.state, "`)`")
                            }
                        },
                    }
                } else {
                    ~+ ParseLetAnnotation { state: id_step.state, annotation_id: ~0 }
                }
            },
        }
    }
    let payload_step: ParseLetAnnotation = payload_outcome ~? |err| ~- err
    let variant: EnumVariant = EnumVariant {
        name: id_step.text,
        payload: payload_step.annotation_id,
    }
    ~+ ParseEnumVariantStep { state: payload_step.state, variant: variant }
}

function parse_enum_variants(state: ParserState) -> ParseEnumVariantsStep~ParseError = {
    let mutable state: ParserState = state
    let mutable variants: Vector<EnumVariant> = new()
    let mutable should_continue: Trilean! = true
    let mutable err_slot: ParseError? = ~0

    let first_peek: SpannedToken? = peek(state)
    match first_peek {
        ~0 => {
            err_slot = make_unexpected_eof_err(state, "`}` or variant name")
            should_continue = false
        },
        _ => {
            if is_rbrace(first_peek!!.token) {
                should_continue = false
            }
        },
    }

    while should_continue {
        let outcome: ParseEnumVariantStep~ParseError = parse_enum_variant(state)
        match outcome {
            ~+ vstep => {
                variants = push(variants, vstep.variant)
                state = vstep.state
                let after: SpannedToken? = peek(state)
                match after {
                    ~0 => {
                        err_slot = make_unexpected_eof_err(state, "`,` or `}`")
                        should_continue = false
                    },
                    _ => {
                        let nt: SpannedToken = after!!
                        if is_comma(nt.token) {
                            state = advance(state)
                            let after_comma: SpannedToken? = peek(state)
                            match after_comma {
                                ~0 => {
                                    err_slot = make_unexpected_eof_err(state, "variant name or `}`")
                                    should_continue = false
                                },
                                _ => {
                                    if is_rbrace(after_comma!!.token) {
                                        should_continue = false
                                    }
                                },
                            }
                        } else {
                            should_continue = false
                        }
                    },
                }
            },
            ~- e => {
                err_slot = e
                should_continue = false
            },
        }
    }

    match err_slot {
        ~+ e => ~- e,
        ~0 => ~+ ParseEnumVariantsStep { state: state, variants: variants },
    }
}

// `enum Foo<G…> { variants }`.
function parse_enum(state: ParserState, head_start: Integer, visibility: Visibility) -> ParseItemStep~ParseError = {
    let after_kw: ParserState = advance(state)
    let name_step: ParseIdentStep = parse_item_name(after_kw, "enum name") ~? |err| ~- err
    let generics_step: ParseGenericsStep = parse_generic_params(name_step.state) ~? |err| ~- err
    let after_open: ParserState = expect_lbrace(generics_step.state) ~? |err| ~- err
    let variants_step: ParseEnumVariantsStep = parse_enum_variants(after_open) ~? |err| ~- err
    let after_close: ParserState = expect_rbrace(variants_step.state) ~? |err| ~- err
    let prev_end: Integer = previous_token_end(after_close, head_start)

    let enum_def: EnumDef = EnumDef {
        visibility: visibility,
        name: name_step.text,
        type_params: generics_step.type_params,
        variants: variants_step.variants,
    }
    let res: AllocResult = alloc_item(
        after_close.arena,
        spanned_item(EnumItem(enum_def), head_start, prev_end),
    )
    ~+ ParseItemStep {
        state: ParserState { tokens: after_close.tokens, cursor: after_close.cursor, arena: res.arena },
        item_id: res.id,
    }
}

// ── Dot path (used by `import`, `from`, future qualified types) ──

function parse_dot_path_root(state: ParserState, what: String) -> ParseIdentStep~ParseError = {
    let nx: SpannedToken? = peek(state)
    match nx {
        ~0 => ~- make_unexpected_eof_err(state, what),
        ~+ nt => {
            match nt.token {
                Identifier(p) => {
                    let advanced: ParserState = advance(state)
                    ~+ ParseIdentStep {
                        state: advanced,
                        text: p.text,
                        span_start: nt.span_start,
                        span_end: nt.span_end,
                    }
                },
                KhiKw => {
                    let advanced: ParserState = advance(state)
                    ~+ ParseIdentStep {
                        state: advanced,
                        text: "khi",
                        span_start: nt.span_start,
                        span_end: nt.span_end,
                    }
                },
                SelfKw => {
                    let advanced: ParserState = advance(state)
                    ~+ ParseIdentStep {
                        state: advanced,
                        text: "self",
                        span_start: nt.span_start,
                        span_end: nt.span_end,
                    }
                },
                SuperKw => {
                    let advanced: ParserState = advance(state)
                    ~+ ParseIdentStep {
                        state: advanced,
                        text: "super",
                        span_start: nt.span_start,
                        span_end: nt.span_end,
                    }
                },
                _ => ~- make_unexpected_token_err(state, what),
            }
        },
    }
}

function parse_dot_path_segment(state: ParserState) -> ParseIdentStep~ParseError =
    parse_ident(state, "identifier after `.`")

function parse_dot_path(state: ParserState, what: String) -> ParseDotPathStep~ParseError = {
    let root_step: ParseIdentStep = parse_dot_path_root(state, what) ~? |err| ~- err
    let mutable state: ParserState = root_step.state
    let mutable segments: Vector<String> = push(new(), root_step.text)
    let mutable should_continue: Trilean! = true
    let mutable err_slot: ParseError? = ~0

    while should_continue {
        let nx: SpannedToken? = peek(state)
        match nx {
            ~0 => {
                should_continue = false
            },
            _ => {
                if is_dot(nx!!.token) {
                    state = advance(state)
                    let seg_outcome: ParseIdentStep~ParseError = parse_dot_path_segment(state)
                    match seg_outcome {
                        ~+ seg_step => {
                            segments = push(segments, seg_step.text)
                            state = seg_step.state
                        },
                        ~- e => {
                            err_slot = e
                            should_continue = false
                        },
                    }
                } else {
                    should_continue = false
                }
            },
        }
    }

    match err_slot {
        ~+ e => ~- e,
        ~0 => ~+ ParseDotPathStep { state: state, segments: segments },
    }
}

// ── Imports ──────────────────────────────────────────────────────

// `import a.b.c ;?`.
function parse_import_item(state: ParserState, head_start: Integer) -> ParseItemStep~ParseError = {
    let after_kw: ParserState = advance(state)
    let path_step: ParseDotPathStep = parse_dot_path(after_kw, "import path") ~? |err| ~- err
    let after_semi: ParserState = eat_semi(path_step.state)
    let prev_end: Integer = previous_token_end(after_semi, head_start)
    let payload: ImportPath = ImportPath { segments: path_step.segments }
    let res: AllocResult = alloc_item(
        after_semi.arena,
        spanned_item(ImportItem(payload), head_start, prev_end),
    )
    ~+ ParseItemStep {
        state: ParserState { tokens: after_semi.tokens, cursor: after_semi.cursor, arena: res.arena },
        item_id: res.id,
    }
}

// `name (as alias)?` — single entry of a from-import name list.
function parse_import_name(state: ParserState) -> ParseImportNameStep~ParseError = {
    let nx: SpannedToken? = peek(state)
    let name_step: ParseIdentStep = match nx {
        ~0 => ~- make_unexpected_eof_err(state, "imported name"),
        ~+ nt => {
            if is_star(nt.token) {
                ~- make_unexpected_token_err(
                    state,
                    "imported name (glob `*` is not supported per ADR-0005)",
                )
            } else {
                parse_ident(state, "imported name") ~? |err| ~- err
            }
        },
    }
    let after_name: ParserState = name_step.state

    // Optional `as alias`.
    let nx_as: SpannedToken? = peek(after_name)
    let alias_outcome: ParseImportNameStep~ParseError = {
        match nx_as {
            ~0 => ~+ ParseImportNameStep {
                state: after_name,
                name: ImportName { name: name_step.text, alias: ~0 },
            },
            _ => {
                let nt2: SpannedToken = nx_as!!
                if is_as_kw(nt2.token) {
                    let after_as: ParserState = advance(after_name)
                    let alias_step: ParseIdentStep = parse_ident(after_as, "alias identifier after `as`") ~? |err| ~- err
                    ~+ ParseImportNameStep {
                        state: alias_step.state,
                        name: ImportName { name: name_step.text, alias: alias_step.text },
                    }
                } else {
                    ~+ ParseImportNameStep {
                        state: after_name,
                        name: ImportName { name: name_step.text, alias: ~0 },
                    }
                }
            },
        }
    }
    alias_outcome
}

function parse_import_name_list(state: ParserState) -> ParseImportNamesStep~ParseError = {
    let first_step: ParseImportNameStep = parse_import_name(state) ~? |err| ~- err
    let mutable state: ParserState = first_step.state
    let mutable names: Vector<ImportName> = push(new(), first_step.name)
    let mutable should_continue: Trilean! = true
    let mutable err_slot: ParseError? = ~0

    while should_continue {
        let nx: SpannedToken? = peek(state)
        match nx {
            ~0 => {
                should_continue = false
            },
            _ => {
                if is_comma(nx!!.token) {
                    state = advance(state)
                    let after_comma: SpannedToken? = peek(state)
                    match after_comma {
                        ~0 => {
                            should_continue = false
                        },
                        _ => {
                            let nt: SpannedToken = after_comma!!
                            if is_semi(nt.token) {
                                // Trailing comma before `;` allowed.
                                should_continue = false
                            } else {
                                let outcome: ParseImportNameStep~ParseError = parse_import_name(state)
                                match outcome {
                                    ~+ step => {
                                        names = push(names, step.name)
                                        state = step.state
                                    },
                                    ~- e => {
                                        err_slot = e
                                        should_continue = false
                                    },
                                }
                            }
                        },
                    }
                } else {
                    should_continue = false
                }
            },
        }
    }

    match err_slot {
        ~+ e => ~- e,
        ~0 => ~+ ParseImportNamesStep { state: state, names: names },
    }
}

// `from a.b import x, y as z ;?`.
function parse_from_import(state: ParserState, head_start: Integer) -> ParseItemStep~ParseError = {
    let after_kw: ParserState = advance(state)
    let source_step: ParseDotPathStep = parse_dot_path(after_kw, "module path after `from`") ~? |err| ~- err

    // expect `import`
    let nx: SpannedToken? = peek(source_step.state)
    let after_import: ParserState = match nx {
        ~0 => ~- make_unexpected_eof_err(source_step.state, "`import`"),
        _ => if is_import_kw(nx!!.token) {
            advance(source_step.state)
        } else {
            ~- make_unexpected_token_err(source_step.state, "`import`")
        },
    }

    let names_step: ParseImportNamesStep = parse_import_name_list(after_import) ~? |err| ~- err
    let after_semi: ParserState = eat_semi(names_step.state)
    let prev_end: Integer = previous_token_end(after_semi, head_start)
    let payload: ImportFromPayload = ImportFromPayload {
        source: source_step.segments,
        names: names_step.names,
    }
    let res: AllocResult = alloc_item(
        after_semi.arena,
        spanned_item(ImportFromItem(payload), head_start, prev_end),
    )
    ~+ ParseItemStep {
        state: ParserState { tokens: after_semi.tokens, cursor: after_semi.cursor, arena: res.arena },
        item_id: res.id,
    }
}

// ── Modules ──────────────────────────────────────────────────────

// `module foo` (file-bound) or `module foo { items… }` (inline).
// ADR-0005 §"File resolution": nested paths must use nested
// `module` blocks — `module foo.bar` is invalid syntax.
function parse_module(state: ParserState, head_start: Integer, visibility: Visibility) -> ParseItemStep~ParseError = {
    let after_kw: ParserState = advance(state)
    let name_step: ParseIdentStep = parse_item_name(after_kw, "module name") ~? |err| ~- err

    // Reject `module foo.bar`.
    let nx_dot: SpannedToken? = peek(name_step.state)
    let after_name: ParserState = match nx_dot {
        ~0 => name_step.state,
        _ => {
            let nt: SpannedToken = nx_dot!!
            if is_dot(nt.token) {
                ~- make_unexpected_token_err(
                    name_step.state,
                    "`{` (inline body), `;`, or end of declaration — nested paths must use nested `module` blocks",
                )
            } else {
                name_step.state
            }
        },
    }

    // `{ items… }` → InlineContent; otherwise ExternalContent.
    let nx_brace: SpannedToken? = peek(after_name)
    let content_outcome: ParseModuleContentStep~ParseError = {
        match nx_brace {
            ~0 => ~+ ParseModuleContentStep { state: eat_semi(after_name), content: ExternalContent },
            _ => {
                let nt: SpannedToken = nx_brace!!
                match nt.token {
                    LBrace => parse_inline_module_body(after_name),
                    _ => ~+ ParseModuleContentStep { state: eat_semi(after_name), content: ExternalContent },
                }
            },
        }
    }
    let content_step: ParseModuleContentStep = content_outcome ~? |err| ~- err
    let prev_end: Integer = previous_token_end(content_step.state, head_start)
    let module_decl: ModuleDecl = ModuleDecl {
        visibility: visibility,
        name: name_step.text,
        content: content_step.content,
    }
    let res: AllocResult = alloc_item(
        content_step.state.arena,
        spanned_item(ModuleItem(module_decl), head_start, prev_end),
    )
    ~+ ParseItemStep {
        state: ParserState {
            tokens: content_step.state.tokens,
            cursor: content_step.state.cursor,
            arena: res.arena,
        },
        item_id: res.id,
    }
}

public struct ParseModuleContentStep {
    state: ParserState,
    content: ModuleContent,
}

function parse_inline_module_body(state: ParserState) -> ParseModuleContentStep~ParseError = {
    let after_open: ParserState = advance(state)  // consume `{`
    let mutable state: ParserState = after_open
    let mutable item_ids: Vector<Integer> = new()
    let mutable should_continue: Trilean! = true
    let mutable err_slot: ParseError? = ~0

    while should_continue {
        let nx: SpannedToken? = peek(state)
        match nx {
            ~0 => {
                err_slot = make_unexpected_eof_err(state, "`}` to close module body")
                should_continue = false
            },
            _ => {
                if is_rbrace(nx!!.token) {
                    should_continue = false
                } else {
                    let outcome: ParseItemStep~ParseError = parse_item(state)
                    match outcome {
                        ~+ step => {
                            item_ids = push(item_ids, step.item_id)
                            state = step.state
                        },
                        ~- e => {
                            err_slot = e
                            should_continue = false
                        },
                    }
                }
            },
        }
    }

    match err_slot {
        ~+ e => ~- e,
        ~0 => {
            let after_close: ParserState = expect_rbrace(state) ~? |err| ~- err
            ~+ ParseModuleContentStep { state: after_close, content: InlineContent(item_ids) }
        },
    }
}

// `parse_item` — visibility prefix + dispatch on the next keyword.
public function parse_item(state: ParserState) -> ParseItemStep~ParseError = {
    // Capture span start before visibility (covers `public` prefix).
    let head_start: Integer = current_span_start(state)
    let vis_step: ParseVisibilityStep = parse_visibility(state) ~? |err| ~- err
    let after_vis: ParserState = vis_step.state
    let visibility: Visibility = vis_step.visibility

    let nx: SpannedToken? = peek(after_vis)
    match nx {
        ~0 => ~- make_unexpected_eof_err(after_vis, "item keyword"),
        ~+ nt => {
            if is_function_kw(nt.token) {
                parse_function(after_vis, head_start, visibility)
            } else {
                if is_constant_kw(nt.token) {
                    parse_constant_item(after_vis, head_start, visibility)
                } else {
                    if is_type_kw(nt.token) {
                        parse_type_alias(after_vis, head_start, visibility)
                    } else {
                        if is_struct_kw(nt.token) {
                            parse_struct(after_vis, head_start, visibility)
                        } else {
                            if is_enum_kw(nt.token) {
                                parse_enum(after_vis, head_start, visibility)
                            } else {
                                if is_module_kw(nt.token) {
                                    parse_module(after_vis, head_start, visibility)
                                } else {
                                    // `import` / `from` do not carry visibility (ADR-0005).
                                    if is_import_kw(nt.token) {
                                        match visibility {
                                            PrivateVis => parse_import_item(after_vis, head_start),
                                            _ => ~- reject_visibility_on_import(after_vis, "import"),
                                        }
                                    } else {
                                        if is_from_kw(nt.token) {
                                            match visibility {
                                                PrivateVis => parse_from_import(after_vis, head_start),
                                                _ => ~- reject_visibility_on_import(after_vis, "from"),
                                            }
                                        } else {
                                            ~- make_unexpected_token_err(
                                                after_vis,
                                                "`function`, `constant`, `type`, `struct`, `enum`, `module`, `import`, `from`, or `public`",
                                            )
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
            }
        },
    }
}

// Imports never carry visibility per ADR-0005 §"Imports — Python style".
// Re-exporting an imported name is a post-v0.2.x feature.
function reject_visibility_on_import(state: ParserState, kw_label: String) -> ParseError = {
    let detail: ParseErrorDetail = ParseErrorDetail {
        expected: "`function`, `constant`, `type`, `struct`, `enum`, or `module` after `public`",
        found: concat("`", concat(kw_label, "` (re-exports of imported names are not yet implemented)")),
        span_start: current_span_start(state),
        span_end: current_span_end(state),
    }
    UnexpectedTokenErr(detail)
}

// ─────────────────────────────────────────────────────────────────
// v0.7.5.6a — error recovery.
//
// `synchronize` skips tokens until the next item / statement
// boundary (or after a `;`) so the parse driver can record one
// error per broken construct and keep going. Mirrors
// triet-parser::parser::synchronize.
//
// `parse_program` returns `ParseProgramStep { program, errors }`
// — errors is `Vector<ParseError>` instead of the old outcome
// shape, because the program itself is always producible (each
// failed item just contributes nothing to `item_ids`). Callers
// inspect `errors.length == 0` for the success path.
// ─────────────────────────────────────────────────────────────────

// Tokens that begin a fresh construct — synchronize STOPS BEFORE
// them so the driver can retry parse_item from a clean position.
function is_sync_stop_before(token: Token) -> Trilean! =
    match token {
        FunctionKw => true,
        LetKw => true,
        ConstantKw => true,
        TypeKw => true,
        IfKw => true,
        IfQKw => true,
        MatchKw => true,
        WhileKw => true,
        WhileQKw => true,
        ForKw => true,
        LoopKw => true,
        ReturnKw => true,
        BreakKw => true,
        ContinueKw => true,
        ImportKw => true,
        FromKw => true,
        ModuleKw => true,
        PublicKw => true,
        StructKw => true,
        EnumKw => true,
        RBrace => true,
        _ => false,
    }

// Skip tokens until we hit a sync boundary (or EOF). After a `;`
// we consume the semi and stop — it ends the bad statement.
public function synchronize(state: ParserState) -> ParserState = {
    let mutable state: ParserState = state
    let mutable done: Trilean! = false
    while done == false {
        let nx: SpannedToken? = peek(state)
        match nx {
            ~0 => {
                done = true
            },
            _ => {
                let nt: SpannedToken = nx!!
                if is_sync_stop_before(nt.token) {
                    done = true
                } else {
                    if is_semi(nt.token) {
                        state = advance(state)
                        done = true
                    } else {
                        state = advance(state)
                    }
                }
            },
        }
    }
    state
}

// `parse_program` — top-level driver. Loops over items until EOF
// and collects their IDs into `Program::item_ids` (source order).
// On `parse_item` failure: record the error, synchronize to the
// next item boundary, and continue. A defensive force-advance
// guards against `parse_item` failing at a sync token (e.g. `}`)
// without consuming anything — without it the driver would spin
// forever at top-level on a malformed corpus.
public function parse_program(state: ParserState) -> ParseProgramStep = {
    let mutable state: ParserState = state
    let mutable item_ids: Vector<Integer> = new()
    let mutable errors: Vector<ParseError> = new()
    let mutable should_continue: Trilean! = true

    while should_continue {
        let at_eof: Trilean! = at_end(state)
        if at_eof {
            should_continue = false
        } else {
            let cursor_before: Integer = state.cursor
            let outcome: ParseItemStep~ParseError = parse_item(state)
            match outcome {
                ~+ step => {
                    item_ids = push(item_ids, step.item_id)
                    state = step.state
                },
                ~- e => {
                    errors = push(errors, e)
                    state = synchronize(state)
                    // Force-advance if synchronize didn't move us.
                    if state.cursor == cursor_before {
                        let still_at_eof: Trilean! = at_end(state)
                        if still_at_eof == false {
                            state = advance(state)
                        }
                    }
                },
            }
        }
    }

    ParseProgramStep {
        program: Program { arena: state.arena, item_ids: item_ids },
        errors: errors,
    }
}

// ─────────────────────────────────────────────────────────────────
// Pretty-printer — s-expression form, used by smoke tests to
// eyeball the parsed AST shape. Mirrors v0.7.5.1 with the new
// variants wired in.
// ─────────────────────────────────────────────────────────────────

function bin_op_name(op: BinaryOperator) -> String =
    match op {
        Add => "+",
        Subtract => "-",
        Multiply => "*",
        Divide => "/",
        Modulo => "%%",
        Power => "**",
        Equal => "==",
        NotEqual => "!=",
        LessThan => "<",
        LessEqual => "<=",
        GreaterThan => ">",
        GreaterEqual => ">=",
        And => "&&",
        Or => "||",
        Xor => "^",
        Iff => "<=>",
        Implies => "=>",
        KleeneXor => "~^",
        KleeneIff => "<~>",
        KleeneImplies => "~>",
    }

function trilean_name(v: TrileanValue) -> String =
    match v {
        TrueValue => "true",
        FalseValue => "false",
        UnknownValue => "unknown",
    }

function outcome_arm_name(arena: OutcomeArm) -> String =
    match arena {
        PositiveArm => "~+",
        ZeroArm => "~0",
        NegativeArm => "~-",
    }

public function format_expr(arena: Arena, id: Integer) -> String = {
    let sp: SpannedExpr = get_expression(arena, id)
    match sp.node {
        IntegerLiteralExpr(p) => from_integer(p.value),
        TernaryLiteralExpr(p) => from_integer(p.value),
        TrileanLiteralExpr(v) => trilean_name(v),
        StringLiteralExpr(p) => concat(concat("\"", p.text), "\""),
        NullLiteralExpr => "null",
        IdentifierExpr(p) => p.text,
        UnaryOpExpr(p) => {
            let inner: String = format_expr(arena, p.operand)
            concat("(- ", concat(inner, ")"))
        },
        BinaryOpExpr(p) => {
            let l: String = format_expr(arena, p.left)
            let r: String = format_expr(arena, p.right)
            let head: String = concat(concat("(", bin_op_name(p.operator)), " ")
            concat(head, concat(l, concat(" ", concat(r, ")"))))
        },
        ForceUnwrapExpr(inner_id) => {
            let inner: String = format_expr(arena, inner_id)
            concat("(!! ", concat(inner, ")"))
        },
        CallExpr(p) => {
            let callee: String = format_expr(arena, p.callee)
            concat("(call ", concat(callee, concat(format_args(arena, p.arguments), ")")))
        },
        FieldAccessExpr(p) => {
            let obj: String = format_expr(arena, p.object)
            concat("(. ", concat(obj, concat(" ", concat(p.field, ")"))))
        },
        MethodCallExpr(p) => {
            let recv: String = format_expr(arena, p.receiver)
            concat(concat("(.call ", concat(recv, concat(" ", p.method))), concat(format_args(arena, p.arguments), ")"))
        },
        OutcomeConstructorExpr(p) => {
            let arm_str: String = outcome_arm_name(p.arm)
            match p.payload {
                ~0 => arm_str,
                _ => {
                    let inner: String = format_expr(arena, p.payload!!)
                    concat("(", concat(arm_str, concat(" ", concat(inner, ")"))))
                },
            }
        },
        OutcomePropagateExpr(p) => {
            let inner: String = format_expr(arena, p.inner)
            let ret: String = format_expr(arena, p.early_return)
            let cap: String = match p.capture_name {
                ~0 => "_",
                _ => p.capture_name!!,
            }
            concat("(~? ", concat(inner, concat(" |", concat(cap, concat("| ", concat(ret, ")"))))))
        },
        OutcomeDefaultExpr(p) => {
            let inner: String = format_expr(arena, p.inner)
            let def: String = format_expr(arena, p.default_expr)
            concat("(~: ", concat(inner, concat(" ", concat(def, ")"))))
        },
        ElvisOpExpr(p) => {
            let obj: String = format_expr(arena, p.object)
            let def: String = format_expr(arena, p.default_expr)
            concat("(?: ", concat(obj, concat(" ", concat(def, ")"))))
        },
        RangeExpr(p) => {
            let l: String = format_expr(arena, p.range_start)
            let r: String = format_expr(arena, p.range_end)
            let op: String = match p.inclusive {
                true => "..=",
                false => "..",
                unknown => "..",
            }
            concat("(", concat(op, concat(" ", concat(l, concat(" ", concat(r, ")"))))))
        },
    }
}

function format_args(arena: Arena, args: Vector<Integer>) -> String = {
    let mutable out: String = ""
    let mutable i: Integer = 0
    let n: Integer = length(args)
    while i < n {
        let arg_id: Integer = get(args, i)!!
        out = concat(out, concat(" ", format_expr(arena, arg_id)))
        i = i + 1
    }
    out
}

// ── v0.7.5.3 pattern / type / stmt / block pretty-printers ──────

public function format_pattern(arena: Arena, id: Integer) -> String = {
    let sp: SpannedPattern = get_pattern(arena, id)
    match sp.node {
        WildcardPattern => "_",
        IdentifierPattern(p) => p.text,
        LiteralPat(lit) => format_literal_pattern(lit),
        NullPat => "null",
        TuplePat(elems) => {
            let mutable out: String = "("
            let n: Integer = length(elems)
            let mutable i: Integer = 0
            while i < n {
                if i > 0 {
                    out = concat(out, ",")
                }
                let elem_id: Integer = get(elems, i)!!
                out = concat(out, format_pattern(arena, elem_id))
                i = i + 1
            }
            concat(out, ")")
        },
        OrPat(alts) => {
            let mutable out: String = "(or"
            let n: Integer = length(alts)
            let mutable i: Integer = 0
            while i < n {
                let alt_id: Integer = get(alts, i)!!
                out = concat(out, concat(" ", format_pattern(arena, alt_id)))
                i = i + 1
            }
            concat(out, ")")
        },
        RangePat(p) => {
            let op: String = if p.inclusive {
                "..="
            } else {
                ".."
            }
            concat("(range ", concat(format_literal_pattern(p.range_start), concat(op, concat(format_literal_pattern(p.range_end), ")"))))
        },
        EnumVariantPat(p) => {
            let payload_str: String = match p.payload {
                ~0 => "",
                _ => concat(" ", format_pattern(arena, p.payload!!)),
            }
            concat("(", concat(p.variant_name, concat(payload_str, ")")))
        },
        OutcomeArmPat(p) => {
            let arm_str: String = outcome_arm_name(p.arm)
            match p.payload {
                ~0 => arm_str,
                _ => concat("(", concat(arm_str, concat(" ", concat(format_pattern(arena, p.payload!!), ")")))),
            }
        },
    }
}

function format_literal_pattern(lit: LiteralPattern) -> String =
    match lit {
        IntegerLit(p) => from_integer(p.value),
        TernaryLit(v) => from_integer(v),
        StringLit(p) => concat("\"", concat(p.text, "\"")),
        TrileanLit(v) => trilean_name(v),
    }

public function format_type(arena: Arena, id: Integer) -> String = {
    let sp: SpannedTypeExpr = get_type(arena, id)
    match sp.node {
        NamedType(p) => p.name,
        GenericType(p) => {
            let mutable out: String = concat(p.name, "<")
            let n: Integer = length(p.arguments)
            let mutable i: Integer = 0
            while i < n {
                if i > 0 {
                    out = concat(out, ",")
                }
                let arg_id: Integer = get(p.arguments, i)!!
                out = concat(out, format_type(arena, arg_id))
                i = i + 1
            }
            concat(out, ">")
        },
        TupleType(elems) => {
            let mutable out: String = "("
            let n: Integer = length(elems)
            let mutable i: Integer = 0
            while i < n {
                if i > 0 {
                    out = concat(out, ",")
                }
                let elem_id: Integer = get(elems, i)!!
                out = concat(out, format_type(arena, elem_id))
                i = i + 1
            }
            concat(out, ")")
        },
        NullableType(inner_id) => concat(format_type(arena, inner_id), "?"),
        FunctionType(p) => {
            let mutable params: String = "("
            let n: Integer = length(p.parameters)
            let mutable i: Integer = 0
            while i < n {
                if i > 0 {
                    params = concat(params, ",")
                }
                let param_id: Integer = get(p.parameters, i)!!
                params = concat(params, format_type(arena, param_id))
                i = i + 1
            }
            params = concat(params, ")")
            concat(params, concat("->", format_type(arena, p.return_type)))
        },
        OutcomeType(p) => {
            let op: String = if p.allow_null_state {
                "?~"
            } else {
                "~"
            }
            concat(format_type(arena, p.value_type), concat(op, format_type(arena, p.error_type)))
        },
        RefinedTrileanType => "Trilean!",
    }
}

public function format_block(arena: Arena, b: Block) -> String = {
    let mutable out: String = "(block"
    let stmts: Vector<Integer> = b.block_statements
    let n: Integer = length(stmts)
    let mutable i: Integer = 0
    while i < n {
        let sid: Integer = get(stmts, i)!!
        out = concat(out, concat(" ", format_stmt(arena, sid)))
        i = i + 1
    }
    match b.block_final {
        ~0 => {},
        _ => {
            let eid: Integer = b.block_final!!
            out = concat(out, concat(" (final ", concat(format_expr(arena, eid), ")")))
        },
    }
    concat(out, ")")
}

public function format_stmt(arena: Arena, id: Integer) -> String = {
    let sp: SpannedStmt = get_statement(arena, id)
    match sp.node {
        LetStmt(p) => {
            let head: String = if p.is_mutable {
                "(let-mut "
            } else {
                "(let "
            }
            let ann: String = match p.type_annotation {
                ~0 => "",
                _ => concat(" :", format_type(arena, p.type_annotation!!)),
            }
            concat(head, concat(p.name, concat(ann, concat(" ", concat(format_expr(arena, p.value), ")")))))
        },
        ConstantStmt(p) => {
            let ann: String = match p.type_annotation {
                ~0 => "",
                _ => concat(" :", format_type(arena, p.type_annotation!!)),
            }
            concat("(const ", concat(p.name, concat(ann, concat(" ", concat(format_expr(arena, p.value), ")")))))
        },
        ReturnStmt(p) => match p.value {
            ~0 => "(return)",
            _ => concat("(return ", concat(format_expr(arena, p.value!!), ")")),
        },
        BreakStmt(p) => match p.value {
            ~0 => "(break)",
            _ => concat("(break ", concat(format_expr(arena, p.value!!), ")")),
        },
        ContinueStmt => "(continue)",
        ForStmt(p) => {
            let var_str: String = format_pattern(arena, p.variable)
            let iter_str: String = format_expr(arena, p.iterable)
            let body_str: String = format_block(arena, p.body)
            concat("(for ", concat(var_str, concat(" ", concat(iter_str, concat(" ", concat(body_str, ")"))))))
        },
        WhileStmt(p) => {
            let head: String = if p.treat_unknown_as_false {
                "(while? "
            } else {
                "(while "
            }
            let cond_str: String = format_expr(arena, p.condition)
            let body_str: String = format_block(arena, p.body)
            concat(head, concat(cond_str, concat(" ", concat(body_str, ")"))))
        },
        LoopStmt(p) => concat("(loop ", concat(format_block(arena, p.body), ")")),
        AssignStmt(p) => concat("(assign ", concat(p.target, concat(" ", concat(format_expr(arena, p.value), ")")))),
        ExpressionStmt(p) => concat("(expr ", concat(format_expr(arena, p.expression), ")")),
    }
}

// ─────────────────────────────────────────────────────────────────
// Smoke harness — lex+parse a source snippet, compare its s-expr
// against the expected shape. Each call asserts; failures panic
// via assert(false) so the bootstrap test surfaces them.
// ─────────────────────────────────────────────────────────────────

function lex_or_fail(source: String) -> Vector<SpannedToken> = {
    let outcome: Vector<SpannedToken>~LexError = lex(source)
    match outcome {
        ~+ toks => toks,
        ~- _ => {
            assert(false)
            new()
        },
    }
}

function parse_or_fail(source: String) -> ParseStep = {
    let toks: Vector<SpannedToken> = lex_or_fail(source)
    let st: ParserState = parser_new(toks)
    let outcome: ParseStep~ParseError = parse_expression(st)
    match outcome {
        ~+ step => step,
        ~- _ => {
            assert(false)
            ParseStep { state: parser_new(new()), expr_id: 0 }
        },
    }
}

function assert_parse(source: String, expected: String) -> Unit = {
    let step: ParseStep = parse_or_fail(source)
    let printed: String = format_expr(step.state.arena, step.expr_id)
    assert(printed == expected)
}

function parse_block_or_fail(source: String) -> ParseBlockStep = {
    let toks: Vector<SpannedToken> = lex_or_fail(source)
    let st: ParserState = parser_new(toks)
    let outcome: ParseBlockStep~ParseError = parse_block(st)
    match outcome {
        ~+ step => step,
        ~- _ => {
            assert(false)
            ParseBlockStep { state: parser_new(new()), block: Block { block_statements: new(), block_final: ~0 } }
        },
    }
}

function assert_parse_block(source: String, expected: String) -> Unit = {
    let step: ParseBlockStep = parse_block_or_fail(source)
    let printed: String = format_block(step.state.arena, step.block)
    assert(printed == expected)
}

// ── v0.7.5.4a item pretty-printer + program smoke harness ───────

function vis_prefix(v: Visibility) -> String =
    match v {
        PrivateVis => "",
        PublicVis => "public ",
        PackageVis => "public(package) ",
    }

function passing_prefix(p: ParameterPassing) -> String =
    match p {
        BorrowedParam => "",
        MutableParam => "mutable ",
        OwnedParam => "owned ",
    }

function format_generics(params: Vector<String>) -> String = {
    let n: Integer = length(params)
    if n == 0 {
        ""
    } else {
        let mutable out: String = "<"
        let mutable i: Integer = 0
        while i < n {
            if i > 0 {
                out = concat(out, ",")
            }
            out = concat(out, get(params, i)!!)
            i = i + 1
        }
        concat(out, ">")
    }
}

function format_params(arena: Arena, params: Vector<FunctionParam>) -> String = {
    let n: Integer = length(params)
    let mutable out: String = "("
    let mutable i: Integer = 0
    while i < n {
        if i > 0 {
            out = concat(out, " ")
        }
        let p: FunctionParam = get(params, i)!!
        let head: String = concat(passing_prefix(p.passing), p.name)
        let ty_str: String = format_type(arena, p.type_annotation)
        out = concat(out, concat(head, concat(":", ty_str)))
        i = i + 1
    }
    concat(out, ")")
}

function format_function_body(arena: Arena, body: FunctionBody) -> String =
    match body {
        BlockBody(b) => format_block(arena, b),
        ExpressionBody(eid) => concat("(= ", concat(format_expr(arena, eid), ")")),
    }

public function format_item(arena: Arena, id: Integer) -> String = {
    let sp: SpannedItem = get_item(arena, id)
    match sp.node {
        FunctionItem(f) => {
            let head: String = concat(vis_prefix(f.visibility), "(fn ")
            let generics: String = format_generics(f.type_params)
            let params_str: String = format_params(arena, f.parameters)
            let ret_str: String = match f.return_type {
                ~0 => "",
                _ => concat(" ->", format_type(arena, f.return_type!!)),
            }
            let body_str: String = format_function_body(arena, f.body)
            concat(head, concat(f.name, concat(generics, concat(" ", concat(params_str, concat(ret_str, concat(" ", concat(body_str, ")"))))))))
        },
        ConstantItem(p) => {
            let head: String = concat(vis_prefix(p.visibility), "(const ")
            let ann: String = match p.type_annotation {
                ~0 => "",
                _ => concat(" :", format_type(arena, p.type_annotation!!)),
            }
            concat(head, concat(p.name, concat(ann, concat(" ", concat(format_expr(arena, p.value), ")")))))
        },
        TypeAliasItem(p) => {
            let head: String = concat(vis_prefix(p.visibility), "(type ")
            let target_str: String = format_type(arena, p.target)
            concat(head, concat(p.name, concat(" ", concat(target_str, ")"))))
        },
        StructItem(sd) => {
            let head: String = concat(vis_prefix(sd.visibility), "(struct ")
            let generics: String = format_generics(sd.type_params)
            let fields_str: String = format_struct_fields(arena, sd.fields)
            concat(head, concat(sd.name, concat(generics, concat(" ", concat(fields_str, ")")))))
        },
        EnumItem(ed) => {
            let head: String = concat(vis_prefix(ed.visibility), "(enum ")
            let generics: String = format_generics(ed.type_params)
            let variants_str: String = format_enum_variants(arena, ed.variants)
            concat(head, concat(ed.name, concat(generics, concat(" ", concat(variants_str, ")")))))
        },
        ImportItem(p) => concat("(import ", concat(format_dot_path(p.segments), ")")),
        ImportFromItem(p) => {
            let src: String = format_dot_path(p.source)
            let names: String = format_import_names(p.names)
            concat("(from-import ", concat(src, concat(" ", concat(names, ")"))))
        },
        ModuleItem(m) => {
            let head: String = concat(vis_prefix(m.visibility), "(module ")
            let content_str: String = match m.content {
                ExternalContent => "external",
                InlineContent(ids) => {
                    let mutable out: String = "(inline"
                    let mutable i: Integer = 0
                    let n: Integer = length(ids)
                    while i < n {
                        let id: Integer = get(ids, i)!!
                        out = concat(out, concat(" ", format_item(arena, id)))
                        i = i + 1
                    }
                    concat(out, ")")
                },
            }
            concat(head, concat(m.name, concat(" ", concat(content_str, ")"))))
        },
    }
}

// ── v0.7.5.4b helper printers ────────────────────────────────────

function format_struct_fields(arena: Arena, fields: Vector<StructField>) -> String = {
    let n: Integer = length(fields)
    let mutable out: String = "("
    let mutable i: Integer = 0
    while i < n {
        if i > 0 {
            out = concat(out, " ")
        }
        let f: StructField = get(fields, i)!!
        out = concat(out, concat(f.name, concat(":", format_type(arena, f.type_annotation))))
        i = i + 1
    }
    concat(out, ")")
}

function format_enum_variants(arena: Arena, variants: Vector<EnumVariant>) -> String = {
    let n: Integer = length(variants)
    let mutable out: String = "("
    let mutable i: Integer = 0
    while i < n {
        if i > 0 {
            out = concat(out, " ")
        }
        let v: EnumVariant = get(variants, i)!!
        let payload_str: String = match v.payload {
            ~0 => "",
            _ => concat("(", concat(format_type(arena, v.payload!!), ")")),
        }
        out = concat(out, concat(v.name, payload_str))
        i = i + 1
    }
    concat(out, ")")
}

function format_dot_path(segments: Vector<String>) -> String = {
    let n: Integer = length(segments)
    let mutable out: String = ""
    let mutable i: Integer = 0
    while i < n {
        if i > 0 {
            out = concat(out, ".")
        }
        out = concat(out, get(segments, i)!!)
        i = i + 1
    }
    out
}

function format_import_names(names: Vector<ImportName>) -> String = {
    let n: Integer = length(names)
    let mutable out: String = "("
    let mutable i: Integer = 0
    while i < n {
        if i > 0 {
            out = concat(out, " ")
        }
        let nm: ImportName = get(names, i)!!
        let entry: String = match nm.alias {
            ~0 => nm.name,
            _ => concat(nm.name, concat("=", nm.alias!!)),
        }
        out = concat(out, entry)
        i = i + 1
    }
    concat(out, ")")
}

public function format_program(p: Program) -> String = {
    let n: Integer = length(p.item_ids)
    let mutable out: String = "(program"
    let mutable i: Integer = 0
    while i < n {
        let id: Integer = get(p.item_ids, i)!!
        out = concat(out, concat(" ", format_item(p.arena, id)))
        i = i + 1
    }
    concat(out, ")")
}


function parse_program_or_fail(source: String) -> Program = {
    let toks: Vector<SpannedToken> = lex_or_fail(source)
    let st: ParserState = parser_new(toks)
    let step: ParseProgramStep = parse_program(st)
    // v0.7.5.6a: smoke harness still expects the success path (zero
    // errors), so assert on the error vector and surface the program.
    let err_count: Integer = length(step.errors)
    assert(err_count == 0)
    step.program
}

function assert_parse_program(source: String, expected: String) -> Unit = {
    let prog: Program = parse_program_or_fail(source)
    let printed: String = format_program(prog)
    assert(printed == expected)
}

// ── v0.7.5.5a type-level smoke helpers ──────────────────────────

function parse_type_or_fail(source: String) -> ParseTypeStep = {
    let toks: Vector<SpannedToken> = lex_or_fail(source)
    let st: ParserState = parser_new(toks)
    let outcome: ParseTypeStep~ParseError = parse_type_minimal(st)
    match outcome {
        ~+ step => step,
        ~- _ => {
            assert(false)
            ParseTypeStep { state: parser_new(new()), type_id: 0 }
        },
    }
}

function assert_parse_type(source: String, expected: String) -> Unit = {
    let step: ParseTypeStep = parse_type_or_fail(source)
    let printed: String = format_type(step.state.arena, step.type_id)
    assert(printed == expected)
}

// ── v0.7.5.5b pattern-level smoke helpers ───────────────────────

function parse_pattern_or_fail(source: String) -> ParsePatternStep = {
    let toks: Vector<SpannedToken> = lex_or_fail(source)
    let st: ParserState = parser_new(toks)
    let outcome: ParsePatternStep~ParseError = parse_pattern(st)
    match outcome {
        ~+ step => step,
        ~- _ => {
            assert(false)
            ParsePatternStep { state: parser_new(new()), pattern_id: 0 }
        },
    }
}

function assert_parse_pattern(source: String, expected: String) -> Unit = {
    let step: ParsePatternStep = parse_pattern_or_fail(source)
    let printed: String = format_pattern(step.state.arena, step.pattern_id)
    assert(printed == expected)
}

// ── v0.7.5.6a recovery smoke helpers ────────────────────────────

// Parse a program and assert (a) it produced exactly `expected_errs`
// errors and (b) the surviving items pretty-print to `expected_shape`.
function assert_parse_program_recovers(
    source: String,
    expected_errs: Integer,
    expected_shape: String,
) -> Unit = {
    let toks: Vector<SpannedToken> = lex_or_fail(source)
    let st: ParserState = parser_new(toks)
    let step: ParseProgramStep = parse_program(st)
    let err_count: Integer = length(step.errors)
    assert(err_count == expected_errs)
    let printed: String = format_program(step.program)
    assert(printed == expected_shape)
}

// ─────────────────────────────────────────────────────────────────
// Entry — exercises the Pratt parser + statement + item layers
// ─────────────────────────────────────────────────────────────────

function main() -> Unit = {
    // Arithmetic + precedence
    assert_parse("1 + 2 * 3", "(+ 1 (* 2 3))")
    assert_parse("1 * 2 + 3", "(+ (* 1 2) 3)")
    assert_parse("(1 + 2) * 3", "(* (+ 1 2) 3)")
    assert_parse("-arena + b", "(+ (- arena) b)")
    assert_parse("2 ** 3 ** 2", "(** 2 (** 3 2))")

    // Comparison + logic
    assert_parse("x == y", "(== x y)")
    assert_parse("arena && b || c", "(|| (&& arena b) c)")
    assert_parse("p => q", "(=> p q)")

    // Postfix
    assert_parse("x!!", "(!! x)")
    assert_parse("f(1, 2)", "(call f 1 2)")
    assert_parse("arena.b", "(. arena b)")
    assert_parse("arena.f(x)", "(.call arena f x)")

    // Outcome + elvis + range
    assert_parse("~+ 7", "(~+ 7)")
    assert_parse("~0", "~0")
    assert_parse("f() ~? |e| 0", "(~? (call f) |e| 0)")
    assert_parse("get() ~: 0", "(~: (call get) 0)")
    assert_parse("x ?: 0", "(?: x 0)")
    assert_parse("0..10", "(.. 0 10)")
    assert_parse("0..=10", "(..= 0 10)")

    // v0.7.5.3 — block + statement layer
    assert_parse_block("{ }", "(block)")
    assert_parse_block("{ 42 }", "(block (final 42))")
    assert_parse_block("{ let x = 5 }", "(block (let x 5))")
    assert_parse_block("{ let mutable y = 0 }", "(block (let-mut y 0))")
    assert_parse_block("{ let x: Integer = 5 }", "(block (let x :Integer 5))")
    assert_parse_block("{ constant PI = 3 }", "(block (const PI 3))")
    assert_parse_block("{ return }", "(block (return))")
    assert_parse_block("{ return 7 }", "(block (return 7))")
    assert_parse_block("{ break }", "(block (break))")
    assert_parse_block("{ break 9 }", "(block (break 9))")
    assert_parse_block("{ continue }", "(block (continue))")
    assert_parse_block("{ count = count + 1 }", "(block (assign count (+ count 1)))")
    assert_parse_block("{ for i in 0..10 { } }", "(block (for i (.. 0 10) (block)))")
    assert_parse_block("{ for _ in xs { } }", "(block (for _ xs (block)))")
    assert_parse_block("{ while running { } }", "(block (while running (block)))")
    assert_parse_block("{ while? maybe { } }", "(block (while? maybe (block)))")
    assert_parse_block("{ loop { } }", "(block (loop (block)))")
    assert_parse_block("{ let x = 5 x + 1 }", "(block (let x 5) (final (+ x 1)))")
    assert_parse_block("{ f(x); g(y) }", "(block (expr (call f x)) (final (call g y)))")
    assert_parse_block("{ let x = 1 let y = 2 x + y }", "(block (let x 1) (let y 2) (final (+ x y)))")

    // v0.7.5.4a — item + program layer (functions, const, typedef, visibility)
    assert_parse_program("", "(program)")
    assert_parse_program(
        "function main() = 0",
        "(program (fn main () (= 0)))",
    )
    assert_parse_program(
        "function double(n: Integer) -> Integer = n * 2",
        "(program (fn double (n:Integer) ->Integer (= (* n 2))))",
    )
    assert_parse_program(
        "public function main() { 0 }",
        "(program public (fn main () (block (final 0))))",
    )
    assert_parse_program(
        "public(package) function helper() = 1",
        "(program public(package) (fn helper () (= 1)))",
    )
    assert_parse_program(
        "function identity<T>(x: T) -> T = x",
        "(program (fn identity<T> (x:T) ->T (= x)))",
    )
    assert_parse_program(
        "function pair<T,U>(arena: T, b: U) = arena",
        "(program (fn pair<T,U> (arena:T b:U) (= arena)))",
    )
    assert_parse_program(
        "function mutate(mutable n: Integer) = n",
        "(program (fn mutate (mutable n:Integer) (= n)))",
    )
    assert_parse_program(
        "function take(owned n: Integer) = n",
        "(program (fn take (owned n:Integer) (= n)))",
    )
    assert_parse_program(
        "function noop() { }",
        "(program (fn noop () (block)))",
    )
    assert_parse_program(
        "constant PI = 3",
        "(program (const PI 3))",
    )
    assert_parse_program(
        "public constant PI: Integer = 3",
        "(program public (const PI :Integer 3))",
    )
    assert_parse_program(
        "type Username = String",
        "(program (type Username String))",
    )
    assert_parse_program(
        "public type Age = Integer",
        "(program public (type Age Integer))",
    )
    assert_parse_program(
        "function arena() = 1 function b() = 2",
        "(program (fn arena () (= 1)) (fn b () (= 2)))",
    )

    // v0.7.5.4b — struct + enum + module + imports
    assert_parse_program(
        "struct Point { x: Integer, y: Integer }",
        "(program (struct Point (x:Integer y:Integer)))",
    )
    assert_parse_program(
        "public struct Box<T> { value: T }",
        "(program public (struct Box<T> (value:T)))",
    )
    assert_parse_program(
        "struct Empty { }",
        "(program (struct Empty ()))",
    )
    assert_parse_program(
        "enum Color { Red, Green, Blue }",
        "(program (enum Color (Red Green Blue)))",
    )
    assert_parse_program(
        "public enum Option<T> { Some(T), None }",
        "(program public (enum Option<T> (Some(T) None)))",
    )
    assert_parse_program(
        "enum Empty { }",
        "(program (enum Empty ()))",
    )
    assert_parse_program(
        "import std.io",
        "(program (import std.io))",
    )
    assert_parse_program(
        "import khi.lexer",
        "(program (import khi.lexer))",
    )
    assert_parse_program(
        "from std.io import println",
        "(program (from-import std.io (println)))",
    )
    assert_parse_program(
        "from std.io import println, print",
        "(program (from-import std.io (println print)))",
    )
    assert_parse_program(
        "from std.io import println as p",
        "(program (from-import std.io (println=p)))",
    )
    assert_parse_program(
        "module foo",
        "(program (module foo external))",
    )
    assert_parse_program(
        "module bar { function helper() = 0 }",
        "(program (module bar (inline (fn helper () (= 0)))))",
    )
    assert_parse_program(
        "public(package) module data { struct Cell { v: Integer } }",
        "(program public(package) (module data (inline (struct Cell (v:Integer)))))",
    )

    // v0.7.5.5a — full type grammar (atom-level, exercised directly
    // through `parse_type_minimal`; item-level wiring stays the same
    // since the placeholder is replaced in place).
    assert_parse_type("Integer", "Integer")
    assert_parse_type("Trilean!", "Trilean!")
    assert_parse_type("Integer?", "Integer?")
    assert_parse_type("Integer??", "Integer??")
    assert_parse_type("Option<Integer>", "Option<Integer>")
    assert_parse_type("HashMap<String, Integer>", "HashMap<String,Integer>")
    assert_parse_type("Result<Vector<Integer>, Error>", "Result<Vector<Integer>,Error>")
    assert_parse_type("(Integer, String)", "(Integer,String)")
    assert_parse_type("(Integer, String, Trilean)", "(Integer,String,Trilean)")
    assert_parse_type("(Integer)", "Integer")
    assert_parse_type("(Integer,)", "(Integer)")
    assert_parse_type("(Integer) -> String", "(Integer)->String")
    assert_parse_type("(Integer, Integer) -> Long", "(Integer,Integer)->Long")
    assert_parse_type("Integer~ParseError", "Integer~ParseError")
    assert_parse_type("Integer?~ParseError", "Integer?~ParseError")
    assert_parse_type("Vector<Token>~LexError", "Vector<Token>~LexError")

    // v0.7.5.5b — full pattern grammar
    assert_parse_pattern("_", "_")
    assert_parse_pattern("x", "x")
    assert_parse_pattern("null", "null")
    assert_parse_pattern("42", "42")
    assert_parse_pattern("\"hello\"", "\"hello\"")
    assert_parse_pattern("true", "true")
    assert_parse_pattern("unknown", "unknown")
    assert_parse_pattern("-5", "-5")
    assert_parse_pattern("0..10", "(range 0..10)")
    assert_parse_pattern("0..=9", "(range 0..=9)")
    assert_parse_pattern("-5..=5", "(range -5..=5)")
    assert_parse_pattern("(arena, b)", "(arena,b)")
    assert_parse_pattern("(arena, _, c)", "(arena,_,c)")
    assert_parse_pattern("(x,)", "(x)")
    assert_parse_pattern("(x)", "x")
    assert_parse_pattern("1 | 2 | 3", "(or 1 2 3)")
    assert_parse_pattern("Some(x)", "(Some x)")
    assert_parse_pattern("None", "None")
    assert_parse_pattern("Some(_)", "(Some _)")
    // Multi-element variant payload uses an explicit tuple wrap —
    // enum variants take exactly one payload per Triết grammar, so
    // `Cell((c, d))` matches a `Cell((Integer, Integer))` shape.
    assert_parse_pattern("Cell((c, d))", "(Cell (c,d))")
    assert_parse_pattern("~+ value", "(~+ value)")
    assert_parse_pattern("~- err", "(~- err)")
    assert_parse_pattern("~0", "~0")
    assert_parse_pattern("~+ _", "(~+ _)")

    // v0.7.5.6a — error recovery: malformed item should not poison
    // subsequent items. The driver records the error, synchronizes
    // to the next item keyword (or after `;`), and continues. A
    // failed parse may surface as 1+ errors per source-level
    // mistake because the synchronizer can land on a sync-stop
    // token (e.g. `type` itself) — the defensive force-advance
    // kicks in, and the next position may fail again. This
    // intentionally mirrors triet-parser::synchronize semantics.
    //
    // Case 1: broken `type = X` between two good functions —
    // surviving items pretty-print cleanly.
    assert_parse_program_recovers(
        "function arena() = 1 type = X function b() = 2",
        2,
        "(program (fn arena () (= 1)) (fn b () (= 2)))",
    )
    // Case 2: leading broken item, valid item follows.
    assert_parse_program_recovers(
        "constant = 7 function ok() = 0",
        2,
        "(program (fn ok () (= 0)))",
    )
    // Case 3: error at very end (no recovery target). EOF
    // terminates the loop after errors are recorded.
    assert_parse_program_recovers(
        "function good() = 1 type =",
        2,
        "(program (fn good () (= 1)))",
    )

    println("v0.7.5.6a item + type + pattern + recovery smoke passed")
}
