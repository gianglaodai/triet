function read_outcome_ctor(data: Vector<Integer>, p: Integer, opcode: Integer) -> ReadResultInstruction~TrivError = {
    let dest_res: ReadResultInteger = read_varint(data, p) ~? |err| ~- err
    let pay_res: ReadResultOperand = read_operand(data, dest_res.next_pos) ~? |err| ~- err
    let payload: InstOutcomeCtorPayload = InstOutcomeCtorPayload {
        dest: ValueId { raw: dest_res.value },
        payload: pay_res.value,
    }
    let inst: Instruction = if opcode == OPCODE_OUTCOME_NEW_POSITIVE {
        OutcomeNewPositiveInst(payload)
    } else {
        OutcomeNewNegativeInst(payload)
    }
    ~+ ReadResultInstruction { value: inst, next_pos: pay_res.next_pos }
}

function read_outcome_new_null(data: Vector<Integer>, p: Integer) -> ReadResultInstruction~TrivError = {
    let dest_res: ReadResultInteger = read_varint(data, p) ~? |err| ~- err
    ~+ ReadResultInstruction {
        value: OutcomeNewNullInst(InstOutcomeNewNullPayload { dest: ValueId { raw: dest_res.value } }),
        next_pos: dest_res.next_pos,
    }
}

function read_outcome_unary(data: Vector<Integer>, p: Integer, opcode: Integer) -> ReadResultInstruction~TrivError = {
    let dest_res: ReadResultInteger = read_varint(data, p) ~? |err| ~- err
    let src_res: ReadResultOperand = read_operand(data, dest_res.next_pos) ~? |err| ~- err
    let payload: InstOutcomeUnaryPayload = InstOutcomeUnaryPayload {
        dest: ValueId { raw: dest_res.value },
        source: src_res.value,
    }
    let inst: Instruction = if opcode == OPCODE_OUTCOME_DISCRIMINANT {
        OutcomeDiscriminantInst(payload)
    } else if opcode == OPCODE_OUTCOME_UNWRAP_VALUE {
        OutcomeUnwrapValueInst(payload)
    } else {
        OutcomeUnwrapErrorInst(payload)
    }
    ~+ ReadResultInstruction { value: inst, next_pos: src_res.next_pos }
}

// ── Global type-table collection across all modules ──────────────
//
// Mirrors `collect_type_table` in Rust serde: walks every function's
// param + return type plus every constant's tag, building a flat
// de-duplicated `TypeTagArena` keyed by index. Composites recurse
// post-order so an inner type always lands before its container.
// First entry is always `Unit` (index 0).

/// Walk a type from its OWNING arena (`source`) and insert it (plus
/// every transitive inner reference) into the GLOBAL arena `dest`.
/// Composite tags rebuild their `inner` field to point at the global
/// arena's index rather than the source arena's. Returns the updated
/// global arena.
function add_type(dest: TypeTagArena, source: TypeTagArena, ty: TypeTag) -> TypeTagArena =
    match ty {
        NullableTag(p) => {
            let inner_ty: TypeTag = lookup_or_unit(source, p.inner)
            let after: TypeTagArena = add_type(dest, source, inner_ty)
            let inner_idx: Integer = global_type_index(after, inner_ty)
            let remapped: TypeTag = NullableTag(TypeTagNullablePayload { inner: inner_idx })
            intern_global_type(after, remapped)
        },
        VectorTag(p) => {
            let inner_ty: TypeTag = lookup_or_unit(source, p.inner)
            let after: TypeTagArena = add_type(dest, source, inner_ty)
            let inner_idx: Integer = global_type_index(after, inner_ty)
            let remapped: TypeTag = VectorTag(TypeTagVectorPayload { inner: inner_idx })
            intern_global_type(after, remapped)
        },
        HashMapTag(p) => {
            let k_ty: TypeTag = lookup_or_unit(source, p.key)
            let v_ty: TypeTag = lookup_or_unit(source, p.value)
            let a1: TypeTagArena = add_type(dest, source, k_ty)
            let a2: TypeTagArena = add_type(a1, source, v_ty)
            let k_idx: Integer = global_type_index(a2, k_ty)
            let v_idx: Integer = global_type_index(a2, v_ty)
            let remapped: TypeTag = HashMapTag(TypeTagHashMapPayload { key: k_idx, value: v_idx })
            intern_global_type(a2, remapped)
        },
        OutcomeTag(p) => {
            let v_ty: TypeTag = lookup_or_unit(source, p.value_type)
            let e_ty: TypeTag = lookup_or_unit(source, p.error_type)
            let a1: TypeTagArena = add_type(dest, source, v_ty)
            let a2: TypeTagArena = add_type(a1, source, e_ty)
            let v_idx: Integer = global_type_index(a2, v_ty)
            let e_idx: Integer = global_type_index(a2, e_ty)
            let remapped: TypeTag = OutcomeTag(TypeTagOutcomePayload {
                value_type: v_idx,
                error_type: e_idx,
                allow_null_state: p.allow_null_state,
            })
            intern_global_type(a2, remapped)
        },
        _ => intern_global_type(dest, ty),
    }

/// Insert a primitive or already-remapped composite into the global
/// arena. Idempotent — no-op if the tag is already present.
function intern_global_type(arena: TypeTagArena, ty: TypeTag) -> TypeTagArena = {
    if global_type_index(arena, ty) < 0 {
        let res: AllocTagResult = alloc_type_tag(arena, ty)
        res.arena
    } else {
        arena
    }
}

function lookup_or_unit(arena: TypeTagArena, idx: Integer) -> TypeTag = {
    let opt: TypeTag? = get_type_tag(arena, idx)
    match opt {
        ~0 => UnitTag(primitive_marker()),
        _ => opt!!,
    }
}

/// Linear-scan index lookup. Returns -1 if absent. Uses TypeTag
/// structural equality (Triết's `==` on enums).
function global_type_index(arena: TypeTagArena, ty: TypeTag) -> Integer = {
    let total: Integer = length(arena.tags)
    let mutable i: Integer = 0
    let mutable found: Integer = -1
    while i < total && found < 0 {
        if type_tag_eq(get(arena.tags, i)!!, ty) {
            found = i
        }
        i = i + 1
    }
    found
}

/// Triết-side VM has no structural `==` for enum values (see
/// `runtime_eq` in crates/triet-ir/src/vm.rs), so we hand-roll the
/// comparison by discriminator-byte + payload fields. For composite
/// types the inner Integer indices are compared directly — this is
/// safe because `add_type` rewrites composites to GLOBAL indices
/// BEFORE handing them to `intern_global_type`.
function type_tag_eq(a: TypeTag, b: TypeTag) -> Trilean! = {
    let da: Integer = type_tag_discriminator(a)
    let db: Integer = type_tag_discriminator(b)
    if da != db { return false }
    if da == TYPE_TAG_NULLABLE { type_tag_nullable_inner(a) == type_tag_nullable_inner(b) }
    else if da == TYPE_TAG_VECTOR { type_tag_vector_inner(a) == type_tag_vector_inner(b) }
    else if da == TYPE_TAG_HASHMAP {
        type_tag_hashmap_key(a) == type_tag_hashmap_key(b)
            && type_tag_hashmap_value(a) == type_tag_hashmap_value(b)
    }
    else if da == TYPE_TAG_OUTCOME {
        type_tag_outcome_value(a) == type_tag_outcome_value(b)
            && type_tag_outcome_error(a) == type_tag_outcome_error(b)
            && type_tag_outcome_allow_null(a) == type_tag_outcome_allow_null(b)
    }
    else { true }
}

function type_tag_discriminator(ty: TypeTag) -> Integer =
    match ty {
        TritTag(_) => TYPE_TAG_TRIT,
        TryteTag(_) => TYPE_TAG_TRYTE,
        IntegerTag(_) => TYPE_TAG_INTEGER,
        LongTag(_) => TYPE_TAG_LONG,
        TrileanTag(_) => TYPE_TAG_TRILEAN,
        StringTag(_) => TYPE_TAG_STRING,
        UnitTag(_) => TYPE_TAG_UNIT,
        NullableTag(_) => TYPE_TAG_NULLABLE,
        VectorTag(_) => TYPE_TAG_VECTOR,
        HashMapTag(_) => TYPE_TAG_HASHMAP,
        OutcomeTag(_) => TYPE_TAG_OUTCOME,
    }

function type_tag_nullable_inner(ty: TypeTag) -> Integer =
    match ty {
        NullableTag(p) => p.inner,
        _ => -1,
    }

function type_tag_vector_inner(ty: TypeTag) -> Integer =
    match ty {
        VectorTag(p) => p.inner,
        _ => -1,
    }

function type_tag_hashmap_key(ty: TypeTag) -> Integer =
    match ty {
        HashMapTag(p) => p.key,
        _ => -1,
    }

function type_tag_hashmap_value(ty: TypeTag) -> Integer =
    match ty {
        HashMapTag(p) => p.value,
        _ => -1,
    }

function type_tag_outcome_value(ty: TypeTag) -> Integer =
    match ty {
        OutcomeTag(p) => p.value_type,
        _ => -1,
    }

function type_tag_outcome_error(ty: TypeTag) -> Integer =
    match ty {
        OutcomeTag(p) => p.error_type,
        _ => -1,
    }

function type_tag_outcome_allow_null(ty: TypeTag) -> Trilean! =
    match ty {
        OutcomeTag(p) => p.allow_null_state,
        _ => false,
    }

/// Build the global type table from an IrProgram. Each function's
/// param + return type tag IDs reference the OWNING MODULE's local
/// `type_arena`; we resolve them to concrete TypeTags then re-intern
/// into the global arena (rewriting composite inner indices).
public function collect_type_table(program: IrProgram) -> TypeTagArena = {
    let mutable arena: TypeTagArena = type_tag_arena_new()
    arena = alloc_type_tag(arena, UnitTag(primitive_marker())).arena
    let m_total: Integer = length(program.modules)
    let mutable m_idx: Integer = 0
    while m_idx < m_total {
        let m: IrModule = get(program.modules, m_idx)!!
        let f_total: Integer = length(m.functions)
        let mutable f_idx: Integer = 0
        while f_idx < f_total {
            let f: Function = get(m.functions, f_idx)!!
            let p_total: Integer = length(f.parameters)
            let mutable p_idx: Integer = 0
            while p_idx < p_total {
                let param: IrFunctionParam = get(f.parameters, p_idx)!!
                let pty: TypeTag = lookup_or_unit(m.type_arena, param.type_tag_id)
                arena = add_type(arena, m.type_arena, pty)
                p_idx = p_idx + 1
            }
            let rty: TypeTag = lookup_or_unit(m.type_arena, f.return_type_id)
            arena = add_type(arena, m.type_arena, rty)
            f_idx = f_idx + 1
        }
        m_idx = m_idx + 1
    }
    // Constants: each constant's type tag is a primitive (or
    // Nullable<Unit> for NullConst); inner is always Unit which is
    // already at index 0 by construction. We build the tag in a
    // scratch arena (for shape) then add it via the dest path.
    let c_total: Integer = length(program.constants.entries)
    let mutable c_idx: Integer = 0
    while c_idx < c_total {
        let c: Constant = get(program.constants.entries, c_idx)!!
        let scratch: AllocTagResult = constant_type_tag(type_tag_arena_new(), c)
        let scratch_arena: TypeTagArena = scratch.arena
        let ctag: TypeTag = get_type_tag(scratch_arena, scratch.tag_id)!!
        arena = add_type(arena, scratch_arena, ctag)
        c_idx = c_idx + 1
    }
    arena
}

// ── Function table + Code section ────────────────────────────────

public function write_function_table(buf: Vector<Integer>, program: IrProgram, types: TypeTagArena) -> Vector<Integer> = {
    let count: Integer = total_function_count(program)
    let header: Vector<Integer> = write_varint(buf, count)
    write_function_metas(header, program, types, 0)
}

// Helper: count total functions across all modules. Bound to its own
// function to dodge a Triết lowerer ValueKind-tracking gap where
// `get(vec, i)!!.field` inline chains lose struct identity.
public function total_function_count(program: IrProgram) -> Integer = {
    let mutable count: Integer = 0
    let m_total: Integer = length(program.modules)
    let mutable m_idx: Integer = 0
    while m_idx < m_total {
        let m: IrModule = get(program.modules, m_idx)!!
        count = count + length(m.functions)
        m_idx = m_idx + 1
    }
    count
}

function write_function_metas(buf: Vector<Integer>, program: IrProgram, types: TypeTagArena, m_idx: Integer) -> Vector<Integer> = {
    if m_idx >= length(program.modules) {
        buf
    } else {
        let m: IrModule = get(program.modules, m_idx)!!
        let mod_path: String = module_path_display(m.path_segments)
        let after_funcs: Vector<Integer> = write_module_funcs(buf, m, mod_path, types, 0)
        write_function_metas(after_funcs, program, types, m_idx + 1)
    }
}

function write_module_funcs(buf: Vector<Integer>, m: IrModule, mod_path: String, types: TypeTagArena, f_idx: Integer) -> Vector<Integer> = {
    if f_idx >= length(m.functions) {
        buf
    } else {
        let f: Function = get(m.functions, f_idx)!!
        let s1: Vector<Integer> = write_string(buf, mod_path)
        let s2: Vector<Integer> = match f.name {
            ~0 => write_u8(s1, 0),
            _ => {
                let h: Vector<Integer> = write_u8(s1, 1)
                write_string(h, f.name!!)
            },
        }
        let s3: Vector<Integer> = write_varint(s2, length(f.parameters))
        let s4: Vector<Integer> = write_func_params(s3, m, f.parameters, types, 0)
        let ret_ty: TypeTag = lookup_or_unit(m.type_arena, f.return_type_id)
        let ret_idx: Integer = lookup_global_index(types, m.type_arena, ret_ty)
        let s5: Vector<Integer> = write_varint(s4, ret_idx)
        write_module_funcs(s5, m, mod_path, types, f_idx + 1)
    }
}

function write_func_params(buf: Vector<Integer>, m: IrModule, params: Vector<IrFunctionParam>, types: TypeTagArena, p_idx: Integer) -> Vector<Integer> = {
    if p_idx >= length(params) {
        buf
    } else {
        let p: IrFunctionParam = get(params, p_idx)!!
        let s1: Vector<Integer> = write_string(buf, p.name)
        let pty: TypeTag = lookup_or_unit(m.type_arena, p.type_tag_id)
        let p_idx_global: Integer = lookup_global_index(types, m.type_arena, pty)
        let s2: Vector<Integer> = write_varint(s1, p_idx_global)
        write_func_params(s2, m, params, types, p_idx + 1)
    }
}

/// Look up a source-arena TypeTag's index in the global arena.
/// Walks the composite tree to remap inner indices from source to
/// global, then performs a structural-equality scan.
function lookup_global_index(global: TypeTagArena, source: TypeTagArena, ty: TypeTag) -> Integer = {
    let remapped: TypeTag = remap_to_global(global, source, ty)
    global_type_index(global, remapped)
}

function remap_to_global(global: TypeTagArena, source: TypeTagArena, ty: TypeTag) -> TypeTag =
    match ty {
        NullableTag(p) => {
            let inner_ty: TypeTag = lookup_or_unit(source, p.inner)
            let inner_remapped: TypeTag = remap_to_global(global, source, inner_ty)
            let inner_idx: Integer = global_type_index(global, inner_remapped)
            NullableTag(TypeTagNullablePayload { inner: inner_idx })
        },
        VectorTag(p) => {
            let inner_ty: TypeTag = lookup_or_unit(source, p.inner)
            let inner_remapped: TypeTag = remap_to_global(global, source, inner_ty)
            let inner_idx: Integer = global_type_index(global, inner_remapped)
            VectorTag(TypeTagVectorPayload { inner: inner_idx })
        },
        HashMapTag(p) => {
            let k_ty: TypeTag = lookup_or_unit(source, p.key)
            let v_ty: TypeTag = lookup_or_unit(source, p.value)
            let k_remapped: TypeTag = remap_to_global(global, source, k_ty)
            let v_remapped: TypeTag = remap_to_global(global, source, v_ty)
            let k_idx: Integer = global_type_index(global, k_remapped)
            let v_idx: Integer = global_type_index(global, v_remapped)
            HashMapTag(TypeTagHashMapPayload { key: k_idx, value: v_idx })
        },
        OutcomeTag(p) => {
            let v_ty: TypeTag = lookup_or_unit(source, p.value_type)
            let e_ty: TypeTag = lookup_or_unit(source, p.error_type)
            let v_remapped: TypeTag = remap_to_global(global, source, v_ty)
            let e_remapped: TypeTag = remap_to_global(global, source, e_ty)
            let v_idx: Integer = global_type_index(global, v_remapped)
            let e_idx: Integer = global_type_index(global, e_remapped)
            OutcomeTag(TypeTagOutcomePayload {
                value_type: v_idx,
                error_type: e_idx,
                allow_null_state: p.allow_null_state,
            })
        },
        _ => ty,
    }

/// Module path display matching Rust's `AbsolutePath::to_string` for
/// the per-module sentinel `AbsolutePath { module_path: segments,
/// name: "" }`. Rust display is `"{segments.join('.')}.{name}"` —
/// empty segments + empty name yields `.` (one byte).
public function module_path_display(segments: Vector<String>) -> String = {
    let total: Integer = length(segments)
    let mutable mod_str: String = ""
    let mutable i: Integer = 0
    while i < total {
        if i > 0 {
            mod_str = concat(mod_str, ".")
        }
        mod_str = concat(mod_str, get(segments, i)!!)
        i = i + 1
    }
    // Append `.{name}` per Rust AbsolutePath::Display. Name is always
    // "" for the IR module sentinel, so result = "<mod>.".
    concat(mod_str, ".")
}

// ── Code section ─────────────────────────────────────────────────

public function write_code(buf: Vector<Integer>, program: IrProgram) -> Vector<Integer> = {
    let count: Integer = total_function_count(program)
    let header: Vector<Integer> = write_varint(buf, count)
    write_code_modules(header, program, 0)
}

function write_code_modules(buf: Vector<Integer>, program: IrProgram, m_idx: Integer) -> Vector<Integer> = {
    if m_idx >= length(program.modules) {
        buf
    } else {
        let m: IrModule = get(program.modules, m_idx)!!
        let after: Vector<Integer> = write_code_module_funcs(buf, m, 0)
        write_code_modules(after, program, m_idx + 1)
    }
}

function write_code_module_funcs(buf: Vector<Integer>, m: IrModule, f_idx: Integer) -> Vector<Integer> = {
    if f_idx >= length(m.functions) {
        buf
    } else {
        let f: Function = get(m.functions, f_idx)!!
        // Rust-side stores blocks in `BTreeMap<BlockId, BasicBlock>`
        // so the wire order is sorted by `block.id`. Triết-side
        // uses a `Vector` with linear `push` from `start_block`,
        // which can interleave control-flow auxiliary blocks
        // (e.g. `while_unknown_panic` starts before `while_body`
        // because `BrTrilean` needs its id as the `unknown_block`
        // target). Sort by `id.raw` here to match Rust's wire
        // order. Tracked as the now-closed
        // `v0.7.x.runtime-fix.block-emission-order`.
        let sorted: Vector<BasicBlock> = sort_blocks_by_id(f.blocks)
        let s1: Vector<Integer> = write_varint(buf, length(sorted))
        let s2: Vector<Integer> = write_blocks(s1, sorted, 0)
        write_code_module_funcs(s2, m, f_idx + 1)
    }
}

/// O(N²) insertion sort over BasicBlocks keyed by `id.raw`. Block
/// counts are tiny (typically ≤8) so the quadratic cost stays
/// negligible.
function sort_blocks_by_id(blocks: Vector<BasicBlock>) -> Vector<BasicBlock> = {
    let total: Integer = length(blocks)
    let mutable out: Vector<BasicBlock> = new()
    let mutable i: Integer = 0
    while i < total {
        let b_opt: BasicBlock? = get(blocks, i)
        out = push(out, b_opt!!)
        i = i + 1
    }
    let mutable a: Integer = 1
    while a < total {
        let mutable bi: Integer = a
        while bi > 0 {
            let cur_opt: BasicBlock? = get(out, bi)
            let prev_opt: BasicBlock? = get(out, bi - 1)
            let cur: BasicBlock = cur_opt!!
            let prev: BasicBlock = prev_opt!!
            if cur.id.raw < prev.id.raw {
                let mutable rebuilt: Vector<BasicBlock> = new()
                let mutable k: Integer = 0
                while k < total {
                    if k == bi - 1 {
                        rebuilt = push(rebuilt, cur)
                    } else if k == bi {
                        rebuilt = push(rebuilt, prev)
                    } else {
                        let kth_opt: BasicBlock? = get(out, k)
                        rebuilt = push(rebuilt, kth_opt!!)
                    }
                    k = k + 1
                }
                out = rebuilt
                bi = bi - 1
            } else {
                bi = 0
            }
        }
        a = a + 1
    }
    out
}

function write_blocks(buf: Vector<Integer>, blocks: Vector<BasicBlock>, i: Integer) -> Vector<Integer> = {
    if i >= length(blocks) {
        buf
    } else {
        let b: BasicBlock = get(blocks, i)!!
        let s1: Vector<Integer> = write_varint(buf, b.id.raw)
        let name_str: String = match b.name {
            ~0 => "",
            _ => b.name!!,
        }
        let s2: Vector<Integer> = write_string(s1, name_str)
        let s3: Vector<Integer> = write_varint(s2, length(b.instructions))
        let s4: Vector<Integer> = write_instructions(s3, b.instructions, 0)
        write_blocks(s4, blocks, i + 1)
    }
}

function write_instructions(buf: Vector<Integer>, instrs: Vector<Instruction>, i: Integer) -> Vector<Integer> = {
    if i >= length(instrs) {
        buf
    } else {
        let next: Vector<Integer> = write_instruction(buf, get(instrs, i)!!)
        write_instructions(next, instrs, i + 1)
    }
}

// ── Top-level write_program ──────────────────────────────────────

public function write_program(program: IrProgram) -> Vector<Integer> = {
    let types: TypeTagArena = collect_type_table(program)
    let type_payload: Vector<Integer> = write_type_table(new(), types)
    let cw: ConstantPoolWriteResult = write_constants_with_types(new(), program.constants, types)
    let const_payload: Vector<Integer> = cw.buf
    let func_payload: Vector<Integer> = write_function_table(new(), program, types)
    let code_payload: Vector<Integer> = write_code(new(), program)

    let mutable buf: Vector<Integer> = new()
    buf = push(buf, TRIV_MAGIC_T)
    buf = push(buf, TRIV_MAGIC_R)
    buf = push(buf, TRIV_MAGIC_I)
    buf = push(buf, TRIV_MAGIC_V)
    buf = write_u32_le(buf, TRIV_VERSION)
    // Witness tables empty for single-package builds at v0.7.9 — 4 sections.
    buf = write_u32_le(buf, 4)
    buf = write_section(buf, SEC_TYPES, type_payload)
    buf = write_section(buf, SEC_CONSTANTS, const_payload)
    buf = write_section(buf, SEC_FUNCTIONS, func_payload)
    buf = write_section(buf, SEC_CODE, code_payload)
    buf
}

/// Variant of `write_constants` that takes a pre-built global types
/// arena (instead of building incrementally). Each constant's type
/// index is looked up against the global table — matching Rust's
/// `write_constants(buf, pool, &types)` flow.
public function write_constants_with_types(
    buf: Vector<Integer>,
    pool: ConstantPool,
    types: TypeTagArena,
) -> ConstantPoolWriteResult = {
    let header: Vector<Integer> = write_varint(buf, length(pool.entries))
    let final_buf: Vector<Integer> = write_constants_with_types_from(header, pool.entries, types, 0)
    ConstantPoolWriteResult { buf: final_buf, arena: types }
}

function write_constants_with_types_from(
    buf: Vector<Integer>,
    entries: Vector<Constant>,
    types: TypeTagArena,
    i: Integer,
) -> Vector<Integer> = {
    if i >= length(entries) {
        buf
    } else {
        let c: Constant = get(entries, i)!!
        let scratch: AllocTagResult = constant_type_tag(type_tag_arena_new(), c)
        let scratch_arena: TypeTagArena = scratch.arena
        let tag: TypeTag = get_type_tag(scratch_arena, scratch.tag_id)!!
        let idx: Integer = lookup_global_index(types, scratch_arena, tag)
        let next: Vector<Integer> = write_constant(buf, c, idx)
        write_constants_with_types_from(next, entries, types, i + 1)
    }
}

public function write_section(buf: Vector<Integer>, section_id: Integer, payload: Vector<Integer>) -> Vector<Integer> = {
    let s1: Vector<Integer> = write_u8(buf, section_id)
    let s2: Vector<Integer> = write_u32_le(s1, length(payload))
    write_bytes(s2, payload)
}

// ── Entry: source → bytes ────────────────────────────────────────

public function serialize_source_to_triv(source: String) -> Vector<Integer> = {
    let ir: IrProgram = lower_source(source)
    write_program(ir)
}

public function debug_function_table(source: String) -> Vector<Integer> = {
    let ir: IrProgram = lower_source(source)
    let types: TypeTagArena = collect_type_table(ir)
    write_function_table(new(), ir, types)
}

public function debug_function_count(source: String) -> Integer = {
    let ir: IrProgram = lower_source(source)
    let mutable count: Integer = 0
    let m_total: Integer = length(ir.modules)
    let mutable m_idx: Integer = 0
    while m_idx < m_total {
        count = count + length(get(ir.modules, m_idx)!!.functions)
        m_idx = m_idx + 1
    }
    count
}

public function debug_program_shape(source: String) -> Integer = {
    let ir: IrProgram = lower_source(source)
    let m_count: Integer = length(ir.modules)
    let mutable fn_total: Integer = 0
    let mutable i: Integer = 0
    while i < m_count {
        let m: IrModule = get(ir.modules, i)!!
        fn_total = fn_total + length(m.functions)
        i = i + 1
    }
    // Encoding: m_count * 1000 + fn_total
    m_count * 1000 + fn_total
}

// ── Smoke entry — synthetic round-trip per v0.7.9.1 acceptance ─────
//
// Build a synthetic arena (covers every TypeTag discriminator
// 0..10) and a synthetic ConstantPool (covers every Constant variant
// 0..7). Encode → decode → re-encode → assert byte-identical at every
// hop. Returns `~+ true` on full round-trip success; the Rust smoke
// invokes this via the VM and asserts the result is `Outcome::Positive`
// carrying `Trilean::True`. Outcome shape lets us thread `~?` through
// the read paths without manually unwrapping each step.

public function pack_writer_smoke_main() -> Trilean!~TrivError = {
    // Build the arena post-order. Discriminator 0..6 are primitives.
    let a0: AllocTagResult = alloc_tag_trit(type_tag_arena_new())
    let a1: AllocTagResult = alloc_tag_tryte(a0.arena)
    let a2: AllocTagResult = alloc_tag_integer(a1.arena)
    let a3: AllocTagResult = alloc_tag_long(a2.arena)
    let a4: AllocTagResult = alloc_tag_trilean(a3.arena)
    let a5: AllocTagResult = alloc_tag_string(a4.arena)
    let a6: AllocTagResult = alloc_tag_unit(a5.arena)
    let a7: AllocTagResult = alloc_tag_nullable(a6.arena, a6.tag_id)
    let a8: AllocTagResult = alloc_tag_vector(a7.arena, a2.tag_id)
    let a9: AllocTagResult = alloc_tag_hashmap(a8.arena, a5.tag_id, a2.tag_id)
    let a10: AllocTagResult = alloc_tag_outcome(a9.arena, a2.tag_id, a5.tag_id, true)
    let arena: TypeTagArena = a10.arena

    // Encode → decode the arena and assert exact length match.
    let type_bytes: Vector<Integer> = write_type_table(new(), arena)
    let parsed: ReadResultArena = read_type_table(type_bytes, 0) ~? |err| ~- err
    if length(parsed.value.tags) != length(arena.tags) {
        return ~- Corrupted(TrivErrorCorrupted { message: "arena length mismatch after round-trip" })
    }

    // Re-encode the decoded arena and assert byte-identical against
    // the first emission (the v0.7.9.1 acceptance criterion).
    let type_bytes_2: Vector<Integer> = write_type_table(new(), parsed.value)
    if !vectors_equal(type_bytes, type_bytes_2) {
        return ~- Corrupted(TrivErrorCorrupted { message: "type-table bytes diverged" })
    }

    // Constant pool covering all 8 variants. Vector mutation is
    // functional in Triết — `entries = push(entries, c)` rebinds.
    let mutable entries: Vector<Constant> = new()
    entries = push(entries, TritConst(ConstantTritPayload { value: 1_trit }))
    entries = push(entries, TryteConst(ConstantTrytePayload { value: 5.to_tryte() }))
    entries = push(entries, IntegerConst(ConstantIntegerPayload { value: 42 }))
    entries = push(entries, LongConst(ConstantLongPayload { value: 100.to_long() }))
    entries = push(entries, TrileanConst(ConstantTrileanPayload { value: unknown }))
    entries = push(entries, StringConst(ConstantStringPayload { value: "hello" }))
    entries = push(entries, UnitConst(primitive_marker()))
    entries = push(entries, NullConst(primitive_marker()))
    let pool: ConstantPool = ConstantPool { entries: entries }

    let cw: ConstantPoolWriteResult = write_constants(new(), pool, type_tag_arena_new())
    let parsed_pool: ReadResultConstantPool = read_constants(cw.buf, 0, cw.arena) ~? |err| ~- err
    if length(parsed_pool.value.entries) != length(pool.entries) {
        return ~- Corrupted(TrivErrorCorrupted { message: "pool length mismatch after round-trip" })
    }

    // Round-trip the pool: re-encode the decoded pool and compare
    // byte-for-byte. The arena that the re-encode produces should
    // match the first arena's length (every tag re-interned).
    let cw_2: ConstantPoolWriteResult = write_constants(new(), parsed_pool.value, type_tag_arena_new())
    if !vectors_equal(cw.buf, cw_2.buf) {
        return ~- Corrupted(TrivErrorCorrupted { message: "constant-pool bytes diverged" })
    }
    if length(cw.arena.tags) != length(cw_2.arena.tags) {
        return ~- Corrupted(TrivErrorCorrupted { message: "re-encode arena length mismatch" })
    }

    ~+ true
}

function vectors_equal(a: Vector<Integer>, b: Vector<Integer>) -> Trilean! = {
    let la: Integer = length(a)
    let lb: Integer = length(b)
    if la != lb { return false }
    let mutable i: Integer = 0
    let mutable equal: Trilean! = true
    while i < la && equal {
        if get(a, i)!! != get(b, i)!! {
            equal = false
        }
        i = i + 1
    }
    equal
}

// ═════════════════════════════════════════════════════════════════
// v0.7.9.3 — `.khi` container writer + reader
//
// Wraps the `.triv` IR payload (from `write_program` above) with an
// ABI metadata header per ADR-0011 + ADR-0014 3-cấp hash tree.
//
// Wire format (mirrors crates/triet-pack/src/serde.rs byte layout):
//   magic = "trip" (4 bytes)
//   pack_version = 1 (u32 LE)
//   section_count = 2 (u32 LE)  // ABI metadata + IR code
//   sections: each = sec_id (u8) + sec_len (u32 LE) + payload
//
// ABI metadata payload (v0.7.9.3 minimal — empty types/exports/
// deps/caps tables; v0.7.9.4 populates them from the lowered IR):
//   abi_version = 2 (u32 LE)
//   pkg_name (lp string)
//   pkg_version: SemVer (3× u32 LE)
//   iface_hash: 32-byte BLAKE3
//   impl_hash: 32-byte BLAKE3
//   modules / types / exports / deps / caps tables (each varint(0)
//   for v0.7.9.3)
//
// Co-located with the .triv writer because the parent-search-dir
// nesting rule (`<parent>/<name>.tri`) means tripack_writer.tri as a
// separate file would force `compiler/pack_writer/parser.tri` lookup
// when loaded transitively. Keeping both in one file dodges that.
// ═════════════════════════════════════════════════════════════════

// ── Magic + version constants ────────────────────────────────────

constant KHI_MAGIC_T: Integer = 116
constant KHI_MAGIC_R: Integer = 114
constant KHI_MAGIC_I: Integer = 105
constant KHI_MAGIC_P: Integer = 112

constant KHI_PACK_VERSION: Integer = 1
constant KHI_ABI_VERSION: Integer = 2

constant KHI_SEC_ABI_METADATA: Integer = 1
constant KHI_SEC_IR_CODE: Integer = 2

constant HASH_LEN: Integer = 32

// ── Domain separators (ADR-0014 §6) ──────────────────────────────
//
// Each separator is exactly 16 bytes of ASCII + trailing NUL pad.
// MUST match `crates/triet-pack/src/hash.rs` byte-for-byte —
// changing one byte invalidates every hash ever computed.

// "triet/term-i  \0\0"
public function domain_term_iface() -> Vector<Integer> = {
    let mutable b: Vector<Integer> = new()
    b = push(b, 116) b = push(b, 114) b = push(b, 105) b = push(b, 101)
    b = push(b, 116) b = push(b, 47)  b = push(b, 116) b = push(b, 101)
    b = push(b, 114) b = push(b, 109) b = push(b, 45)  b = push(b, 105)
    b = push(b, 32)  b = push(b, 32)  b = push(b, 0)   b = push(b, 0)
    b
}

// "triet/term-m  \0\0"
public function domain_term_impl() -> Vector<Integer> = {
    let mutable b: Vector<Integer> = new()
    b = push(b, 116) b = push(b, 114) b = push(b, 105) b = push(b, 101)
    b = push(b, 116) b = push(b, 47)  b = push(b, 116) b = push(b, 101)
    b = push(b, 114) b = push(b, 109) b = push(b, 45)  b = push(b, 109)
    b = push(b, 32)  b = push(b, 32)  b = push(b, 0)   b = push(b, 0)
    b
}

// "triet/mod-i   \0\0"
public function domain_mod_iface() -> Vector<Integer> = {
    let mutable b: Vector<Integer> = new()
    b = push(b, 116) b = push(b, 114) b = push(b, 105) b = push(b, 101)
    b = push(b, 116) b = push(b, 47)  b = push(b, 109) b = push(b, 111)
    b = push(b, 100) b = push(b, 45)  b = push(b, 105) b = push(b, 32)
    b = push(b, 32)  b = push(b, 32)  b = push(b, 0)   b = push(b, 0)
    b
}

// "triet/mod-m   \0\0"
public function domain_mod_impl() -> Vector<Integer> = {
    let mutable b: Vector<Integer> = new()
    b = push(b, 116) b = push(b, 114) b = push(b, 105) b = push(b, 101)
    b = push(b, 116) b = push(b, 47)  b = push(b, 109) b = push(b, 111)
    b = push(b, 100) b = push(b, 45)  b = push(b, 109) b = push(b, 32)
    b = push(b, 32)  b = push(b, 32)  b = push(b, 0)   b = push(b, 0)
    b
}

// "triet/pkg-i   \0\0"
public function domain_pkg_iface() -> Vector<Integer> = {
    let mutable b: Vector<Integer> = new()
    b = push(b, 116) b = push(b, 114) b = push(b, 105) b = push(b, 101)
    b = push(b, 116) b = push(b, 47)  b = push(b, 112) b = push(b, 107)
    b = push(b, 103) b = push(b, 45)  b = push(b, 105) b = push(b, 32)
    b = push(b, 32)  b = push(b, 32)  b = push(b, 0)   b = push(b, 0)
    b
}

// "triet/pkg-m   \0\0"
public function domain_pkg_impl() -> Vector<Integer> = {
    let mutable b: Vector<Integer> = new()
    b = push(b, 116) b = push(b, 114) b = push(b, 105) b = push(b, 101)
    b = push(b, 116) b = push(b, 47)  b = push(b, 112) b = push(b, 107)
    b = push(b, 103) b = push(b, 45)  b = push(b, 109) b = push(b, 32)
    b = push(b, 32)  b = push(b, 32)  b = push(b, 0)   b = push(b, 0)
    b
}

// ── SemVer ───────────────────────────────────────────────────────

public struct SemVer {
    major: Integer,
    minor: Integer,
    patch: Integer,
}

public function semver_zero() -> SemVer = SemVer { major: 0, minor: 0, patch: 0 }

public function write_semver(buf: Vector<Integer>, v: SemVer) -> Vector<Integer> = {
    let s1: Vector<Integer> = write_u32_le(buf, v.major)
    let s2: Vector<Integer> = write_u32_le(s1, v.minor)
    write_u32_le(s2, v.patch)
}

public struct ReadResultSemVer {
    value: SemVer,
    next_pos: Integer,
}

public function read_semver(data: Vector<Integer>, pos: Integer) -> ReadResultSemVer~TrivError = {
    let maj_res: ReadResultInteger = read_u32_le(data, pos) ~? |err| ~- err
    let min_res: ReadResultInteger = read_u32_le(data, maj_res.next_pos) ~? |err| ~- err
    let pat_res: ReadResultInteger = read_u32_le(data, min_res.next_pos) ~? |err| ~- err
    ~+ ReadResultSemVer {
        value: SemVer { major: maj_res.value, minor: min_res.value, patch: pat_res.value },
        next_pos: pat_res.next_pos,
    }
}

// ── ABI metadata (minimal v0.7.9.3 shape) ────────────────────────

public struct AbiMetadata {
    abi_version: Integer,
    pkg_name: String,
    pkg_version: SemVer,
    iface_hash: Vector<Integer>,  // 32 bytes
    impl_hash: Vector<Integer>,   // 32 bytes
    // Empty for v0.7.9.3 — modules / types / exports / deps / caps
    // tables are all []; the writer + reader serialize them as
    // `varint(0)`. v0.7.9.4 populates real types/exports when
    // `compiler/main.tri` walks the lowered IR.
}

public function abi_metadata_empty(pkg_name: String, pkg_version: SemVer) -> AbiMetadata =
    AbiMetadata {
        abi_version: KHI_ABI_VERSION,
        pkg_name: pkg_name,
        pkg_version: pkg_version,
        iface_hash: zero_hash(),
        impl_hash: zero_hash(),
    }

public function zero_hash() -> Vector<Integer> = {
    let mutable b: Vector<Integer> = new()
    let mutable i: Integer = 0
    while i < HASH_LEN {
        b = push(b, 0)
        i = i + 1
    }
    b
}

// ── BLAKE3 helpers ───────────────────────────────────────────────
//
// All hashes flow through the `blake3_hash` builtin added in
// v0.7.9.1 (Vector<Integer> → 32-byte Vector<Integer>). Domain
// separators are prepended to the input bytes so each hash level
// stays distinct.

public function blake3_with_domain(domain: Vector<Integer>, payload: Vector<Integer>) -> Vector<Integer> = {
    let mutable input: Vector<Integer> = new()
    input = append_bytes_to(input, domain)
    input = append_bytes_to(input, payload)
    blake3_hash(input)
}

function append_bytes_to(dest: Vector<Integer>, src: Vector<Integer>) -> Vector<Integer> = {
    let mutable out: Vector<Integer> = dest
    let total: Integer = length(src)
    let mutable i: Integer = 0
    while i < total {
        out = push(out, get(src, i)!!)
        i = i + 1
    }
    out
}

// ── Canonical encoders for hash inputs ───────────────────────────

/// Encode the empty deps table for the iface hash. Matches Rust
/// `serde::encode_deps_for_hash(&[])` = `varint(0)` = 1 byte (0x00).
public function encode_deps_for_hash_empty() -> Vector<Integer> =
    write_varint(new(), 0)

/// Encode the empty caps table for the iface hash. Matches
/// `serde::encode_caps_for_hash(&[])` = `varint(0)` = 1 byte.
public function encode_caps_for_hash_empty() -> Vector<Integer> =
    write_varint(new(), 0)

// ── Package hash chain ──────────────────────────────────────────
//
// For v0.7.9.3 minimal (empty types/exports/deps/caps): the iface
// hash collapses to `BLAKE3(domain ‖ lp_pkg_name ‖ 0_modules_count
// ‖ empty_deps ‖ empty_caps)` and impl is
// `BLAKE3(domain ‖ iface ‖ code_section)`.

public function compute_iface_hash_empty(pkg_name: String) -> Vector<Integer> = {
    // Mirrors `crates/triet-pack/src/hash.rs::compute_iface_hash`
    // byte-for-byte: domain ‖ lp_string(pkg_name) ‖ <per-module entries
    // — empty here> ‖ deps_bytes ‖ caps_bytes. Rust iterates the
    // sorted-module slice with no count prefix, so we MUST NOT emit
    // a leading `varint(0)` for the module count even though `payload`
    // mirrors a write_varint shape elsewhere.
    //
    // CAVEAT: the hash-side length-prefix is `u32_le` (per
    // `hash.rs::write_lp_string` line 249), NOT the LEB128 varint
    // that the on-disk `write_string` uses. The two formats differ
    // for any non-empty payload — `pkg_name = "compiler"` (8 chars)
    // encodes as 12 bytes here (4 LE + 8) but only 9 bytes when
    // written into the on-disk metadata block.
    let mutable payload: Vector<Integer> = new()
    payload = write_u32_le(payload, text_len(pkg_name))
    payload = append_bytes_to(payload, into_bytes(pkg_name))
    payload = append_bytes_to(payload, encode_deps_for_hash_empty())
    payload = append_bytes_to(payload, encode_caps_for_hash_empty())
    blake3_with_domain(domain_pkg_iface(), payload)
}

public function compute_impl_hash(iface: Vector<Integer>, code_section: Vector<Integer>) -> Vector<Integer> = {
    let mutable payload: Vector<Integer> = new()
    payload = append_bytes_to(payload, iface)
    payload = append_bytes_to(payload, code_section)
    blake3_with_domain(domain_pkg_impl(), payload)
}

// ── ABI metadata serialization ────────────────────────────────────

public function write_abi_metadata(buf: Vector<Integer>, meta: AbiMetadata) -> Vector<Integer> = {
    let s1: Vector<Integer> = write_u32_le(buf, meta.abi_version)
    let s2: Vector<Integer> = write_string(s1, meta.pkg_name)
    let s3: Vector<Integer> = write_semver(s2, meta.pkg_version)
    let s4: Vector<Integer> = append_bytes_to(s3, meta.iface_hash)
    let s5: Vector<Integer> = append_bytes_to(s4, meta.impl_hash)
    // Empty tables: varint(0) for modules / types / exports / deps / caps.
    let s6: Vector<Integer> = write_varint(s5, 0)
    let s7: Vector<Integer> = write_varint(s6, 0)
    let s8: Vector<Integer> = write_varint(s7, 0)
    let s9: Vector<Integer> = write_varint(s8, 0)
    write_varint(s9, 0)
}

public struct ReadResultAbiMetadata {
    value: AbiMetadata,
    next_pos: Integer,
}

public function read_abi_metadata(data: Vector<Integer>, pos: Integer) -> ReadResultAbiMetadata~TrivError = {
    let abi_res: ReadResultInteger = read_u32_le(data, pos) ~? |err| ~- err
    if abi_res.value != KHI_ABI_VERSION {
        return ~- Corrupted(TrivErrorCorrupted { message: "unsupported abi_version" })
    }
    let name_res: ReadResultString = read_string(data, abi_res.next_pos) ~? |err| ~- err
    let ver_res: ReadResultSemVer = read_semver(data, name_res.next_pos) ~? |err| ~- err
    let iface_res: ReadResultHash = read_hash(data, ver_res.next_pos) ~? |err| ~- err
    let impl_res: ReadResultHash = read_hash(data, iface_res.next_pos) ~? |err| ~- err
    // Skip empty tables (5× varint=0).
    let m_res: ReadResultInteger = read_varint(data, impl_res.next_pos) ~? |err| ~- err
    if m_res.value != 0 {
        return ~- Corrupted(TrivErrorCorrupted { message: "v0.7.9.3 expects empty modules table" })
    }
    let t_res: ReadResultInteger = read_varint(data, m_res.next_pos) ~? |err| ~- err
    if t_res.value != 0 {
        return ~- Corrupted(TrivErrorCorrupted { message: "v0.7.9.3 expects empty types table" })
    }
    let e_res: ReadResultInteger = read_varint(data, t_res.next_pos) ~? |err| ~- err
    if e_res.value != 0 {
        return ~- Corrupted(TrivErrorCorrupted { message: "v0.7.9.3 expects empty exports table" })
    }
    let d_res: ReadResultInteger = read_varint(data, e_res.next_pos) ~? |err| ~- err
    if d_res.value != 0 {
        return ~- Corrupted(TrivErrorCorrupted { message: "v0.7.9.3 expects empty deps table" })
    }
    let c_res: ReadResultInteger = read_varint(data, d_res.next_pos) ~? |err| ~- err
    if c_res.value != 0 {
        return ~- Corrupted(TrivErrorCorrupted { message: "v0.7.9.3 expects empty caps table" })
    }
    ~+ ReadResultAbiMetadata {
        value: AbiMetadata {
            abi_version: abi_res.value,
            pkg_name: name_res.value,
            pkg_version: ver_res.value,
            iface_hash: iface_res.value,
            impl_hash: impl_res.value,
        },
        next_pos: c_res.next_pos,
    }
}

public struct ReadResultHash {
    value: Vector<Integer>,
    next_pos: Integer,
}

public function read_hash(data: Vector<Integer>, pos: Integer) -> ReadResultHash~TrivError = {
    if pos + HASH_LEN > length(data) {
        ~- Corrupted(TrivErrorCorrupted { message: "truncated hash" })
    } else {
        let mutable bytes: Vector<Integer> = new()
        let mutable i: Integer = 0
        while i < HASH_LEN {
            bytes = push(bytes, get(data, pos + i)!!)
            i = i + 1
        }
        ~+ ReadResultHash { value: bytes, next_pos: pos + HASH_LEN }
    }
}

// ── Top-level write_khi ──────────────────────────────────────

public function write_khi(meta: AbiMetadata, code_section: Vector<Integer>) -> Vector<Integer> = {
    // Compute canonical hashes BEFORE writing the metadata block —
    // the on-disk iface_hash + impl_hash fields must reflect the
    // final values, not the user-provided sentinels.
    let iface: Vector<Integer> = compute_iface_hash_empty(meta.pkg_name)
    let impl_h: Vector<Integer> = compute_impl_hash(iface, code_section)
    let final_meta: AbiMetadata = AbiMetadata {
        abi_version: meta.abi_version,
        pkg_name: meta.pkg_name,
        pkg_version: meta.pkg_version,
        iface_hash: iface,
        impl_hash: impl_h,
    }
    let meta_payload: Vector<Integer> = write_abi_metadata(new(), final_meta)

    let mutable buf: Vector<Integer> = new()
    buf = push(buf, KHI_MAGIC_T)
    buf = push(buf, KHI_MAGIC_R)
    buf = push(buf, KHI_MAGIC_I)
    buf = push(buf, KHI_MAGIC_P)
    buf = write_u32_le(buf, KHI_PACK_VERSION)
    buf = write_u32_le(buf, 2)  // 2 sections: ABI metadata + IR code
    buf = write_section(buf, KHI_SEC_ABI_METADATA, meta_payload)
    buf = write_section(buf, KHI_SEC_IR_CODE, code_section)
    buf
}

public struct KhiRead {
    metadata: AbiMetadata,
    code_section: Vector<Integer>,
}

public struct ReadSectionsResult {
    metadata: AbiMetadata?,
    code_section: Vector<Integer>,
}

public function read_khi(data: Vector<Integer>) -> KhiRead~TrivError = {
    if length(data) < 12 {
        return ~- Corrupted(TrivErrorCorrupted { message: "file too small" })
    }
    if get(data, 0)!! != KHI_MAGIC_T
        || get(data, 1)!! != KHI_MAGIC_R
        || get(data, 2)!! != KHI_MAGIC_I
        || get(data, 3)!! != KHI_MAGIC_P
    {
        return ~- Corrupted(TrivErrorCorrupted { message: "bad magic (expected trip)" })
    }
    let ver_res: ReadResultInteger = read_u32_le(data, 4) ~? |err| ~- err
    if ver_res.value > KHI_PACK_VERSION {
        return ~- Corrupted(TrivErrorCorrupted { message: "unsupported pack_version" })
    }
    let count_res: ReadResultInteger = read_u32_le(data, ver_res.next_pos) ~? |err| ~- err
    let sec_result: ReadSectionsResult = read_sections(data, count_res.next_pos, count_res.value) ~? |err| ~- err
    match sec_result.metadata {
        ~0 => ~- Corrupted(TrivErrorCorrupted { message: "missing ABI metadata section" }),
        _ => ~+ KhiRead {
            metadata: sec_result.metadata!!,
            code_section: sec_result.code_section,
        },
    }
}

function read_sections(
    data: Vector<Integer>,
    start_pos: Integer,
    count: Integer,
) -> ReadSectionsResult~TrivError = {
    let mutable pos: Integer = start_pos
    let mutable meta: AbiMetadata? = ~0
    let mutable code: Vector<Integer> = new()
    let mutable i: Integer = 0
    while i < count {
        let id_res: ReadResultU8 = read_u8(data, pos) ~? |err| ~- err
        let sec_id: Integer = id_res.value
        let len_res: ReadResultInteger = read_u32_le(data, id_res.next_pos) ~? |err| ~- err
        let sec_len: Integer = len_res.value
        let payload_start: Integer = len_res.next_pos
        let payload_end: Integer = payload_start + sec_len
        if payload_end > length(data) {
            return ~- Corrupted(TrivErrorCorrupted { message: "section runs past EOF" })
        }
        if sec_id == KHI_SEC_ABI_METADATA {
            let abi_res: ReadResultAbiMetadata = read_abi_metadata(data, payload_start) ~? |err| ~- err
            meta = abi_res.value
        } else if sec_id == KHI_SEC_IR_CODE {
            code = slice_bytes(data, payload_start, payload_end)
        }
        // Unknown sections are skipped per ADR-0011 (forward-compat).
        pos = payload_end
        i = i + 1
    }
    ~+ ReadSectionsResult { metadata: meta, code_section: code }
}

function slice_bytes(data: Vector<Integer>, start: Integer, end_idx: Integer) -> Vector<Integer> = {
    let mutable out: Vector<Integer> = new()
    let mutable i: Integer = start
    while i < end_idx {
        out = push(out, get(data, i)!!)
        i = i + 1
    }
    out
}

// ── Source → tripack convenience entry ───────────────────────────

public function serialize_source_to_khi(source: String, pkg_name: String) -> Vector<Integer> = {
    let ir: IrProgram = lower_source(source)
    let code: Vector<Integer> = write_program(ir)
    let meta: AbiMetadata = abi_metadata_empty(pkg_name, semver_zero())
    write_khi(meta, code)
}

// ── Smoke entry — round-trip per v0.7.9.3 acceptance ─────────────
//
// Returns `~+ true` when:
//   1. tripack writes successfully for `function f() -> Integer = 42`,
//   2. read_khi round-trips it,
//   3. pkg_name + abi_version + iface_hash length match,
//   4. extracted code section is non-empty (= the embedded .triv).

public function khi_smoke_main() -> Trilean!~TrivError = {
    let source: String = "function f() -> Integer = 42"
    let pkg_name: String = "compiler"
    let bytes: Vector<Integer> = serialize_source_to_khi(source, pkg_name)
    let parsed: KhiRead = read_khi(bytes) ~? |err| ~- err
    if parsed.metadata.abi_version != KHI_ABI_VERSION {
        return ~- Corrupted(TrivErrorCorrupted { message: "abi_version round-trip mismatch" })
    }
    if parsed.metadata.pkg_name != pkg_name {
        return ~- Corrupted(TrivErrorCorrupted { message: "pkg_name round-trip mismatch" })
    }
    if length(parsed.metadata.iface_hash) != HASH_LEN {
        return ~- Corrupted(TrivErrorCorrupted { message: "iface_hash length mismatch" })
    }
    if length(parsed.metadata.impl_hash) != HASH_LEN {
        return ~- Corrupted(TrivErrorCorrupted { message: "impl_hash length mismatch" })
    }
    if length(parsed.code_section) <= 12 {
        return ~- Corrupted(TrivErrorCorrupted { message: "code section too small (missing triv header)" })
    }
    ~+ true
}
