// `.triv` byte writer + reader, v0.7.9.1 scope: LEB128 primitives +
// TypeTag arena round-trip + ConstantPool round-trip. Instruction
// encoder + function table + full IrProgram writer land in v0.7.9.2.
//
// Wire format per crates/triet-ir/src/serde.rs:
// - LEB128 varints for lengths + indices.
// - i16 / i64 little-endian for Tryte / Integer / Long constants.
// - Type table: varint count + N type tags (post-order; composites
//   reference earlier entries by index).
// - Constant pool: varint count + N (varint type_index + body).
//
// Triết-side gotcha: Vector is functionally pure (per ADR-0019 §5 +
// Addendum §A4 Q1-A). `push(buf, x)` returns a NEW vector — it does
// NOT mutate `buf`. Every `write_X(...)` helper here threads the
// buffer through its return value so callers can chain
// `buf = write_X(buf, ...)`. Rust's `&mut Vec<u8>` idiom doesn't
// translate; Triết's mirror is whole-buffer return.

module parser;
module ir_lowerer;

from std.collections.vector import new, push, length, get
from std.text import into_bytes, from_bytes, concat, len as text_len
from std.string import substring
from std.crypto import blake3_hash
from khi.ir_lowerer import TypeTag, TritTag, TryteTag, IntegerTag, LongTag, TrileanTag, StringTag, UnitTag, NullableTag, VectorTag, HashMapTag, OutcomeTag
from khi.ir_lowerer import TypeTagArena, AllocTagResult, PrimitiveMarker
from khi.ir_lowerer import TypeTagNullablePayload, TypeTagVectorPayload, TypeTagHashMapPayload, TypeTagOutcomePayload
from khi.ir_lowerer import Constant, TritConst, TryteConst, IntegerConst, LongConst, TrileanConst, StringConst, UnitConst, NullConst
from khi.ir_lowerer import ConstantTritPayload, ConstantTrytePayload, ConstantIntegerPayload, ConstantLongPayload, ConstantTrileanPayload, ConstantStringPayload
from khi.ir_lowerer import ConstantPool
from khi.ir_lowerer import type_tag_arena_new, get_type_tag, constant_pool_new, constant_type_tag, alloc_type_tag
from khi.ir_lowerer import alloc_tag_trit, alloc_tag_tryte, alloc_tag_integer, alloc_tag_long, alloc_tag_trilean, alloc_tag_string, alloc_tag_unit, alloc_tag_nullable, alloc_tag_vector, alloc_tag_hashmap, alloc_tag_outcome
from khi.ir_lowerer import ValueId, BlockId, FuncId, ConstId
from khi.ir_lowerer import Operand, ValueOp, ConstOp, PhiIncoming
from khi.ir_lowerer import BuiltinName, PrintlnBuiltin, PrintBuiltin, AssertBuiltin, AssertEqBuiltin, FStringConcatBuiltin, TextLenBuiltin, TextConcatBuiltin, TextFromIntegerBuiltin, VectorNewBuiltin, VectorPushBuiltin, VectorGetBuiltin, VectorLengthBuiltin, HashMapNewBuiltin, HashMapInsertBuiltin, HashMapGetBuiltin, HashMapKeysBuiltin, HashMapContainsBuiltin, ReadFileBuiltin, WriteFileBuiltin, FileExistsBuiltin, PathJoinBuiltin, PathParentBuiltin, PathBasenameBuiltin, StringSubstringBuiltin, StringSplitBuiltin, StringIndexOfBuiltin, ParseIntegerBuiltin, TextIntoBytesBuiltin, TextFromBytesBuiltin, Blake3HashBuiltin, WriteFileBytesBuiltin
from khi.ir_lowerer import Instruction
from khi.ir_lowerer import ConstInst, AddInst, SubInst, MulInst, DivInst, ModInst, PowInst, NegInst
from khi.ir_lowerer import LukAndInst, LukOrInst, LukImpliesInst, LukXorInst, LukIffInst, KleeneImpliesInst, KleeneXorInst, KleeneIffInst
from khi.ir_lowerer import EqInst, NeInst, LtInst, LeInst, GtInst, GeInst
from khi.ir_lowerer import ToIntegerInst, ToTryteInst, ToLongInst, ToTritInst, ToTrileanInst
from khi.ir_lowerer import StructNewInst, FieldGetInst, FieldSetInst
from khi.ir_lowerer import EnumNewInst, EnumTagInst, EnumPayloadInst
from khi.ir_lowerer import NullWrapInst, NullUnwrapInst, NullCheckInst
from khi.ir_lowerer import CallLocalInst, CallCrossModuleInst, WitnessCallInst, CallBuiltinInst
from khi.ir_lowerer import ClosureNewInst, ClosureCallInst
from khi.ir_lowerer import BrInst, BrIfInst, BrTrileanInst, RetInst, UnreachableInst, PhiInst
from khi.ir_lowerer import OutcomeNewPositiveInst, OutcomeNewNegativeInst, OutcomeNewNullInst, OutcomeDiscriminantInst, OutcomeUnwrapValueInst, OutcomeUnwrapErrorInst
from khi.ir_lowerer import InstConstPayload, InstBinaryOpPayload, InstPowPayload, InstUnaryOpPayload
from khi.ir_lowerer import InstStructNewPayload, InstFieldGetPayload, InstFieldSetPayload
from khi.ir_lowerer import InstEnumNewPayload, InstEnumTagPayload, InstEnumPayloadPayload
from khi.ir_lowerer import InstNullWrapPayload, InstNullUnwrapPayload, InstNullCheckPayload
from khi.ir_lowerer import InstCallLocalPayload, InstCallCrossModulePayload, InstWitnessCallPayload, InstCallBuiltinPayload
from khi.ir_lowerer import InstClosureNewPayload, InstClosureCallPayload
from khi.ir_lowerer import InstBrPayload, InstBrIfPayload, InstBrTrileanPayload, InstRetPayload, InstPhiPayload
from khi.ir_lowerer import InstOutcomeUnaryPayload, InstOutcomeCtorPayload, InstOutcomeNewNullPayload
from khi.ir_lowerer import BasicBlock, IrFunctionParam, Function, IrModule, IrProgram, WitnessTable
from khi.ir_lowerer import lower_source

// ── Errors ─────────────────────────────────────────────────────────

public struct TrivErrorCorrupted { message: String }
public struct TrivErrorUnsupportedVersion { found: Integer, max_supported: Integer }
public struct TrivErrorUnknownTypeDiscriminant { disc: Integer }

public enum TrivError {
    Corrupted(TrivErrorCorrupted),
    UnsupportedVersion(TrivErrorUnsupportedVersion),
    UnknownTypeDiscriminant(TrivErrorUnknownTypeDiscriminant),
}

public function primitive_marker() -> PrimitiveMarker =
    PrimitiveMarker { placeholder: 0 }

// ── LEB128 + low-level byte helpers ────────────────────────────────

public function write_leb128(buf: Vector<Integer>, value: Integer) -> Vector<Integer> = {
    // Recursive form: single-byte fast path + tail recursion for
    // multi-byte values. Avoids the `let mutable out` + `loop {}`
    // pattern whose post-loop scope handling appears to drop the
    // latest rebind under v0.7.8.3 lowering (write_u8 was receiving
    // Unit instead of the threaded Vector). Recursion ends cleanly
    // because each level returns a fresh Vector.
    let byte: Integer = value %% 128
    let rest: Integer = value / 128
    if rest == 0 {
        push(buf, byte)
    } else {
        let next: Vector<Integer> = push(buf, byte + 128)
        write_leb128(next, rest)
    }
}

public struct ReadResultInteger {
    value: Integer,
    next_pos: Integer,
}

public function read_leb128(data: Vector<Integer>, pos: Integer) -> ReadResultInteger~TrivError = {
    let mutable result: Integer = 0
    let mutable shift: Integer = 0
    let mutable current_pos: Integer = pos
    let mutable multiplier: Integer = 1
    let mutable continue_loop: Trilean! = true

    // `while` form (not `loop {}`) — the v0.7.8.3b phi-stitching at
    // the while header makes mutable rebinds visible after the loop.
    // Pure `loop {}` skips that path and the lowerer leaves stale
    // pre-loop bindings live at the exit block.
    while continue_loop {
        if current_pos >= length(data) {
            return ~- Corrupted(TrivErrorCorrupted { message: "truncated LEB128" })
        }
        let byte: Integer = get(data, current_pos)!!
        current_pos = current_pos + 1

        let val: Integer = byte %% 128
        result = result + val * multiplier

        if byte < 128 {
            return ~+ ReadResultInteger { value: result, next_pos: current_pos }
        }

        shift = shift + 7
        if shift >= 35 {
            return ~- Corrupted(TrivErrorCorrupted { message: "LEB128 overflow" })
        }
        multiplier = multiplier * 128
    }
    ~- Corrupted(TrivErrorCorrupted { message: "unreachable" })
}

public function write_varint(buf: Vector<Integer>, value: Integer) -> Vector<Integer> =
    write_leb128(buf, value)

public function read_varint(data: Vector<Integer>, pos: Integer) -> ReadResultInteger~TrivError =
    read_leb128(data, pos)

public function write_bytes(buf: Vector<Integer>, bytes: Vector<Integer>) -> Vector<Integer> =
    write_bytes_from(buf, bytes, 0)

function write_bytes_from(buf: Vector<Integer>, bytes: Vector<Integer>, i: Integer) -> Vector<Integer> = {
    if i >= length(bytes) {
        buf
    } else {
        let next: Vector<Integer> = push(buf, get(bytes, i)!!)
        write_bytes_from(next, bytes, i + 1)
    }
}

public function write_u8(buf: Vector<Integer>, value: Integer) -> Vector<Integer> =
    push(buf, value)

public struct ReadResultU8 {
    value: Integer,
    next_pos: Integer,
}

public function read_u8(data: Vector<Integer>, pos: Integer) -> ReadResultU8~TrivError = {
    if pos >= length(data) {
        ~- Corrupted(TrivErrorCorrupted { message: "unexpected EOF" })
    } else {
        let byte: Integer = get(data, pos)!!
        ~+ ReadResultU8 { value: byte, next_pos: pos + 1 }
    }
}

public function write_u32_le(buf: Vector<Integer>, value: Integer) -> Vector<Integer> = {
    let b0: Integer = value %% 256
    let b1: Integer = (value / 256) %% 256
    let b2: Integer = (value / 65536) %% 256
    let b3: Integer = (value / 16777216) %% 256
    let s1: Vector<Integer> = push(buf, b0)
    let s2: Vector<Integer> = push(s1, b1)
    let s3: Vector<Integer> = push(s2, b2)
    push(s3, b3)
}

public function read_u32_le(data: Vector<Integer>, pos: Integer) -> ReadResultInteger~TrivError = {
    if pos + 4 > length(data) {
        ~- Corrupted(TrivErrorCorrupted { message: "unexpected EOF reading u32" })
    } else {
        let b0: Integer = get(data, pos)!!
        let b1: Integer = get(data, pos + 1)!!
        let b2: Integer = get(data, pos + 2)!!
        let b3: Integer = get(data, pos + 3)!!
        let val: Integer = b0 + b1 * 256 + b2 * 65536 + b3 * 16777216
        ~+ ReadResultInteger { value: val, next_pos: pos + 4 }
    }
}

public function write_i16_le(buf: Vector<Integer>, value: Integer) -> Vector<Integer> = {
    let unsigned: Integer = if value < 0 { value + 65536 } else { value }
    let b0: Integer = unsigned %% 256
    let b1: Integer = (unsigned / 256) %% 256
    let s1: Vector<Integer> = push(buf, b0)
    push(s1, b1)
}

public function read_i16_le(data: Vector<Integer>, pos: Integer) -> ReadResultInteger~TrivError = {
    if pos + 2 > length(data) {
        ~- Corrupted(TrivErrorCorrupted { message: "unexpected EOF reading i16" })
    } else {
        let b0: Integer = get(data, pos)!!
        let b1: Integer = get(data, pos + 1)!!
        let val: Integer = b0 + b1 * 256
        let signed: Integer = if val >= 32768 { val - 65536 } else { val }
        ~+ ReadResultInteger { value: signed, next_pos: pos + 2 }
    }
}

public function write_i64_le(buf: Vector<Integer>, value: Integer) -> Vector<Integer> =
    write_i64_le_at(buf, value, 0)

function write_i64_le_at(buf: Vector<Integer>, value: Integer, i: Integer) -> Vector<Integer> = {
    if i >= 8 {
        buf
    } else {
        let byte: Integer = value %% 256
        let normalised: Integer = if byte < 0 { byte + 256 } else { byte }
        let next: Vector<Integer> = push(buf, normalised)
        write_i64_le_at(next, (value - normalised) / 256, i + 1)
    }
}

public function read_i64_le(data: Vector<Integer>, pos: Integer) -> ReadResultInteger~TrivError = {
    if pos + 8 > length(data) {
        ~- Corrupted(TrivErrorCorrupted { message: "unexpected EOF reading i64" })
    } else {
        let b0: Integer = get(data, pos)!!
        let b1: Integer = get(data, pos + 1)!!
        let b2: Integer = get(data, pos + 2)!!
        let b3: Integer = get(data, pos + 3)!!
        let b4: Integer = get(data, pos + 4)!!
        let b5: Integer = get(data, pos + 5)!!
        let b6: Integer = get(data, pos + 6)!!
        let b7: Integer = get(data, pos + 7)!!
        // Triết's Integer caps at 3_812_798_742_493 (3^27 / 2). Values
        // outside ±2^31 can't round-trip into Integer at v0.7.9.1 —
        // bail out. v0.7.9.2 will widen `ReadResult*` to Long when
        // the lowerer can carry both shapes through the type table.
        let high_all_zero: Trilean! = b4 == 0 && b5 == 0 && b6 == 0 && b7 == 0
        let high_all_one: Trilean! = b4 == 255 && b5 == 255 && b6 == 255 && b7 == 255
        if !(high_all_zero || high_all_one) {
            ~- Corrupted(TrivErrorCorrupted { message: "i64 value outside Integer range at v0.7.9.1" })
        } else {
            let low: Integer = b0 + b1 * 256 + b2 * 65536 + b3 * 16777216
            // Sign-extend the 32-bit window. If the high bytes are all
            // 0xFF the original value is negative, so we subtract 2^32.
            let signed: Integer = if high_all_one { low - 4_294_967_295 - 1 } else { low }
            ~+ ReadResultInteger { value: signed, next_pos: pos + 8 }
        }
    }
}

public function write_string(buf: Vector<Integer>, s: String) -> Vector<Integer> = {
    let bytes: Vector<Integer> = into_bytes(s)
    let s1: Vector<Integer> = write_varint(buf, length(bytes))
    write_bytes(s1, bytes)
}

public struct ReadResultString {
    value: String,
    next_pos: Integer,
}

public function read_string(data: Vector<Integer>, pos: Integer) -> ReadResultString~TrivError = {
    let len_res: ReadResultInteger = read_varint(data, pos) ~? |err| ~- err
    let len_val: Integer = len_res.value
    let current_pos: Integer = len_res.next_pos

    if current_pos + len_val > length(data) {
        ~- Corrupted(TrivErrorCorrupted { message: "truncated string" })
    } else {
        let mutable bytes: Vector<Integer> = new()
        let mutable i: Integer = 0
        while i < len_val {
            bytes = push(bytes, get(data, current_pos + i)!!)
            i = i + 1
        }
        let s: String = from_bytes(bytes) ~: ""
        ~+ ReadResultString { value: s, next_pos: current_pos + len_val }
    }
}

// ── TypeTag table ──────────────────────────────────────────────────
//
// Wire format: varint(count) + count × type_tag. Each tag is one
// discriminator byte (0..10) plus inner varint refs for composites
// (Nullable / Vector / HashMap / Outcome). The arena is post-order —
// every composite's inner index points at a strictly earlier slot.

constant TYPE_TAG_TRIT: Integer = 0
constant TYPE_TAG_TRYTE: Integer = 1
constant TYPE_TAG_INTEGER: Integer = 2
constant TYPE_TAG_LONG: Integer = 3
constant TYPE_TAG_TRILEAN: Integer = 4
constant TYPE_TAG_STRING: Integer = 5
constant TYPE_TAG_UNIT: Integer = 6
constant TYPE_TAG_NULLABLE: Integer = 7
constant TYPE_TAG_VECTOR: Integer = 8
constant TYPE_TAG_HASHMAP: Integer = 9
constant TYPE_TAG_OUTCOME: Integer = 10

public function write_type_table(buf: Vector<Integer>, arena: TypeTagArena) -> Vector<Integer> = {
    let header: Vector<Integer> = write_varint(buf, length(arena.tags))
    write_type_tags_from(header, arena.tags, 0)
}

function write_type_tags_from(buf: Vector<Integer>, tags: Vector<TypeTag>, i: Integer) -> Vector<Integer> = {
    if i >= length(tags) {
        buf
    } else {
        let next: Vector<Integer> = write_type_tag(buf, get(tags, i)!!)
        write_type_tags_from(next, tags, i + 1)
    }
}

public function write_type_tag(buf: Vector<Integer>, ty: TypeTag) -> Vector<Integer> = {
    match ty {
        TritTag(_) => write_u8(buf, TYPE_TAG_TRIT),
        TryteTag(_) => write_u8(buf, TYPE_TAG_TRYTE),
        IntegerTag(_) => write_u8(buf, TYPE_TAG_INTEGER),
        LongTag(_) => write_u8(buf, TYPE_TAG_LONG),
        TrileanTag(_) => write_u8(buf, TYPE_TAG_TRILEAN),
        StringTag(_) => write_u8(buf, TYPE_TAG_STRING),
        UnitTag(_) => write_u8(buf, TYPE_TAG_UNIT),
        NullableTag(p) => {
            let s1: Vector<Integer> = write_u8(buf, TYPE_TAG_NULLABLE)
            write_varint(s1, p.inner)
        },
        VectorTag(p) => {
            let s1: Vector<Integer> = write_u8(buf, TYPE_TAG_VECTOR)
            write_varint(s1, p.inner)
        },
        HashMapTag(p) => {
            let s1: Vector<Integer> = write_u8(buf, TYPE_TAG_HASHMAP)
            let s2: Vector<Integer> = write_varint(s1, p.key)
            write_varint(s2, p.value)
        },
        OutcomeTag(p) => {
            let s1: Vector<Integer> = write_u8(buf, TYPE_TAG_OUTCOME)
            let null_byte: Integer = if p.allow_null_state { 1 } else { 0 }
            let s2: Vector<Integer> = write_u8(s1, null_byte)
            let s3: Vector<Integer> = write_varint(s2, p.value_type)
            write_varint(s3, p.error_type)
        },
    }
}

public struct ReadResultArena {
    value: TypeTagArena,
    next_pos: Integer,
}

public function read_type_table(data: Vector<Integer>, pos: Integer) -> ReadResultArena~TrivError = {
    let count_res: ReadResultInteger = read_varint(data, pos) ~? |err| ~- err
    let count: Integer = count_res.value
    let mutable p: Integer = count_res.next_pos
    let mutable tags: Vector<TypeTag> = new()
    let mutable i: Integer = 0
    while i < count {
        let t_res: ReadResultTypeTag = read_type_tag(data, p) ~? |err| ~- err
        tags = push(tags, t_res.value)
        p = t_res.next_pos
        i = i + 1
    }
    ~+ ReadResultArena { value: TypeTagArena { tags: tags }, next_pos: p }
}

public struct ReadResultTypeTag {
    value: TypeTag,
    next_pos: Integer,
}

public function read_type_tag(data: Vector<Integer>, pos: Integer) -> ReadResultTypeTag~TrivError = {
    let disc_res: ReadResultU8 = read_u8(data, pos) ~? |err| ~- err
    let disc: Integer = disc_res.value
    let p: Integer = disc_res.next_pos
    if disc == TYPE_TAG_TRIT {
        ~+ ReadResultTypeTag { value: TritTag(primitive_marker()), next_pos: p }
    } else if disc == TYPE_TAG_TRYTE {
        ~+ ReadResultTypeTag { value: TryteTag(primitive_marker()), next_pos: p }
    } else if disc == TYPE_TAG_INTEGER {
        ~+ ReadResultTypeTag { value: IntegerTag(primitive_marker()), next_pos: p }
    } else if disc == TYPE_TAG_LONG {
        ~+ ReadResultTypeTag { value: LongTag(primitive_marker()), next_pos: p }
    } else if disc == TYPE_TAG_TRILEAN {
        ~+ ReadResultTypeTag { value: TrileanTag(primitive_marker()), next_pos: p }
    } else if disc == TYPE_TAG_STRING {
        ~+ ReadResultTypeTag { value: StringTag(primitive_marker()), next_pos: p }
    } else if disc == TYPE_TAG_UNIT {
        ~+ ReadResultTypeTag { value: UnitTag(primitive_marker()), next_pos: p }
    } else if disc == TYPE_TAG_NULLABLE {
        let inner_res: ReadResultInteger = read_varint(data, p) ~? |err| ~- err
        ~+ ReadResultTypeTag {
            value: NullableTag(TypeTagNullablePayload { inner: inner_res.value }),
            next_pos: inner_res.next_pos,
        }
    } else if disc == TYPE_TAG_VECTOR {
        let inner_res: ReadResultInteger = read_varint(data, p) ~? |err| ~- err
        ~+ ReadResultTypeTag {
            value: VectorTag(TypeTagVectorPayload { inner: inner_res.value }),
            next_pos: inner_res.next_pos,
        }
    } else if disc == TYPE_TAG_HASHMAP {
        let key_res: ReadResultInteger = read_varint(data, p) ~? |err| ~- err
        let val_res: ReadResultInteger = read_varint(data, key_res.next_pos) ~? |err| ~- err
        ~+ ReadResultTypeTag {
            value: HashMapTag(TypeTagHashMapPayload {
                key: key_res.value,
                value: val_res.value,
            }),
            next_pos: val_res.next_pos,
        }
    } else if disc == TYPE_TAG_OUTCOME {
        let null_res: ReadResultU8 = read_u8(data, p) ~? |err| ~- err
        let val_res: ReadResultInteger = read_varint(data, null_res.next_pos) ~? |err| ~- err
        let err_res: ReadResultInteger = read_varint(data, val_res.next_pos) ~? |err| ~- err
        let allow_null: Trilean! = null_res.value != 0
        ~+ ReadResultTypeTag {
            value: OutcomeTag(TypeTagOutcomePayload {
                value_type: val_res.value,
                error_type: err_res.value,
                allow_null_state: allow_null,
            }),
            next_pos: err_res.next_pos,
        }
    } else {
        ~- UnknownTypeDiscriminant(TrivErrorUnknownTypeDiscriminant { disc: disc })
    }
}

// ── Constant pool ──────────────────────────────────────────────────
//
// Wire format: varint(count) + count × constant. Each constant emits
// a varint type-index into the type table, then variant-specific body
// bytes. Mirrors `triet_ir::serde::write_constants`.
//
// Trit encoding (per ADR-0010): 0 → Negative, 1 → Zero, 2 → Positive.
// Trilean encoding: 0 → False, 1 → Unknown, 2 → True.

constant TRIT_BYTE_NEGATIVE: Integer = 0
constant TRIT_BYTE_ZERO: Integer = 1
constant TRIT_BYTE_POSITIVE: Integer = 2

constant TRILEAN_BYTE_FALSE: Integer = 0
constant TRILEAN_BYTE_UNKNOWN: Integer = 1
constant TRILEAN_BYTE_TRUE: Integer = 2

// Trit / Trilean value extraction via `if?` chains. `Trit == Trit`
// + `Trilean == Trilean` return generic `Trilean` per ADR-0021
// (Unknown propagates), but for concrete Trit values the Unknown
// branch is never taken at runtime. `if?` treats Unknown as false,
// which is safe here — the final `else` arm acts as the default.

function trit_to_byte(t: Trit) -> Integer = {
    if? t == -1_trit { TRIT_BYTE_NEGATIVE }
    else if? t == 0_trit { TRIT_BYTE_ZERO }
    else { TRIT_BYTE_POSITIVE }
}

function byte_to_trit(b: Integer) -> Trit = {
    if b == TRIT_BYTE_NEGATIVE { -1_trit }
    else if b == TRIT_BYTE_ZERO { 0_trit }
    else { 1_trit }
}

function trilean_to_byte(tl: Trilean) -> Integer = {
    if? tl == false { TRILEAN_BYTE_FALSE }
    else if? tl == unknown { TRILEAN_BYTE_UNKNOWN }
    else { TRILEAN_BYTE_TRUE }
}

function byte_to_trilean(b: Integer) -> Trilean = {
    if b == TRILEAN_BYTE_FALSE { false }
    else if b == TRILEAN_BYTE_UNKNOWN { unknown }
    else { true }
}

public function write_constant(buf: Vector<Integer>, c: Constant, type_idx: Integer) -> Vector<Integer> = {
    let s1: Vector<Integer> = write_varint(buf, type_idx)
    match c {
        TritConst(p) => write_u8(s1, trit_to_byte(p.value)),
        TryteConst(p) => write_i16_le(s1, p.value.to_integer()),
        IntegerConst(p) => write_i64_le(s1, p.value),
        LongConst(p) => write_i64_le(s1, p.value.to_integer()),
        TrileanConst(p) => write_u8(s1, trilean_to_byte(p.value)),
        StringConst(p) => write_string(s1, p.value),
        UnitConst(_) => s1,
        NullConst(_) => s1,
    }
}

public struct ConstantPoolWriteResult {
    buf: Vector<Integer>,
    arena: TypeTagArena,
}

/// Write the constant pool while populating the type-table arena with
/// each constant's declared type. Returns both the updated buffer and
/// the updated arena so the caller can serialize the type table
/// afterwards (the type table must include every constant's tag for
/// the reader to decode).
public function write_constants(
    buf: Vector<Integer>,
    pool: ConstantPool,
    arena: TypeTagArena,
) -> ConstantPoolWriteResult = {
    let header: Vector<Integer> = write_varint(buf, length(pool.entries))
    write_constants_from(header, pool.entries, arena, 0)
}

function write_constants_from(
    buf: Vector<Integer>,
    entries: Vector<Constant>,
    arena: TypeTagArena,
    i: Integer,
) -> ConstantPoolWriteResult = {
    if i >= length(entries) {
        ConstantPoolWriteResult { buf: buf, arena: arena }
    } else {
        let c: Constant = get(entries, i)!!
        let alloc: AllocTagResult = constant_type_tag(arena, c)
        let next: Vector<Integer> = write_constant(buf, c, alloc.tag_id)
        write_constants_from(next, entries, alloc.arena, i + 1)
    }
}

public struct ReadResultConstant {
    value: Constant,
    next_pos: Integer,
}

public function read_constant(
    data: Vector<Integer>,
    pos: Integer,
    arena: TypeTagArena,
) -> ReadResultConstant~TrivError = {
    let idx_res: ReadResultInteger = read_varint(data, pos) ~? |err| ~- err
    let type_idx: Integer = idx_res.value
    let p: Integer = idx_res.next_pos
    let tag_opt: TypeTag? = get_type_tag(arena, type_idx)
    // Outer match dispatches on null-vs-present so the function's
    // Outcome return type unifies cleanly. `return ~- ...` inside a
    // pattern arm makes Triết's typechecker mis-infer the arm as Unit
    // (it has no Never type), which trips E1013 against the rest of
    // the match; the outer-match shape avoids the mixed-type arm.
    match tag_opt {
        ~0 => ~- Corrupted(TrivErrorCorrupted { message: "invalid type index in constant" }),
        _ => read_constant_for_tag(data, p, tag_opt!!),
    }
}

function read_constant_for_tag(
    data: Vector<Integer>,
    p: Integer,
    tag: TypeTag,
) -> ReadResultConstant~TrivError = {
    match tag {
        TritTag(_) => {
            let b_res: ReadResultU8 = read_u8(data, p) ~? |err| ~- err
            ~+ ReadResultConstant {
                value: TritConst(ConstantTritPayload { value: byte_to_trit(b_res.value) }),
                next_pos: b_res.next_pos,
            }
        },
        TryteTag(_) => {
            let v_res: ReadResultInteger = read_i16_le(data, p) ~? |err| ~- err
            ~+ ReadResultConstant {
                value: TryteConst(ConstantTrytePayload { value: v_res.value.to_tryte() }),
                next_pos: v_res.next_pos,
            }
        },
        IntegerTag(_) => {
            let v_res: ReadResultInteger = read_i64_le(data, p) ~? |err| ~- err
            ~+ ReadResultConstant {
                value: IntegerConst(ConstantIntegerPayload { value: v_res.value }),
                next_pos: v_res.next_pos,
            }
        },
        LongTag(_) => {
            let v_res: ReadResultInteger = read_i64_le(data, p) ~? |err| ~- err
            ~+ ReadResultConstant {
                value: LongConst(ConstantLongPayload { value: v_res.value.to_long() }),
                next_pos: v_res.next_pos,
            }
        },
        TrileanTag(_) => {
            let b_res: ReadResultU8 = read_u8(data, p) ~? |err| ~- err
            ~+ ReadResultConstant {
                value: TrileanConst(ConstantTrileanPayload { value: byte_to_trilean(b_res.value) }),
                next_pos: b_res.next_pos,
            }
        },
        StringTag(_) => {
            let s_res: ReadResultString = read_string(data, p) ~? |err| ~- err
            ~+ ReadResultConstant {
                value: StringConst(ConstantStringPayload { value: s_res.value }),
                next_pos: s_res.next_pos,
            }
        },
        UnitTag(_) => ~+ ReadResultConstant {
            value: UnitConst(primitive_marker()),
            next_pos: p,
        },
        NullableTag(_) => ~+ ReadResultConstant {
            value: NullConst(primitive_marker()),
            next_pos: p,
        },
        _ => ~- Corrupted(TrivErrorCorrupted { message: "Vector/HashMap/Outcome have no constant-pool encoding" }),
    }
}

public struct ReadResultConstantPool {
    value: ConstantPool,
    next_pos: Integer,
}

public function read_constants(
    data: Vector<Integer>,
    pos: Integer,
    arena: TypeTagArena,
) -> ReadResultConstantPool~TrivError = {
    let count_res: ReadResultInteger = read_varint(data, pos) ~? |err| ~- err
    let count: Integer = count_res.value
    let mutable p: Integer = count_res.next_pos
    let mutable entries: Vector<Constant> = new()
    let mutable i: Integer = 0
    while i < count {
        let c_res: ReadResultConstant = read_constant(data, p, arena) ~? |err| ~- err
        entries = push(entries, c_res.value)
        p = c_res.next_pos
        i = i + 1
    }
    ~+ ReadResultConstantPool { value: ConstantPool { entries: entries }, next_pos: p }
}

// ═════════════════════════════════════════════════════════════════
// v0.7.9.2 — Instruction + Function + Code + Program encoders
//
// Wire format byte layout mirrors crates/triet-ir/src/serde.rs.
// Opcode constants per [ADR-0008] (4-bit category prefix + sequence
// within category).
// ═════════════════════════════════════════════════════════════════

// ── Opcode table ─────────────────────────────────────────────────

constant OPCODE_CONST: Integer = 0
constant OPCODE_ADD: Integer = 16
constant OPCODE_SUB: Integer = 17
constant OPCODE_MUL: Integer = 18
constant OPCODE_DIV: Integer = 19
constant OPCODE_MOD: Integer = 20
constant OPCODE_POW: Integer = 21
constant OPCODE_NEG: Integer = 22
constant OPCODE_LUK_AND: Integer = 32
constant OPCODE_LUK_OR: Integer = 33
constant OPCODE_LUK_IMPLIES: Integer = 34
constant OPCODE_LUK_XOR: Integer = 35
constant OPCODE_LUK_IFF: Integer = 36
constant OPCODE_KLEENE_IMPLIES: Integer = 48
constant OPCODE_KLEENE_XOR: Integer = 49
constant OPCODE_KLEENE_IFF: Integer = 50
constant OPCODE_EQ: Integer = 64
constant OPCODE_NE: Integer = 65
constant OPCODE_LT: Integer = 66
constant OPCODE_LE: Integer = 67
constant OPCODE_GT: Integer = 68
constant OPCODE_GE: Integer = 69
constant OPCODE_TO_INTEGER: Integer = 80
constant OPCODE_TO_TRYTE: Integer = 81
constant OPCODE_TO_LONG: Integer = 82
constant OPCODE_TO_TRIT: Integer = 83
constant OPCODE_TO_TRILEAN: Integer = 84
constant OPCODE_STRUCT_NEW: Integer = 96
constant OPCODE_FIELD_GET: Integer = 97
constant OPCODE_FIELD_SET: Integer = 98
constant OPCODE_ENUM_NEW: Integer = 112
constant OPCODE_ENUM_TAG: Integer = 113
constant OPCODE_ENUM_PAYLOAD: Integer = 114
constant OPCODE_NULL_WRAP: Integer = 128
constant OPCODE_NULL_UNWRAP: Integer = 129
constant OPCODE_NULL_CHECK: Integer = 130
constant OPCODE_CALL_LOCAL: Integer = 144
constant OPCODE_CALL_CROSS_MODULE: Integer = 145
constant OPCODE_CALL_BUILTIN: Integer = 146
constant OPCODE_WITNESS_CALL: Integer = 147
constant OPCODE_CLOSURE_NEW: Integer = 160
constant OPCODE_CLOSURE_CALL: Integer = 161
constant OPCODE_BR: Integer = 176
constant OPCODE_BR_IF: Integer = 177
constant OPCODE_RET: Integer = 178
constant OPCODE_UNREACHABLE: Integer = 179
constant OPCODE_BR_TRILEAN: Integer = 180
constant OPCODE_PHI: Integer = 192
constant OPCODE_OUTCOME_NEW_POSITIVE: Integer = 193
constant OPCODE_OUTCOME_NEW_NEGATIVE: Integer = 194
constant OPCODE_OUTCOME_NEW_NULL: Integer = 195
constant OPCODE_OUTCOME_DISCRIMINANT: Integer = 196
constant OPCODE_OUTCOME_UNWRAP_VALUE: Integer = 197
constant OPCODE_OUTCOME_UNWRAP_ERROR: Integer = 198

constant OPERAND_CONST: Integer = 0
constant OPERAND_VALUE: Integer = 1

// ── Section IDs + magic + version ────────────────────────────────

constant SEC_TYPES: Integer = 1
constant SEC_CONSTANTS: Integer = 2
constant SEC_FUNCTIONS: Integer = 3
constant SEC_CODE: Integer = 4
constant SEC_WITNESS_TABLES: Integer = 5

constant TRIV_VERSION: Integer = 5
constant TRIV_MAGIC_T: Integer = 116
constant TRIV_MAGIC_R: Integer = 114
constant TRIV_MAGIC_I: Integer = 105
constant TRIV_MAGIC_V: Integer = 118

// ── Builtin ID encoding ──────────────────────────────────────────
//
// Mirrors `crates/triet-ir/src/serde.rs::write_builtin`. IDs 0–29
// shipped through v0.7.9.1 (Blake3Hash latest); future additions
// extend additively per ADR-0019 Addendum §A1 (no `.triv` version
// bump since the CallBuiltin opcode byte is unchanged).

public function builtin_to_byte(b: BuiltinName) -> Integer =
    match b {
        PrintlnBuiltin(_) => 0,
        PrintBuiltin(_) => 1,
        AssertBuiltin(_) => 2,
        AssertEqBuiltin(_) => 3,
        FStringConcatBuiltin(_) => 4,
        TextLenBuiltin(_) => 5,
        TextConcatBuiltin(_) => 6,
        TextFromIntegerBuiltin(_) => 7,
        VectorNewBuiltin(_) => 8,
        VectorPushBuiltin(_) => 9,
        VectorGetBuiltin(_) => 10,
        VectorLengthBuiltin(_) => 11,
        HashMapNewBuiltin(_) => 12,
        HashMapInsertBuiltin(_) => 13,
        HashMapGetBuiltin(_) => 14,
        HashMapKeysBuiltin(_) => 15,
        HashMapContainsBuiltin(_) => 16,
        ReadFileBuiltin(_) => 17,
        WriteFileBuiltin(_) => 18,
        FileExistsBuiltin(_) => 19,
        PathJoinBuiltin(_) => 20,
        PathParentBuiltin(_) => 21,
        PathBasenameBuiltin(_) => 22,
        StringSubstringBuiltin(_) => 23,
        StringSplitBuiltin(_) => 24,
        StringIndexOfBuiltin(_) => 25,
        ParseIntegerBuiltin(_) => 26,
        TextIntoBytesBuiltin(_) => 27,
        TextFromBytesBuiltin(_) => 28,
        Blake3HashBuiltin(_) => 29,
        WriteFileBytesBuiltin(_) => 30,
        EnvGetBuiltin(_) => 31,
    }

public function byte_to_builtin(b: Integer) -> BuiltinName~TrivError = {
    if b == 0 { ~+ PrintlnBuiltin(primitive_marker()) }
    else if b == 1 { ~+ PrintBuiltin(primitive_marker()) }
    else if b == 2 { ~+ AssertBuiltin(primitive_marker()) }
    else if b == 3 { ~+ AssertEqBuiltin(primitive_marker()) }
    else if b == 4 { ~+ FStringConcatBuiltin(primitive_marker()) }
    else if b == 5 { ~+ TextLenBuiltin(primitive_marker()) }
    else if b == 6 { ~+ TextConcatBuiltin(primitive_marker()) }
    else if b == 7 { ~+ TextFromIntegerBuiltin(primitive_marker()) }
    else if b == 8 { ~+ VectorNewBuiltin(primitive_marker()) }
    else if b == 9 { ~+ VectorPushBuiltin(primitive_marker()) }
    else if b == 10 { ~+ VectorGetBuiltin(primitive_marker()) }
    else if b == 11 { ~+ VectorLengthBuiltin(primitive_marker()) }
    else if b == 12 { ~+ HashMapNewBuiltin(primitive_marker()) }
    else if b == 13 { ~+ HashMapInsertBuiltin(primitive_marker()) }
    else if b == 14 { ~+ HashMapGetBuiltin(primitive_marker()) }
    else if b == 15 { ~+ HashMapKeysBuiltin(primitive_marker()) }
    else if b == 16 { ~+ HashMapContainsBuiltin(primitive_marker()) }
    else if b == 17 { ~+ ReadFileBuiltin(primitive_marker()) }
    else if b == 18 { ~+ WriteFileBuiltin(primitive_marker()) }
    else if b == 19 { ~+ FileExistsBuiltin(primitive_marker()) }
    else if b == 20 { ~+ PathJoinBuiltin(primitive_marker()) }
    else if b == 21 { ~+ PathParentBuiltin(primitive_marker()) }
    else if b == 22 { ~+ PathBasenameBuiltin(primitive_marker()) }
    else if b == 23 { ~+ StringSubstringBuiltin(primitive_marker()) }
    else if b == 24 { ~+ StringSplitBuiltin(primitive_marker()) }
    else if b == 25 { ~+ StringIndexOfBuiltin(primitive_marker()) }
    else if b == 26 { ~+ ParseIntegerBuiltin(primitive_marker()) }
    else if b == 27 { ~+ TextIntoBytesBuiltin(primitive_marker()) }
    else if b == 28 { ~+ TextFromBytesBuiltin(primitive_marker()) }
    else if b == 29 { ~+ Blake3HashBuiltin(primitive_marker()) }
    else if b == 30 { ~+ WriteFileBytesBuiltin(primitive_marker()) }
    else if b == 31 { ~+ EnvGetBuiltin(primitive_marker()) }
    else { ~- Corrupted(TrivErrorCorrupted { message: "unknown builtin id" }) }
}

public function write_builtin(buf: Vector<Integer>, b: BuiltinName) -> Vector<Integer> =
    write_u8(buf, builtin_to_byte(b))

public struct ReadResultBuiltin {
    value: BuiltinName,
    next_pos: Integer,
}

public function read_builtin(data: Vector<Integer>, pos: Integer) -> ReadResultBuiltin~TrivError = {
    let b_res: ReadResultU8 = read_u8(data, pos) ~? |err| ~- err
    let name: BuiltinName = byte_to_builtin(b_res.value) ~? |err| ~- err
    ~+ ReadResultBuiltin { value: name, next_pos: b_res.next_pos }
}

// ── Operand encoding ─────────────────────────────────────────────

public function write_operand(buf: Vector<Integer>, op: Operand) -> Vector<Integer> =
    match op {
        ConstOp(c) => {
            let s1: Vector<Integer> = write_u8(buf, OPERAND_CONST)
            write_varint(s1, c.raw)
        },
        ValueOp(v) => {
            let s1: Vector<Integer> = write_u8(buf, OPERAND_VALUE)
            write_varint(s1, v.raw)
        },
    }

public struct ReadResultOperand {
    value: Operand,
    next_pos: Integer,
}

public function read_operand(data: Vector<Integer>, pos: Integer) -> ReadResultOperand~TrivError = {
    let tag_res: ReadResultU8 = read_u8(data, pos) ~? |err| ~- err
    let tag: Integer = tag_res.value
    let p: Integer = tag_res.next_pos
    if tag == OPERAND_CONST {
        let id_res: ReadResultInteger = read_varint(data, p) ~? |err| ~- err
        ~+ ReadResultOperand {
            value: ConstOp(ConstId { raw: id_res.value }),
            next_pos: id_res.next_pos,
        }
    } else if tag == OPERAND_VALUE {
        let id_res: ReadResultInteger = read_varint(data, p) ~? |err| ~- err
        ~+ ReadResultOperand {
            value: ValueOp(ValueId { raw: id_res.value }),
            next_pos: id_res.next_pos,
        }
    } else {
        ~- Corrupted(TrivErrorCorrupted { message: "unknown operand tag" })
    }
}

// ── Optional ValueId (for call dest) ─────────────────────────────

public function write_option_value(buf: Vector<Integer>, dest: ValueId?) -> Vector<Integer> =
    match dest {
        ~0 => write_u8(buf, 0),
        _ => {
            let s1: Vector<Integer> = write_u8(buf, 1)
            write_varint(s1, dest!!.raw)
        },
    }

public struct ReadResultOptionValue {
    value: ValueId?,
    next_pos: Integer,
}

public function read_option_value(data: Vector<Integer>, pos: Integer) -> ReadResultOptionValue~TrivError = {
    let has_res: ReadResultU8 = read_u8(data, pos) ~? |err| ~- err
    let has: Integer = has_res.value
    let p: Integer = has_res.next_pos
    if has == 0 {
        ~+ ReadResultOptionValue { value: ~0, next_pos: p }
    } else if has == 1 {
        let id_res: ReadResultInteger = read_varint(data, p) ~? |err| ~- err
        ~+ ReadResultOptionValue {
            value: ValueId { raw: id_res.value },
            next_pos: id_res.next_pos,
        }
    } else {
        ~- Corrupted(TrivErrorCorrupted { message: "invalid option value byte" })
    }
}

// ── Optional Operand (for Ret value, EnumNew payload) ────────────

public function write_option_operand(buf: Vector<Integer>, op: Operand?) -> Vector<Integer> =
    match op {
        ~0 => write_u8(buf, 0),
        _ => {
            let s1: Vector<Integer> = write_u8(buf, 1)
            write_operand(s1, op!!)
        },
    }

public struct ReadResultOptionOperand {
    value: Operand?,
    next_pos: Integer,
}

public function read_option_operand(data: Vector<Integer>, pos: Integer) -> ReadResultOptionOperand~TrivError = {
    let has_res: ReadResultU8 = read_u8(data, pos) ~? |err| ~- err
    let has: Integer = has_res.value
    let p: Integer = has_res.next_pos
    if has == 0 {
        ~+ ReadResultOptionOperand { value: ~0, next_pos: p }
    } else if has == 1 {
        let op_res: ReadResultOperand = read_operand(data, p) ~? |err| ~- err
        ~+ ReadResultOptionOperand {
            value: op_res.value,
            next_pos: op_res.next_pos,
        }
    } else {
        ~- Corrupted(TrivErrorCorrupted { message: "invalid option operand byte" })
    }
}

// ── Vector<Operand> + Vector<ValueId> serialization ──────────────

public function write_operand_list(buf: Vector<Integer>, ops: Vector<Operand>) -> Vector<Integer> = {
    let header: Vector<Integer> = write_varint(buf, length(ops))
    write_operand_list_from(header, ops, 0)
}

function write_operand_list_from(buf: Vector<Integer>, ops: Vector<Operand>, i: Integer) -> Vector<Integer> = {
    if i >= length(ops) {
        buf
    } else {
        let next: Vector<Integer> = write_operand(buf, get(ops, i)!!)
        write_operand_list_from(next, ops, i + 1)
    }
}

public struct ReadResultOperandList {
    value: Vector<Operand>,
    next_pos: Integer,
}

public function read_operand_list(data: Vector<Integer>, pos: Integer) -> ReadResultOperandList~TrivError = {
    let count_res: ReadResultInteger = read_varint(data, pos) ~? |err| ~- err
    let count: Integer = count_res.value
    let mutable p: Integer = count_res.next_pos
    let mutable ops: Vector<Operand> = new()
    let mutable i: Integer = 0
    while i < count {
        let op_res: ReadResultOperand = read_operand(data, p) ~? |err| ~- err
        ops = push(ops, op_res.value)
        p = op_res.next_pos
        i = i + 1
    }
    ~+ ReadResultOperandList { value: ops, next_pos: p }
}

public function write_value_id_list(buf: Vector<Integer>, ids: Vector<ValueId>) -> Vector<Integer> = {
    let header: Vector<Integer> = write_varint(buf, length(ids))
    write_value_id_list_from(header, ids, 0)
}

function write_value_id_list_from(buf: Vector<Integer>, ids: Vector<ValueId>, i: Integer) -> Vector<Integer> = {
    if i >= length(ids) {
        buf
    } else {
        let id: ValueId = get(ids, i)!!
        let next: Vector<Integer> = write_varint(buf, id.raw)
        write_value_id_list_from(next, ids, i + 1)
    }
}

public struct ReadResultValueIdList {
    value: Vector<ValueId>,
    next_pos: Integer,
}

public function read_value_id_list(data: Vector<Integer>, pos: Integer) -> ReadResultValueIdList~TrivError = {
    let count_res: ReadResultInteger = read_varint(data, pos) ~? |err| ~- err
    let count: Integer = count_res.value
    let mutable p: Integer = count_res.next_pos
    let mutable ids: Vector<ValueId> = new()
    let mutable i: Integer = 0
    while i < count {
        let id_res: ReadResultInteger = read_varint(data, p) ~? |err| ~- err
        ids = push(ids, ValueId { raw: id_res.value })
        p = id_res.next_pos
        i = i + 1
    }
    ~+ ReadResultValueIdList { value: ids, next_pos: p }
}

// ── PhiIncoming list ─────────────────────────────────────────────

public function write_phi_incoming_list(buf: Vector<Integer>, incs: Vector<PhiIncoming>) -> Vector<Integer> = {
    let header: Vector<Integer> = write_varint(buf, length(incs))
    write_phi_incoming_list_from(header, incs, 0)
}

function write_phi_incoming_list_from(buf: Vector<Integer>, incs: Vector<PhiIncoming>, i: Integer) -> Vector<Integer> = {
    if i >= length(incs) {
        buf
    } else {
        let inc: PhiIncoming = get(incs, i)!!
        let s1: Vector<Integer> = write_varint(buf, inc.value.raw)
        let s2: Vector<Integer> = write_varint(s1, inc.block.raw)
        write_phi_incoming_list_from(s2, incs, i + 1)
    }
}

public struct ReadResultPhiIncomingList {
    value: Vector<PhiIncoming>,
    next_pos: Integer,
}

public function read_phi_incoming_list(data: Vector<Integer>, pos: Integer) -> ReadResultPhiIncomingList~TrivError = {
    let count_res: ReadResultInteger = read_varint(data, pos) ~? |err| ~- err
    let count: Integer = count_res.value
    let mutable p: Integer = count_res.next_pos
    let mutable incs: Vector<PhiIncoming> = new()
    let mutable i: Integer = 0
    while i < count {
        let v_res: ReadResultInteger = read_varint(data, p) ~? |err| ~- err
        let b_res: ReadResultInteger = read_varint(data, v_res.next_pos) ~? |err| ~- err
        incs = push(incs, PhiIncoming {
            value: ValueId { raw: v_res.value },
            block: BlockId { raw: b_res.value },
        })
        p = b_res.next_pos
        i = i + 1
    }
    ~+ ReadResultPhiIncomingList { value: incs, next_pos: p }
}

// ── Absolute-path (cross-module call) encoding ───────────────────
//
// Rust serde encodes `AbsolutePath` via `to_string()` which produces
// `<crate>.<seg1>.<seg2>...::<name>`. The Triết-side IR stores the
// path as `Vector<String>` where the LAST segment is the name and
// the preceding ones are the module path. Mirror Rust's `Display`:
// dot-separated module segments, then `::`, then the name.

public function absolute_path_to_string(segments: Vector<String>) -> String = {
    let total: Integer = length(segments)
    if total == 0 {
        ""
    } else {
        let name: String = get(segments, total - 1)!!
        let mutable mod_str: String = ""
        let mutable i: Integer = 0
        while i < total - 1 {
            if i > 0 {
                mod_str = concat(mod_str, ".")
            }
            mod_str = concat(mod_str, get(segments, i)!!)
            i = i + 1
        }
        if total == 1 {
            concat("::", name)
        } else {
            concat(concat(mod_str, "::"), name)
        }
    }
}

/// Parse a Rust-format AbsolutePath ("a.b.c::name") back to the
/// segments + name shape the Triết IR uses (`Vector<String>` with
/// name as last entry). The `::` separator marks the name boundary.
public function string_to_absolute_path(s: String) -> Vector<String> = {
    let sep_idx: Integer? = find_double_colon(s, 0)
    let mutable segments: Vector<String> = new()
    match sep_idx {
        ~0 => {
            // No `::` — treat the whole string as a single name.
            push(segments, s)
        },
        _ => {
            let idx: Integer = sep_idx!!
            let mod_str: String = substring(s, 0, idx)
            let name: String = substring(s, idx + 2, text_len(s))
            // Split mod_str on '.'
            let mod_segments: Vector<String> = split_on_dot(mod_str)
            let mutable j: Integer = 0
            while j < length(mod_segments) {
                segments = push(segments, get(mod_segments, j)!!)
                j = j + 1
            }
            push(segments, name)
        },
    }
}

// Helpers — text_len / substring / split provided by std.
// (Triết-side has no `String::find` etc.; loop over chars.)

function find_double_colon(s: String, start: Integer) -> Integer? = {
    let total: Integer = text_len(s)
    let mutable i: Integer = start
    let mutable result: Integer? = ~0
    let mutable found: Trilean! = false
    while i + 1 < total && !found {
        let pair: String = substring(s, i, i + 2)
        if pair == "::" {
            result = i
            found = true
        }
        i = i + 1
    }
    result
}

function split_on_dot(s: String) -> Vector<String> = {
    let total: Integer = text_len(s)
    let mutable segments: Vector<String> = new()
    let mutable start: Integer = 0
    let mutable i: Integer = 0
    while i < total {
        let ch: String = substring(s, i, i + 1)
        if ch == "." {
            segments = push(segments, substring(s, start, i))
            start = i + 1
        }
        i = i + 1
    }
    if start <= total {
        segments = push(segments, substring(s, start, total))
    }
    segments
}

// ── Instruction encoder ──────────────────────────────────────────

public function write_instruction(buf: Vector<Integer>, instr: Instruction) -> Vector<Integer> = {
    match instr {
        ConstInst(p) => write_inst_const(buf, p),
        AddInst(p) => write_binary_inst(buf, OPCODE_ADD, p),
        SubInst(p) => write_binary_inst(buf, OPCODE_SUB, p),
        MulInst(p) => write_binary_inst(buf, OPCODE_MUL, p),
        DivInst(p) => write_binary_inst(buf, OPCODE_DIV, p),
        ModInst(p) => write_binary_inst(buf, OPCODE_MOD, p),
        PowInst(p) => write_inst_pow(buf, p),
        NegInst(p) => write_unary_inst(buf, OPCODE_NEG, p),
        LukAndInst(p) => write_binary_inst(buf, OPCODE_LUK_AND, p),
        LukOrInst(p) => write_binary_inst(buf, OPCODE_LUK_OR, p),
        LukImpliesInst(p) => write_binary_inst(buf, OPCODE_LUK_IMPLIES, p),
        LukXorInst(p) => write_binary_inst(buf, OPCODE_LUK_XOR, p),
        LukIffInst(p) => write_binary_inst(buf, OPCODE_LUK_IFF, p),
        KleeneImpliesInst(p) => write_binary_inst(buf, OPCODE_KLEENE_IMPLIES, p),
        KleeneXorInst(p) => write_binary_inst(buf, OPCODE_KLEENE_XOR, p),
        KleeneIffInst(p) => write_binary_inst(buf, OPCODE_KLEENE_IFF, p),
        EqInst(p) => write_binary_inst(buf, OPCODE_EQ, p),
        NeInst(p) => write_binary_inst(buf, OPCODE_NE, p),
        LtInst(p) => write_binary_inst(buf, OPCODE_LT, p),
        LeInst(p) => write_binary_inst(buf, OPCODE_LE, p),
        GtInst(p) => write_binary_inst(buf, OPCODE_GT, p),
        GeInst(p) => write_binary_inst(buf, OPCODE_GE, p),
        ToIntegerInst(p) => write_unary_inst(buf, OPCODE_TO_INTEGER, p),
        ToTryteInst(p) => write_unary_inst(buf, OPCODE_TO_TRYTE, p),
        ToLongInst(p) => write_unary_inst(buf, OPCODE_TO_LONG, p),
        ToTritInst(p) => write_unary_inst(buf, OPCODE_TO_TRIT, p),
        ToTrileanInst(p) => write_unary_inst(buf, OPCODE_TO_TRILEAN, p),
        StructNewInst(p) => write_inst_struct_new(buf, p),
        FieldGetInst(p) => write_inst_field_get(buf, p),
        FieldSetInst(p) => write_inst_field_set(buf, p),
        EnumNewInst(p) => write_inst_enum_new(buf, p),
        EnumTagInst(p) => write_inst_enum_unary(buf, OPCODE_ENUM_TAG, p.dest, p.scrutinee),
        EnumPayloadInst(p) => write_inst_enum_payload(buf, p),
        NullWrapInst(p) => write_inst_null_wrap(buf, p),
        NullUnwrapInst(p) => write_inst_null_unwrap(buf, p),
        NullCheckInst(p) => write_inst_null_check(buf, p),
        CallLocalInst(p) => write_inst_call_local(buf, p),
        CallCrossModuleInst(p) => write_inst_call_cross_module(buf, p),
        WitnessCallInst(p) => write_inst_witness_call(buf, p),
        CallBuiltinInst(p) => write_inst_call_builtin(buf, p),
        ClosureNewInst(p) => write_inst_closure_new(buf, p),
        ClosureCallInst(p) => write_inst_closure_call(buf, p),
        BrInst(p) => write_inst_br(buf, p),
        BrIfInst(p) => write_inst_br_if(buf, p),
        BrTrileanInst(p) => write_inst_br_trilean(buf, p),
        RetInst(p) => write_inst_ret(buf, p),
        UnreachableInst(_) => write_u8(buf, OPCODE_UNREACHABLE),
        PhiInst(p) => write_inst_phi(buf, p),
        OutcomeNewPositiveInst(p) => write_outcome_ctor(buf, OPCODE_OUTCOME_NEW_POSITIVE, p),
        OutcomeNewNegativeInst(p) => write_outcome_ctor(buf, OPCODE_OUTCOME_NEW_NEGATIVE, p),
        OutcomeNewNullInst(p) => write_outcome_new_null(buf, p),
        OutcomeDiscriminantInst(p) => write_outcome_unary(buf, OPCODE_OUTCOME_DISCRIMINANT, p),
        OutcomeUnwrapValueInst(p) => write_outcome_unary(buf, OPCODE_OUTCOME_UNWRAP_VALUE, p),
        OutcomeUnwrapErrorInst(p) => write_outcome_unary(buf, OPCODE_OUTCOME_UNWRAP_ERROR, p),
    }
}

function write_inst_const(buf: Vector<Integer>, p: InstConstPayload) -> Vector<Integer> = {
    let s1: Vector<Integer> = write_u8(buf, OPCODE_CONST)
    let s2: Vector<Integer> = write_varint(s1, p.dest.raw)
    write_varint(s2, p.const_id.raw)
}

function write_binary_inst(buf: Vector<Integer>, opcode: Integer, p: InstBinaryOpPayload) -> Vector<Integer> = {
    let s1: Vector<Integer> = write_u8(buf, opcode)
    let s2: Vector<Integer> = write_varint(s1, p.dest.raw)
    let s3: Vector<Integer> = write_operand(s2, p.lhs)
    write_operand(s3, p.rhs)
}

function write_inst_pow(buf: Vector<Integer>, p: InstPowPayload) -> Vector<Integer> = {
    let s1: Vector<Integer> = write_u8(buf, OPCODE_POW)
    let s2: Vector<Integer> = write_varint(s1, p.dest.raw)
    let s3: Vector<Integer> = write_operand(s2, p.base)
    write_operand(s3, p.exp)
}

function write_unary_inst(buf: Vector<Integer>, opcode: Integer, p: InstUnaryOpPayload) -> Vector<Integer> = {
    let s1: Vector<Integer> = write_u8(buf, opcode)
    let s2: Vector<Integer> = write_varint(s1, p.dest.raw)
    write_operand(s2, p.operand)
}

function write_inst_struct_new(buf: Vector<Integer>, p: InstStructNewPayload) -> Vector<Integer> = {
    let s1: Vector<Integer> = write_u8(buf, OPCODE_STRUCT_NEW)
    let s2: Vector<Integer> = write_varint(s1, p.dest.raw)
    write_operand_list(s2, p.fields)
}

function write_inst_field_get(buf: Vector<Integer>, p: InstFieldGetPayload) -> Vector<Integer> = {
    let s1: Vector<Integer> = write_u8(buf, OPCODE_FIELD_GET)
    let s2: Vector<Integer> = write_varint(s1, p.dest.raw)
    let s3: Vector<Integer> = write_operand(s2, p.object)
    write_varint(s3, p.field_idx)
}

function write_inst_field_set(buf: Vector<Integer>, p: InstFieldSetPayload) -> Vector<Integer> = {
    let s1: Vector<Integer> = write_u8(buf, OPCODE_FIELD_SET)
    let s2: Vector<Integer> = write_varint(s1, p.dest.raw)
    let s3: Vector<Integer> = write_operand(s2, p.object)
    let s4: Vector<Integer> = write_varint(s3, p.field_idx)
    write_operand(s4, p.value)
}

function write_inst_enum_new(buf: Vector<Integer>, p: InstEnumNewPayload) -> Vector<Integer> = {
    let s1: Vector<Integer> = write_u8(buf, OPCODE_ENUM_NEW)
    let s2: Vector<Integer> = write_varint(s1, p.dest.raw)
    let s3: Vector<Integer> = write_varint(s2, p.variant_idx)
    write_option_operand(s3, p.payload)
}

function write_inst_enum_unary(buf: Vector<Integer>, opcode: Integer, dest: ValueId, scrutinee: Operand) -> Vector<Integer> = {
    let s1: Vector<Integer> = write_u8(buf, opcode)
    let s2: Vector<Integer> = write_varint(s1, dest.raw)
    write_operand(s2, scrutinee)
}

function write_inst_enum_payload(buf: Vector<Integer>, p: InstEnumPayloadPayload) -> Vector<Integer> = {
    let s1: Vector<Integer> = write_u8(buf, OPCODE_ENUM_PAYLOAD)
    let s2: Vector<Integer> = write_varint(s1, p.dest.raw)
    write_operand(s2, p.scrutinee)
}

function write_inst_null_wrap(buf: Vector<Integer>, p: InstNullWrapPayload) -> Vector<Integer> = {
    let s1: Vector<Integer> = write_u8(buf, OPCODE_NULL_WRAP)
    let s2: Vector<Integer> = write_varint(s1, p.dest.raw)
    write_operand(s2, p.value)
}

function write_inst_null_unwrap(buf: Vector<Integer>, p: InstNullUnwrapPayload) -> Vector<Integer> = {
    let s1: Vector<Integer> = write_u8(buf, OPCODE_NULL_UNWRAP)
    let s2: Vector<Integer> = write_varint(s1, p.dest.raw)
    write_operand(s2, p.nullable)
}

function write_inst_null_check(buf: Vector<Integer>, p: InstNullCheckPayload) -> Vector<Integer> = {
    let s1: Vector<Integer> = write_u8(buf, OPCODE_NULL_CHECK)
    let s2: Vector<Integer> = write_varint(s1, p.dest.raw)
    write_operand(s2, p.nullable)
}

function write_inst_call_local(buf: Vector<Integer>, p: InstCallLocalPayload) -> Vector<Integer> = {
    let s1: Vector<Integer> = write_u8(buf, OPCODE_CALL_LOCAL)
    let s2: Vector<Integer> = write_option_value(s1, p.dest)
    let s3: Vector<Integer> = write_varint(s2, p.callee.raw)
    write_operand_list(s3, p.args)
}

function write_inst_call_cross_module(buf: Vector<Integer>, p: InstCallCrossModulePayload) -> Vector<Integer> = {
    let s1: Vector<Integer> = write_u8(buf, OPCODE_CALL_CROSS_MODULE)
    let s2: Vector<Integer> = write_option_value(s1, p.dest)
    let s3: Vector<Integer> = write_string(s2, absolute_path_to_string(p.path_segments))
    write_operand_list(s3, p.args)
}

function write_inst_witness_call(buf: Vector<Integer>, p: InstWitnessCallPayload) -> Vector<Integer> = {
    let s1: Vector<Integer> = write_u8(buf, OPCODE_WITNESS_CALL)
    let s2: Vector<Integer> = write_option_value(s1, p.dest)
    let s3: Vector<Integer> = write_string(s2, absolute_path_to_string(p.path_segments))
    let s4: Vector<Integer> = write_varint(s3, p.witness_idx)
    write_operand_list(s4, p.args)
}

function write_inst_call_builtin(buf: Vector<Integer>, p: InstCallBuiltinPayload) -> Vector<Integer> = {
    let s1: Vector<Integer> = write_u8(buf, OPCODE_CALL_BUILTIN)
    let s2: Vector<Integer> = write_option_value(s1, p.dest)
    let s3: Vector<Integer> = write_builtin(s2, p.name)
    write_operand_list(s3, p.args)
}

function write_inst_closure_new(buf: Vector<Integer>, p: InstClosureNewPayload) -> Vector<Integer> = {
    let s1: Vector<Integer> = write_u8(buf, OPCODE_CLOSURE_NEW)
    let s2: Vector<Integer> = write_varint(s1, p.dest.raw)
    let s3: Vector<Integer> = write_varint(s2, p.lambda.raw)
    write_value_id_list(s3, p.captures)
}

function write_inst_closure_call(buf: Vector<Integer>, p: InstClosureCallPayload) -> Vector<Integer> = {
    let s1: Vector<Integer> = write_u8(buf, OPCODE_CLOSURE_CALL)
    let s2: Vector<Integer> = write_option_value(s1, p.dest)
    let s3: Vector<Integer> = write_operand(s2, p.closure)
    write_operand_list(s3, p.args)
}

function write_inst_br(buf: Vector<Integer>, p: InstBrPayload) -> Vector<Integer> = {
    let s1: Vector<Integer> = write_u8(buf, OPCODE_BR)
    write_varint(s1, p.target.raw)
}

function write_inst_br_if(buf: Vector<Integer>, p: InstBrIfPayload) -> Vector<Integer> = {
    let s1: Vector<Integer> = write_u8(buf, OPCODE_BR_IF)
    let s2: Vector<Integer> = write_operand(s1, p.cond)
    let s3: Vector<Integer> = write_varint(s2, p.then_block.raw)
    write_varint(s3, p.else_block.raw)
}

function write_inst_br_trilean(buf: Vector<Integer>, p: InstBrTrileanPayload) -> Vector<Integer> = {
    let s1: Vector<Integer> = write_u8(buf, OPCODE_BR_TRILEAN)
    let s2: Vector<Integer> = write_operand(s1, p.cond)
    let s3: Vector<Integer> = write_varint(s2, p.true_block.raw)
    let s4: Vector<Integer> = write_varint(s3, p.unknown_block.raw)
    write_varint(s4, p.false_block.raw)
}

function write_inst_ret(buf: Vector<Integer>, p: InstRetPayload) -> Vector<Integer> = {
    let s1: Vector<Integer> = write_u8(buf, OPCODE_RET)
    write_option_operand(s1, p.value)
}

function write_inst_phi(buf: Vector<Integer>, p: InstPhiPayload) -> Vector<Integer> = {
    let s1: Vector<Integer> = write_u8(buf, OPCODE_PHI)
    let s2: Vector<Integer> = write_varint(s1, p.dest.raw)
    write_phi_incoming_list(s2, p.incoming)
}

function write_outcome_ctor(buf: Vector<Integer>, opcode: Integer, p: InstOutcomeCtorPayload) -> Vector<Integer> = {
    let s1: Vector<Integer> = write_u8(buf, opcode)
    let s2: Vector<Integer> = write_varint(s1, p.dest.raw)
    write_operand(s2, p.payload)
}

function write_outcome_new_null(buf: Vector<Integer>, p: InstOutcomeNewNullPayload) -> Vector<Integer> = {
    let s1: Vector<Integer> = write_u8(buf, OPCODE_OUTCOME_NEW_NULL)
    write_varint(s1, p.dest.raw)
}

function write_outcome_unary(buf: Vector<Integer>, opcode: Integer, p: InstOutcomeUnaryPayload) -> Vector<Integer> = {
    let s1: Vector<Integer> = write_u8(buf, opcode)
    let s2: Vector<Integer> = write_varint(s1, p.dest.raw)
    write_operand(s2, p.source)
}

// ── Instruction decoder ──────────────────────────────────────────

public struct ReadResultInstruction {
    value: Instruction,
    next_pos: Integer,
}

public function read_instruction(data: Vector<Integer>, pos: Integer) -> ReadResultInstruction~TrivError = {
    let op_res: ReadResultU8 = read_u8(data, pos) ~? |err| ~- err
    let opcode: Integer = op_res.value
    let p: Integer = op_res.next_pos
    if opcode == OPCODE_CONST { read_inst_const(data, p) }
    else if opcode == OPCODE_ADD { read_binary_inst(data, p, OPCODE_ADD) }
    else if opcode == OPCODE_SUB { read_binary_inst(data, p, OPCODE_SUB) }
    else if opcode == OPCODE_MUL { read_binary_inst(data, p, OPCODE_MUL) }
    else if opcode == OPCODE_DIV { read_binary_inst(data, p, OPCODE_DIV) }
    else if opcode == OPCODE_MOD { read_binary_inst(data, p, OPCODE_MOD) }
    else if opcode == OPCODE_POW { read_inst_pow(data, p) }
    else if opcode == OPCODE_NEG { read_unary_inst(data, p, OPCODE_NEG) }
    else if opcode == OPCODE_LUK_AND { read_binary_inst(data, p, OPCODE_LUK_AND) }
    else if opcode == OPCODE_LUK_OR { read_binary_inst(data, p, OPCODE_LUK_OR) }
    else if opcode == OPCODE_LUK_IMPLIES { read_binary_inst(data, p, OPCODE_LUK_IMPLIES) }
    else if opcode == OPCODE_LUK_XOR { read_binary_inst(data, p, OPCODE_LUK_XOR) }
    else if opcode == OPCODE_LUK_IFF { read_binary_inst(data, p, OPCODE_LUK_IFF) }
    else if opcode == OPCODE_KLEENE_IMPLIES { read_binary_inst(data, p, OPCODE_KLEENE_IMPLIES) }
    else if opcode == OPCODE_KLEENE_XOR { read_binary_inst(data, p, OPCODE_KLEENE_XOR) }
    else if opcode == OPCODE_KLEENE_IFF { read_binary_inst(data, p, OPCODE_KLEENE_IFF) }
    else if opcode == OPCODE_EQ { read_binary_inst(data, p, OPCODE_EQ) }
    else if opcode == OPCODE_NE { read_binary_inst(data, p, OPCODE_NE) }
    else if opcode == OPCODE_LT { read_binary_inst(data, p, OPCODE_LT) }
    else if opcode == OPCODE_LE { read_binary_inst(data, p, OPCODE_LE) }
    else if opcode == OPCODE_GT { read_binary_inst(data, p, OPCODE_GT) }
    else if opcode == OPCODE_GE { read_binary_inst(data, p, OPCODE_GE) }
    else if opcode == OPCODE_TO_INTEGER { read_unary_inst(data, p, OPCODE_TO_INTEGER) }
    else if opcode == OPCODE_TO_TRYTE { read_unary_inst(data, p, OPCODE_TO_TRYTE) }
    else if opcode == OPCODE_TO_LONG { read_unary_inst(data, p, OPCODE_TO_LONG) }
    else if opcode == OPCODE_TO_TRIT { read_unary_inst(data, p, OPCODE_TO_TRIT) }
    else if opcode == OPCODE_TO_TRILEAN { read_unary_inst(data, p, OPCODE_TO_TRILEAN) }
    else if opcode == OPCODE_STRUCT_NEW { read_inst_struct_new(data, p) }
    else if opcode == OPCODE_FIELD_GET { read_inst_field_get(data, p) }
    else if opcode == OPCODE_FIELD_SET { read_inst_field_set(data, p) }
    else if opcode == OPCODE_ENUM_NEW { read_inst_enum_new(data, p) }
    else if opcode == OPCODE_ENUM_TAG { read_inst_enum_tag(data, p) }
    else if opcode == OPCODE_ENUM_PAYLOAD { read_inst_enum_payload(data, p) }
    else if opcode == OPCODE_NULL_WRAP { read_inst_null_wrap(data, p) }
    else if opcode == OPCODE_NULL_UNWRAP { read_inst_null_unwrap(data, p) }
    else if opcode == OPCODE_NULL_CHECK { read_inst_null_check(data, p) }
    else if opcode == OPCODE_CALL_LOCAL { read_inst_call_local(data, p) }
    else if opcode == OPCODE_CALL_CROSS_MODULE { read_inst_call_cross_module(data, p) }
    else if opcode == OPCODE_CALL_BUILTIN { read_inst_call_builtin(data, p) }
    else if opcode == OPCODE_WITNESS_CALL { read_inst_witness_call(data, p) }
    else if opcode == OPCODE_CLOSURE_NEW { read_inst_closure_new(data, p) }
    else if opcode == OPCODE_CLOSURE_CALL { read_inst_closure_call(data, p) }
    else if opcode == OPCODE_BR { read_inst_br(data, p) }
    else if opcode == OPCODE_BR_IF { read_inst_br_if(data, p) }
    else if opcode == OPCODE_RET { read_inst_ret(data, p) }
    else if opcode == OPCODE_UNREACHABLE { ~+ ReadResultInstruction { value: UnreachableInst(primitive_marker()), next_pos: p } }
    else if opcode == OPCODE_BR_TRILEAN { read_inst_br_trilean(data, p) }
    else if opcode == OPCODE_PHI { read_inst_phi(data, p) }
    else if opcode == OPCODE_OUTCOME_NEW_POSITIVE { read_outcome_ctor(data, p, OPCODE_OUTCOME_NEW_POSITIVE) }
    else if opcode == OPCODE_OUTCOME_NEW_NEGATIVE { read_outcome_ctor(data, p, OPCODE_OUTCOME_NEW_NEGATIVE) }
    else if opcode == OPCODE_OUTCOME_NEW_NULL { read_outcome_new_null(data, p) }
    else if opcode == OPCODE_OUTCOME_DISCRIMINANT { read_outcome_unary(data, p, OPCODE_OUTCOME_DISCRIMINANT) }
    else if opcode == OPCODE_OUTCOME_UNWRAP_VALUE { read_outcome_unary(data, p, OPCODE_OUTCOME_UNWRAP_VALUE) }
    else if opcode == OPCODE_OUTCOME_UNWRAP_ERROR { read_outcome_unary(data, p, OPCODE_OUTCOME_UNWRAP_ERROR) }
    else { ~- Corrupted(TrivErrorCorrupted { message: "unknown opcode" }) }
}

function read_inst_const(data: Vector<Integer>, p: Integer) -> ReadResultInstruction~TrivError = {
    let dest_res: ReadResultInteger = read_varint(data, p) ~? |err| ~- err
    let c_res: ReadResultInteger = read_varint(data, dest_res.next_pos) ~? |err| ~- err
    ~+ ReadResultInstruction {
        value: ConstInst(InstConstPayload {
            dest: ValueId { raw: dest_res.value },
            const_id: ConstId { raw: c_res.value },
        }),
        next_pos: c_res.next_pos,
    }
}

function read_binary_inst(data: Vector<Integer>, p: Integer, opcode: Integer) -> ReadResultInstruction~TrivError = {
    let dest_res: ReadResultInteger = read_varint(data, p) ~? |err| ~- err
    let lhs_res: ReadResultOperand = read_operand(data, dest_res.next_pos) ~? |err| ~- err
    let rhs_res: ReadResultOperand = read_operand(data, lhs_res.next_pos) ~? |err| ~- err
    let payload: InstBinaryOpPayload = InstBinaryOpPayload {
        dest: ValueId { raw: dest_res.value },
        lhs: lhs_res.value,
        rhs: rhs_res.value,
    }
    let inst: Instruction = construct_binary_inst(opcode, payload)
    ~+ ReadResultInstruction { value: inst, next_pos: rhs_res.next_pos }
}

function construct_binary_inst(opcode: Integer, payload: InstBinaryOpPayload) -> Instruction = {
    if opcode == OPCODE_ADD { AddInst(payload) }
    else if opcode == OPCODE_SUB { SubInst(payload) }
    else if opcode == OPCODE_MUL { MulInst(payload) }
    else if opcode == OPCODE_DIV { DivInst(payload) }
    else if opcode == OPCODE_MOD { ModInst(payload) }
    else if opcode == OPCODE_LUK_AND { LukAndInst(payload) }
    else if opcode == OPCODE_LUK_OR { LukOrInst(payload) }
    else if opcode == OPCODE_LUK_IMPLIES { LukImpliesInst(payload) }
    else if opcode == OPCODE_LUK_XOR { LukXorInst(payload) }
    else if opcode == OPCODE_LUK_IFF { LukIffInst(payload) }
    else if opcode == OPCODE_KLEENE_IMPLIES { KleeneImpliesInst(payload) }
    else if opcode == OPCODE_KLEENE_XOR { KleeneXorInst(payload) }
    else if opcode == OPCODE_KLEENE_IFF { KleeneIffInst(payload) }
    else if opcode == OPCODE_EQ { EqInst(payload) }
    else if opcode == OPCODE_NE { NeInst(payload) }
    else if opcode == OPCODE_LT { LtInst(payload) }
    else if opcode == OPCODE_LE { LeInst(payload) }
    else if opcode == OPCODE_GT { GtInst(payload) }
    else if opcode == OPCODE_GE { GeInst(payload) }
    else { AddInst(payload) }
}

function read_inst_pow(data: Vector<Integer>, p: Integer) -> ReadResultInstruction~TrivError = {
    let dest_res: ReadResultInteger = read_varint(data, p) ~? |err| ~- err
    let base_res: ReadResultOperand = read_operand(data, dest_res.next_pos) ~? |err| ~- err
    let exp_res: ReadResultOperand = read_operand(data, base_res.next_pos) ~? |err| ~- err
    ~+ ReadResultInstruction {
        value: PowInst(InstPowPayload {
            dest: ValueId { raw: dest_res.value },
            base: base_res.value,
            exp: exp_res.value,
        }),
        next_pos: exp_res.next_pos,
    }
}

function read_unary_inst(data: Vector<Integer>, p: Integer, opcode: Integer) -> ReadResultInstruction~TrivError = {
    let dest_res: ReadResultInteger = read_varint(data, p) ~? |err| ~- err
    let op_res: ReadResultOperand = read_operand(data, dest_res.next_pos) ~? |err| ~- err
    let payload: InstUnaryOpPayload = InstUnaryOpPayload {
        dest: ValueId { raw: dest_res.value },
        operand: op_res.value,
    }
    let inst: Instruction = construct_unary_inst(opcode, payload)
    ~+ ReadResultInstruction { value: inst, next_pos: op_res.next_pos }
}

function construct_unary_inst(opcode: Integer, payload: InstUnaryOpPayload) -> Instruction = {
    if opcode == OPCODE_NEG { NegInst(payload) }
    else if opcode == OPCODE_TO_INTEGER { ToIntegerInst(payload) }
    else if opcode == OPCODE_TO_TRYTE { ToTryteInst(payload) }
    else if opcode == OPCODE_TO_LONG { ToLongInst(payload) }
    else if opcode == OPCODE_TO_TRIT { ToTritInst(payload) }
    else if opcode == OPCODE_TO_TRILEAN { ToTrileanInst(payload) }
    else { NegInst(payload) }
}

function read_inst_struct_new(data: Vector<Integer>, p: Integer) -> ReadResultInstruction~TrivError = {
    let dest_res: ReadResultInteger = read_varint(data, p) ~? |err| ~- err
    let fields_res: ReadResultOperandList = read_operand_list(data, dest_res.next_pos) ~? |err| ~- err
    ~+ ReadResultInstruction {
        value: StructNewInst(InstStructNewPayload {
            dest: ValueId { raw: dest_res.value },
            fields: fields_res.value,
        }),
        next_pos: fields_res.next_pos,
    }
}

function read_inst_field_get(data: Vector<Integer>, p: Integer) -> ReadResultInstruction~TrivError = {
    let dest_res: ReadResultInteger = read_varint(data, p) ~? |err| ~- err
    let obj_res: ReadResultOperand = read_operand(data, dest_res.next_pos) ~? |err| ~- err
    let idx_res: ReadResultInteger = read_varint(data, obj_res.next_pos) ~? |err| ~- err
    ~+ ReadResultInstruction {
        value: FieldGetInst(InstFieldGetPayload {
            dest: ValueId { raw: dest_res.value },
            object: obj_res.value,
            field_idx: idx_res.value,
        }),
        next_pos: idx_res.next_pos,
    }
}

