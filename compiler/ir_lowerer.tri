// Triết-in-Triết IR lowerer port — bootstrap source for the
// self-hosting compiler ([ADR-0019][adr-0019] §A7.8 v0.7.8 umbrella).
//
// v0.7.8.1 — IR types + Instruction enum scaffolding. Mirrors
// crates/triet-ir/src/{types.rs, constant.rs, instr.rs, module.rs}:
// declares the SSA value / block / function / constant ID wrappers,
// the recursive `TypeTag` (via arena because Triết enum variants
// can't recursively contain themselves), the `Constant` value
// enum, the `Operand` union, the full 53-variant `Instruction`
// enum, the `BuiltinName` enum, and the `BasicBlock` / `Function`
// / `IrModule` / `IrProgram` containers. v0.7.8.{2..5} build the
// `lower_program` driver, the wire-format `read_program` /
// `write_program`, and the `lowerer_differential` byte-diff gate
// on top of this surface.
//
// Types coverage:
//   - 4 ID wrappers (`ValueId` / `BlockId` / `FuncId` / `ConstId`),
//     each carrying a `raw: Integer` payload + `*_display` helper
//     that reproduces Rust's `impl Display` (`%n` / `bn` / `@fn` /
//     `cn`).
//   - `TypeTag` (12 variants — Trit / Tryte / Integer / Long /
//     Trilean / String / Unit / Nullable / Vector / HashMap /
//     Outcome). Recursive references go through `TypeArena` (same
//     pattern as parser.tri / typecheck.tri).
//   - `Constant` (8 variants — Trit / Tryte / Integer / Long /
//     Trilean / String / Unit / Null) + `ConstantPool` (Vector +
//     identity-string index map for dedup).
//   - `Operand` 2-variant union (ValueOp / ConstOp).
//   - `Instruction` — 53 variants covering ADR-0007's full opcode
//     set: Const, 7 arithmetic, 5 Ł3 logic, 3 K3 logic, 6
//     comparisons, 5 conversions, 3 struct ops, 3 enum ops, 3
//     nullable ops, 4 call ops, 2 closure ops, 5 control-flow
//     terminators, Phi, 6 Outcome ops.
//   - `BuiltinName` (~24 variants — io / text / vector / hashmap /
//     string / path / fs / parse / assert).
//   - `PhiIncoming` carrier struct.
//   - `BasicBlock { id, name, instructions }`,
//     `Function { id, name, parameters, return_type, blocks }`,
//     `IrModule { path_segments, functions }`,
//     `IrProgram { modules, constants, witness_tables }`.
//
// v0.7.8.1 is types-only: no `lower_*` driver yet. Smoke main
// exercises construction + display of every Instruction variant +
// the IR program containers so the integration test
// (`ir_lowerer_types_smoke.rs`) can confirm the surface compiles +
// round-trips through the VM. v0.7.8.{2..5} build the actual
// lowerer logic on this foundation.
//
// [adr-0019]: ../docs/decisions/0019-self-hosting-compiler-bootstrap.md

module parser;

from std.io import println
from std.collections.vector import new, push, length, get
from std.collections.hashmap import new as hashmap_new, insert, get as hashmap_get, contains as hashmap_contains
from std.text import concat, from_integer, len as text_len
from std.string import substring
from std.assert import assert

from khi.parser.lexer import SpannedToken, LexError, lex
from khi.parser import Arena, get_expression, get_statement, get_type as get_type_expr, get_item, get_pattern
from khi.parser import Program, ParseProgramStep, parser_new, parse_program, ParserState
from khi.parser import Expr, IntegerLiteralExpr, TernaryLiteralExpr, TrileanLiteralExpr, StringLiteralExpr, NullLiteralExpr, IdentifierExpr, UnaryOpExpr, BinaryOpExpr, ForceUnwrapExpr, CallExpr, FieldAccessExpr, MethodCallExpr, OutcomeConstructorExpr, OutcomePropagateExpr, OutcomeDefaultExpr, ElvisOpExpr, RangeExpr, IfExpr, MatchExpr
from khi.parser import Stmt, LetStmt, ConstantStmt, ReturnStmt, BreakStmt, ContinueStmt, ForStmt, WhileStmt, LoopStmt, AssignStmt, ExpressionStmt
from khi.parser import TypeExpr, NamedType, GenericType, TupleType, NullableType, FunctionType, OutcomeType, RefinedTrileanType
from khi.parser import Item, FunctionItem, ConstantItem, TypeAliasItem, StructItem, EnumItem, ImportItem, ImportFromItem, ModuleItem
from khi.parser import Block, SpannedExpr, SpannedStmt, SpannedTypeExpr, SpannedItem
from khi.parser import FunctionDef, FunctionBody, BlockBody, ExpressionBody, FunctionParam, ConstantItemPayload
from khi.parser import StructDef, StructField, EnumDef, EnumVariant
from khi.parser import OutcomeArm, PositiveArm, ZeroArm, NegativeArm
from khi.parser import Pattern, SpannedPattern, WildcardPattern, IdentifierPattern, LiteralPat, NullPat, EnumVariantPat, OutcomeArmPat
from khi.parser import LiteralPattern, IntegerLit, TernaryLit, StringLit, TrileanLit, LiteralIntegerPattern
from khi.parser import EnumVariantPatternPayload, OutcomeArmPatternPayload
from khi.parser import BinaryOperator, Add, Subtract, Multiply, Divide, Modulo, Power, Equal, NotEqual, LessThan, LessEqual, GreaterThan, GreaterEqual, And, Or, Xor, Iff, Implies, KleeneXor, KleeneIff, KleeneImplies
from khi.parser import UnaryOperator, Negate
from khi.parser import TrileanValue, TrueValue, FalseValue, UnknownValue
from khi.parser import BinaryOpPayload, UnaryOpPayload, CallPayload, FieldAccessPayload, MethodCallPayload, OutcomeConstructorPayload, OutcomeDefaultPayload, OutcomePropagatePayload, RangePayload, ElvisOpPayload, IfExprPayload, MatchExprPayload, MatchArm, LetStmtPayload, ConstantStmtPayload, ReturnStmtPayload, BreakStmtPayload, LoopStmtPayload, AssignStmtPayload, ExpressionStmtPayload, WhileStmtPayload, ForStmtPayload, NamedTypePayload, GenericTypePayload
from khi.parser.lexer import IntLiteral, StringPayload as ParseStringPayload, NumericSuffix, TritSuffix, TryteSuffix, IntegerSuffix, LongSuffix

// ─────────────────────────────────────────────────────────────────
// ID wrappers — Triết enum payloads need a struct, so each ID
// gets a single-field carrier with `raw: Integer`. Display helpers
// match Rust's `impl Display`: `%n` / `bn` / `@fn` / `cn`.
// ─────────────────────────────────────────────────────────────────

public struct ValueId {
    raw: Integer,
}

public struct BlockId {
    raw: Integer,
}

public struct FuncId {
    raw: Integer,
}

public struct ConstId {
    raw: Integer,
}

public function value_id_display(id: ValueId) -> String =
    concat("%", from_integer(id.raw))

public function block_id_display(id: BlockId) -> String =
    concat("b", from_integer(id.raw))

public function func_id_display(id: FuncId) -> String =
    concat("@f", from_integer(id.raw))

public function const_id_display(id: ConstId) -> String =
    concat("c", from_integer(id.raw))

// ─────────────────────────────────────────────────────────────────
// TypeTag — discriminator for the IR's per-register type tag.
//
// Recursive variants (Nullable / Vector / HashMap / Outcome) hold
// arena IDs into the parallel `TypeTagArena.tags` Vector, mirroring
// the parser.tri / typecheck.tri pattern.
// ─────────────────────────────────────────────────────────────────

public struct PrimitiveMarker {
    placeholder: Integer,
}

public struct TypeTagNullablePayload {
    inner: Integer,
}

public struct TypeTagVectorPayload {
    inner: Integer,
}

public struct TypeTagHashMapPayload {
    key: Integer,
    value: Integer,
}

public struct TypeTagOutcomePayload {
    value_type: Integer,
    error_type: Integer,
    allow_null_state: Trilean!,
}

public enum TypeTag {
    TritTag(PrimitiveMarker),
    TryteTag(PrimitiveMarker),
    IntegerTag(PrimitiveMarker),
    LongTag(PrimitiveMarker),
    TrileanTag(PrimitiveMarker),
    StringTag(PrimitiveMarker),
    UnitTag(PrimitiveMarker),
    NullableTag(TypeTagNullablePayload),
    VectorTag(TypeTagVectorPayload),
    HashMapTag(TypeTagHashMapPayload),
    OutcomeTag(TypeTagOutcomePayload),
}

public struct TypeTagArena {
    tags: Vector<TypeTag>,
}

public struct AllocTagResult {
    arena: TypeTagArena,
    tag_id: Integer,
}

public function type_tag_arena_new() -> TypeTagArena =
    TypeTagArena { tags: new() }

public function alloc_type_tag(arena: TypeTagArena, tag: TypeTag) -> AllocTagResult = {
    let next_id: Integer = length(arena.tags)
    let updated: TypeTagArena = TypeTagArena { tags: push(arena.tags, tag) }
    AllocTagResult { arena: updated, tag_id: next_id }
}

public function get_type_tag(arena: TypeTagArena, tag_id: Integer) -> TypeTag? =
    get(arena.tags, tag_id)

function primitive_marker() -> PrimitiveMarker =
    PrimitiveMarker { placeholder: 0 }

public function alloc_tag_trit(arena: TypeTagArena) -> AllocTagResult =
    alloc_type_tag(arena, TritTag(primitive_marker()))

public function alloc_tag_tryte(arena: TypeTagArena) -> AllocTagResult =
    alloc_type_tag(arena, TryteTag(primitive_marker()))

public function alloc_tag_integer(arena: TypeTagArena) -> AllocTagResult =
    alloc_type_tag(arena, IntegerTag(primitive_marker()))

public function alloc_tag_long(arena: TypeTagArena) -> AllocTagResult =
    alloc_type_tag(arena, LongTag(primitive_marker()))

public function alloc_tag_trilean(arena: TypeTagArena) -> AllocTagResult =
    alloc_type_tag(arena, TrileanTag(primitive_marker()))

public function alloc_tag_string(arena: TypeTagArena) -> AllocTagResult =
    alloc_type_tag(arena, StringTag(primitive_marker()))

public function alloc_tag_unit(arena: TypeTagArena) -> AllocTagResult =
    alloc_type_tag(arena, UnitTag(primitive_marker()))

public function alloc_tag_nullable(arena: TypeTagArena, inner: Integer) -> AllocTagResult =
    alloc_type_tag(arena, NullableTag(TypeTagNullablePayload { inner: inner }))

public function alloc_tag_vector(arena: TypeTagArena, inner: Integer) -> AllocTagResult =
    alloc_type_tag(arena, VectorTag(TypeTagVectorPayload { inner: inner }))

public function alloc_tag_hashmap(arena: TypeTagArena, key: Integer, value: Integer) -> AllocTagResult =
    alloc_type_tag(arena, HashMapTag(TypeTagHashMapPayload { key: key, value: value }))

public function alloc_tag_outcome(
    arena: TypeTagArena,
    value_type: Integer,
    error_type: Integer,
    allow_null_state: Trilean!,
) -> AllocTagResult =
    alloc_type_tag(arena, OutcomeTag(TypeTagOutcomePayload {
        value_type: value_type,
        error_type: error_type,
        allow_null_state: allow_null_state,
    }))

/// Recursive type tag printer. Mirrors Rust's `impl Display for TypeTag`.
public function type_tag_display(arena: TypeTagArena, tag_id: Integer) -> String = {
    let node_opt: TypeTag? = get_type_tag(arena, tag_id)
    match node_opt {
        ~0 => "?",
        _ => {
            match node_opt!! {
                TritTag(_) => "Trit",
                TryteTag(_) => "Tryte",
                IntegerTag(_) => "Integer",
                LongTag(_) => "Long",
                TrileanTag(_) => "Trilean",
                StringTag(_) => "String",
                UnitTag(_) => "Unit",
                NullableTag(p) => concat(type_tag_display(arena, p.inner), "?"),
                VectorTag(p) => concat(concat("Vector<", type_tag_display(arena, p.inner)), ">"),
                HashMapTag(p) => {
                    let k_str: String = type_tag_display(arena, p.key)
                    let v_str: String = type_tag_display(arena, p.value)
                    concat(concat(concat(concat("HashMap<", k_str), ", "), v_str), ">")
                },
                OutcomeTag(p) => {
                    let v_str: String = type_tag_display(arena, p.value_type)
                    let e_str: String = type_tag_display(arena, p.error_type)
                    let sep: String = if p.allow_null_state { "?~" } else { "~" }
                    concat(concat(v_str, sep), e_str)
                },
            }
        },
    }
}

// ─────────────────────────────────────────────────────────────────
// Constant — compile-time known values referenced inline via
// `ConstId`. Per-variant payload struct because Triết enum
// variants take exactly one payload.
// ─────────────────────────────────────────────────────────────────

public struct ConstantTritPayload {
    value: Trit,
}

public struct ConstantTrytePayload {
    value: Tryte,
}

public struct ConstantIntegerPayload {
    value: Integer,
}

public struct ConstantLongPayload {
    value: Long,
}

public struct ConstantTrileanPayload {
    value: Trilean,
}

public struct ConstantStringPayload {
    value: String,
}

public enum Constant {
    TritConst(ConstantTritPayload),
    TryteConst(ConstantTrytePayload),
    IntegerConst(ConstantIntegerPayload),
    LongConst(ConstantLongPayload),
    TrileanConst(ConstantTrileanPayload),
    StringConst(ConstantStringPayload),
    UnitConst(PrimitiveMarker),
    NullConst(PrimitiveMarker),
}

/// `Constant` → `TypeTag` mapping. Mirrors Rust `Constant::type_tag`
/// — `NullConst` returns `Nullable<Unit>` because the constant
/// pool's canonical null carries no inner type info; the lowerer
/// witnesses the actual `T?` shape at the call site via
/// `NullWrap`/`NullCheck` operand context.
public function constant_type_tag(arena: TypeTagArena, c: Constant) -> AllocTagResult =
    match c {
        TritConst(_) => alloc_tag_trit(arena),
        TryteConst(_) => alloc_tag_tryte(arena),
        IntegerConst(_) => alloc_tag_integer(arena),
        LongConst(_) => alloc_tag_long(arena),
        TrileanConst(_) => alloc_tag_trilean(arena),
        StringConst(_) => alloc_tag_string(arena),
        UnitConst(_) => alloc_tag_unit(arena),
        NullConst(_) => {
            let inner: AllocTagResult = alloc_tag_unit(arena)
            alloc_tag_nullable(inner.arena, inner.tag_id)
        },
    }

/// Interned constant pool. The simpler shape than Rust's
/// HashMap-backed dedup index — for v0.7.8.1 scaffolding we
/// expose the entries vector directly and add a linear-scan
/// `intern` helper. v0.7.8.{2..} can swap the lookup to a
/// hashmap if profile-pressure justifies it.
public struct ConstantPool {
    entries: Vector<Constant>,
}

public function constant_pool_new() -> ConstantPool =
    ConstantPool { entries: new() }

public function constant_pool_get(pool: ConstantPool, id: ConstId) -> Constant? =
    get(pool.entries, id.raw)

public function constant_pool_count(pool: ConstantPool) -> Integer =
    length(pool.entries)

public struct InternResult {
    pool: ConstantPool,
    id: ConstId,
}

/// Append a constant to the pool, returning its `ConstId`. v0.7.8.1
/// does NOT dedup (the linear-scan equality across `Constant` values
/// would require a generic equality helper that Triết doesn't yet
/// expose). Re-interning the same value yields a fresh id — the
/// lowerer can layer dedup on top once needed.
public function constant_pool_intern(pool: ConstantPool, c: Constant) -> InternResult = {
    // Linear-scan dedup to match Rust `ConstantPool::intern` semantic
    // (Rust uses a `HashMap<Constant, ConstId>` for O(1); Triết's
    // small pools don't warrant the wire-format overhead). Returning
    // the existing ID for a duplicate keeps `.triv` byte output
    // byte-identical with the Rust impl after round-trip — without
    // dedup the Triết pool grows monotonically and the Rust reader's
    // intern collapses the duplicates, breaking re-emit symmetry.
    let total: Integer = length(pool.entries)
    let mutable i: Integer = 0
    let mutable existing: Integer = -1
    while i < total && existing < 0 {
        if constant_eq(get(pool.entries, i)!!, c) {
            existing = i
        }
        i = i + 1
    }
    if existing >= 0 {
        InternResult { pool: pool, id: ConstId { raw: existing } }
    } else {
        let next_id: Integer = length(pool.entries)
        let updated: ConstantPool = ConstantPool { entries: push(pool.entries, c) }
        InternResult { pool: updated, id: ConstId { raw: next_id } }
    }
}

/// Structural equality on Constant. Hand-rolled because the VM's
/// `runtime_eq` (crates/triet-ir/src/vm.rs) doesn't cover enum
/// values — `==` on `Constant` would always return false at runtime.
function constant_eq(a: Constant, b: Constant) -> Trilean! = {
    let da: Integer = constant_discriminator(a)
    let db: Integer = constant_discriminator(b)
    if da != db { return false }
    if da == 0 { trit_eq(constant_trit_value(a), constant_trit_value(b)) }
    else if da == 1 { constant_tryte_value(a) == constant_tryte_value(b) }
    else if da == 2 { constant_integer_value(a) == constant_integer_value(b) }
    else if da == 3 { long_eq(constant_long_value(a), constant_long_value(b)) }
    else if da == 4 { trilean_eq(constant_trilean_value(a), constant_trilean_value(b)) }
    else if da == 5 { constant_string_value(a) == constant_string_value(b) }
    else { true }
}

function constant_discriminator(c: Constant) -> Integer =
    match c {
        TritConst(_) => 0,
        TryteConst(_) => 1,
        IntegerConst(_) => 2,
        LongConst(_) => 3,
        TrileanConst(_) => 4,
        StringConst(_) => 5,
        UnitConst(_) => 6,
        NullConst(_) => 7,
    }

function constant_trit_value(c: Constant) -> Trit =
    match c {
        TritConst(p) => p.value,
        _ => 0_trit,
    }

function constant_tryte_value(c: Constant) -> Tryte =
    match c {
        TryteConst(p) => p.value,
        _ => 0.to_tryte(),
    }

function constant_integer_value(c: Constant) -> Integer =
    match c {
        IntegerConst(p) => p.value,
        _ => 0,
    }

function constant_long_value(c: Constant) -> Long =
    match c {
        LongConst(p) => p.value,
        _ => 0.to_long(),
    }

function constant_trilean_value(c: Constant) -> Trilean =
    match c {
        TrileanConst(p) => p.value,
        _ => false,
    }

function constant_string_value(c: Constant) -> String =
    match c {
        StringConst(p) => p.value,
        _ => "",
    }

function trit_eq(a: Trit, b: Trit) -> Trilean! = {
    let av: Integer = if? a == -1_trit { 0 } else if? a == 0_trit { 1 } else { 2 }
    let bv: Integer = if? b == -1_trit { 0 } else if? b == 0_trit { 1 } else { 2 }
    av == bv
}

function trilean_eq(a: Trilean, b: Trilean) -> Trilean! = {
    let av: Integer = if? a == false { 0 } else if? a == unknown { 1 } else { 2 }
    let bv: Integer = if? b == false { 0 } else if? b == unknown { 1 } else { 2 }
    av == bv
}

function long_eq(a: Long, b: Long) -> Trilean! =
    a.to_integer() == b.to_integer()

// ─────────────────────────────────────────────────────────────────
// Operand — instruction inputs are either an SSA virtual register
// reference (`ValueOp`) or a constant-pool reference (`ConstOp`).
// ─────────────────────────────────────────────────────────────────

public enum Operand {
    ValueOp(ValueId),
    ConstOp(ConstId),
}

public function operand_display(op: Operand) -> String =
    match op {
        ValueOp(v) => value_id_display(v),
        ConstOp(c) => const_id_display(c),
    }

// ─────────────────────────────────────────────────────────────────
// PhiIncoming — `(value, predecessor block)` pair for SSA φ-nodes.
// ─────────────────────────────────────────────────────────────────

public struct PhiIncoming {
    value: ValueId,
    block: BlockId,
}

// ─────────────────────────────────────────────────────────────────
// BuiltinName — enumerated names of VM-side builtin functions.
// Mirrors the Rust `BuiltinName` enum (instr.rs:421-534). Each
// variant is a unit (zero-field) marker via `PrimitiveMarker`.
// ─────────────────────────────────────────────────────────────────

public enum BuiltinName {
    PrintlnBuiltin(PrimitiveMarker),
    PrintBuiltin(PrimitiveMarker),
    AssertBuiltin(PrimitiveMarker),
    AssertEqBuiltin(PrimitiveMarker),
    FStringConcatBuiltin(PrimitiveMarker),
    TextLenBuiltin(PrimitiveMarker),
    TextConcatBuiltin(PrimitiveMarker),
    TextFromIntegerBuiltin(PrimitiveMarker),
    VectorNewBuiltin(PrimitiveMarker),
    VectorPushBuiltin(PrimitiveMarker),
    VectorGetBuiltin(PrimitiveMarker),
    VectorLengthBuiltin(PrimitiveMarker),
    HashMapNewBuiltin(PrimitiveMarker),
    HashMapInsertBuiltin(PrimitiveMarker),
    HashMapGetBuiltin(PrimitiveMarker),
    HashMapKeysBuiltin(PrimitiveMarker),
    HashMapContainsBuiltin(PrimitiveMarker),
    ReadFileBuiltin(PrimitiveMarker),
    WriteFileBuiltin(PrimitiveMarker),
    FileExistsBuiltin(PrimitiveMarker),
    PathJoinBuiltin(PrimitiveMarker),
    PathParentBuiltin(PrimitiveMarker),
    PathBasenameBuiltin(PrimitiveMarker),
    StringSubstringBuiltin(PrimitiveMarker),
    StringSplitBuiltin(PrimitiveMarker),
    StringIndexOfBuiltin(PrimitiveMarker),
    ParseIntegerBuiltin(PrimitiveMarker),
    TextIntoBytesBuiltin(PrimitiveMarker),
    TextFromBytesBuiltin(PrimitiveMarker),
    Blake3HashBuiltin(PrimitiveMarker),
    WriteFileBytesBuiltin(PrimitiveMarker),
    EnvGetBuiltin(PrimitiveMarker),
}

public function builtin_name_display(name: BuiltinName) -> String =
    match name {
        PrintlnBuiltin(_) => "println",
        PrintBuiltin(_) => "print",
        AssertBuiltin(_) => "assert",
        AssertEqBuiltin(_) => "assert_eq",
        FStringConcatBuiltin(_) => "fstring_concat",
        TextLenBuiltin(_) => "text_len",
        TextConcatBuiltin(_) => "text_concat",
        TextFromIntegerBuiltin(_) => "text_from_integer",
        VectorNewBuiltin(_) => "vector_new",
        VectorPushBuiltin(_) => "vector_push",
        VectorGetBuiltin(_) => "vector_get",
        VectorLengthBuiltin(_) => "vector_length",
        HashMapNewBuiltin(_) => "hashmap_new",
        HashMapInsertBuiltin(_) => "hashmap_insert",
        HashMapGetBuiltin(_) => "hashmap_get",
        HashMapKeysBuiltin(_) => "hashmap_keys",
        HashMapContainsBuiltin(_) => "hashmap_contains",
        ReadFileBuiltin(_) => "read_file",
        WriteFileBuiltin(_) => "write_file",
        FileExistsBuiltin(_) => "file_exists",
        PathJoinBuiltin(_) => "path_join",
        PathParentBuiltin(_) => "path_parent",
        PathBasenameBuiltin(_) => "path_basename",
        StringSubstringBuiltin(_) => "string_substring",
        StringSplitBuiltin(_) => "string_split",
        StringIndexOfBuiltin(_) => "string_index_of",
        ParseIntegerBuiltin(_) => "parse_integer",
        TextIntoBytesBuiltin(_) => "into_bytes",
        TextFromBytesBuiltin(_) => "from_bytes",
        Blake3HashBuiltin(_) => "blake3_hash",
        WriteFileBytesBuiltin(_) => "write_file_bytes",
        EnvGetBuiltin(_) => "get_env",
    }

// ─────────────────────────────────────────────────────────────────
// Instruction payload structs — one per variant. Triết enum
// variants carry a single payload struct, so multi-field opcodes
// get a named carrier.
//
// Categories mirror ADR-0007 §"Phân nhóm instruction":
//   - Const
//   - Arithmetic (7)
//   - Ł3 Logic (5)
//   - K3 Logic (3)
//   - Comparison (6)
//   - Conversion (5)
//   - Struct (3)
//   - Enum (3)
//   - Nullable (3)
//   - Call (4)
//   - Closure (2)
//   - Control flow (5)
//   - Phi
//   - Outcome (6)
// ─────────────────────────────────────────────────────────────────

public struct InstConstPayload {
    dest: ValueId,
    const_id: ConstId,
}

// Binary-op shape: dest + lhs + rhs. Used by Add/Sub/Mul/Div/Mod/
// LukAnd/LukOr/LukImplies/LukXor/LukIff/KleeneImplies/KleeneXor/
// KleeneIff/Eq/Ne/Lt/Le/Gt/Ge.
public struct InstBinaryOpPayload {
    dest: ValueId,
    lhs: Operand,
    rhs: Operand,
}

// Pow shape: dest + base + exp (named differently from generic
// lhs/rhs for readability).
public struct InstPowPayload {
    dest: ValueId,
    base: Operand,
    exp: Operand,
}

// Unary-op shape: dest + operand. Used by Neg/ToInteger/ToTryte/
// ToLong/ToTrit/ToTrilean.
public struct InstUnaryOpPayload {
    dest: ValueId,
    operand: Operand,
}

public struct InstStructNewPayload {
    dest: ValueId,
    fields: Vector<Operand>,
}

public struct InstFieldGetPayload {
    dest: ValueId,
    object: Operand,
    field_idx: Integer,
}

public struct InstFieldSetPayload {
    dest: ValueId,
    object: Operand,
    field_idx: Integer,
    value: Operand,
}

public struct InstEnumNewPayload {
    dest: ValueId,
    variant_idx: Integer,
    payload: Operand?,
}

public struct InstEnumTagPayload {
    dest: ValueId,
    scrutinee: Operand,
}

public struct InstEnumPayloadPayload {
    dest: ValueId,
    scrutinee: Operand,
}

public struct InstNullWrapPayload {
    dest: ValueId,
    value: Operand,
}

public struct InstNullUnwrapPayload {
    dest: ValueId,
    nullable: Operand,
}

public struct InstNullCheckPayload {
    dest: ValueId,
    nullable: Operand,
}

public struct InstCallLocalPayload {
    dest: ValueId?,
    callee: FuncId,
    args: Vector<Operand>,
}

// Cross-module / witness calls carry an `AbsolutePath` in the
// Rust impl. v0.7.8.1 stores it as a path-segments Vector<String>
// (re-use the same encoding modules.tri uses) — the lowerer can
// reconstruct the `AbsolutePath` shape from this when emitting.
public struct InstCallCrossModulePayload {
    dest: ValueId?,
    path_segments: Vector<String>,
    args: Vector<Operand>,
}

public struct InstWitnessCallPayload {
    dest: ValueId?,
    path_segments: Vector<String>,
    witness_idx: Integer,
    args: Vector<Operand>,
}

public struct InstCallBuiltinPayload {
    dest: ValueId?,
    name: BuiltinName,
    args: Vector<Operand>,
}

public struct InstClosureNewPayload {
    dest: ValueId,
    lambda: FuncId,
    captures: Vector<ValueId>,
}

public struct InstClosureCallPayload {
    dest: ValueId?,
    closure: Operand,
    args: Vector<Operand>,
}

public struct InstBrPayload {
    target: BlockId,
}

public struct InstBrIfPayload {
    cond: Operand,
    then_block: BlockId,
    else_block: BlockId,
}

public struct InstBrTrileanPayload {
    cond: Operand,
    true_block: BlockId,
    unknown_block: BlockId,
    false_block: BlockId,
}

public struct InstRetPayload {
    value: Operand?,
}

public struct InstPhiPayload {
    dest: ValueId,
    incoming: Vector<PhiIncoming>,
}

// Outcome-op shape: dest + source. Used by OutcomeDiscriminant /
// OutcomeUnwrapValue / OutcomeUnwrapError.
public struct InstOutcomeUnaryPayload {
    dest: ValueId,
    source: Operand,
}

// Outcome constructor shape: dest + payload. Used by
// OutcomeNewPositive / OutcomeNewNegative.
public struct InstOutcomeCtorPayload {
    dest: ValueId,
    payload: Operand,
}

public struct InstOutcomeNewNullPayload {
    dest: ValueId,
}

public enum Instruction {
    ConstInst(InstConstPayload),
    AddInst(InstBinaryOpPayload),
    SubInst(InstBinaryOpPayload),
    MulInst(InstBinaryOpPayload),
    DivInst(InstBinaryOpPayload),
    ModInst(InstBinaryOpPayload),
    PowInst(InstPowPayload),
    NegInst(InstUnaryOpPayload),
    LukAndInst(InstBinaryOpPayload),
    LukOrInst(InstBinaryOpPayload),
    LukImpliesInst(InstBinaryOpPayload),
    LukXorInst(InstBinaryOpPayload),
    LukIffInst(InstBinaryOpPayload),
    KleeneImpliesInst(InstBinaryOpPayload),
    KleeneXorInst(InstBinaryOpPayload),
    KleeneIffInst(InstBinaryOpPayload),
    EqInst(InstBinaryOpPayload),
    NeInst(InstBinaryOpPayload),
    LtInst(InstBinaryOpPayload),
    LeInst(InstBinaryOpPayload),
    GtInst(InstBinaryOpPayload),
    GeInst(InstBinaryOpPayload),
    ToIntegerInst(InstUnaryOpPayload),
    ToTryteInst(InstUnaryOpPayload),
    ToLongInst(InstUnaryOpPayload),
    ToTritInst(InstUnaryOpPayload),
    ToTrileanInst(InstUnaryOpPayload),
    StructNewInst(InstStructNewPayload),
    FieldGetInst(InstFieldGetPayload),
    FieldSetInst(InstFieldSetPayload),
    EnumNewInst(InstEnumNewPayload),
    EnumTagInst(InstEnumTagPayload),
    EnumPayloadInst(InstEnumPayloadPayload),
    NullWrapInst(InstNullWrapPayload),
    NullUnwrapInst(InstNullUnwrapPayload),
    NullCheckInst(InstNullCheckPayload),
    CallLocalInst(InstCallLocalPayload),
    CallCrossModuleInst(InstCallCrossModulePayload),
    WitnessCallInst(InstWitnessCallPayload),
    CallBuiltinInst(InstCallBuiltinPayload),
    ClosureNewInst(InstClosureNewPayload),
    ClosureCallInst(InstClosureCallPayload),
    BrInst(InstBrPayload),
    BrIfInst(InstBrIfPayload),
    BrTrileanInst(InstBrTrileanPayload),
    RetInst(InstRetPayload),
    UnreachableInst(PrimitiveMarker),
    PhiInst(InstPhiPayload),
    OutcomeNewPositiveInst(InstOutcomeCtorPayload),
    OutcomeNewNegativeInst(InstOutcomeCtorPayload),
    OutcomeNewNullInst(InstOutcomeNewNullPayload),
    OutcomeDiscriminantInst(InstOutcomeUnaryPayload),
    OutcomeUnwrapValueInst(InstOutcomeUnaryPayload),
    OutcomeUnwrapErrorInst(InstOutcomeUnaryPayload),
}

/// True iff `inst` is a basic-block terminator (Br / BrIf /
/// BrTrilean / Ret / Unreachable). Used by the verifier to assert
/// each block ends with exactly one terminator.
public function instruction_is_terminator(inst: Instruction) -> Trilean! =
    match inst {
        BrInst(_) => true,
        BrIfInst(_) => true,
        BrTrileanInst(_) => true,
        RetInst(_) => true,
        UnreachableInst(_) => true,
        _ => false,
    }

/// Return the destination `ValueId` if `inst` produces a value,
/// `~0` otherwise. Mirrors Rust `Instruction::destination`.
/// Defensive on `Call*` arms: those carry `ValueId?` — when the
/// call's return value is unused we return `~0` (matching Rust's
/// `None` arm).
public function instruction_destination(inst: Instruction) -> ValueId? =
    match inst {
        ConstInst(p) => p.dest,
        AddInst(p) => p.dest,
        SubInst(p) => p.dest,
        MulInst(p) => p.dest,
        DivInst(p) => p.dest,
        ModInst(p) => p.dest,
        PowInst(p) => p.dest,
        NegInst(p) => p.dest,
        LukAndInst(p) => p.dest,
        LukOrInst(p) => p.dest,
        LukImpliesInst(p) => p.dest,
        LukXorInst(p) => p.dest,
        LukIffInst(p) => p.dest,
        KleeneImpliesInst(p) => p.dest,
        KleeneXorInst(p) => p.dest,
        KleeneIffInst(p) => p.dest,
        EqInst(p) => p.dest,
        NeInst(p) => p.dest,
        LtInst(p) => p.dest,
        LeInst(p) => p.dest,
        GtInst(p) => p.dest,
        GeInst(p) => p.dest,
        ToIntegerInst(p) => p.dest,
        ToTryteInst(p) => p.dest,
        ToLongInst(p) => p.dest,
        ToTritInst(p) => p.dest,
        ToTrileanInst(p) => p.dest,
        StructNewInst(p) => p.dest,
        FieldGetInst(p) => p.dest,
        FieldSetInst(p) => p.dest,
        EnumNewInst(p) => p.dest,
        EnumTagInst(p) => p.dest,
        EnumPayloadInst(p) => p.dest,
        NullWrapInst(p) => p.dest,
        NullUnwrapInst(p) => p.dest,
        NullCheckInst(p) => p.dest,
        CallLocalInst(p) => p.dest,
        CallCrossModuleInst(p) => p.dest,
        WitnessCallInst(p) => p.dest,
        CallBuiltinInst(p) => p.dest,
        ClosureNewInst(p) => p.dest,
        ClosureCallInst(p) => p.dest,
        BrInst(_) => ~0,
        BrIfInst(_) => ~0,
        BrTrileanInst(_) => ~0,
        RetInst(_) => ~0,
        UnreachableInst(_) => ~0,
        PhiInst(p) => p.dest,
        OutcomeNewPositiveInst(p) => p.dest,
        OutcomeNewNegativeInst(p) => p.dest,
        OutcomeNewNullInst(p) => p.dest,
        OutcomeDiscriminantInst(p) => p.dest,
        OutcomeUnwrapValueInst(p) => p.dest,
        OutcomeUnwrapErrorInst(p) => p.dest,
    }

/// Opcode discriminator name. Useful for debug dumps + the
/// v0.7.8.6 byte-diff gate.
public function instruction_opcode_name(inst: Instruction) -> String =
    match inst {
        ConstInst(_) => "Const",
        AddInst(_) => "Add",
        SubInst(_) => "Sub",
        MulInst(_) => "Mul",
        DivInst(_) => "Div",
        ModInst(_) => "Mod",
        PowInst(_) => "Pow",
        NegInst(_) => "Neg",
        LukAndInst(_) => "LukAnd",
        LukOrInst(_) => "LukOr",
        LukImpliesInst(_) => "LukImplies",
        LukXorInst(_) => "LukXor",
        LukIffInst(_) => "LukIff",
        KleeneImpliesInst(_) => "KleeneImplies",
        KleeneXorInst(_) => "KleeneXor",
        KleeneIffInst(_) => "KleeneIff",
        EqInst(_) => "Eq",
        NeInst(_) => "Ne",
        LtInst(_) => "Lt",
        LeInst(_) => "Le",
        GtInst(_) => "Gt",
        GeInst(_) => "Ge",
        ToIntegerInst(_) => "ToInteger",
        ToTryteInst(_) => "ToTryte",
        ToLongInst(_) => "ToLong",
        ToTritInst(_) => "ToTrit",
        ToTrileanInst(_) => "ToTrilean",
        StructNewInst(_) => "StructNew",
        FieldGetInst(_) => "FieldGet",
        FieldSetInst(_) => "FieldSet",
        EnumNewInst(_) => "EnumNew",
        EnumTagInst(_) => "EnumTag",
        EnumPayloadInst(_) => "EnumPayload",
        NullWrapInst(_) => "NullWrap",
        NullUnwrapInst(_) => "NullUnwrap",
        NullCheckInst(_) => "NullCheck",
        CallLocalInst(_) => "CallLocal",
        CallCrossModuleInst(_) => "CallCrossModule",
        WitnessCallInst(_) => "WitnessCall",
        CallBuiltinInst(_) => "CallBuiltin",
        ClosureNewInst(_) => "ClosureNew",
        ClosureCallInst(_) => "ClosureCall",
        BrInst(_) => "Br",
        BrIfInst(_) => "BrIf",
        BrTrileanInst(_) => "BrTrilean",
        RetInst(_) => "Ret",
        UnreachableInst(_) => "Unreachable",
        PhiInst(_) => "Phi",
        OutcomeNewPositiveInst(_) => "OutcomeNewPositive",
        OutcomeNewNegativeInst(_) => "OutcomeNewNegative",
        OutcomeNewNullInst(_) => "OutcomeNewNull",
        OutcomeDiscriminantInst(_) => "OutcomeDiscriminant",
        OutcomeUnwrapValueInst(_) => "OutcomeUnwrapValue",
        OutcomeUnwrapErrorInst(_) => "OutcomeUnwrapError",
    }

// ─────────────────────────────────────────────────────────────────
// BasicBlock / Function / IrModule / IrProgram containers.
// Mirrors crates/triet-ir/src/module.rs.
// ─────────────────────────────────────────────────────────────────

public struct BasicBlock {
    id: BlockId,
    name: String?,
    instructions: Vector<Instruction>,
}

public function basic_block_new(id: BlockId, name: String?) -> BasicBlock =
    BasicBlock { id: id, name: name, instructions: new() }

public function basic_block_push(block: BasicBlock, inst: Instruction) -> BasicBlock =
    BasicBlock {
        id: block.id,
        name: block.name,
        instructions: push(block.instructions, inst),
    }

/// Return the terminator instruction if the block ends in one, else
/// `~0`. Used by the verifier to assert well-formedness.
public function basic_block_terminator(block: BasicBlock) -> Instruction? = {
    let total: Integer = length(block.instructions)
    if total == 0 {
        ~0
    } else {
        let last_opt: Instruction? = get(block.instructions, total - 1)
        match last_opt {
            ~0 => ~0,
            _ => {
                let last: Instruction = last_opt!!
                if instruction_is_terminator(last) {
                    last_opt
                } else {
                    ~0
                }
            },
        }
    }
}

/// Function-parameter pair: `(name, type_tag_id)`. Type IDs index
/// the function's owning `IrModule.type_arena`.
public struct IrFunctionParam {
    name: String,
    type_tag_id: Integer,
}

public struct Function {
    id: FuncId,
    name: String?,
    parameters: Vector<IrFunctionParam>,
    return_type_id: Integer,
    blocks: Vector<BasicBlock>,
}

public function function_new(
    id: FuncId,
    name: String?,
    parameters: Vector<IrFunctionParam>,
    return_type_id: Integer,
) -> Function =
    Function {
        id: id,
        name: name,
        parameters: parameters,
        return_type_id: return_type_id,
        blocks: new(),
    }

public function function_push_block(fn: Function, block: BasicBlock) -> Function =
    Function {
        id: fn.id,
        name: fn.name,
        parameters: fn.parameters,
        return_type_id: fn.return_type_id,
        blocks: push(fn.blocks, block),
    }

/// True iff every block ends with a terminator and there's at
/// least one block. Mirrors Rust `Function::is_well_formed`.
public function function_is_well_formed(fn: Function) -> Trilean! = {
    let total: Integer = length(fn.blocks)
    if total == 0 {
        false
    } else {
        let mutable i: Integer = 0
        let mutable all_ok: Trilean! = true
        while i < total {
            let b_opt: BasicBlock? = get(fn.blocks, i)
            let b: BasicBlock = b_opt!!
            match basic_block_terminator(b) {
                ~0 => { all_ok = false },
                _ => { },
            }
            i = i + 1
        }
        all_ok
    }
}

public struct IrModule {
    path_segments: Vector<String>,
    functions: Vector<Function>,
    type_arena: TypeTagArena,
}

public function ir_module_new(path_segments: Vector<String>) -> IrModule =
    IrModule {
        path_segments: path_segments,
        functions: new(),
        type_arena: type_tag_arena_new(),
    }

public function ir_module_push_function(m: IrModule, fn: Function) -> IrModule =
    IrModule {
        path_segments: m.path_segments,
        functions: push(m.functions, fn),
        type_arena: m.type_arena,
    }

public function ir_module_with_type_arena(m: IrModule, arena: TypeTagArena) -> IrModule =
    IrModule {
        path_segments: m.path_segments,
        functions: m.functions,
        type_arena: arena,
    }

/// v0.7.11.2: replace the path segments on an existing IrModule.
/// Used by `lower_program` to patch each module's source-level path
/// over the placeholder `["khi"]` that `lower_module_with_imports`
/// always seeds.
public function ir_module_with_path(m: IrModule, segments: Vector<String>) -> IrModule =
    IrModule {
        path_segments: segments,
        functions: m.functions,
        type_arena: m.type_arena,
    }

/// Witness table — type args bound at link time per ADR-0012. Stub
/// in v0.7.8.1 (carries only the type tag IDs of the
/// instantiation); v0.7.8.{3,4} populate as cross-package generic
/// dispatch lands.
public struct WitnessTable {
    type_args: Vector<Integer>,
}

public struct IrProgram {
    modules: Vector<IrModule>,
    constants: ConstantPool,
    witness_tables: Vector<WitnessTable>,
}

public function ir_program_new() -> IrProgram =
    IrProgram {
        modules: new(),
        constants: constant_pool_new(),
        witness_tables: new(),
    }

public function ir_program_push_module(p: IrProgram, m: IrModule) -> IrProgram =
    IrProgram {
        modules: push(p.modules, m),
        constants: p.constants,
        witness_tables: p.witness_tables,
    }

public function ir_program_with_constants(p: IrProgram, pool: ConstantPool) -> IrProgram =
    IrProgram {
        modules: p.modules,
        constants: pool,
        witness_tables: p.witness_tables,
    }

/// Total function count across all modules. Mirrors Rust
/// `IrProgram::function_count`.
public function ir_program_function_count(p: IrProgram) -> Integer = {
    let mod_total: Integer = length(p.modules)
    let mutable sum: Integer = 0
    let mutable i: Integer = 0
    while i < mod_total {
        let m_opt: IrModule? = get(p.modules, i)
        let m: IrModule = m_opt!!
        sum = sum + length(m.functions)
        i = i + 1
    }
    sum
}

// ─────────────────────────────────────────────────────────────────
// Smoke main — exercises ID display, TypeTag construction +
// display, Constant + ConstantPool, every Instruction variant
// constructor, BasicBlock / Function / IrModule / IrProgram
// container builders + terminator detection + function well-
// formedness. The v0.7.8.1 integration test
// (`ir_lowerer_types_smoke.rs`) confirms the surface compiles +
// round-trips through the VM. v0.7.8.{2..6} build the actual
// `lower_program` driver on top.
// ─────────────────────────────────────────────────────────────────

function assert_string_eq(actual: String, expected: String) -> Unit =
    assert(actual == expected)

function assert_some_value_id(opt: ValueId?, expected_raw: Integer) -> Unit =
    match opt {
        ~0 => assert(false),
        _ => assert(opt!!.raw == expected_raw),
    }

function assert_none_value_id(opt: ValueId?) -> Unit =
    match opt {
        ~0 => assert(true),
        _ => assert(false),
    }

// ═════════════════════════════════════════════════════════════════
// v0.7.8.2 — Literal + binding + control-flow lowering
//
// Implements the bottom of the `lower_program` driver per ADR-0019
// §A7.8: the LowerCtx state thread + minimal expression / statement
// lowering set so the smoke can lower simple programs end-to-end.
//
// In-scope at v0.7.8.2:
//   - Literals: Integer / Trit (TernaryLiteral) / Trilean / String / Null
//   - Identifier (parameter + let-bound lookup via scope stack)
//   - Binary ops: arithmetic (Add/Sub/Mul/Div/Mod/Pow) + comparisons
//     (Eq/Ne/Lt/Le/Gt/Ge) + Ł3 logic (And/Or/Xor/Iff/Implies) + K3
//     logic (KleeneXor/KleeneIff/KleeneImplies)
//   - Unary: Negate
//   - Force unwrap (`!!`): emits `NullUnwrap`
//   - Statements: Let / Constant / Return / ExpressionStmt
//   - Block lowering: statements in order + final expr
//   - Function lowering: entry block + parameter ValueId allocation
//     + body emission + auto-Ret if body didn't terminate
//   - Top-level lower_program driver: pass-1a struct/enum declare
//     (stub), pass-1b FuncId assignment, pass-2 body lowering
//   - `lower_source(source) -> IrProgram` convenience for smoke tests
//
// Deferred to v0.7.8.3:
//   - Function calls (CallLocal / CallCrossModule / CallBuiltin)
//   - Method calls + builtin dispatch table
//   - While / For / Loop / Break / Continue / Assign — these need
//     phi-node insertion + LoopContext stack tracking (ADR-0023
//     ValueKind propagation also lands then)
//
// Deferred to v0.7.8.4:
//   - Struct / Enum / Pattern / Outcome opcodes
//   - StructLiteral / EnumLiteral / Match
//
// ═════════════════════════════════════════════════════════════════

// ── LowerCtx — threaded state ────────────────────────────────────
//
// Functional-update style (mirrors typecheck.tri's CheckerState).
// Every lowering helper takes a `LowerCtx` and returns either an
// updated `LowerCtx` directly (for statement-style helpers) or a
// `LowerExprResult { ctx, value_id }` pair (for expression-style
// helpers that produce a value).

public struct Scope {
    bindings: HashMap<String, ValueId>,
}

public function scope_new() -> Scope =
    Scope { bindings: hashmap_new() }

// LoopContext — break/continue branch targets for the active loop.
// Pushed onto LowerCtx.loop_stack on loop entry, popped on exit.
public struct LoopContext {
    break_target: BlockId,
    continue_target: BlockId,
}

// v0.7.8.4: per-enum variant resolution. Looking up a bare
// variant name (e.g. `Some` in `enum Option { None, Some(I) }`)
// returns the parent enum name + 0-based variant index, so the
// lowerer can emit `EnumNew { variant_idx, … }`.
public struct VariantInfo {
    enum_name: String,
    variant_idx: Integer,
}

public struct LowerCtx {
    parser_arena: Arena,
    value_counter: Integer,
    block_counter: Integer,
    blocks: Vector<BasicBlock>,
    current_block_idx: Integer,
    scopes: Vector<Scope>,
    type_arena: TypeTagArena,
    constants: ConstantPool,
    return_type_id: Integer,
    // v0.7.8.3: function table for CallExpr → CallLocal. Keyed by
    // bare function name. Populated by lower_module's pass-1 sweep
    // before any body lowering begins so forward calls resolve.
    func_table: HashMap<String, FuncId>,
    // v0.7.8.3: loop nesting stack for Break/Continue branch
    // resolution. Innermost active loop is top of stack.
    loop_stack: Vector<LoopContext>,
    // v0.7.8.4: struct-name → ordered field-name vector. Resolves
    // `FieldGet`'s `field_idx` from the source-level field name.
    struct_fields: HashMap<String, Vector<String>>,
    // v0.7.8.4: bare variant name → owning enum + position.
    // Bare-identifier callee form (`Some(42)`) and tuple-variant
    // call resolution land alongside StructLiteral parser surface
    // in v0.7.8.4+.
    variant_index: HashMap<String, VariantInfo>,
    // v0.7.8.4: enum-name → ordered variant-name vector. Mirrors
    // `struct_fields` shape so the same `EnumTag` resolution flow
    // can index into it.
    enum_variants: HashMap<String, Vector<String>>,
    // v0.7.10 (post-audit fix): bare imported name → full
    // dot-separated absolute path (e.g. `"get"` → `"std.env.get"`).
    // Populated from `Module.bindings` by the multi-module
    // `lower_program` driver. Empty for single-source `lower_source`
    // smoke tests — those fall back to bare-name builtin match.
    // Mirrors Rust's lowerer.rs:3106 `current_module().bindings`
    // lookup so two builtins sharing the same bare name (`get` ↔
    // `VectorGet` vs `EnvGet`) disambiguate by their import path.
    import_paths: HashMap<String, String>,
}

public function lower_ctx_new(parser_arena: Arena) -> LowerCtx = {
    let mutable scopes: Vector<Scope> = new()
    scopes = push(scopes, scope_new())
    LowerCtx {
        parser_arena: parser_arena,
        value_counter: 0,
        block_counter: 0,
        blocks: new(),
        current_block_idx: 0,
        scopes: scopes,
        type_arena: type_tag_arena_new(),
        constants: constant_pool_new(),
        return_type_id: 0,
        func_table: hashmap_new(),
        loop_stack: new(),
        struct_fields: hashmap_new(),
        variant_index: hashmap_new(),
        enum_variants: hashmap_new(),
        import_paths: hashmap_new(),
    }
}

public struct LowerExprResult {
    ctx: LowerCtx,
    value_id: ValueId,
}

// ── Functional-update setters ────────────────────────────────────

function ctx_with_value_counter(ctx: LowerCtx, n: Integer) -> LowerCtx =
    LowerCtx {
        parser_arena: ctx.parser_arena,
        value_counter: n,
        block_counter: ctx.block_counter,
        blocks: ctx.blocks,
        current_block_idx: ctx.current_block_idx,
        scopes: ctx.scopes,
        type_arena: ctx.type_arena,
        constants: ctx.constants,
        return_type_id: ctx.return_type_id,
        func_table: ctx.func_table,
        loop_stack: ctx.loop_stack,
        struct_fields: ctx.struct_fields,
        variant_index: ctx.variant_index,
        enum_variants: ctx.enum_variants,
        import_paths: ctx.import_paths,
    }

function ctx_with_block_counter(ctx: LowerCtx, n: Integer) -> LowerCtx =
    LowerCtx {
        parser_arena: ctx.parser_arena,
        value_counter: ctx.value_counter,
        block_counter: n,
        blocks: ctx.blocks,
        current_block_idx: ctx.current_block_idx,
        scopes: ctx.scopes,
        type_arena: ctx.type_arena,
        constants: ctx.constants,
        return_type_id: ctx.return_type_id,
        func_table: ctx.func_table,
        loop_stack: ctx.loop_stack,
        struct_fields: ctx.struct_fields,
        variant_index: ctx.variant_index,
        enum_variants: ctx.enum_variants,
        import_paths: ctx.import_paths,
    }

function ctx_with_blocks(ctx: LowerCtx, blocks: Vector<BasicBlock>) -> LowerCtx =
    LowerCtx {
        parser_arena: ctx.parser_arena,
        value_counter: ctx.value_counter,
        block_counter: ctx.block_counter,
        blocks: blocks,
        current_block_idx: ctx.current_block_idx,
        scopes: ctx.scopes,
        type_arena: ctx.type_arena,
        constants: ctx.constants,
        return_type_id: ctx.return_type_id,
        func_table: ctx.func_table,
        loop_stack: ctx.loop_stack,
        struct_fields: ctx.struct_fields,
        variant_index: ctx.variant_index,
        enum_variants: ctx.enum_variants,
        import_paths: ctx.import_paths,
    }

function ctx_with_current_block(ctx: LowerCtx, idx: Integer) -> LowerCtx =
    LowerCtx {
        parser_arena: ctx.parser_arena,
        value_counter: ctx.value_counter,
        block_counter: ctx.block_counter,
        blocks: ctx.blocks,
        current_block_idx: idx,
        scopes: ctx.scopes,
        type_arena: ctx.type_arena,
        constants: ctx.constants,
        return_type_id: ctx.return_type_id,
        func_table: ctx.func_table,
        loop_stack: ctx.loop_stack,
        struct_fields: ctx.struct_fields,
        variant_index: ctx.variant_index,
        enum_variants: ctx.enum_variants,
        import_paths: ctx.import_paths,
    }

function ctx_with_scopes(ctx: LowerCtx, scopes: Vector<Scope>) -> LowerCtx =
    LowerCtx {
        parser_arena: ctx.parser_arena,
        value_counter: ctx.value_counter,
        block_counter: ctx.block_counter,
        blocks: ctx.blocks,
        current_block_idx: ctx.current_block_idx,
        scopes: scopes,
        type_arena: ctx.type_arena,
        constants: ctx.constants,
        return_type_id: ctx.return_type_id,
        func_table: ctx.func_table,
        loop_stack: ctx.loop_stack,
        struct_fields: ctx.struct_fields,
        variant_index: ctx.variant_index,
        enum_variants: ctx.enum_variants,
        import_paths: ctx.import_paths,
    }

function ctx_with_type_arena(ctx: LowerCtx, ta: TypeTagArena) -> LowerCtx =
    LowerCtx {
        parser_arena: ctx.parser_arena,
        value_counter: ctx.value_counter,
        block_counter: ctx.block_counter,
        blocks: ctx.blocks,
        current_block_idx: ctx.current_block_idx,
        scopes: ctx.scopes,
        type_arena: ta,
        constants: ctx.constants,
        return_type_id: ctx.return_type_id,
        func_table: ctx.func_table,
        loop_stack: ctx.loop_stack,
        struct_fields: ctx.struct_fields,
        variant_index: ctx.variant_index,
        enum_variants: ctx.enum_variants,
        import_paths: ctx.import_paths,
    }

