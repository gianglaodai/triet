// ── Fresh ValueId / BlockId ──────────────────────────────────────

function fresh_value(ctx: LowerCtx) -> LowerExprResult = {
    let n: Integer = ctx.value_counter
    let new_ctx: LowerCtx = ctx_with_value_counter(ctx, n + 1)
    LowerExprResult { ctx: new_ctx, value_id: ValueId { raw: n } }
}

public struct FreshBlockResult {
    ctx: LowerCtx,
    block_id: BlockId,
}

function fresh_block(ctx: LowerCtx) -> FreshBlockResult = {
    let n: Integer = ctx.block_counter
    let new_ctx: LowerCtx = ctx_with_block_counter(ctx, n + 1)
    FreshBlockResult { ctx: new_ctx, block_id: BlockId { raw: n } }
}

// ── Block management ─────────────────────────────────────────────

// Start a new block: append a fresh BasicBlock to `ctx.blocks` and
// set `current_block_idx` to its index. Subsequent `emit` calls
// push into this block until another `start_block` runs.
function start_block(ctx: LowerCtx, id: BlockId, name: String?) -> LowerCtx = {
    let bb: BasicBlock = basic_block_new(id, name)
    let new_blocks: Vector<BasicBlock> = push(ctx.blocks, bb)
    let new_idx: Integer = length(new_blocks) - 1
    ctx_with_current_block(ctx_with_blocks(ctx, new_blocks), new_idx)
}

// Append an instruction to the current block. Rebuild the blocks
// vector since Triết Vectors are immutable.
function emit(ctx: LowerCtx, inst: Instruction) -> LowerCtx = {
    let total: Integer = length(ctx.blocks)
    let mutable new_blocks: Vector<BasicBlock> = new()
    let mutable i: Integer = 0
    while i < total {
        let b_opt: BasicBlock? = get(ctx.blocks, i)
        let b: BasicBlock = b_opt!!
        if i == ctx.current_block_idx {
            new_blocks = push(new_blocks, basic_block_push(b, inst))
        } else {
            new_blocks = push(new_blocks, b)
        }
        i = i + 1
    }
    ctx_with_blocks(ctx, new_blocks)
}

// True iff the current block already ends with a terminator. Used
// to skip auto-`Ret` emission when the body's final expression
// path already terminated explicitly.
function current_block_has_terminator(ctx: LowerCtx) -> Trilean! = {
    let b_opt: BasicBlock? = get(ctx.blocks, ctx.current_block_idx)
    match b_opt {
        ~0 => false,
        _ => {
            match basic_block_terminator(b_opt!!) {
                ~0 => false,
                _ => true,
            }
        },
    }
}

// ── Scope / variable binding ─────────────────────────────────────

function push_scope(ctx: LowerCtx) -> LowerCtx =
    ctx_with_scopes(ctx, push(ctx.scopes, scope_new()))

function pop_scope(ctx: LowerCtx) -> LowerCtx = {
    let total: Integer = length(ctx.scopes)
    if total <= 1 {
        ctx
    } else {
        let mutable rebuilt: Vector<Scope> = new()
        let mutable i: Integer = 0
        while i < total - 1 {
            let s_opt: Scope? = get(ctx.scopes, i)
            rebuilt = push(rebuilt, s_opt!!)
            i = i + 1
        }
        ctx_with_scopes(ctx, rebuilt)
    }
}

// Insert `name → value` into the innermost scope.
function bind_var(ctx: LowerCtx, name: String, value: ValueId) -> LowerCtx = {
    let total: Integer = length(ctx.scopes)
    if total == 0 {
        ctx
    } else {
        let top_opt: Scope? = get(ctx.scopes, total - 1)
        let top: Scope = top_opt!!
        let updated_map: HashMap<String, ValueId> = insert(top.bindings, name, value)
        let updated_top: Scope = Scope { bindings: updated_map }
        let mutable rebuilt: Vector<Scope> = new()
        let mutable i: Integer = 0
        while i < total - 1 {
            let s_opt: Scope? = get(ctx.scopes, i)
            rebuilt = push(rebuilt, s_opt!!)
            i = i + 1
        }
        rebuilt = push(rebuilt, updated_top)
        ctx_with_scopes(ctx, rebuilt)
    }
}

// Look up `name`, walking scopes innermost-first. Returns `~0` if
// unbound (caller can emit a placeholder fresh_value).
function resolve_var(ctx: LowerCtx, name: String) -> ValueId? = {
    let total: Integer = length(ctx.scopes)
    let mutable found: ValueId? = ~0
    let mutable i: Integer = total
    while i > 0 {
        i = i - 1
        let s_opt: Scope? = get(ctx.scopes, i)
        let s: Scope = s_opt!!
        let v_opt: ValueId? = hashmap_get(s.bindings, name)
        match v_opt {
            ~0 => { },
            _ => {
                match found {
                    ~0 => { found = v_opt },
                    _ => { },
                }
            },
        }
    }
    found
}

// ── TypeExpr → TypeTag resolver (minimal subset) ─────────────────
//
// v0.7.8.2 covers NamedType primitives + NullableType wrapper. Full
// generic / outcome / function resolution lands with the rest of
// the lowerer infrastructure in v0.7.8.{3,4}.

public struct ResolveTagResult {
    ctx: LowerCtx,
    tag_id: Integer,
}

function resolve_type_expr_to_tag(ctx: LowerCtx, type_expr_id: Integer) -> ResolveTagResult = {
    let spanned: SpannedTypeExpr = get_type_expr(ctx.parser_arena, type_expr_id)
    match spanned.node {
        NamedType(p) => resolve_named_type_tag(ctx, p.name),
        NullableType(inner_id) => {
            let inner_r: ResolveTagResult = resolve_type_expr_to_tag(ctx, inner_id)
            let r: AllocTagResult = alloc_tag_nullable(inner_r.ctx.type_arena, inner_r.tag_id)
            ResolveTagResult {
                ctx: ctx_with_type_arena(inner_r.ctx, r.arena),
                tag_id: r.tag_id,
            }
        },
        RefinedTrileanType => {
            let r: AllocTagResult = alloc_tag_trilean(ctx.type_arena)
            ResolveTagResult {
                ctx: ctx_with_type_arena(ctx, r.arena),
                tag_id: r.tag_id,
            }
        },
        // Unknown / generic / tuple / function / outcome → Unit
        // placeholder. v0.7.8.{3,4} fills these in.
        _ => {
            let r: AllocTagResult = alloc_tag_unit(ctx.type_arena)
            ResolveTagResult {
                ctx: ctx_with_type_arena(ctx, r.arena),
                tag_id: r.tag_id,
            }
        },
    }
}

function resolve_named_type_tag(ctx: LowerCtx, name: String) -> ResolveTagResult = {
    if name == "Integer" {
        let r: AllocTagResult = alloc_tag_integer(ctx.type_arena)
        return ResolveTagResult { ctx: ctx_with_type_arena(ctx, r.arena), tag_id: r.tag_id }
    }
    if name == "String" {
        let r: AllocTagResult = alloc_tag_string(ctx.type_arena)
        return ResolveTagResult { ctx: ctx_with_type_arena(ctx, r.arena), tag_id: r.tag_id }
    }
    if name == "Trit" {
        let r: AllocTagResult = alloc_tag_trit(ctx.type_arena)
        return ResolveTagResult { ctx: ctx_with_type_arena(ctx, r.arena), tag_id: r.tag_id }
    }
    if name == "Tryte" {
        let r: AllocTagResult = alloc_tag_tryte(ctx.type_arena)
        return ResolveTagResult { ctx: ctx_with_type_arena(ctx, r.arena), tag_id: r.tag_id }
    }
    if name == "Long" {
        let r: AllocTagResult = alloc_tag_long(ctx.type_arena)
        return ResolveTagResult { ctx: ctx_with_type_arena(ctx, r.arena), tag_id: r.tag_id }
    }
    if name == "Trilean" {
        let r: AllocTagResult = alloc_tag_trilean(ctx.type_arena)
        return ResolveTagResult { ctx: ctx_with_type_arena(ctx, r.arena), tag_id: r.tag_id }
    }
    if name == "Unit" {
        let r: AllocTagResult = alloc_tag_unit(ctx.type_arena)
        return ResolveTagResult { ctx: ctx_with_type_arena(ctx, r.arena), tag_id: r.tag_id }
    }
    // Unknown user type — Unit placeholder for v0.7.8.2.
    let r: AllocTagResult = alloc_tag_unit(ctx.type_arena)
    ResolveTagResult { ctx: ctx_with_type_arena(ctx, r.arena), tag_id: r.tag_id }
}

// ── Constant interning ───────────────────────────────────────────

public struct InternCtxResult {
    ctx: LowerCtx,
    const_id: ConstId,
}

function intern_constant(ctx: LowerCtx, c: Constant) -> InternCtxResult = {
    let r: InternResult = constant_pool_intern(ctx.constants, c)
    InternCtxResult { ctx: ctx_with_constants(ctx, r.pool), const_id: r.id }
}

// ── Expression lowering ──────────────────────────────────────────

function lower_integer_literal(ctx: LowerCtx, lit: IntLiteral) -> LowerExprResult = {
    let payload: ConstantIntegerPayload = ConstantIntegerPayload { value: lit.value }
    let c: Constant = IntegerConst(payload)
    let intern_r: InternCtxResult = intern_constant(ctx, c)
    let dest_r: LowerExprResult = fresh_value(intern_r.ctx)
    let inst: Instruction = ConstInst(InstConstPayload {
        dest: dest_r.value_id,
        const_id: intern_r.const_id,
    })
    let final_ctx: LowerCtx = emit(dest_r.ctx, inst)
    LowerExprResult { ctx: final_ctx, value_id: dest_r.value_id }
}

function lower_trilean_literal(ctx: LowerCtx, tv: TrileanValue) -> LowerExprResult = {
    let value: Trilean = match tv {
        TrueValue => true,
        FalseValue => false,
        UnknownValue => unknown,
    }
    let c: Constant = TrileanConst(ConstantTrileanPayload { value: value })
    let intern_r: InternCtxResult = intern_constant(ctx, c)
    let dest_r: LowerExprResult = fresh_value(intern_r.ctx)
    let inst: Instruction = ConstInst(InstConstPayload {
        dest: dest_r.value_id,
        const_id: intern_r.const_id,
    })
    LowerExprResult { ctx: emit(dest_r.ctx, inst), value_id: dest_r.value_id }
}

function lower_string_literal(ctx: LowerCtx, text: String) -> LowerExprResult = {
    let c: Constant = StringConst(ConstantStringPayload { value: text })
    let intern_r: InternCtxResult = intern_constant(ctx, c)
    let dest_r: LowerExprResult = fresh_value(intern_r.ctx)
    let inst: Instruction = ConstInst(InstConstPayload {
        dest: dest_r.value_id,
        const_id: intern_r.const_id,
    })
    LowerExprResult { ctx: emit(dest_r.ctx, inst), value_id: dest_r.value_id }
}

function lower_null_literal(ctx: LowerCtx) -> LowerExprResult = {
    let c: Constant = NullConst(primitive_marker())
    let intern_r: InternCtxResult = intern_constant(ctx, c)
    let dest_r: LowerExprResult = fresh_value(intern_r.ctx)
    let inst: Instruction = ConstInst(InstConstPayload {
        dest: dest_r.value_id,
        const_id: intern_r.const_id,
    })
    LowerExprResult { ctx: emit(dest_r.ctx, inst), value_id: dest_r.value_id }
}

function lower_identifier(ctx: LowerCtx, name: String) -> LowerExprResult = {
    let v_opt: ValueId? = resolve_var(ctx, name)
    match v_opt {
        ~0 => {
            // v0.7.8.4: bare-identifier referring to a unit enum
            // variant (e.g. `None` in `enum Option { None, Some(I) }`).
            // The parser leaves it as `IdentifierExpr`; we promote
            // to `EnumNew { variant_idx, payload: ~0 }`. Mirrors
            // Rust lowerer.rs:1015-1033.
            match hashmap_get(ctx.variant_index, name) {
                ~0 => fresh_value(ctx),
                _ => {
                    let info: VariantInfo = hashmap_get(ctx.variant_index, name)!!
                    let dest_r: LowerExprResult = fresh_value(ctx)
                    let inst: Instruction = EnumNewInst(InstEnumNewPayload {
                        dest: dest_r.value_id,
                        variant_idx: info.variant_idx,
                        payload: ~0,
                    })
                    LowerExprResult { ctx: emit(dest_r.ctx, inst), value_id: dest_r.value_id }
                },
            }
        },
        _ => LowerExprResult { ctx: ctx, value_id: v_opt!! },
    }
}

// Map a parser BinaryOperator to the corresponding Instruction
// constructor. Each branch returns a function-application-shaped
// builder taking the binary-op payload.
function lower_binary_op_inst(
    op: BinaryOperator,
    payload: InstBinaryOpPayload,
    pow_payload: InstPowPayload,
) -> Instruction =
    match op {
        Add => AddInst(payload),
        Subtract => SubInst(payload),
        Multiply => MulInst(payload),
        Divide => DivInst(payload),
        Modulo => ModInst(payload),
        Power => PowInst(pow_payload),
        Equal => EqInst(payload),
        NotEqual => NeInst(payload),
        LessThan => LtInst(payload),
        LessEqual => LeInst(payload),
        GreaterThan => GtInst(payload),
        GreaterEqual => GeInst(payload),
        And => LukAndInst(payload),
        Or => LukOrInst(payload),
        Xor => LukXorInst(payload),
        Iff => LukIffInst(payload),
        Implies => LukImpliesInst(payload),
        KleeneXor => KleeneXorInst(payload),
        KleeneIff => KleeneIffInst(payload),
        KleeneImplies => KleeneImpliesInst(payload),
    }

function lower_binary_op(
    ctx: LowerCtx,
    op: BinaryOperator,
    left_id: Integer,
    right_id: Integer,
) -> LowerExprResult = {
    let left_r: LowerExprResult = lower_expression(ctx, left_id)
    let right_r: LowerExprResult = lower_expression(left_r.ctx, right_id)
    let dest_r: LowerExprResult = fresh_value(right_r.ctx)
    let lhs_op: Operand = ValueOp(left_r.value_id)
    let rhs_op: Operand = ValueOp(right_r.value_id)
    let bin_payload: InstBinaryOpPayload = InstBinaryOpPayload {
        dest: dest_r.value_id,
        lhs: lhs_op,
        rhs: rhs_op,
    }
    let pow_payload: InstPowPayload = InstPowPayload {
        dest: dest_r.value_id,
        base: lhs_op,
        exp: rhs_op,
    }
    let inst: Instruction = lower_binary_op_inst(op, bin_payload, pow_payload)
    LowerExprResult { ctx: emit(dest_r.ctx, inst), value_id: dest_r.value_id }
}

function lower_unary_op(
    ctx: LowerCtx,
    op: UnaryOperator,
    operand_id: Integer,
) -> LowerExprResult = {
    let operand_r: LowerExprResult = lower_expression(ctx, operand_id)
    let dest_r: LowerExprResult = fresh_value(operand_r.ctx)
    let payload: InstUnaryOpPayload = InstUnaryOpPayload {
        dest: dest_r.value_id,
        operand: ValueOp(operand_r.value_id),
    }
    // v0.7.8.2 only has Negate; future v0.7.8.3+ can add conversions.
    let inst: Instruction = match op {
        Negate => NegInst(payload),
    }
    LowerExprResult { ctx: emit(dest_r.ctx, inst), value_id: dest_r.value_id }
}

function lower_force_unwrap(ctx: LowerCtx, inner_id: Integer) -> LowerExprResult = {
    let inner_r: LowerExprResult = lower_expression(ctx, inner_id)
    let dest_r: LowerExprResult = fresh_value(inner_r.ctx)
    let inst: Instruction = NullUnwrapInst(InstNullUnwrapPayload {
        dest: dest_r.value_id,
        nullable: ValueOp(inner_r.value_id),
    })
    LowerExprResult { ctx: emit(dest_r.ctx, inst), value_id: dest_r.value_id }
}

// ── Builtin-name resolution ──────────────────────────────────────
//
// Two-stage dispatch mirroring Rust's `path_to_builtin`
// (`crates/triet-ir/src/vm.rs:1717`) + `resolve_builtin`
// (`crates/triet-ir/src/lowerer.rs:3158`):
//
//   1. **Path-based** (v0.7.10 post-audit fix): look up the bare
//      identifier in `LowerCtx.import_paths` to recover the fully-
//      qualified absolute path (e.g. `"get"` → `"std.env.get"`),
//      then match the full path against the known stdlib catalog.
//      Disambiguates collisions like `get` ↔ `VectorGet` vs `EnvGet`.
//   2. **Bare-name fallback** (single-source / prelude case): when
//      no binding is present, fall back to bare-name match. Matches
//      existing smoke-test behavior where `lower_source` programs
//      use stdlib helpers without explicit imports.

/// Resolve a builtin by fully-qualified absolute path (e.g.
/// `"std.env.get"`). Mirrors Rust's `path_to_builtin` arms.
function resolve_builtin_by_path(path: String) -> BuiltinName? = {
    if path == "std.io.println" { return PrintlnBuiltin(primitive_marker()) }
    if path == "std.io.print" { return PrintBuiltin(primitive_marker()) }
    if path == "std.assert.assert" { return AssertBuiltin(primitive_marker()) }
    if path == "std.assert.assert_eq" { return AssertEqBuiltin(primitive_marker()) }
    if path == "std.text.len" { return TextLenBuiltin(primitive_marker()) }
    if path == "std.text.concat" { return TextConcatBuiltin(primitive_marker()) }
    if path == "std.text.from_integer" { return TextFromIntegerBuiltin(primitive_marker()) }
    if path == "std.collections.vector.new" { return VectorNewBuiltin(primitive_marker()) }
    if path == "std.collections.vector.push" { return VectorPushBuiltin(primitive_marker()) }
    if path == "std.collections.vector.get" { return VectorGetBuiltin(primitive_marker()) }
    if path == "std.collections.vector.length" { return VectorLengthBuiltin(primitive_marker()) }
    if path == "std.collections.hashmap.new" { return HashMapNewBuiltin(primitive_marker()) }
    if path == "std.collections.hashmap.insert" { return HashMapInsertBuiltin(primitive_marker()) }
    if path == "std.collections.hashmap.get" { return HashMapGetBuiltin(primitive_marker()) }
    if path == "std.collections.hashmap.keys" { return HashMapKeysBuiltin(primitive_marker()) }
    if path == "std.collections.hashmap.contains" { return HashMapContainsBuiltin(primitive_marker()) }
    if path == "std.io.fs.read" { return ReadFileBuiltin(primitive_marker()) }
    if path == "std.io.fs.write" { return WriteFileBuiltin(primitive_marker()) }
    if path == "std.io.fs.write_bytes" { return WriteFileBytesBuiltin(primitive_marker()) }
    if path == "std.io.fs.exists" { return FileExistsBuiltin(primitive_marker()) }
    if path == "std.path.join" { return PathJoinBuiltin(primitive_marker()) }
    if path == "std.path.parent" { return PathParentBuiltin(primitive_marker()) }
    if path == "std.path.basename" { return PathBasenameBuiltin(primitive_marker()) }
    if path == "std.string.substring" { return StringSubstringBuiltin(primitive_marker()) }
    if path == "std.string.split" { return StringSplitBuiltin(primitive_marker()) }
    if path == "std.string.index_of" { return StringIndexOfBuiltin(primitive_marker()) }
    if path == "std.text.parse_integer" { return ParseIntegerBuiltin(primitive_marker()) }
    if path == "std.text.into_bytes" { return TextIntoBytesBuiltin(primitive_marker()) }
    if path == "std.text.from_bytes" { return TextFromBytesBuiltin(primitive_marker()) }
    if path == "std.crypto.blake3_hash" { return Blake3HashBuiltin(primitive_marker()) }
    if path == "std.env.get" { return EnvGetBuiltin(primitive_marker()) }
    ~0
}

/// Resolve a builtin from a bare identifier. Consults `import_paths`
/// first to disambiguate collisions; falls back to bare-name match
/// when no binding is present.
function resolve_builtin_name(name: String, import_paths: HashMap<String, String>) -> BuiltinName? = {
    // Stage 1: path-based dispatch (multi-module / import-bound).
    let full_opt: String? = hashmap_get(import_paths, name)
    match full_opt {
        ~0 => { },
        _ => {
            let by_path: BuiltinName? = resolve_builtin_by_path(full_opt!!)
            match by_path {
                ~0 => { },
                _ => { return by_path },
            }
        },
    }

    // Stage 2: bare-name fallback. `get` here resolves to VectorGet
    // (the bootstrap-test consumer at this stage); `std.env.get`
    // requires an explicit import and lands via Stage 1.
    if name == "println" { return PrintlnBuiltin(primitive_marker()) }
    if name == "print" { return PrintBuiltin(primitive_marker()) }
    if name == "assert" { return AssertBuiltin(primitive_marker()) }
    if name == "assert_eq" { return AssertEqBuiltin(primitive_marker()) }
    if name == "len" { return TextLenBuiltin(primitive_marker()) }
    if name == "concat" { return TextConcatBuiltin(primitive_marker()) }
    if name == "from_integer" { return TextFromIntegerBuiltin(primitive_marker()) }
    if name == "new" { return VectorNewBuiltin(primitive_marker()) }
    if name == "push" { return VectorPushBuiltin(primitive_marker()) }
    if name == "get" { return VectorGetBuiltin(primitive_marker()) }
    if name == "length" { return VectorLengthBuiltin(primitive_marker()) }
    if name == "hashmap_new" { return HashMapNewBuiltin(primitive_marker()) }
    if name == "insert" { return HashMapInsertBuiltin(primitive_marker()) }
    if name == "hashmap_get" { return HashMapGetBuiltin(primitive_marker()) }
    if name == "keys" { return HashMapKeysBuiltin(primitive_marker()) }
    if name == "contains" { return HashMapContainsBuiltin(primitive_marker()) }
    if name == "read" { return ReadFileBuiltin(primitive_marker()) }
    if name == "write" { return WriteFileBuiltin(primitive_marker()) }
    if name == "write_bytes" { return WriteFileBytesBuiltin(primitive_marker()) }
    if name == "exists" { return FileExistsBuiltin(primitive_marker()) }
    if name == "join" { return PathJoinBuiltin(primitive_marker()) }
    if name == "parent" { return PathParentBuiltin(primitive_marker()) }
    if name == "basename" { return PathBasenameBuiltin(primitive_marker()) }
    if name == "substring" { return StringSubstringBuiltin(primitive_marker()) }
    if name == "split" { return StringSplitBuiltin(primitive_marker()) }
    if name == "index_of" { return StringIndexOfBuiltin(primitive_marker()) }
    if name == "parse_integer" { return ParseIntegerBuiltin(primitive_marker()) }
    if name == "into_bytes" { return TextIntoBytesBuiltin(primitive_marker()) }
    if name == "from_bytes" { return TextFromBytesBuiltin(primitive_marker()) }
    ~0
}

// ── Call lowering ────────────────────────────────────────────────
//
// Mirrors `lower_call` in the Rust lowerer (lines 2980-3068).
// Dispatch order:
//   1. Identifier callee → builtin match (println / assert / etc.)
//   2. Identifier callee → local-function table (CallLocal)
//   3. Otherwise: emit placeholder fresh value (closure / cross-
//      module dispatch defers to v0.7.8.{4,5}).

function lower_call(ctx: LowerCtx, call: CallPayload) -> LowerExprResult = {
    // Lower argument values first; threaded ctx accumulates emissions.
    let mutable st: LowerCtx = ctx
    let mutable arg_ops: Vector<Operand> = new()
    let arg_total: Integer = length(call.arguments)
    let mutable i: Integer = 0
    while i < arg_total {
        let aid_opt: Integer? = get(call.arguments, i)
        let arg_r: LowerExprResult = lower_expression(st, aid_opt!!)
        st = arg_r.ctx
        arg_ops = push(arg_ops, ValueOp(arg_r.value_id))
        i = i + 1
    }

    // Resolve callee: only bare Identifier supported at v0.7.8.3.
    let callee_spanned: SpannedExpr = get_expression(st.parser_arena, call.callee)
    let callee_name: String = match callee_spanned.node {
        IdentifierExpr(sp) => sp.text,
        _ => "",
    }

    // v0.7.8.4: tuple-variant promotion. `Some(42)` parses as
    // `CallExpr { callee: Identifier("Some"), args: [42] }`; the
    // type-checker resolves it but the parser doesn't rewrite the
    // node. Promote to `EnumNew` here so the IR carries proper
    // variant identity. Mirrors lowerer.rs:2996-3005.
    match hashmap_get(st.variant_index, callee_name) {
        ~0 => { },
        _ => {
            let info: VariantInfo = hashmap_get(st.variant_index, callee_name)!!
            let mutable payload_opt: Operand? = ~0
            if arg_total > 0 {
                payload_opt = get(arg_ops, 0)
            }
            let dest_r: LowerExprResult = fresh_value(st)
            let inst: Instruction = EnumNewInst(InstEnumNewPayload {
                dest: dest_r.value_id,
                variant_idx: info.variant_idx,
                payload: payload_opt,
            })
            return LowerExprResult { ctx: emit(dest_r.ctx, inst), value_id: dest_r.value_id }
        },
    }

    // Builtin path first — matches Rust precedence.
    let builtin_opt: BuiltinName? = resolve_builtin_name(callee_name, st.import_paths)
    match builtin_opt {
        ~0 => { },
        _ => {
            let dest_r: LowerExprResult = fresh_value(st)
            let inst: Instruction = CallBuiltinInst(InstCallBuiltinPayload {
                dest: dest_r.value_id,
                name: builtin_opt!!,
                args: arg_ops,
            })
            return LowerExprResult { ctx: emit(dest_r.ctx, inst), value_id: dest_r.value_id }
        },
    }

    // Local function table.
    match hashmap_get(st.func_table, callee_name) {
        ~0 => { },
        _ => {
            let func_id_opt: FuncId? = hashmap_get(st.func_table, callee_name)
            let dest_r: LowerExprResult = fresh_value(st)
            let inst: Instruction = CallLocalInst(InstCallLocalPayload {
                dest: dest_r.value_id,
                callee: func_id_opt!!,
                args: arg_ops,
            })
            return LowerExprResult { ctx: emit(dest_r.ctx, inst), value_id: dest_r.value_id }
        },
    }

    // Unresolved callee — typecheck should have caught this. Emit a
    // placeholder fresh value so downstream lowering keeps moving;
    // the verifier or v0.7.8.6 byte-diff gate will flag.
    fresh_value(st)
}

// ── v0.7.8.4: struct field access, outcome constructors ──────────

// Resolve a struct's field index by name. Linear scan over the
// ordered field-name vector populated by lower_module pass 1.
// Returns 0 on a miss — `FieldGet` with an invalid field_idx
// is a typecheck-caught condition.
function resolve_field_idx(ctx: LowerCtx, struct_name: String, field_name: String) -> Integer = {
    let fields_opt: Vector<String>? = hashmap_get(ctx.struct_fields, struct_name)
    match fields_opt {
        ~0 => 0,
        _ => {
            let fields: Vector<String> = fields_opt!!
            let total: Integer = length(fields)
            let mutable idx: Integer = 0
            let mutable found: Trilean! = false
            while idx < total && !found {
                let n_opt: String? = get(fields, idx)
                if n_opt!! == field_name {
                    found = true
                } else {
                    idx = idx + 1
                }
            }
            if found { idx } else { 0 }
        },
    }
}

// `lower_field_access` — emits `FieldGet { object, field_idx }`.
// `field_idx` resolution defers to v0.7.8.4 follow-up when the
// ValueKind tracking machinery (ADR-0023) lands; for now we walk
// the parser-side type information attached to the object's
// expression — if the object is a bare `Identifier` whose declared
// type is a known struct, look up the field index from
// `struct_fields`. Otherwise emit `field_idx = 0` as a placeholder.
function lower_field_access(ctx: LowerCtx, p: FieldAccessPayload) -> LowerExprResult = {
    let obj_r: LowerExprResult = lower_expression(ctx, p.object)
    // TODO(v0.7.8.4 followup, ADR-0023): the Rust impl tracks
    // per-ValueId ValueKind to walk struct identity through
    // Nullable/Outcome wrappers. v0.7.8.4 ports the declaration
    // tables but not the ValueKind tracker — field_idx falls back
    // to 0 here. Once ValueKind lands, callers will resolve the
    // correct slot via `resolve_field_idx(carrier, p.field)`.
    let dest_r: LowerExprResult = fresh_value(obj_r.ctx)
    let inst: Instruction = FieldGetInst(InstFieldGetPayload {
        dest: dest_r.value_id,
        object: ValueOp(obj_r.value_id),
        field_idx: 0,
    })
    LowerExprResult { ctx: emit(dest_r.ctx, inst), value_id: dest_r.value_id }
}

// `lower_outcome_constructor` — emits the appropriate Outcome
// opcode based on the constructor arm. `~+ x` →
// `OutcomeNewPositive`, `~- x` → `OutcomeNewNegative`, `~0` →
// `OutcomeNewNull` (no payload). Mirrors Rust lowerer's
// `Expr::OutcomeConstructor` arm.
function lower_outcome_constructor(
    ctx: LowerCtx,
    p: OutcomeConstructorPayload,
) -> LowerExprResult = {
    match p.arm {
        ZeroArm => {
            let dest_r: LowerExprResult = fresh_value(ctx)
            let inst: Instruction = OutcomeNewNullInst(InstOutcomeNewNullPayload {
                dest: dest_r.value_id,
            })
            LowerExprResult { ctx: emit(dest_r.ctx, inst), value_id: dest_r.value_id }
        },
        PositiveArm => {
            match p.payload {
                ~0 => fresh_value(ctx),
                _ => {
                    let pay_r: LowerExprResult = lower_expression(ctx, p.payload!!)
                    let dest_r: LowerExprResult = fresh_value(pay_r.ctx)
                    let inst: Instruction = OutcomeNewPositiveInst(InstOutcomeCtorPayload {
                        dest: dest_r.value_id,
                        payload: ValueOp(pay_r.value_id),
                    })
                    LowerExprResult { ctx: emit(dest_r.ctx, inst), value_id: dest_r.value_id }
                },
            }
        },
        NegativeArm => {
            match p.payload {
                ~0 => fresh_value(ctx),
                _ => {
                    let pay_r: LowerExprResult = lower_expression(ctx, p.payload!!)
                    let dest_r: LowerExprResult = fresh_value(pay_r.ctx)
                    let inst: Instruction = OutcomeNewNegativeInst(InstOutcomeCtorPayload {
                        dest: dest_r.value_id,
                        payload: ValueOp(pay_r.value_id),
                    })
                    LowerExprResult { ctx: emit(dest_r.ctx, inst), value_id: dest_r.value_id }
                },
            }
        },
    }
}

// `lower_range_expr` — emits the two endpoint expressions and
// returns the END value (a Range value itself has no runtime
// representation pre-iterator; the For-loop driver consumes the
// start/end pair directly when it sees `Iterable = Range`). The
// IR encoding is the lowerer's responsibility; v0.7.8.4 emits a
// placeholder fresh value for now — full range materialization
// (StructNew of a `Range { start, end, inclusive }` aggregate)
// defers alongside StructLiteralExpr parser surface.
function lower_range_expr(ctx: LowerCtx, p: RangePayload) -> LowerExprResult = {
    let start_r: LowerExprResult = lower_expression(ctx, p.range_start)
    let end_r: LowerExprResult = lower_expression(start_r.ctx, p.range_end)
    fresh_value(end_r.ctx)
}

// ── v0.7.11.1a: Elvis operator `obj ?: default` ──────────────────
//
// Mirrors `lower_expr Expr::ElvisOp` in `crates/triet-ir/src/lowerer.rs`
// (line 1341): null-check the object, branch True → unwrap-and-use,
// Unknown/False → use default, then Phi-merge at the join block.
//
// ADR-0010: null is `Trit::Zero` ≡ `Trilean::Unknown`, so the
// BrTrilean's `unknown_block` and `false_block` both route to the
// default-arm block.
function lower_elvis_op(ctx: LowerCtx, p: ElvisOpPayload) -> LowerExprResult = {
    // Step 1: lower the object expression.
    let obj_r: LowerExprResult = lower_expression(ctx, p.object)
    let mutable st: LowerCtx = obj_r.ctx
    let obj_val: ValueId = obj_r.value_id

    // Step 2: NullCheck — Trilean True iff non-null.
    let nc_r: LowerExprResult = fresh_value(st)
    st = nc_r.ctx
    st = emit(st, NullCheckInst(InstNullCheckPayload {
        dest: nc_r.value_id,
        nullable: ValueOp(obj_val),
    }))

    // Step 3: spawn then / else / merge blocks.
    let then_r: FreshBlockResult = fresh_block(st)
    st = then_r.ctx
    let else_r: FreshBlockResult = fresh_block(st)
    st = else_r.ctx
    let merge_r: FreshBlockResult = fresh_block(st)
    st = merge_r.ctx

    // Step 4: BrTrilean — True → then, Unknown/False → else.
    st = emit(st, BrTrileanInst(InstBrTrileanPayload {
        cond: ValueOp(nc_r.value_id),
        true_block: then_r.block_id,
        unknown_block: else_r.block_id,
        false_block: else_r.block_id,
    }))

    // Step 5: then block — NullUnwrap then Br merge.
    st = start_block(st, then_r.block_id, "elvis_some")
    let unwrap_r: LowerExprResult = fresh_value(st)
    st = unwrap_r.ctx
    st = emit(st, NullUnwrapInst(InstNullUnwrapPayload {
        dest: unwrap_r.value_id,
        nullable: ValueOp(obj_val),
    }))
    st = emit(st, BrInst(InstBrPayload { target: merge_r.block_id }))
    let then_end_id: BlockId = block_id_at(st, ctx_current_block_idx(st))

    // Step 6: else block — lower default expression, Br merge.
    st = start_block(st, else_r.block_id, "elvis_default")
    let default_r: LowerExprResult = lower_expression(st, p.default_expr)
    st = default_r.ctx
    st = emit(st, BrInst(InstBrPayload { target: merge_r.block_id }))
    let else_end_id: BlockId = block_id_at(st, ctx_current_block_idx(st))

    // Step 7: merge block — Phi { then_unwrapped, else_default }.
    st = start_block(st, merge_r.block_id, "elvis_merge")
    let merge_dest_r: LowerExprResult = fresh_value(st)
    st = merge_dest_r.ctx
    let mutable incoming: Vector<PhiIncoming> = new()
    incoming = push(incoming, PhiIncoming {
        value: unwrap_r.value_id,
        block: then_end_id,
    })
    incoming = push(incoming, PhiIncoming {
        value: default_r.value_id,
        block: else_end_id,
    })
    st = emit(st, PhiInst(InstPhiPayload {
        dest: merge_dest_r.value_id,
        incoming: incoming,
    }))

    LowerExprResult { ctx: st, value_id: merge_dest_r.value_id }
}

// ── v0.7.11.1b: Outcome default `inner ~: default` ───────────────
//
// Mirrors `lower_outcome_default` in `crates/triet-ir/src/lowerer.rs`
// (line 1608): discriminate the outcome, success → unwrap value,
// Zero/Negative → evaluate default, then Phi-merge.
//
// BrTrilean reads the discriminator: Positive → True (success arm),
// Zero → Unknown (fallback), Negative → False (fallback). Both null
// and failure paths land in `oc_default_fallback`.
function lower_outcome_default(
    ctx: LowerCtx,
    p: OutcomeDefaultPayload,
) -> LowerExprResult = {
    // Step 1: lower the inner outcome expression.
    let inner_r: LowerExprResult = lower_expression(ctx, p.inner)
    let mutable st: LowerCtx = inner_r.ctx
    let inner_val: ValueId = inner_r.value_id

    // Step 2: emit OutcomeDiscriminant — Positive/Zero/Negative Trit.
    let disc_r: LowerExprResult = fresh_value(st)
    st = disc_r.ctx
    st = emit(st, OutcomeDiscriminantInst(InstOutcomeUnaryPayload {
        dest: disc_r.value_id,
        source: ValueOp(inner_val),
    }))

    // Step 3: spawn success / fallback / merge blocks.
    let success_r: FreshBlockResult = fresh_block(st)
    st = success_r.ctx
    let fallback_r: FreshBlockResult = fresh_block(st)
    st = fallback_r.ctx
    let merge_r: FreshBlockResult = fresh_block(st)
    st = merge_r.ctx

    // Step 4: BrTrilean — True → success, Zero/Negative → fallback.
    st = emit(st, BrTrileanInst(InstBrTrileanPayload {
        cond: ValueOp(disc_r.value_id),
        true_block: success_r.block_id,
        unknown_block: fallback_r.block_id,
        false_block: fallback_r.block_id,
    }))

    // Step 5: success block — OutcomeUnwrapValue then Br merge.
    st = start_block(st, success_r.block_id, "oc_default_success")
    let unwrap_r: LowerExprResult = fresh_value(st)
    st = unwrap_r.ctx
    st = emit(st, OutcomeUnwrapValueInst(InstOutcomeUnaryPayload {
        dest: unwrap_r.value_id,
        source: ValueOp(inner_val),
    }))
    st = emit(st, BrInst(InstBrPayload { target: merge_r.block_id }))
    let success_end_id: BlockId = block_id_at(st, ctx_current_block_idx(st))

    // Step 6: fallback block — lower default expression, Br merge.
    st = start_block(st, fallback_r.block_id, "oc_default_fallback")
    let default_r: LowerExprResult = lower_expression(st, p.default_expr)
    st = default_r.ctx
    st = emit(st, BrInst(InstBrPayload { target: merge_r.block_id }))
    let fallback_end_id: BlockId = block_id_at(st, ctx_current_block_idx(st))

    // Step 7: merge block — Phi { success_unwrapped, fallback_default }.
    st = start_block(st, merge_r.block_id, "oc_default_merge")
    let merge_dest_r: LowerExprResult = fresh_value(st)
    st = merge_dest_r.ctx
    let mutable incoming: Vector<PhiIncoming> = new()
    incoming = push(incoming, PhiIncoming {
        value: unwrap_r.value_id,
        block: success_end_id,
    })
    incoming = push(incoming, PhiIncoming {
        value: default_r.value_id,
        block: fallback_end_id,
    })
    st = emit(st, PhiInst(InstPhiPayload {
        dest: merge_dest_r.value_id,
        incoming: incoming,
    }))

    LowerExprResult { ctx: st, value_id: merge_dest_r.value_id }
}

// ── v0.7.11.1c: Outcome propagate `inner ~? |capture| early_return` ──
//
// Mirrors `lower_outcome_propagate` in `crates/triet-ir/src/lowerer.rs`
// (line 1702). Semantics per ADR-0020 §3.1:
//
//   - Positive arm  → OutcomeUnwrapValue, fall through to merge.
//   - Zero arm      → Const(Null), fall through to merge (only
//                     reachable for `T?~E` shape; binary `T~E`
//                     statically excludes it but the block stays
//                     for verifier well-formedness).
//   - Negative arm  → OutcomeUnwrapError into the capture binding,
//                     lower the `early_return` expression, then
//                     `Ret` it (divergent — does NOT branch back to
//                     merge; typecheck E1031 enforces divergence).
//
// Merge collects only the Positive + Zero edges (Negative arm
// terminates via Ret).
function lower_outcome_propagate(
    ctx: LowerCtx,
    p: OutcomePropagatePayload,
) -> LowerExprResult = {
    // Step 1: lower the inner outcome expression.
    let inner_r: LowerExprResult = lower_expression(ctx, p.inner)
    let mutable st: LowerCtx = inner_r.ctx
    let inner_val: ValueId = inner_r.value_id

    // Step 2: emit OutcomeDiscriminant.
    let disc_r: LowerExprResult = fresh_value(st)
    st = disc_r.ctx
    st = emit(st, OutcomeDiscriminantInst(InstOutcomeUnaryPayload {
        dest: disc_r.value_id,
        source: ValueOp(inner_val),
    }))

    // Step 3: spawn success / null / failure / merge blocks (4 total).
    let success_r: FreshBlockResult = fresh_block(st)
    st = success_r.ctx
    let null_r: FreshBlockResult = fresh_block(st)
    st = null_r.ctx
    let failure_r: FreshBlockResult = fresh_block(st)
    st = failure_r.ctx
    let merge_r: FreshBlockResult = fresh_block(st)
    st = merge_r.ctx

    // Step 4: BrTrilean — distinct routing for each Trit (unlike
    // Elvis / Default which collapsed null + failure).
    st = emit(st, BrTrileanInst(InstBrTrileanPayload {
        cond: ValueOp(disc_r.value_id),
        true_block: success_r.block_id,
        unknown_block: null_r.block_id,
        false_block: failure_r.block_id,
    }))

    // Step 5: success block — OutcomeUnwrapValue then Br merge.
    st = start_block(st, success_r.block_id, "oc_prop_success")
    let unwrap_r: LowerExprResult = fresh_value(st)
    st = unwrap_r.ctx
    st = emit(st, OutcomeUnwrapValueInst(InstOutcomeUnaryPayload {
        dest: unwrap_r.value_id,
        source: ValueOp(inner_val),
    }))
    st = emit(st, BrInst(InstBrPayload { target: merge_r.block_id }))
    let success_end_id: BlockId = block_id_at(st, ctx_current_block_idx(st))

    // Step 6: null block — Const(Null) then Br merge.
    st = start_block(st, null_r.block_id, "oc_prop_null")
    let null_const_r: InternCtxResult = intern_constant(st, NullConst(primitive_marker()))
    st = null_const_r.ctx
    let null_dest_r: LowerExprResult = fresh_value(st)
    st = null_dest_r.ctx
    st = emit(st, ConstInst(InstConstPayload {
        dest: null_dest_r.value_id,
        const_id: null_const_r.const_id,
    }))
    st = emit(st, BrInst(InstBrPayload { target: merge_r.block_id }))
    let null_end_id: BlockId = block_id_at(st, ctx_current_block_idx(st))

    // Step 7: failure block — bind capture, lower early_return,
    // then Ret. Push a fresh scope so the capture binding doesn't
    // leak into the merge/exit paths.
    st = start_block(st, failure_r.block_id, "oc_prop_failure")
    st = push_scope(st)
    let err_r: LowerExprResult = fresh_value(st)
    st = err_r.ctx
    st = emit(st, OutcomeUnwrapErrorInst(InstOutcomeUnaryPayload {
        dest: err_r.value_id,
        source: ValueOp(inner_val),
    }))
    // Bind capture name if present. `~0` arm first (Triết match is
    // first-match-wins per memory).
    match p.capture_name {
        ~0 => { },
        _ => {
            st = bind_var(st, p.capture_name!!, err_r.value_id)
        },
    }
    let early_r: LowerExprResult = lower_expression(st, p.early_return)
    st = early_r.ctx
    st = emit(st, RetInst(InstRetPayload {
        value: ValueOp(early_r.value_id),
    }))
    st = pop_scope(st)

    // Step 8: merge block — Phi with 2 incoming (success + null).
    // The failure arm Ret-ed so its edge does NOT appear.
    st = start_block(st, merge_r.block_id, "oc_prop_merge")
    let merge_dest_r: LowerExprResult = fresh_value(st)
    st = merge_dest_r.ctx
    let mutable incoming: Vector<PhiIncoming> = new()
    incoming = push(incoming, PhiIncoming {
        value: unwrap_r.value_id,
        block: success_end_id,
    })
    incoming = push(incoming, PhiIncoming {
        value: null_dest_r.value_id,
        block: null_end_id,
    })
    st = emit(st, PhiInst(InstPhiPayload {
        dest: merge_dest_r.value_id,
        incoming: incoming,
    }))

    LowerExprResult { ctx: st, value_id: merge_dest_r.value_id }
}

// ── v0.7.11.1d: Method call dispatch ─────────────────────────────
//
// Mirrors `lower_expr Expr::MethodCall` in `crates/triet-ir/src/lowerer.rs`
// (line 1165). Covers the v0.2 stdlib surface — no full method-table
// lookup yet:
//
//   - `<receiver>.length()` (zero args) → CallBuiltin(text_len).
//     Receiver must be String; downstream typecheck enforces.
//   - `<receiver>.unwrap_value(msg)` / `.unwrap_error(msg)` (one
//     arg) per ADR-0020 §6 verbose strict-unwrap pairs. The `msg`
//     argument is lowered for source-contract side effect but the
//     VM does not consume it (E2210 panic uses a hardcoded label).
//   - Other methods fall through to the receiver — matches Rust's
//     current incomplete behavior. Future generic method-table
//     dispatch lifts post-v0.7.
function lower_method_call(ctx: LowerCtx, p: MethodCallPayload) -> LowerExprResult = {
    let arg_count: Integer = length(p.arguments)

    // `.length()` zero-arg → CallBuiltin(text_len) on the receiver.
    if p.method == "length" && arg_count == 0 {
        let recv_r: LowerExprResult = lower_expression(ctx, p.receiver)
        let mutable st: LowerCtx = recv_r.ctx
        let dest_r: LowerExprResult = fresh_value(st)
        st = dest_r.ctx
        let mutable args: Vector<Operand> = new()
        args = push(args, ValueOp(recv_r.value_id))
        st = emit(st, CallBuiltinInst(InstCallBuiltinPayload {
            dest: dest_r.value_id,
            name: TextLenBuiltin(primitive_marker()),
            args: args,
        }))
        return LowerExprResult { ctx: st, value_id: dest_r.value_id }
    }

    // `.unwrap_value(msg)` / `.unwrap_error(msg)` — OutcomeUnwrap*.
    // ADR-0020 §6: msg lowered for parity, ignored at VM.
    if arg_count == 1 && (p.method == "unwrap_value" || p.method == "unwrap_error") {
        let recv_r: LowerExprResult = lower_expression(ctx, p.receiver)
        let msg_arg_opt: Integer? = get(p.arguments, 0)
        let msg_r: LowerExprResult = lower_expression(recv_r.ctx, msg_arg_opt!!)
        let mutable st: LowerCtx = msg_r.ctx
        let dest_r: LowerExprResult = fresh_value(st)
        st = dest_r.ctx
        let payload: InstOutcomeUnaryPayload = InstOutcomeUnaryPayload {
            dest: dest_r.value_id,
            source: ValueOp(recv_r.value_id),
        }
        let inst: Instruction = if p.method == "unwrap_value" {
            OutcomeUnwrapValueInst(payload)
        } else {
            OutcomeUnwrapErrorInst(payload)
        }
        st = emit(st, inst)
        return LowerExprResult { ctx: st, value_id: dest_r.value_id }
    }

    // Fallback — unknown method, return the receiver value
    // unchanged (matches Rust's current incomplete arm).
    lower_expression(ctx, p.receiver)
}

// ── v0.7.11.1e2: If-expression with phi-stitch ───────────────────
//
// Mirrors `lower_if_expr` in `crates/triet-ir/src/lowerer.rs`
// (line 1931). Canonical 3-block shape (entry / then / else / merge)
// for `if?` (Unknown → else), 4-block shape for plain `if` (Unknown
// → fresh panic block holding Unreachable per ADR-0010 / SPEC
// §7.1.1). Phi at merge for the if's value AND for each variable
// mutated by either branch.
//
// Triết scope discipline (mirrors v0.7.x.runtime-fix.while-body-
// scope-pop-order): wrap each branch's body with explicit
// push_scope / lower_block_inline / snapshot via resolve_var /
// pop_scope. This way the body's AssignStmt rebinds land in the
// inner scope and `resolve_var` (called BEFORE pop) captures the
// body-end SSA value. After pop the outer scope's bindings are
// unchanged — so the else-branch starts from the same dominator
// state as then (no manual "restore pre-if bindings" pass needed,
// unlike Rust's `rebind_var` walk-up-chain semantics).
function lower_if_expr(ctx: LowerCtx, p: IfExprPayload) -> LowerExprResult = {
    let arena: Arena = ctx.parser_arena

    // Step 1: collect mutated vars from BOTH branches (union; dedup
    // via linear scan since mutated counts are small).
    let mutable mutated: Vector<String> = collect_assigned_vars(arena, p.then_branch)
    match p.else_branch {
        ~0 => { },
        _ => {
            let else_muts: Vector<String> = collect_assigned_vars(arena, p.else_branch!!)
            let etotal: Integer = length(else_muts)
            let mutable k: Integer = 0
            while k < etotal {
                let nm_opt: String? = get(else_muts, k)
                let nm: String = nm_opt!!
                let mtotal: Integer = length(mutated)
                let mutable found: Trilean! = false
                let mutable j: Integer = 0
                while j < mtotal {
                    let existing_opt: String? = get(mutated, j)
                    if existing_opt!! == nm {
                        found = true
                    }
                    j = j + 1
                }
                if !found {
                    mutated = push(mutated, nm)
                }
                k = k + 1
            }
        },
    }
    let mut_total: Integer = length(mutated)

    // Step 2: snapshot pre-if values (sentinel raw=-1 for unbound).
    let mutable pre_vals: Vector<ValueId> = new()
    let mutable i: Integer = 0
    while i < mut_total {
        let n_opt: String? = get(mutated, i)
        let v_opt: ValueId? = resolve_var(ctx, n_opt!!)
        let pv: ValueId = match v_opt {
            ~0 => ValueId { raw: -1 },
            _ => v_opt!!,
        }
        pre_vals = push(pre_vals, pv)
        i = i + 1
    }

    // Step 3: lower the condition.
    let cond_r: LowerExprResult = lower_expression(ctx, p.condition)
    let mutable st: LowerCtx = cond_r.ctx

    // Step 4: spawn then / else / merge blocks. For plain `if`
    // (Unknown panic), also spawn the panic block now.
    let then_r: FreshBlockResult = fresh_block(st)
    st = then_r.ctx
    let else_r: FreshBlockResult = fresh_block(st)
    st = else_r.ctx
    let merge_r: FreshBlockResult = fresh_block(st)
    st = merge_r.ctx

    let mutable unk_target: BlockId = else_r.block_id
    if !p.treat_unknown_as_false {
        let unk_r: FreshBlockResult = fresh_block(st)
        st = unk_r.ctx
        unk_target = unk_r.block_id
    }

    // Step 5: BrTrilean. For `if?`, Unknown→else; for plain `if`,
    // Unknown→panic block (filled below with Unreachable).
    st = emit(st, BrTrileanInst(InstBrTrileanPayload {
        cond: ValueOp(cond_r.value_id),
        true_block: then_r.block_id,
        unknown_block: unk_target,
        false_block: else_r.block_id,
    }))

    // Step 5b: materialize the unknown-panic block now if plain `if`.
    if !p.treat_unknown_as_false {
        st = start_block(st, unk_target, "if_unknown_panic")
        st = emit(st, UnreachableInst(primitive_marker()))
    }

    // Step 6: then block — push inner scope so body AssignStmts
    // land there; snapshot then-end values BEFORE pop_scope.
    st = start_block(st, then_r.block_id, "then")
    st = push_scope(st)
    let then_body_r: LowerExprResult = lower_block_inline(st, p.then_branch)
    st = then_body_r.ctx
    let mutable then_vals: Vector<ValueId> = new()
    i = 0
    while i < mut_total {
        let n_opt2: String? = get(mutated, i)
        let v2_opt: ValueId? = resolve_var(st, n_opt2!!)
        let tv: ValueId = match v2_opt {
            ~0 => ValueId { raw: -1 },
            _ => v2_opt!!,
        }
        then_vals = push(then_vals, tv)
        i = i + 1
    }
    st = pop_scope(st)
    if !current_block_has_terminator(st) {
        st = emit(st, BrInst(InstBrPayload { target: merge_r.block_id }))
    }
    let then_end_id: BlockId = block_id_at(st, ctx_current_block_idx(st))

    // Step 7: else block — same shape. If no else_branch present,
    // emit a Unit const as the produced value (matches Rust).
    st = start_block(st, else_r.block_id, "else")
    st = push_scope(st)
    let else_body_r: LowerExprResult = match p.else_branch {
        ~0 => {
            let cu: Constant = UnitConst(primitive_marker())
            let intern_r: InternCtxResult = intern_constant(st, cu)
            let unit_dest_r: LowerExprResult = fresh_value(intern_r.ctx)
            let inst: Instruction = ConstInst(InstConstPayload {
                dest: unit_dest_r.value_id,
                const_id: intern_r.const_id,
            })
            LowerExprResult { ctx: emit(unit_dest_r.ctx, inst), value_id: unit_dest_r.value_id }
        },
        _ => lower_block_inline(st, p.else_branch!!),
    }
    st = else_body_r.ctx
    let mutable else_vals: Vector<ValueId> = new()
    i = 0
    while i < mut_total {
        let n_opt3: String? = get(mutated, i)
        let v3_opt: ValueId? = resolve_var(st, n_opt3!!)
        let ev: ValueId = match v3_opt {
            ~0 => ValueId { raw: -1 },
            _ => v3_opt!!,
        }
        else_vals = push(else_vals, ev)
        i = i + 1
    }
    st = pop_scope(st)
    if !current_block_has_terminator(st) {
        st = emit(st, BrInst(InstBrPayload { target: merge_r.block_id }))
    }
    let else_end_id: BlockId = block_id_at(st, ctx_current_block_idx(st))

    // Step 8: merge block — Phi for the if's value first.
    st = start_block(st, merge_r.block_id, "merge")
    let merge_dest_r: LowerExprResult = fresh_value(st)
    st = merge_dest_r.ctx
    let mutable v_incoming: Vector<PhiIncoming> = new()
    v_incoming = push(v_incoming, PhiIncoming {
        value: then_body_r.value_id,
        block: then_end_id,
    })
    v_incoming = push(v_incoming, PhiIncoming {
        value: else_body_r.value_id,
        block: else_end_id,
    })
    st = emit(st, PhiInst(InstPhiPayload {
        dest: merge_dest_r.value_id,
        incoming: v_incoming,
    }))

    // Step 9: Phi per mutated variable. Branch that didn't write to
    // the name uses the pre-if value as its incoming. Skip names
    // the pre-if scope didn't define (typecheck rejects those
    // anyway; defensive).
    i = 0
    while i < mut_total {
        let pre_opt: ValueId? = get(pre_vals, i)
        let pre: ValueId = pre_opt!!
        if pre.raw >= 0 {
            let then_opt: ValueId? = get(then_vals, i)
            let then_v_raw: ValueId = then_opt!!
            let then_v: ValueId = if then_v_raw.raw < 0 { pre } else { then_v_raw }
            let else_opt: ValueId? = get(else_vals, i)
            let else_v_raw: ValueId = else_opt!!
            let else_v: ValueId = if else_v_raw.raw < 0 { pre } else { else_v_raw }
            // Both branches left the value untouched — rebind to pre,
            // no phi needed.
            if then_v.raw == pre.raw && else_v.raw == pre.raw {
                let n_opt4: String? = get(mutated, i)
                st = bind_var(st, n_opt4!!, pre)
            } else {
                let phi_r: LowerExprResult = fresh_value(st)
                st = phi_r.ctx
                let mutable inc: Vector<PhiIncoming> = new()
                inc = push(inc, PhiIncoming { value: then_v, block: then_end_id })
                inc = push(inc, PhiIncoming { value: else_v, block: else_end_id })
                st = emit(st, PhiInst(InstPhiPayload {
                    dest: phi_r.value_id,
                    incoming: inc,
                }))
                let n_opt5: String? = get(mutated, i)
                st = bind_var(st, n_opt5!!, phi_r.value_id)
            }
        }
        i = i + 1
    }

    LowerExprResult { ctx: st, value_id: merge_dest_r.value_id }
}

// ── v0.7.11.1f2: Match-expression pattern test + binding ─────────
//
// Mirrors `lower_pattern_test` in `crates/triet-ir/src/lowerer.rs`
// (line 2784). Returns `~0` to mean "pattern matches anything"
// (wildcard / bare variable that doesn't shadow an enum variant),
// otherwise a Trilean ValueId for the runtime check. ADR-0010:
// Unknown maps to skip-to-next-test (same as False) in BrTrilean.

// Result wrapper — a `ValueId?` paired with the ctx. `value: ~0`
// signals unconditional match.
struct PatternTestResult {
    ctx: LowerCtx,
    value: ValueId?,
}

function emit_const_int(ctx: LowerCtx, n: Integer) -> LowerExprResult = {
    let c: Constant = IntegerConst(ConstantIntegerPayload { value: n })
    let intern_r: InternCtxResult = intern_constant(ctx, c)
    let dest_r: LowerExprResult = fresh_value(intern_r.ctx)
    let inst: Instruction = ConstInst(InstConstPayload {
        dest: dest_r.value_id,
        const_id: intern_r.const_id,
    })
    LowerExprResult { ctx: emit(dest_r.ctx, inst), value_id: dest_r.value_id }
}

function emit_const_trit(ctx: LowerCtx, t: Trit) -> LowerExprResult = {
    let c: Constant = TritConst(ConstantTritPayload { value: t })
    let intern_r: InternCtxResult = intern_constant(ctx, c)
    let dest_r: LowerExprResult = fresh_value(intern_r.ctx)
    let inst: Instruction = ConstInst(InstConstPayload {
        dest: dest_r.value_id,
        const_id: intern_r.const_id,
    })
    LowerExprResult { ctx: emit(dest_r.ctx, inst), value_id: dest_r.value_id }
}

function emit_const_trilean(ctx: LowerCtx, tv: Trilean) -> LowerExprResult = {
    let c: Constant = TrileanConst(ConstantTrileanPayload { value: tv })
    let intern_r: InternCtxResult = intern_constant(ctx, c)
    let dest_r: LowerExprResult = fresh_value(intern_r.ctx)
    let inst: Instruction = ConstInst(InstConstPayload {
        dest: dest_r.value_id,
        const_id: intern_r.const_id,
    })
    LowerExprResult { ctx: emit(dest_r.ctx, inst), value_id: dest_r.value_id }
}

function emit_const_string(ctx: LowerCtx, s: String) -> LowerExprResult = {
    let c: Constant = StringConst(ConstantStringPayload { value: s })
    let intern_r: InternCtxResult = intern_constant(ctx, c)
    let dest_r: LowerExprResult = fresh_value(intern_r.ctx)
    let inst: Instruction = ConstInst(InstConstPayload {
        dest: dest_r.value_id,
        const_id: intern_r.const_id,
    })
    LowerExprResult { ctx: emit(dest_r.ctx, inst), value_id: dest_r.value_id }
}

// Emit Eq(lhs, rhs) → Trilean. Used by literal / enum-tag / null
// pattern tests.
function emit_eq(ctx: LowerCtx, lhs: ValueId, rhs: ValueId) -> LowerExprResult = {
    let dest_r: LowerExprResult = fresh_value(ctx)
    let inst: Instruction = EqInst(InstBinaryOpPayload {
        dest: dest_r.value_id,
        lhs: ValueOp(lhs),
        rhs: ValueOp(rhs),
    })
    LowerExprResult { ctx: emit(dest_r.ctx, inst), value_id: dest_r.value_id }
}

function lower_pattern_test(
    ctx: LowerCtx,
    pattern: Pattern,
    scrutinee: ValueId,
) -> PatternTestResult = {
    match pattern {
        WildcardPattern => PatternTestResult { ctx: ctx, value: ~0 },
        IdentifierPattern(sp) => {
            // Bare identifier — disambiguate via variant_index. If
            // the name resolves to a known unit-variant, treat as
            // EnumVariant tag check; otherwise catch-all binding.
            // Mirrors Rust lowerer.rs:2804-2829. Use match on
            // hashmap_get's `T?` result (hashmap_contains returns
            // generic Trilean and would trip E1033 inside a plain
            // `if`).
            match hashmap_get(ctx.variant_index, sp.text) {
                ~0 => PatternTestResult { ctx: ctx, value: ~0 },
                _ => {
                    let info: VariantInfo = hashmap_get(ctx.variant_index, sp.text)!!
                    let tag_r: LowerExprResult = fresh_value(ctx)
                    let mutable st: LowerCtx = tag_r.ctx
                    st = emit(st, EnumTagInst(InstEnumTagPayload {
                        dest: tag_r.value_id,
                        scrutinee: ValueOp(scrutinee),
                    }))
                    let idx_r: LowerExprResult = emit_const_int(st, info.variant_idx)
                    st = idx_r.ctx
                    let cmp_r: LowerExprResult = emit_eq(st, tag_r.value_id, idx_r.value_id)
                    PatternTestResult { ctx: cmp_r.ctx, value: cmp_r.value_id }
                },
            }
        },
        NullPat => {
            // NullCheck returns Trit: Zero = null. Compare against
            // Trit::Zero. ADR-0010 §C unified null encoding.
            let chk_r: LowerExprResult = fresh_value(ctx)
            let mutable st: LowerCtx = chk_r.ctx
            st = emit(st, NullCheckInst(InstNullCheckPayload {
                dest: chk_r.value_id,
                nullable: ValueOp(scrutinee),
            }))
            let zero_r: LowerExprResult = emit_const_trit(st, 0_trit)
            st = zero_r.ctx
            let cmp_r: LowerExprResult = emit_eq(st, chk_r.value_id, zero_r.value_id)
            PatternTestResult { ctx: cmp_r.ctx, value: cmp_r.value_id }
        },
        LiteralPat(lit) => {
            let lit_r: LowerExprResult = match lit {
                IntegerLit(p) => emit_const_int(ctx, p.value),
                TernaryLit(v) => emit_const_int(ctx, v),
                StringLit(sp) => emit_const_string(ctx, sp.text),
                TrileanLit(tv) => emit_const_trilean(ctx, match tv {
                    TrueValue => true,
                    FalseValue => false,
                    UnknownValue => unknown,
                }),
            }
            let cmp_r: LowerExprResult = emit_eq(lit_r.ctx, scrutinee, lit_r.value_id)
            PatternTestResult { ctx: cmp_r.ctx, value: cmp_r.value_id }
        },
        EnumVariantPat(p) => {
            // Tag check identical to bare-variant case.
            let idx: Integer = match hashmap_get(ctx.variant_index, p.variant_name) {
                ~0 => 0,
                _ => hashmap_get(ctx.variant_index, p.variant_name)!!.variant_idx,
            }
            let tag_r: LowerExprResult = fresh_value(ctx)
            let mutable st: LowerCtx = tag_r.ctx
            st = emit(st, EnumTagInst(InstEnumTagPayload {
                dest: tag_r.value_id,
                scrutinee: ValueOp(scrutinee),
            }))
            let idx_r: LowerExprResult = emit_const_int(st, idx)
            st = idx_r.ctx
            let cmp_r: LowerExprResult = emit_eq(st, tag_r.value_id, idx_r.value_id)
            PatternTestResult { ctx: cmp_r.ctx, value: cmp_r.value_id }
        },
        OutcomeArmPat(p) => {
            // OutcomeDiscriminant → expected Trit. ADR-0020 §5.
            let disc_r: LowerExprResult = fresh_value(ctx)
            let mutable st: LowerCtx = disc_r.ctx
            st = emit(st, OutcomeDiscriminantInst(InstOutcomeUnaryPayload {
                dest: disc_r.value_id,
                source: ValueOp(scrutinee),
            }))
            let expected: Trit = match p.arm {
                PositiveArm => 1_trit,
                ZeroArm => 0_trit,
                NegativeArm => -1_trit,
            }
            let trit_r: LowerExprResult = emit_const_trit(st, expected)
            st = trit_r.ctx
            let cmp_r: LowerExprResult = emit_eq(st, disc_r.value_id, trit_r.value_id)
            PatternTestResult { ctx: cmp_r.ctx, value: cmp_r.value_id }
        },
        // Tuple / Or / Range patterns deferred — not exercised by
        // current compiler/*.tri match arms. Treat as match-all so
        // the surrounding match's last-arm dispatch still works.
        _ => PatternTestResult { ctx: ctx, value: ~0 },
    }
}

// Bind variables introduced by pattern destructure. For wildcard
// / literal / null / enum-tag-only / variant-without-payload, no
// bindings. For Variable (non-variant), bind to scrutinee directly.
// For EnumVariantPat with payload sub-pattern, extract via
// EnumPayload then recurse. For OutcomeArmPat (Positive/Negative)
// with payload, extract via OutcomeUnwrap{Value,Error}. `~0` has
// no payload.
function bind_pattern_vars(ctx: LowerCtx, pattern: Pattern, scrutinee: ValueId) -> LowerCtx = {
    match pattern {
        IdentifierPattern(sp) => {
            // Skip if the name resolves to an enum variant (the
            // pattern is a tag check, not a binding). Use match on
            // hashmap_get for refined Trilean! at the branch.
            match hashmap_get(ctx.variant_index, sp.text) {
                ~0 => bind_var(ctx, sp.text, scrutinee),
                _ => ctx,
            }
        },
        EnumVariantPat(p) => {
            match p.payload {
                ~0 => ctx,
                _ => {
                    let inner_id: Integer = p.payload!!
                    let inner_pat: Pattern = get_pattern(ctx.parser_arena, inner_id).node
                    let pay_r: LowerExprResult = fresh_value(ctx)
                    let st: LowerCtx = emit(pay_r.ctx, EnumPayloadInst(InstEnumPayloadPayload {
                        dest: pay_r.value_id,
                        scrutinee: ValueOp(scrutinee),
                    }))
                    bind_pattern_vars(st, inner_pat, pay_r.value_id)
                },
            }
        },
        OutcomeArmPat(p) => {
            match p.payload {
                ~0 => ctx,
                _ => {
                    let inner_id: Integer = p.payload!!
                    let inner_pat: Pattern = get_pattern(ctx.parser_arena, inner_id).node
                    match p.arm {
                        ZeroArm => ctx,
                        PositiveArm => {
                            let pay_r: LowerExprResult = fresh_value(ctx)
                            let st: LowerCtx = emit(pay_r.ctx, OutcomeUnwrapValueInst(InstOutcomeUnaryPayload {
                                dest: pay_r.value_id,
                                source: ValueOp(scrutinee),
                            }))
                            bind_pattern_vars(st, inner_pat, pay_r.value_id)
                        },
                        NegativeArm => {
                            let pay_r: LowerExprResult = fresh_value(ctx)
                            let st: LowerCtx = emit(pay_r.ctx, OutcomeUnwrapErrorInst(InstOutcomeUnaryPayload {
                                dest: pay_r.value_id,
                                source: ValueOp(scrutinee),
                            }))
                            bind_pattern_vars(st, inner_pat, pay_r.value_id)
                        },
                    }
                },
            }
        },
        _ => ctx,
    }
}

// ── v0.7.11.1f2: Match expression ────────────────────────────────
//
// Mirrors `lower_match_expr` in `crates/triet-ir/src/lowerer.rs`
// (line 2565). Each arm becomes test_block → arm_body_block →
// merge. Per-mutated-var phi is OMITTED at v0.7.11.1f2 because the
// Triết-side Expr enum has no Block expression yet — match arm
// bodies can only be single expressions (no AssignStmt). When a
// future sub-task adds BlockExpr to the parser, this lowerer will
// need the v0.7.4.3-debt.5 mutation-phi pass; tracked as
// `v0.7.x.runtime-fix.match-arm-mutation-phi-port` in the deferred
// bugs section.
function lower_match_expr(ctx: LowerCtx, p: MatchExprPayload) -> LowerExprResult = {
    let scrutinee_r: LowerExprResult = lower_expression(ctx, p.scrutinee)
    let mutable st: LowerCtx = scrutinee_r.ctx
    let scrutinee_val: ValueId = scrutinee_r.value_id

    let arm_total: Integer = length(p.arms)
    if arm_total == 0 {
        // Empty match — emit a Unit const so downstream has a real
        // ValueId. Matches Rust line 2571.
        let cu: Constant = UnitConst(primitive_marker())
        let intern_r: InternCtxResult = intern_constant(st, cu)
        let dest_r: LowerExprResult = fresh_value(intern_r.ctx)
        let inst: Instruction = ConstInst(InstConstPayload {
            dest: dest_r.value_id,
            const_id: intern_r.const_id,
        })
        return LowerExprResult { ctx: emit(dest_r.ctx, inst), value_id: dest_r.value_id }
    }

    // Allocate merge block up front.
    let merge_r: FreshBlockResult = fresh_block(st)
    st = merge_r.ctx

    let mutable arm_end_blocks: Vector<BlockId> = new()
    let mutable arm_values: Vector<ValueId> = new()

    let mutable i: Integer = 0
    while i < arm_total {
        let arm_opt: MatchArm? = get(p.arms, i)
        let arm: MatchArm = arm_opt!!
        let is_last: Trilean! = (i + 1) == arm_total

        // Allocate the arm body block.
        let body_blk_r: FreshBlockResult = fresh_block(st)
        st = body_blk_r.ctx

        // Allocate the next-test block iff this is NOT the last arm.
        let next_test_id: BlockId = if is_last {
            body_blk_r.block_id
        } else {
            let nt_r: FreshBlockResult = fresh_block(st)
            st = nt_r.ctx
            nt_r.block_id
        }

        // Pattern test in the CURRENT block. Last arm is
        // unconditional (typecheck guarantees exhaustiveness).
        if is_last {
            st = emit(st, BrInst(InstBrPayload { target: body_blk_r.block_id }))
        } else {
            let pat_node: Pattern = get_pattern(st.parser_arena, arm.pattern).node
            let test_r: PatternTestResult = lower_pattern_test(st, pat_node, scrutinee_val)
            st = test_r.ctx
            match test_r.value {
                ~0 => {
                    // Wildcard/variable: unconditional jump.
                    st = emit(st, BrInst(InstBrPayload { target: body_blk_r.block_id }))
                },
                _ => {
                    st = emit(st, BrTrileanInst(InstBrTrileanPayload {
                        cond: ValueOp(test_r.value!!),
                        true_block: body_blk_r.block_id,
                        unknown_block: next_test_id,
                        false_block: next_test_id,
                    }))
                },
            }
        }

        // Lower the arm body.
        let arm_name: String = concat("match_arm_", from_integer(i))
        st = start_block(st, body_blk_r.block_id, arm_name)
        st = push_scope(st)
        let pat_node2: Pattern = get_pattern(st.parser_arena, arm.pattern).node
        st = bind_pattern_vars(st, pat_node2, scrutinee_val)
        let arm_body_r: LowerExprResult = lower_expression(st, arm.body)
        st = arm_body_r.ctx
        st = pop_scope(st)
        let arm_end_id: BlockId = block_id_at(st, ctx_current_block_idx(st))
        if !current_block_has_terminator(st) {
            st = emit(st, BrInst(InstBrPayload { target: merge_r.block_id }))
        }
        arm_end_blocks = push(arm_end_blocks, arm_end_id)
        arm_values = push(arm_values, arm_body_r.value_id)

        // Move to the next test block (already named "match_test_N"
        // for non-last arms; last arm's "next_test" ≡ body_blk so we
        // don't re-enter).
        if !is_last {
            let test_name: String = concat("match_test_", from_integer(i + 1))
            st = start_block(st, next_test_id, test_name)
        }

        i = i + 1
    }

    // Merge block — Phi for the result value, one incoming per arm.
    st = start_block(st, merge_r.block_id, "match_merge")
    let merge_dest_r: LowerExprResult = fresh_value(st)
    st = merge_dest_r.ctx
    let mutable incoming: Vector<PhiIncoming> = new()
    let mutable k: Integer = 0
    while k < arm_total {
        let end_opt: BlockId? = get(arm_end_blocks, k)
        let val_opt: ValueId? = get(arm_values, k)
        incoming = push(incoming, PhiIncoming {
            value: val_opt!!,
            block: end_opt!!,
        })
        k = k + 1
    }
    st = emit(st, PhiInst(InstPhiPayload {
        dest: merge_dest_r.value_id,
        incoming: incoming,
    }))

    LowerExprResult { ctx: st, value_id: merge_dest_r.value_id }
}

public function lower_expression(ctx: LowerCtx, expr_id: Integer) -> LowerExprResult = {
    let spanned: SpannedExpr = get_expression(ctx.parser_arena, expr_id)
    match spanned.node {
        IntegerLiteralExpr(lit) => lower_integer_literal(ctx, lit),
        TernaryLiteralExpr(lit) => lower_integer_literal(ctx, lit),
        TrileanLiteralExpr(tv) => lower_trilean_literal(ctx, tv),
        StringLiteralExpr(sp) => lower_string_literal(ctx, sp.text),
        NullLiteralExpr => lower_null_literal(ctx),
        IdentifierExpr(sp) => lower_identifier(ctx, sp.text),
        UnaryOpExpr(p) => lower_unary_op(ctx, p.operator, p.operand),
        BinaryOpExpr(p) => lower_binary_op(ctx, p.operator, p.left, p.right),
        ForceUnwrapExpr(inner_id) => lower_force_unwrap(ctx, inner_id),
        CallExpr(call) => lower_call(ctx, call),
        FieldAccessExpr(p) => lower_field_access(ctx, p),
        MethodCallExpr(p) => lower_method_call(ctx, p),
        OutcomeConstructorExpr(p) => lower_outcome_constructor(ctx, p),
        RangeExpr(p) => lower_range_expr(ctx, p),
        ElvisOpExpr(p) => lower_elvis_op(ctx, p),
        OutcomeDefaultExpr(p) => lower_outcome_default(ctx, p),
        OutcomePropagateExpr(p) => lower_outcome_propagate(ctx, p),
        IfExpr(p) => lower_if_expr(ctx, p),
        MatchExpr(p) => lower_match_expr(ctx, p),
        _ => fresh_value(ctx),
    }
}

// ── Statement lowering ───────────────────────────────────────────

function lower_let_stmt(ctx: LowerCtx, p: LetStmtPayload) -> LowerCtx = {
    let val_r: LowerExprResult = lower_expression(ctx, p.value)
    bind_var(val_r.ctx, p.name, val_r.value_id)
}

function lower_constant_stmt(ctx: LowerCtx, p: ConstantStmtPayload) -> LowerCtx = {
    let val_r: LowerExprResult = lower_expression(ctx, p.value)
    bind_var(val_r.ctx, p.name, val_r.value_id)
}

function lower_return_stmt(ctx: LowerCtx, p: ReturnStmtPayload) -> LowerCtx = {
    match p.value {
        ~0 => emit(ctx, RetInst(InstRetPayload { value: ~0 })),
        _ => {
            let val_r: LowerExprResult = lower_expression(ctx, p.value!!)
            emit(val_r.ctx, RetInst(InstRetPayload { value: ValueOp(val_r.value_id) }))
        },
    }
}

function lower_expression_stmt(ctx: LowerCtx, p: ExpressionStmtPayload) -> LowerCtx = {
    let val_r: LowerExprResult = lower_expression(ctx, p.expression)
    val_r.ctx
}

// v0.7.8.3 — AssignStmt: re-evaluate the value expression, rebind
// the target name in the innermost scope. Mirrors the Rust lowerer's
// simple `Stmt::Assign` arm (no Phi insertion needed at v0.7.8.3
// since While/For — the contexts that require SSA stitching — defer
// to v0.7.8.3b).
function lower_assign_stmt(ctx: LowerCtx, p: AssignStmtPayload) -> LowerCtx = {
    let val_r: LowerExprResult = lower_expression(ctx, p.value)
    bind_var(val_r.ctx, p.target, val_r.value_id)
}

// v0.7.8.3 — Loop / Break / Continue lowering.
//
// `loop { body }` mirrors `lower_loop_stmt` in the Rust lowerer:
//   pre:       Br loop_body
//   loop_body: <body> Br loop_body  (if no terminator yet)
//   loop_exit: (control returns here on `break`)
//
// `break` emits `Br loop_stack.top.break_target`. `continue` emits
// `Br loop_stack.top.continue_target`. The LoopContext stack ensures
// nested loops dispatch to the innermost. `break` carrying a value
// is type-checked but the value flow (via phi) defers to v0.7.8.3b.

function loop_stack_top(ctx: LowerCtx) -> LoopContext? = {
    let total: Integer = length(ctx.loop_stack)
    if total == 0 {
        ~0
    } else {
        get(ctx.loop_stack, total - 1)
    }
}

function loop_stack_pop(ctx: LowerCtx) -> LowerCtx = {
    let total: Integer = length(ctx.loop_stack)
    if total == 0 {
        ctx
    } else {
        let mutable rebuilt: Vector<LoopContext> = new()
        let mutable i: Integer = 0
        while i < total - 1 {
            let lc_opt: LoopContext? = get(ctx.loop_stack, i)
            rebuilt = push(rebuilt, lc_opt!!)
            i = i + 1
        }
        ctx_with_loop_stack(ctx, rebuilt)
    }
}

function lower_loop_stmt(ctx: LowerCtx, p: LoopStmtPayload) -> LowerCtx = {
    let body_blk: FreshBlockResult = fresh_block(ctx)
    let mutable st: LowerCtx = body_blk.ctx
    let exit_blk: FreshBlockResult = fresh_block(st)
    st = exit_blk.ctx

    // Branch from the current block into the loop body header.
    st = emit(st, BrInst(InstBrPayload { target: body_blk.block_id }))

    // Start the loop body block.
    st = start_block(st, body_blk.block_id, "loop_body")

    // Push LoopContext so nested `break` / `continue` see this loop.
    let lc: LoopContext = LoopContext {
        break_target: exit_blk.block_id,
        continue_target: body_blk.block_id,
    }
    st = ctx_with_loop_stack(st, push(ctx_loop_stack(st), lc))
    st = push_scope(st)
    let body_r: LowerExprResult = lower_block(st, p.body)
    st = body_r.ctx
    st = pop_scope(st)
    st = loop_stack_pop(st)

    // Implicit branch back to the body header if the body didn't
    // terminate explicitly (e.g., via `break`/`return`).
    if !current_block_has_terminator(st) {
        st = emit(st, BrInst(InstBrPayload { target: body_blk.block_id }))
    }

    // Continue lowering in the exit block.
    start_block(st, exit_blk.block_id, "loop_exit")
}

function lower_break_stmt(ctx: LowerCtx, p: BreakStmtPayload) -> LowerCtx = {
    // Evaluate the optional value expression so any side-effects
    // still emit, then branch. Break-with-value plumbing via phi
    // defers to v0.7.8.3b.
    let mutable st: LowerCtx = ctx
    match p.value {
        ~0 => { },
        _ => {
            let val_r: LowerExprResult = lower_expression(st, p.value!!)
            st = val_r.ctx
        },
    }
    match loop_stack_top(st) {
        ~0 => st,
        _ => emit(st, BrInst(InstBrPayload { target: loop_stack_top(st)!!.break_target })),
    }
}

function lower_continue_stmt(ctx: LowerCtx) -> LowerCtx =
    match loop_stack_top(ctx) {
        ~0 => ctx,
        _ => emit(ctx, BrInst(InstBrPayload { target: loop_stack_top(ctx)!!.continue_target })),
    }

// ── v0.7.8.3b: While + phi-node insertion ────────────────────────
//
// Patch helper: rebuild `blocks` with the specified block's `Phi`
// instruction (matching `phi_dest`) replaced to carry
// `new_incoming`. Used after the loop body has lowered, when we
// finally know the body-end SSA value + block ID for each phi'd
// var. Triết Vectors are immutable so every layer must rebuild —
// O(N²) but the corpus is tens of blocks at worst.

function patch_phi_incoming(
    blocks: Vector<BasicBlock>,
    block_idx: Integer,
    phi_dest: ValueId,
    new_incoming: Vector<PhiIncoming>,
) -> Vector<BasicBlock> = {
    let total: Integer = length(blocks)
    let mutable new_blocks: Vector<BasicBlock> = new()
    let mutable i: Integer = 0
    while i < total {
        let b_opt: BasicBlock? = get(blocks, i)
        let b: BasicBlock = b_opt!!
        if i == block_idx {
            let inst_total: Integer = length(b.instructions)
            let mutable new_insts: Vector<Instruction> = new()
            let mutable j: Integer = 0
            while j < inst_total {
                let inst_opt: Instruction? = get(b.instructions, j)
                let inst: Instruction = inst_opt!!
                let patched: Instruction = match inst {
                    PhiInst(p) => {
                        if p.dest.raw == phi_dest.raw {
                            PhiInst(InstPhiPayload {
                                dest: p.dest,
                                incoming: new_incoming,
                            })
                        } else {
                            inst
                        }
                    },
                    _ => inst,
                }
                new_insts = push(new_insts, patched)
                j = j + 1
            }
            new_blocks = push(new_blocks, BasicBlock {
                id: b.id,
                name: b.name,
                instructions: new_insts,
            })
        } else {
            new_blocks = push(new_blocks, b)
        }
        i = i + 1
    }
    new_blocks
}

// Walk a Block's statements and collect target names of every
// `AssignStmt` for phi-node planning. Dedupes via linear scan
// (corpus has a handful of distinct names — fine).
function collect_assigned_vars(arena: Arena, body: Block) -> Vector<String> = {
    let mutable names: Vector<String> = new()
    let total: Integer = length(body.block_statements)
    let mutable i: Integer = 0
    while i < total {
        let sid_opt: Integer? = get(body.block_statements, i)
        let spanned: SpannedStmt = get_statement(arena, sid_opt!!)
        match spanned.node {
            AssignStmt(p) => {
                let mutable found: Trilean! = false
                let n_total: Integer = length(names)
                let mutable k: Integer = 0
                while k < n_total {
                    let existing_opt: String? = get(names, k)
                    if existing_opt!! == p.target {
                        found = true
                    }
                    k = k + 1
                }
                if !found {
                    names = push(names, p.target)
                }
            },
            _ => { },
        }
        i = i + 1
    }
    names
}

// Build a 1-incoming Phi placeholder. Patched by
// `patch_phi_incoming` after the body has lowered.
function emit_phi_placeholder(
    ctx: LowerCtx,
    pre_value: ValueId,
    pre_block_id: BlockId,
) -> LowerExprResult = {
    let dest_r: LowerExprResult = fresh_value(ctx)
    let mut_inc: Vector<PhiIncoming> = new()
    let single_inc: Vector<PhiIncoming> = push(
        mut_inc,
        PhiIncoming { value: pre_value, block: pre_block_id },
    )
    let st: LowerCtx = emit(dest_r.ctx, PhiInst(InstPhiPayload {
        dest: dest_r.value_id,
        incoming: single_inc,
    }))
    LowerExprResult { ctx: st, value_id: dest_r.value_id }
}

// Read-only field accessors. Defining these so the lowerer's
// `field_idx` resolution (driven by ValueKind tracking — see
// ADR-0023) stays accurate even after `st = result.ctx` rebinds
// that lose the LowerCtx kind tag. Calling
// `ctx_current_block_idx(st)` re-enters a typed-parameter context.
function ctx_current_block_idx(ctx: LowerCtx) -> Integer = ctx.current_block_idx
function ctx_blocks(ctx: LowerCtx) -> Vector<BasicBlock> = ctx.blocks
function ctx_loop_stack(ctx: LowerCtx) -> Vector<LoopContext> = ctx.loop_stack

// Get the BlockId of the block at the given index. Defensive `~0`
// fallback shouldn't fire — callers always pass a valid index from
// `current_block_idx`.
function block_id_at(ctx: LowerCtx, idx: Integer) -> BlockId = {
    let b_opt: BasicBlock? = get(ctx.blocks, idx)
    match b_opt {
        ~0 => BlockId { raw: 0 },
        _ => b_opt!!.id,
    }
}

function lower_while_loop(ctx: LowerCtx, p: WhileStmtPayload) -> LowerCtx = {
    let arena: Arena = ctx.parser_arena

    // Step 1: collect mutated vars + snapshot pre-loop SSA bindings.
    // Use a sentinel `ValueId { raw: -1 }` to mark "var not bound
    // pre-loop, skip phi" — avoids `Vector<ValueId?>` (which Triết
    // wraps as `Vector<Nullable<ValueId>>` and `get` returns
    // `Nullable<Nullable<ValueId>>`, mismatching the slot
    // annotation).
    let mutated: Vector<String> = collect_assigned_vars(arena, p.body)
    let mutated_total: Integer = length(mutated)
    let pre_block_idx: Integer = ctx.current_block_idx
    let pre_block_id: BlockId = block_id_at(ctx, pre_block_idx)
    let mutable pre_vals: Vector<ValueId> = new()
    let mutable i: Integer = 0
    while i < mutated_total {
        let n_opt: String? = get(mutated, i)
        let v_opt: ValueId? = resolve_var(ctx, n_opt!!)
        let pre_v: ValueId = match v_opt {
            ~0 => ValueId { raw: -1 },
            _ => v_opt!!,
        }
        pre_vals = push(pre_vals, pre_v)
        i = i + 1
    }

    // Step 2: spawn header / body / exit blocks.
    let header_r: FreshBlockResult = fresh_block(ctx)
    let mutable st: LowerCtx = header_r.ctx
    let body_r: FreshBlockResult = fresh_block(st)
    st = body_r.ctx
    let exit_r: FreshBlockResult = fresh_block(st)
    st = exit_r.ctx

    // Step 3: branch from pre-loop block into header.
    st = emit(st, BrInst(InstBrPayload { target: header_r.block_id }))

    // Step 4: header block — emit Phi placeholders. Same sentinel
    // pattern for `phi_dests` (raw = -1 → no phi for this slot).
    st = start_block(st, header_r.block_id, "while_header")
    let header_block_idx: Integer = ctx_current_block_idx(st)
    let mutable phi_dests: Vector<ValueId> = new()
    i = 0
    while i < mutated_total {
        let pre_v_e_opt: ValueId? = get(pre_vals, i)
        let pre_v: ValueId = pre_v_e_opt!!
        if pre_v.raw < 0 {
            // Pre-loop unbound — skip phi for this slot.
            phi_dests = push(phi_dests, ValueId { raw: -1 })
        } else {
            let phi_r: LowerExprResult = emit_phi_placeholder(st, pre_v, pre_block_id)
            st = phi_r.ctx
            phi_dests = push(phi_dests, phi_r.value_id)
            let n_opt: String? = get(mutated, i)
            st = bind_var(st, n_opt!!, phi_r.value_id)
        }
        i = i + 1
    }

    // Step 5: lower the condition (reads phi'd values).
    let cond_r: LowerExprResult = lower_expression(st, p.condition)
    st = cond_r.ctx

    // Step 6: compute unknown_target for BrTrilean.
    // - `while cond { … }` → panic on Unknown (spawn a fresh
    //   block holding `Unreachable`, branch there)
    // - `while? cond { … }` → treat as False (branch to exit)
    let mutable unk_target: BlockId = exit_r.block_id
    if !p.treat_unknown_as_false {
        let unk_r: FreshBlockResult = fresh_block(st)
        st = unk_r.ctx
        // Switch to unknown block, emit Unreachable, switch back.
        st = start_block(st, unk_r.block_id, "while_unknown_panic")
        st = emit(st, UnreachableInst(primitive_marker()))
        st = ctx_with_current_block(st, header_block_idx)
        unk_target = unk_r.block_id
    }

    // Emit BrTrilean from the header. current_block_idx is still
    // header (we switched back after possibly spawning unknown).
    st = emit(st, BrTrileanInst(InstBrTrileanPayload {
        cond: ValueOp(cond_r.value_id),
        true_block: body_r.block_id,
        unknown_block: unk_target,
        false_block: exit_r.block_id,
    }))

    // Step 7: lower body.
    //
    // Mirrors Rust's `lower_while_loop`: push ONE scope for body
    // rebinds, lower the body's stmts/final-expr (no nested scope
    // push — `lower_block_inline` skips the push/pop that
    // `lower_block` does), THEN snapshot the body-end values
    // before popping. Pre-fix Triết called `lower_block` which
    // pushes its own scope; combined with the outer `push_scope`
    // here the AssignStmt rebinds landed in the inner scope which
    // `lower_block` immediately popped, so `resolve_var` at step
    // 7b resolved to the header-scope phi-dest — phi-incoming
    // became a self-loop `[pre, %3@body]` instead of the correct
    // `[pre, %6@body]`.
    st = start_block(st, body_r.block_id, "while_body")
    st = push_scope(st)
    let body_res: LowerExprResult = lower_block_inline(st, p.body)
    st = body_res.ctx

    // Step 7b: snapshot the body-end SSA value of each mutated name
    // BEFORE popping the body scope. Mirrors `lowerer.rs:2191-2196`
    // — Rust's `post_body_vals` is collected pre-`pop_scope` so
    // `resolve_var(name)` returns the body's latest rebind (the
    // `Add` / `Mul` result) instead of the header-scope phi-dest.
    let mutable body_end_vals: Vector<ValueId> = new()
    i = 0
    while i < mutated_total {
        let nm_opt_pre: String? = get(mutated, i)
        let resolved_pre: ValueId? = resolve_var(st, nm_opt_pre!!)
        let captured: ValueId = match resolved_pre {
            ~0 => ValueId { raw: -1 },
            _ => resolved_pre!!,
        }
        body_end_vals = push(body_end_vals, captured)
        i = i + 1
    }
    st = pop_scope(st)

    // Step 8: patch header's Phi placeholders with body-end edges.
    let body_end_block_idx: Integer = ctx_current_block_idx(st)
    let body_end_block_id: BlockId = block_id_at(st, body_end_block_idx)
    let mutable patched_blocks: Vector<BasicBlock> = ctx_blocks(st)
    i = 0
    while i < mutated_total {
        let pd_e_opt: ValueId? = get(phi_dests, i)
        let phi_d: ValueId = pd_e_opt!!
        if phi_d.raw >= 0 {
            let body_v_opt: ValueId? = get(body_end_vals, i)
            let body_v: ValueId = body_v_opt!!
            if body_v.raw >= 0 {
                let pre_v_e_opt2: ValueId? = get(pre_vals, i)
                let pre_v: ValueId = pre_v_e_opt2!!
                let mutable new_inc: Vector<PhiIncoming> = new()
                new_inc = push(new_inc, PhiIncoming {
                    value: pre_v,
                    block: pre_block_id,
                })
                new_inc = push(new_inc, PhiIncoming {
                    value: body_v,
                    block: body_end_block_id,
                })
                patched_blocks = patch_phi_incoming(
                    patched_blocks,
                    header_block_idx,
                    phi_d,
                    new_inc,
                )
            }
        }
        i = i + 1
    }
    st = ctx_with_blocks(st, patched_blocks)

    // Step 9: Br back to header (if body didn't terminate via
    // explicit `break` / `return`).
    if !current_block_has_terminator(st) {
        st = emit(st, BrInst(InstBrPayload { target: header_r.block_id }))
    }

    // Step 10: start exit block as the new current block.
    start_block(st, exit_r.block_id, "while_exit")
}

// ── v0.7.8.4: For loop over Range ────────────────────────────────
//
// Mirrors `lower_for_loop` in the Rust lowerer (lines 2179+),
// specialized to the Range case (the general iterator protocol
// defers post-v0.7.8 since it needs closures or a state machine
// value per ADR-0019 §A7.8).
//
// Shape:
//   pre:        Const(start) → %s, Const(end) → %e, Br header
//   header:     %c = Phi [(%s, pre)], cond = %c < %e,
//               BrTrilean cond → body | exit | exit
//   body:       bind pattern.var → %c
//               <body>
//               %c_next = Add %c, Const(1)
//               Br header  (with phi patched [(%s, pre), (%c_next, body_end)])
//   exit:       (new current block)
//
// Variable assigned inside the body get their own phi nodes too,
// via the same `collect_assigned_vars` machinery as While.

// Extract identifier name from a pattern. Returns "" for
// wildcard or any non-identifier pattern (those don't bind a
// name; the counter SSA value just flows through unused).
function pattern_var_name(arena: Arena, pattern_id: Integer) -> String = {
    let spanned: SpannedPattern = get_pattern(arena, pattern_id)
    match spanned.node {
        IdentifierPattern(sp) => sp.text,
        _ => "",
    }
}

function lower_for_loop(ctx: LowerCtx, p: ForStmtPayload) -> LowerCtx = {
    let arena: Arena = ctx.parser_arena

    // Only Range iterables supported at v0.7.8.4. Other iterators
    // (Vector, generic iterator protocol) defer post-v0.7.8.
    let iter_spanned: SpannedExpr = get_expression(arena, p.iterable)
    let mutable st: LowerCtx = ctx
    let mutable start_val: ValueId = ValueId { raw: 0 }
    let mutable end_val: ValueId = ValueId { raw: 0 }
    let mutable is_range: Trilean! = false
    match iter_spanned.node {
        RangeExpr(rp) => {
            let s_r: LowerExprResult = lower_expression(st, rp.range_start)
            st = s_r.ctx
            start_val = s_r.value_id
            let e_r: LowerExprResult = lower_expression(st, rp.range_end)
            st = e_r.ctx
            end_val = e_r.value_id
            is_range = true
        },
        _ => {
            // Non-range iterable — defer to v0.7.8.4 followup. For
            // now still lower the iterable (side-effects) but the
            // For body runs once with an Unknown counter value.
            let dummy_r: LowerExprResult = lower_expression(st, p.iterable)
            st = dummy_r.ctx
        },
    }

    if !is_range {
        // Lower the body once as straight-line code (without
        // counter / phi), then bail. Matches the v0.7.7.4 pattern-
        // binding-only behavior.
        st = push_scope(st)
        let body_r: LowerExprResult = lower_block(st, p.body)
        st = body_r.ctx
        return pop_scope(st)
    }

    // Pattern variable name (for binding inside body).
    let var_name: String = pattern_var_name(arena, p.variable)

    // Collect mutated vars in body (Phi candidates beyond the counter).
    let mutated: Vector<String> = collect_assigned_vars(arena, p.body)
    let mutated_total: Integer = length(mutated)

    let pre_block_idx: Integer = ctx_current_block_idx(st)
    let pre_block_id: BlockId = block_id_at(st, pre_block_idx)
    let mutable pre_vals: Vector<ValueId> = new()
    let mutable mi: Integer = 0
    while mi < mutated_total {
        let n_opt: String? = get(mutated, mi)
        let v_opt: ValueId? = resolve_var(st, n_opt!!)
        let pre_v: ValueId = match v_opt {
            ~0 => ValueId { raw: -1 },
            _ => v_opt!!,
        }
        pre_vals = push(pre_vals, pre_v)
        mi = mi + 1
    }

    // Spawn header / body / exit blocks.
    let header_r: FreshBlockResult = fresh_block(st)
    st = header_r.ctx
    let body_blk_r: FreshBlockResult = fresh_block(st)
    st = body_blk_r.ctx
    let exit_r: FreshBlockResult = fresh_block(st)
    st = exit_r.ctx

    // Br from pre-block into header.
    st = emit(st, BrInst(InstBrPayload { target: header_r.block_id }))

    // Header block: counter phi + body-var phis + cond check.
    st = start_block(st, header_r.block_id, "for_header")
    let header_block_idx: Integer = ctx_current_block_idx(st)

    // Counter phi (always present for Range).
    let counter_phi: LowerExprResult = emit_phi_placeholder(st, start_val, pre_block_id)
    st = counter_phi.ctx

    // Body-mutated var phis.
    let mutable phi_dests: Vector<ValueId> = new()
    mi = 0
    while mi < mutated_total {
        let pre_v_e_opt: ValueId? = get(pre_vals, mi)
        let pre_v: ValueId = pre_v_e_opt!!
        if pre_v.raw < 0 {
            phi_dests = push(phi_dests, ValueId { raw: -1 })
        } else {
            let phi_r: LowerExprResult = emit_phi_placeholder(st, pre_v, pre_block_id)
            st = phi_r.ctx
            phi_dests = push(phi_dests, phi_r.value_id)
            let n_opt: String? = get(mutated, mi)
            st = bind_var(st, n_opt!!, phi_r.value_id)
        }
        mi = mi + 1
    }

    // Condition: counter < end. Emit Lt instruction.
    let cond_r: LowerExprResult = fresh_value(st)
    st = cond_r.ctx
    st = emit(st, LtInst(InstBinaryOpPayload {
        dest: cond_r.value_id,
        lhs: ValueOp(counter_phi.value_id),
        rhs: ValueOp(end_val),
    }))

    // BrTrilean (cond) → body | exit | exit (Lt always produces a
    // Trilean! so Unknown branch is unreachable but the opcode
    // requires three targets).
    st = emit(st, BrTrileanInst(InstBrTrileanPayload {
        cond: ValueOp(cond_r.value_id),
        true_block: body_blk_r.block_id,
        unknown_block: exit_r.block_id,
        false_block: exit_r.block_id,
    }))

    // Body block: bind counter to pattern var, lower body, increment.
    st = start_block(st, body_blk_r.block_id, "for_body")
    if var_name != "" {
        st = bind_var(st, var_name, counter_phi.value_id)
    }
    // Push LoopContext for break/continue.
    let lc: LoopContext = LoopContext {
        break_target: exit_r.block_id,
        continue_target: header_r.block_id,
    }
    st = ctx_with_loop_stack(st, push(ctx_loop_stack(st), lc))
    st = push_scope(st)
    let body_r: LowerExprResult = lower_block(st, p.body)
    st = body_r.ctx
    st = pop_scope(st)
    st = loop_stack_pop(st)

    // Increment counter: %c_next = %c + 1.
    let one_intern: InternCtxResult = intern_constant(st, IntegerConst(ConstantIntegerPayload { value: 1 }))
    st = one_intern.ctx
    let one_dest: LowerExprResult = fresh_value(st)
    st = emit(one_dest.ctx, ConstInst(InstConstPayload {
        dest: one_dest.value_id,
        const_id: one_intern.const_id,
    }))
    let inc_dest: LowerExprResult = fresh_value(st)
    st = emit(inc_dest.ctx, AddInst(InstBinaryOpPayload {
        dest: inc_dest.value_id,
        lhs: ValueOp(counter_phi.value_id),
        rhs: ValueOp(one_dest.value_id),
    }))

    // Patch phi placeholders with body-end edges. Counter phi
    // gets [(start_val, pre_block), (inc_dest, body_end_block)];
    // user-var phis get [(pre_val, pre_block), (cur_val,
    // body_end_block)].
    let body_end_block_idx: Integer = ctx_current_block_idx(st)
    let body_end_block_id: BlockId = block_id_at(st, body_end_block_idx)
    let mutable patched_blocks: Vector<BasicBlock> = ctx_blocks(st)

    // Counter phi patch.
    let mutable counter_inc: Vector<PhiIncoming> = new()
    counter_inc = push(counter_inc, PhiIncoming { value: start_val, block: pre_block_id })
    counter_inc = push(counter_inc, PhiIncoming { value: inc_dest.value_id, block: body_end_block_id })
    patched_blocks = patch_phi_incoming(patched_blocks, header_block_idx, counter_phi.value_id, counter_inc)

    // User-var phi patches.
    mi = 0
    while mi < mutated_total {
        let pd_e_opt: ValueId? = get(phi_dests, mi)
        let phi_d: ValueId = pd_e_opt!!
        if phi_d.raw >= 0 {
            let nm_opt: String? = get(mutated, mi)
            let nm: String = nm_opt!!
            let cur_v_opt: ValueId? = resolve_var(st, nm)
            match cur_v_opt {
                ~0 => { },
                _ => {
                    let pre_v_e_opt2: ValueId? = get(pre_vals, mi)
                    let pre_v: ValueId = pre_v_e_opt2!!
                    let mutable inc_list: Vector<PhiIncoming> = new()
                    inc_list = push(inc_list, PhiIncoming { value: pre_v, block: pre_block_id })
                    inc_list = push(inc_list, PhiIncoming { value: cur_v_opt!!, block: body_end_block_id })
                    patched_blocks = patch_phi_incoming(patched_blocks, header_block_idx, phi_d, inc_list)
                },
            }
        }
        mi = mi + 1
    }
    st = ctx_with_blocks(st, patched_blocks)

    // Br back to header.
    if !current_block_has_terminator(st) {
        st = emit(st, BrInst(InstBrPayload { target: header_r.block_id }))
    }

    // Start exit block.
    start_block(st, exit_r.block_id, "for_exit")
}

public function lower_statement(ctx: LowerCtx, stmt_id: Integer) -> LowerCtx = {
    let spanned: SpannedStmt = get_statement(ctx.parser_arena, stmt_id)
    match spanned.node {
        LetStmt(p) => lower_let_stmt(ctx, p),
        ConstantStmt(p) => lower_constant_stmt(ctx, p),
        ReturnStmt(p) => lower_return_stmt(ctx, p),
        ExpressionStmt(p) => lower_expression_stmt(ctx, p),
        AssignStmt(p) => lower_assign_stmt(ctx, p),
        LoopStmt(p) => lower_loop_stmt(ctx, p),
        BreakStmt(p) => lower_break_stmt(ctx, p),
        ContinueStmt => lower_continue_stmt(ctx),
        WhileStmt(p) => lower_while_loop(ctx, p),
        ForStmt(p) => lower_for_loop(ctx, p),
        _ => ctx,
    }
}

// Lower a block: open a fresh scope, lower each statement in
// order, lower the final expression (or use Unit if absent), then
// pop the scope. Returns the block's value.
public function lower_block(ctx: LowerCtx, block: Block) -> LowerExprResult = {
    let scoped: LowerCtx = push_scope(ctx)
    let stepped: LowerExprResult = lower_block_inline(scoped, block)
    let unscoped: LowerCtx = pop_scope(stepped.ctx)
    LowerExprResult { ctx: unscoped, value_id: stepped.value_id }
}

/// Lower the body of a block WITHOUT pushing or popping a scope.
/// Used by `lower_while_loop` / `lower_for_loop` etc., which
/// manage their own scope so they can snapshot body-end SSA
/// values (`resolve_var(name)` for each mutated var) before the
/// scope unwinds — mirrors Rust's `lower_block` (no internal
/// push/pop) + `lower_while_loop`'s explicit `pop_scope` after
/// the `post_body_vals` capture.
function lower_block_inline(ctx: LowerCtx, block: Block) -> LowerExprResult = {
    let mutable st: LowerCtx = ctx
    let stmt_total: Integer = length(block.block_statements)
    let mutable i: Integer = 0
    while i < stmt_total {
        let sid_opt: Integer? = get(block.block_statements, i)
        st = lower_statement(st, sid_opt!!)
        i = i + 1
    }
    match block.block_final {
        ~0 => {
            // Unit-value block: emit a Unit const so the block
            // produces a real ValueId (downstream Ret needs one).
            let c: Constant = UnitConst(primitive_marker())
            let intern_r: InternCtxResult = intern_constant(st, c)
            let dest_r: LowerExprResult = fresh_value(intern_r.ctx)
            let inst: Instruction = ConstInst(InstConstPayload {
                dest: dest_r.value_id,
                const_id: intern_r.const_id,
            })
            LowerExprResult { ctx: emit(dest_r.ctx, inst), value_id: dest_r.value_id }
        },
        _ => lower_expression(st, block.block_final!!),
    }
}

// ── Function lowering ────────────────────────────────────────────

public struct LowerFunctionResult {
    ctx: LowerCtx,
    fn: Function,
}

function lower_function(
    ctx_outer: LowerCtx,
    func_id: FuncId,
    def: FunctionDef,
) -> LowerFunctionResult = {
    // Fresh per-function counters + blocks (the ctx_outer carries
    // the module-shared `constants` + `type_arena` so we forward
    // those but reset everything else).
    let mutable ctx: LowerCtx = LowerCtx {
        parser_arena: ctx_outer.parser_arena,
        value_counter: 0,
        block_counter: 0,
        blocks: new(),
        current_block_idx: 0,
        scopes: ctx_outer.scopes,
        type_arena: ctx_outer.type_arena,
        constants: ctx_outer.constants,
        return_type_id: ctx_outer.return_type_id,
        func_table: ctx_outer.func_table,
        loop_stack: ctx_outer.loop_stack,
        struct_fields: ctx_outer.struct_fields,
        variant_index: ctx_outer.variant_index,
        enum_variants: ctx_outer.enum_variants,
        import_paths: ctx_outer.import_paths,
    }
    ctx = push_scope(ctx)

    // Resolve return type to a TypeTag id. Use the function's
    // annotated type if present, else Unit.
    let ret_r: ResolveTagResult = match def.return_type {
        ~0 => {
            let r: AllocTagResult = alloc_tag_unit(ctx.type_arena)
            ResolveTagResult { ctx: ctx_with_type_arena(ctx, r.arena), tag_id: r.tag_id }
        },
        _ => resolve_type_expr_to_tag(ctx, def.return_type!!),
    }
    ctx = ctx_with_return_type(ret_r.ctx, ret_r.tag_id)

    // Entry block.
    let entry_r: FreshBlockResult = fresh_block(ctx)
    ctx = start_block(entry_r.ctx, entry_r.block_id, "entry")

    // Allocate parameter ValueIds + bind them in the function scope.
    let mutable param_specs: Vector<IrFunctionParam> = new()
    let p_total: Integer = length(def.parameters)
    let mutable pi: Integer = 0
    while pi < p_total {
        let param_opt: FunctionParam? = get(def.parameters, pi)
        let param: FunctionParam = param_opt!!
        let v_r: LowerExprResult = fresh_value(ctx)
        ctx = v_r.ctx
        let tag_r: ResolveTagResult = resolve_type_expr_to_tag(ctx, param.type_annotation)
        ctx = tag_r.ctx
        ctx = bind_var(ctx, param.name, v_r.value_id)
        param_specs = push(param_specs, IrFunctionParam {
            name: param.name,
            type_tag_id: tag_r.tag_id,
        })
        pi = pi + 1
    }

    // Lower the body.
    let body_r: LowerExprResult = match def.body {
        BlockBody(block) => lower_block(ctx, block),
        ExpressionBody(expr_id) => lower_expression(ctx, expr_id),
    }
    ctx = body_r.ctx

    // Auto-Ret if the body didn't terminate.
    if !current_block_has_terminator(ctx) {
        ctx = emit(ctx, RetInst(InstRetPayload { value: ValueOp(body_r.value_id) }))
    }

    ctx = pop_scope(ctx)

    let lowered: Function = function_with_blocks(
        function_new(func_id, def.name, param_specs, ctx.return_type_id),
        ctx.blocks,
    )
    LowerFunctionResult { ctx: ctx, fn: lowered }
}

// Helper: build a Function with the given blocks. Mirrors
// `Function::new` + `func.blocks = blocks` pattern.
function function_with_blocks(fn: Function, blocks: Vector<BasicBlock>) -> Function =
    Function {
        id: fn.id,
        name: fn.name,
        parameters: fn.parameters,
        return_type_id: fn.return_type_id,
        blocks: blocks,
    }

// ── Top-level lower_program driver ───────────────────────────────
//
// Single-module variant: walks the parsed Items list, assigns
// FuncIds in source order, lowers each function body. Cross-module
// resolution (CallCrossModule path emission) defers to v0.7.8.{3,5}
// when the multi-module driver lands alongside the wire format.

// Result of `lower_module`: the `IrModule` itself plus the
// threaded `ConstantPool` that accumulated across all functions in
// the module. The caller (`lower_source`) lifts the pool onto the
// final `IrProgram` so per-function `Const` instructions can
// resolve their `ConstId` references.
public struct LowerModuleResult {
    ir_module: IrModule,
    constants: ConstantPool,
}

public function lower_module(arena: Arena, item_ids: Vector<Integer>) -> LowerModuleResult =
    lower_module_with_imports(arena, item_ids, hashmap_new())

/// v0.7.10: like `lower_module` but seeds `LowerCtx.import_paths`
/// from the resolved module's `bindings` map (converted to
/// dot-string form). Enables path-based builtin disambiguation
/// per Rust's `lowerer.rs:3106` semantics.
public function lower_module_with_imports(
    arena: Arena,
    item_ids: Vector<Integer>,
    import_paths: HashMap<String, String>,
) -> LowerModuleResult = {
    // Pass 1a (v0.7.8.4): register struct + enum declarations so
    // FieldGet's `field_idx` and EnumNew's `variant_idx` resolve
    // by source-level name. Mirrors lowerer.rs:39-62 (Pass 1a).
    let item_total: Integer = length(item_ids)
    let mutable struct_fields: HashMap<String, Vector<String>> = hashmap_new()
    let mutable enum_variants: HashMap<String, Vector<String>> = hashmap_new()
    let mutable variant_index: HashMap<String, VariantInfo> = hashmap_new()
    let mutable items_i: Integer = 0
    while items_i < item_total {
        let id_opt: Integer? = get(item_ids, items_i)
        let spanned: SpannedItem = get_item(arena, id_opt!!)
        match spanned.node {
            StructItem(sd) => {
                let mutable names: Vector<String> = new()
                let f_total: Integer = length(sd.fields)
                let mutable fi: Integer = 0
                while fi < f_total {
                    let f_opt: StructField? = get(sd.fields, fi)
                    names = push(names, f_opt!!.name)
                    fi = fi + 1
                }
                struct_fields = insert(struct_fields, sd.name, names)
            },
            EnumItem(ed) => {
                let mutable vnames: Vector<String> = new()
                let v_total: Integer = length(ed.variants)
                let mutable vi: Integer = 0
                while vi < v_total {
                    let v_opt: EnumVariant? = get(ed.variants, vi)
                    let v: EnumVariant = v_opt!!
                    vnames = push(vnames, v.name)
                    variant_index = insert(variant_index, v.name, VariantInfo {
                        enum_name: ed.name,
                        variant_idx: vi,
                    })
                    vi = vi + 1
                }
                enum_variants = insert(enum_variants, ed.name, vnames)
            },
            _ => { },
        }
        items_i = items_i + 1
    }

    // Pass 1b: collect function definitions in source order.
    let mutable function_defs: Vector<FunctionDef> = new()
    let mutable i: Integer = 0
    while i < item_total {
        let id_opt2: Integer? = get(item_ids, i)
        let spanned2: SpannedItem = get_item(arena, id_opt2!!)
        match spanned2.node {
            FunctionItem(def) => { function_defs = push(function_defs, def) },
            _ => { },
        }
        i = i + 1
    }

    // Pass 1.5 (v0.7.8.3): build func_table so any forward call
    // (callee declared after caller in source order) resolves to a
    // FuncId via `lower_call`. FuncId raw values match the
    // `function_defs` index, so position-based assignment suffices.
    //
    // Path segments start at `["khi"]` to mirror Rust's
    // `ModulePath::crate_root()` — `write_function_table`
    // serializes `module.path.to_string()` which renders
    // `"khi"` for the local-crate root. Empty segments here
    // emit `"."` instead, breaking byte-identical against the
    // Rust pipeline (tracked as the now-closed
    // `v0.7.x.runtime-fix.write-function-table-module-prefix`).
    let mod_path: Vector<String> = push(new(), "khi")
    let mutable ir_mod: IrModule = ir_module_new(mod_path)
    let mutable ctx: LowerCtx = lower_ctx_new(arena)
    ctx = ctx_with_struct_fields(ctx, struct_fields)
    ctx = ctx_with_variant_index(ctx, variant_index)
    ctx = ctx_with_enum_variants(ctx, enum_variants)
    let fn_total: Integer = length(function_defs)
    let mutable mut_ft: HashMap<String, FuncId> = hashmap_new()
    let mutable k: Integer = 0
    while k < fn_total {
        let d_opt: FunctionDef? = get(function_defs, k)
        let d: FunctionDef = d_opt!!
        mut_ft = insert(mut_ft, d.name, FuncId { raw: k })
        k = k + 1
    }
    ctx = ctx_with_func_table(ctx, mut_ft)
    ctx = ctx_with_import_paths(ctx, import_paths)

    // Pass 2: lower each function body.
    let mutable j: Integer = 0
    while j < fn_total {
        let def_opt: FunctionDef? = get(function_defs, j)
        let def: FunctionDef = def_opt!!
        let lr: LowerFunctionResult = lower_function(ctx, FuncId { raw: j }, def)
        // v0.7.8.2 keeps each function's blocks independent but
        // shares the constants pool + type arena via the threaded
        // ctx. Cross-function constant dedup lands v0.7.8.5.
        ctx = lr.ctx
        ir_mod = ir_module_push_function(ir_mod, lr.fn)
        j = j + 1
    }
    let final_mod: IrModule = ir_module_with_type_arena(ir_mod, ctx.type_arena)
    LowerModuleResult { ir_module: final_mod, constants: ctx.constants }
}

// Convenience entry: lex + parse + lower in one call. Returns an
// empty `IrProgram` on lex failure (matches typecheck.tri's
// `check_source` shape).
//
// v0.7.11.2 note: the multi-file `lower_program(ResolvedProgram) ->
// IrProgram` driver lives in `compiler/driver.tri` (NOT here)
// because importing `ResolvedProgram` directly into ir_lowerer.tri
// would force a `module modules;` declaration that cycles with
// pack_writer.tri's existing `module ir_lowerer;` graph. driver.tri
// declares both `module ir_lowerer;` and `module modules;` as
// siblings — main.tri loads driver.tri and dispatches `dao build`
// through it.
public function lower_source(source: String) -> IrProgram = {
    let tokens_outcome: Vector<SpannedToken>~LexError = lex(source)
    match tokens_outcome {
        ~+ tokens => {
            let pstate: ParserState = parser_new(tokens)
            let pstep: ParseProgramStep = parse_program(pstate)
            let lr: LowerModuleResult = lower_module(pstep.program.arena, pstep.program.item_ids)
            let prog: IrProgram = ir_program_push_module(ir_program_new(), lr.ir_module)
            ir_program_with_constants(prog, lr.constants)
        },
    ~- _ => ir_program_new(),
    }
}


// ── v0.7.8.2 smoke ───────────────────────────────────────────────

public function lower_source_smoke_main() -> Unit = {
    // Test 1: empty program → IrProgram with no functions
    let p1: IrProgram = lower_source("")
    assert(ir_program_function_count(p1) == 0)

    // Test 2: minimal integer-body function → 1 function, 1 block,
    // exactly 2 instructions (Const + Ret).
    let p2: IrProgram = lower_source("function f() -> Integer = 42")
    assert(ir_program_function_count(p2) == 1)
    let m2: IrModule = get(p2.modules, 0)!!
    let f2: Function = get(m2.functions, 0)!!
    assert(length(f2.blocks) == 1)
    let bb2: BasicBlock = get(f2.blocks, 0)!!
    assert(length(bb2.instructions) == 2)
    let inst20: Instruction = get(bb2.instructions, 0)!!
    let inst21: Instruction = get(bb2.instructions, 1)!!
    assert_string_eq(instruction_opcode_name(inst20), "Const")
    assert_string_eq(instruction_opcode_name(inst21), "Ret")
    assert(function_is_well_formed(f2))

    // Test 3: BlockBody with let + arithmetic. Note: `= { … }`
    // ExpressionBody isn't parser-side surfaced yet (v0.7.5.6 gap);
    // use BlockBody form (`function g() -> T { … }`).
    let p3: IrProgram = lower_source("function g() -> Integer { let x: Integer = 5 x + 3 }")
    assert(ir_program_function_count(p3) == 1)
    let m3: IrModule = get(p3.modules, 0)!!
    let f3: Function = get(m3.functions, 0)!!
    let bb3: BasicBlock = get(f3.blocks, 0)!!
    let len3: Integer = length(bb3.instructions)
    // Const(5) + Const(3) + Add + Ret.
    assert(len3 == 4)
    let last3: Instruction = get(bb3.instructions, len3 - 1)!!
    assert_string_eq(instruction_opcode_name(last3), "Ret")
    assert(function_is_well_formed(f3))

    // Test 4: Function with parameters — uses param ValueIds.
    let p4: IrProgram = lower_source("function add(x: Integer, y: Integer) -> Integer = x + y")
    let m4: IrModule = get(p4.modules, 0)!!
    let f4: Function = get(m4.functions, 0)!!
    assert(length(f4.parameters) == 2)
    let param0: IrFunctionParam = get(f4.parameters, 0)!!
    let param1: IrFunctionParam = get(f4.parameters, 1)!!
    assert_string_eq(param0.name, "x")
    assert_string_eq(param1.name, "y")
    assert_string_eq(type_tag_display(m4.type_arena, param0.type_tag_id), "Integer")

    // Test 5: Unary negate → Const + Neg + Ret
    let p5: IrProgram = lower_source("function neg() -> Integer = -7")
    let m5: IrModule = get(p5.modules, 0)!!
    let f5: Function = get(m5.functions, 0)!!
    let bb5: BasicBlock = get(f5.blocks, 0)!!
    let neg_inst5: Instruction = get(bb5.instructions, 1)!!
    assert_string_eq(instruction_opcode_name(neg_inst5), "Neg")

    // Test 6: Comparison emits an Lt instruction
    let p6: IrProgram = lower_source("function lt(a: Integer, b: Integer) -> Trilean! = a < b")
    let m6: IrModule = get(p6.modules, 0)!!
    let f6: Function = get(m6.functions, 0)!!
    let bb6: BasicBlock = get(f6.blocks, 0)!!
    let lt_inst: Instruction = get(bb6.instructions, 0)!!
    assert_string_eq(instruction_opcode_name(lt_inst), "Lt")

    // Test 7: String literal interns a constant; pool grows.
    // (Post-runtime-fix: `lower_source` now propagates the threaded
    // ConstantPool from `lower_module` to the final `IrProgram`,
    // so the pool exposes the interned string + the auto-emitted
    // Unit for the block's value.)
    let p7: IrProgram = lower_source("function s() -> String = \"hi\"")
    assert(constant_pool_count(p7.constants) >= 1)

    println("v0.7.8.2 ir_lowerer literal+binding smoke OK")
}

// ── v0.7.8.3 smoke — call + assign + loop/break/continue ────────

public function call_loop_smoke_main() -> Unit = {
    // Test 1: builtin call — println("hi") emits one CallBuiltin
    // instruction + the string Const + the Unit auto-Ret.
    let p1: IrProgram = lower_source("function main() -> Unit = println(\"hi\")")
    let m1: IrModule = get(p1.modules, 0)!!
    let f1: Function = get(m1.functions, 0)!!
    let bb1: BasicBlock = get(f1.blocks, 0)!!
    let len1: Integer = length(bb1.instructions)
    // Const("hi"), CallBuiltin(println, [%0]), Ret.
    assert(len1 == 3)
    let i10: Instruction = get(bb1.instructions, 0)!!
    let i11: Instruction = get(bb1.instructions, 1)!!
    let i12: Instruction = get(bb1.instructions, 2)!!
    assert_string_eq(instruction_opcode_name(i10), "Const")
    assert_string_eq(instruction_opcode_name(i11), "CallBuiltin")
    assert_string_eq(instruction_opcode_name(i12), "Ret")

    // Test 2: local function call — `add(1, 2)` resolves through
    // the per-module func_table. The lowered `main` should emit
    // Const(1), Const(2), CallLocal(@f0, [%0, %1]), Ret.
    let src2: String = "function add(a: Integer, b: Integer) -> Integer = a + b\nfunction main() -> Integer = add(1, 2)"
    let p2: IrProgram = lower_source(src2)
    let m2: IrModule = get(p2.modules, 0)!!
    assert(length(m2.functions) == 2)
    let main_fn: Function = get(m2.functions, 1)!!
    let main_bb: BasicBlock = get(main_fn.blocks, 0)!!
    let main_len: Integer = length(main_bb.instructions)
    // Const(1), Const(2), CallLocal, Ret.
    assert(main_len == 4)
    let call_inst: Instruction = get(main_bb.instructions, 2)!!
    assert_string_eq(instruction_opcode_name(call_inst), "CallLocal")

    // Test 3: AssignStmt at top-level scope — rebinds variable.
    // `function f() -> Integer { let mutable x: Integer = 0 x = 5 x }`
    // → Const(0), Const(5), Ret(%1).
    let src3: String = "function f() -> Integer { let mutable x: Integer = 0 x = 5 x }"
    let p3: IrProgram = lower_source(src3)
    let m3: IrModule = get(p3.modules, 0)!!
    let f3: Function = get(m3.functions, 0)!!
    let bb3: BasicBlock = get(f3.blocks, 0)!!
    let len3: Integer = length(bb3.instructions)
    // Const(0), Const(5), Ret.
    assert(len3 == 3)

    // Test 4: Loop + Break — `loop { break }` produces 3 blocks:
    // entry (Br loop_body), loop_body (Br loop_exit), loop_exit
    // (Ret). Ret-value source is the block-final unit emitted at
    // block exit, threading through auto-Ret.
    let src4: String = "function f() -> Unit { loop { break } }"
    let p4: IrProgram = lower_source(src4)
    let m4: IrModule = get(p4.modules, 0)!!
    let f4: Function = get(m4.functions, 0)!!
    // 3 blocks expected: entry, loop_body, loop_exit.
    assert(length(f4.blocks) == 3)
    let entry4: BasicBlock = get(f4.blocks, 0)!!
    let body4: BasicBlock = get(f4.blocks, 1)!!
    let exit4: BasicBlock = get(f4.blocks, 2)!!
    // entry → Br loop_body
    let entry_last: Instruction = get(entry4.instructions, length(entry4.instructions) - 1)!!
    assert_string_eq(instruction_opcode_name(entry_last), "Br")
    // loop_body → Br loop_exit (from break)
    let body_last: Instruction = get(body4.instructions, length(body4.instructions) - 1)!!
    assert_string_eq(instruction_opcode_name(body_last), "Br")
    // loop_exit ends with Ret
    let exit_last: Instruction = get(exit4.instructions, length(exit4.instructions) - 1)!!
    assert_string_eq(instruction_opcode_name(exit_last), "Ret")

    // Test 5: Loop + Continue — `loop { continue }` emits a single
    // Br back to loop_body. Tests that continue resolves the
    // innermost loop's `continue_target`.
    let src5: String = "function f() -> Unit { loop { continue } }"
    let p5: IrProgram = lower_source(src5)
    let m5: IrModule = get(p5.modules, 0)!!
    let f5: Function = get(m5.functions, 0)!!
    assert(length(f5.blocks) == 3)

    println("v0.7.8.3 ir_lowerer call+loop smoke OK")
}

// ── v0.7.8.3b smoke — While loop + phi-node insertion ────────────

public function while_phi_smoke_main() -> Unit = {
    // Test 1: empty-body `while?` over a Trilean condition → no
    // mutated vars, no phi. Canonical 4-block shape: entry,
    // while_header, while_body, while_exit. With treat_unknown_as_false
    // (the `while?` form), unknown branches to exit (no panic block).
    let s1: String = "function f() -> Unit { while? unknown { } }"
    let p1: IrProgram = lower_source(s1)
    let m1: IrModule = get(p1.modules, 0)!!
    let f1: Function = get(m1.functions, 0)!!
    assert(length(f1.blocks) == 4)

    // Test 2: plain `while` produces an extra `unknown_panic`
    // block (5 blocks total: entry, header, unknown_panic, body,
    // exit). The order of body / unknown_panic depends on
    // spawn timing; we just assert the total count.
    let s2: String = "function f() -> Unit { let mutable i: Integer = 0 while i < 10 { i = i + 1 } }"
    let p2: IrProgram = lower_source(s2)
    let m2: IrModule = get(p2.modules, 0)!!
    let f2: Function = get(m2.functions, 0)!!
    assert(length(f2.blocks) == 5)

    // Test 3: header block carries a Phi for the assigned var `i`.
    // Inspect block at index 1 (header) — first instruction should
    // be a Phi.
    let header2: BasicBlock = get(f2.blocks, 1)!!
    let first_inst: Instruction = get(header2.instructions, 0)!!
    assert_string_eq(instruction_opcode_name(first_inst), "Phi")

    // Test 4: the Phi has 2 incoming edges (pre-loop entry +
    // body-end after assign). Patching from the v0.7.8.3b
    // `patch_phi_incoming` helper makes both edges visible.
    let phi_count: Integer = match first_inst {
        PhiInst(pp) => length(pp.incoming),
        _ => 0,
    }
    assert(phi_count == 2)

    // Test 5: header's terminator is BrTrilean (3-way branch on
    // the Trilean condition, ADR-0010).
    let header_inst_total: Integer = length(header2.instructions)
    let header_last: Instruction = get(header2.instructions, header_inst_total - 1)!!
    assert_string_eq(instruction_opcode_name(header_last), "BrTrilean")

    println("v0.7.8.3b ir_lowerer while+phi smoke OK")
}

// ── v0.7.8.4 smoke — struct/enum/outcome/for ─────────────────────

public function struct_enum_outcome_smoke_main() -> Unit = {
    // Test 1: struct declaration registers fields. Lowering a
    // program with just `struct Point { x: Integer, y: Integer }`
    // (plus a placeholder main) succeeds with 0 functions in
    // user code apart from main.
    let s1: String = "struct Point { x: Integer, y: Integer }\nfunction main() -> Integer = 0"
    let p1: IrProgram = lower_source(s1)
    let m1: IrModule = get(p1.modules, 0)!!
    assert(length(m1.functions) == 1)

    // Test 2: enum declaration + unit-variant identifier promotes
    // to EnumNew. `None` referenced bare → `EnumNew { variant_idx: 0 }`.
    let s2: String = "enum Maybe { None, Some(Integer) }\nfunction f() -> Maybe = None"
    let p2: IrProgram = lower_source(s2)
    let m2: IrModule = get(p2.modules, 0)!!
    let f2: Function = get(m2.functions, 0)!!
    let bb2: BasicBlock = get(f2.blocks, 0)!!
    let i20: Instruction = get(bb2.instructions, 0)!!
    assert_string_eq(instruction_opcode_name(i20), "EnumNew")

    // Test 3: tuple-variant call (e.g. `Some(42)`) promotes to
    // EnumNew with a payload operand. Const(42) + EnumNew + Ret.
    let s3: String = "enum Maybe { None, Some(Integer) }\nfunction f() -> Maybe = Some(42)"
    let p3: IrProgram = lower_source(s3)
    let m3: IrModule = get(p3.modules, 0)!!
    let f3: Function = get(m3.functions, 0)!!
    let bb3: BasicBlock = get(f3.blocks, 0)!!
    let len3: Integer = length(bb3.instructions)
    // Const(42), EnumNew, Ret.
    assert(len3 == 3)
    let i31: Instruction = get(bb3.instructions, 1)!!
    assert_string_eq(instruction_opcode_name(i31), "EnumNew")

    // Test 4: Outcome constructor — success arm `~+ 42` →
    // `Const + OutcomeNewPositive + Ret`.
    let s4: String = "function ok() -> Integer~String = ~+ 42"
    let p4: IrProgram = lower_source(s4)
    let m4: IrModule = get(p4.modules, 0)!!
    let f4: Function = get(m4.functions, 0)!!
    let bb4: BasicBlock = get(f4.blocks, 0)!!
    let i41: Instruction = get(bb4.instructions, 1)!!
    assert_string_eq(instruction_opcode_name(i41), "OutcomeNewPositive")

    // Test 5: Outcome constructor — error arm `~- "bad"`.
    let s5: String = "function bad() -> Integer~String = ~- \"bad\""
    let p5: IrProgram = lower_source(s5)
    let m5: IrModule = get(p5.modules, 0)!!
    let f5: Function = get(m5.functions, 0)!!
    let bb5: BasicBlock = get(f5.blocks, 0)!!
    let i51: Instruction = get(bb5.instructions, 1)!!
    assert_string_eq(instruction_opcode_name(i51), "OutcomeNewNegative")

    // Test 6: Outcome constructor — null arm `~0` → no payload,
    // single OutcomeNewNull + Ret.
    let s6: String = "function none_val() -> Integer?~String = ~0"
    let p6: IrProgram = lower_source(s6)
    let m6: IrModule = get(p6.modules, 0)!!
    let f6: Function = get(m6.functions, 0)!!
    let bb6: BasicBlock = get(f6.blocks, 0)!!
    let i60: Instruction = get(bb6.instructions, 0)!!
    assert_string_eq(instruction_opcode_name(i60), "OutcomeNewNull")

    // Test 7: For loop over Range with no body assigns. Shape:
    // entry → for_header (counter phi + Lt + BrTrilean) → for_body
    // (Br header) → for_exit. 4 blocks.
    let s7: String = "function f() -> Unit { for i in 0..10 { } }"
    let p7: IrProgram = lower_source(s7)
    let m7: IrModule = get(p7.modules, 0)!!
    let f7: Function = get(m7.functions, 0)!!
    assert(length(f7.blocks) == 4)
    let h7: BasicBlock = get(f7.blocks, 1)!!
    // Header's first instruction is the counter Phi.
    let h7_first: Instruction = get(h7.instructions, 0)!!
    assert_string_eq(instruction_opcode_name(h7_first), "Phi")

    println("v0.7.8.4 ir_lowerer struct+enum+outcome+for smoke OK")
}

// ── v0.7.11.1a smoke — Elvis operator ────────────────────────────

public function elvis_smoke_main() -> Unit = {
    // Test 1: `x ?: 0` over `Integer?` parameter — canonical 4-block
    // shape (entry, elvis_some, elvis_default, elvis_merge). Entry
    // ends in BrTrilean; merge starts with Phi + ends with Ret.
    let s1: String = "function f(x: Integer?) -> Integer = x ?: 0"
    let p1: IrProgram = lower_source(s1)
    let m1: IrModule = get(p1.modules, 0)!!
    let f1: Function = get(m1.functions, 0)!!
    assert(length(f1.blocks) == 4)

    // Test 2: entry block (index 0) — last instruction is BrTrilean
    // because Elvis's BrTrilean routes True→elvis_some,
    // Unknown/False→elvis_default per ADR-0010 (null is Trit::Zero
    // ≡ Trilean::Unknown).
    let entry1: BasicBlock = get(f1.blocks, 0)!!
    let entry_total: Integer = length(entry1.instructions)
    let entry_last: Instruction = get(entry1.instructions, entry_total - 1)!!
    assert_string_eq(instruction_opcode_name(entry_last), "BrTrilean")

    // Test 3: entry block also carries the NullCheck (immediately
    // before the BrTrilean).
    let entry_pen: Instruction = get(entry1.instructions, entry_total - 2)!!
    assert_string_eq(instruction_opcode_name(entry_pen), "NullCheck")

    // Test 4: elvis_some block (index 1) starts with NullUnwrap.
    let some1: BasicBlock = get(f1.blocks, 1)!!
    let some_first: Instruction = get(some1.instructions, 0)!!
    assert_string_eq(instruction_opcode_name(some_first), "NullUnwrap")

    // Test 5: elvis_merge block (index 3) — first instruction is
    // Phi with exactly 2 incoming edges (then_end + else_end).
    let merge1: BasicBlock = get(f1.blocks, 3)!!
    let merge_first: Instruction = get(merge1.instructions, 0)!!
    assert_string_eq(instruction_opcode_name(merge_first), "Phi")
    let phi_count: Integer = match merge_first {
        PhiInst(pp) => length(pp.incoming),
        _ => 0,
    }
    assert(phi_count == 2)

    // Test 6: default arm is a non-null expression (Integer 0). The
    // BrTrilean's unknown_block and false_block must both target
    // elvis_default — meaning the BrTrilean's three target slots
    // hold exactly two distinct block IDs.
    let bt: Instruction = entry_last
    match bt {
        BrTrileanInst(p) => {
            assert(p.unknown_block.raw == p.false_block.raw)
        },
        _ => { },
    }

    println("v0.7.11.1a ir_lowerer elvis smoke OK")
}

// ── v0.7.11.1b smoke — Outcome default (`~:`) ────────────────────

public function outcome_default_smoke_main() -> Unit = {
    // Test 1: `x ~: 0` over `Integer~String` parameter — canonical
    // 4-block shape (entry, oc_default_success, oc_default_fallback,
    // oc_default_merge).
    let s1: String = "function f(x: Integer~String) -> Integer = x ~: 0"
    let p1: IrProgram = lower_source(s1)
    let m1: IrModule = get(p1.modules, 0)!!
    let f1: Function = get(m1.functions, 0)!!
    assert(length(f1.blocks) == 4)

    // Test 2: entry block — OutcomeDiscriminant immediately precedes
    // the BrTrilean terminator. BrTrilean routes Positive→success,
    // Zero/Negative→fallback (both unknown_block and false_block
    // target the same fallback block — mirrors the Elvis arm).
    let entry1: BasicBlock = get(f1.blocks, 0)!!
    let entry_total: Integer = length(entry1.instructions)
    let entry_last: Instruction = get(entry1.instructions, entry_total - 1)!!
    assert_string_eq(instruction_opcode_name(entry_last), "BrTrilean")
    let entry_pen: Instruction = get(entry1.instructions, entry_total - 2)!!
    assert_string_eq(instruction_opcode_name(entry_pen), "OutcomeDiscriminant")

    // Test 3: oc_default_success block (index 1) starts with
    // OutcomeUnwrapValue.
    let succ1: BasicBlock = get(f1.blocks, 1)!!
    let succ_first: Instruction = get(succ1.instructions, 0)!!
    assert_string_eq(instruction_opcode_name(succ_first), "OutcomeUnwrapValue")

    // Test 4: oc_default_merge block (index 3) — first instruction
    // is Phi with exactly 2 incoming edges.
    let merge1: BasicBlock = get(f1.blocks, 3)!!
    let merge_first: Instruction = get(merge1.instructions, 0)!!
    assert_string_eq(instruction_opcode_name(merge_first), "Phi")
    let phi_count: Integer = match merge_first {
        PhiInst(pp) => length(pp.incoming),
        _ => 0,
    }
    assert(phi_count == 2)

    // Test 5: BrTrilean's unknown_block ≡ false_block (both route to
    // the fallback arm — Zero ≡ null path and Negative ≡ error path
    // share the same default-evaluation block).
    match entry_last {
        BrTrileanInst(p) => {
            assert(p.unknown_block.raw == p.false_block.raw)
        },
        _ => { },
    }

    println("v0.7.11.1b ir_lowerer outcome-default smoke OK")
}

// ── v0.7.11.1c smoke — Outcome propagate (`~?`) ──────────────────

public function outcome_propagate_smoke_main() -> Unit = {
    // Test 1: `x ~? |err| ~- err; ~+ v` over `Integer~String` —
    // 5-block shape (entry + 4 spawned blocks: oc_prop_success,
    // oc_prop_null, oc_prop_failure, oc_prop_merge). After merge,
    // the outer function body continues into the same merge block
    // with the OutcomeNewPositive + Ret tail.
    //
    // Note: function uses block-body form (no `=` before `{`) — the
    // `function f() = { … }` form is blocked by
    // v0.7.x.runtime-fix.parser-eq-block-body (closes in v0.7.11.1g).
    let s1: String = "function read_value(x: Integer~String) -> Integer~String { let v: Integer = x ~? |err| ~- err ~+ v }"
    let p1: IrProgram = lower_source(s1)
    let m1: IrModule = get(p1.modules, 0)!!
    let f1: Function = get(m1.functions, 0)!!
    assert(length(f1.blocks) == 5)

    // Test 2: entry — OutcomeDiscriminant + BrTrilean. Unlike Elvis
    // and OutcomeDefault, propagate's BrTrilean has three DISTINCT
    // target blocks (null and failure must not collapse — they have
    // different runtime semantics: null carries through, failure
    // Ret-s).
    let entry1: BasicBlock = get(f1.blocks, 0)!!
    let entry_total: Integer = length(entry1.instructions)
    let entry_last: Instruction = get(entry1.instructions, entry_total - 1)!!
    assert_string_eq(instruction_opcode_name(entry_last), "BrTrilean")
    match entry_last {
        BrTrileanInst(p) => {
            assert(p.true_block.raw != p.unknown_block.raw)
            assert(p.unknown_block.raw != p.false_block.raw)
            assert(p.true_block.raw != p.false_block.raw)
        },
        _ => { },
    }

    // Test 3: oc_prop_failure (index 3) terminates via Ret. The
    // failure arm is DIVERGENT (ADR-0020 §3.1) — no Br back to
    // merge. Looking for Ret as the block's last instruction.
    let fail1: BasicBlock = get(f1.blocks, 3)!!
    let fail_total: Integer = length(fail1.instructions)
    let fail_last: Instruction = get(fail1.instructions, fail_total - 1)!!
    assert_string_eq(instruction_opcode_name(fail_last), "Ret")

    // Test 4: oc_prop_failure starts with OutcomeUnwrapError to
    // bind the `err` capture name.
    let fail_first: Instruction = get(fail1.instructions, 0)!!
    assert_string_eq(instruction_opcode_name(fail_first), "OutcomeUnwrapError")

    // Test 5: oc_prop_merge (index 4) first instruction is Phi
    // with EXACTLY 2 incoming edges — success + null (failure
    // Ret-ed so no third edge).
    let merge1: BasicBlock = get(f1.blocks, 4)!!
    let merge_first: Instruction = get(merge1.instructions, 0)!!
    assert_string_eq(instruction_opcode_name(merge_first), "Phi")
    let phi_count: Integer = match merge_first {
        PhiInst(pp) => length(pp.incoming),
        _ => 0,
    }
    assert(phi_count == 2)

    println("v0.7.11.1c ir_lowerer outcome-propagate smoke OK")
}

// ── v0.7.11.1d smoke — Method call dispatch ──────────────────────

public function method_call_smoke_main() -> Unit = {
    // Test 1: `.length()` zero-arg on a String → CallBuiltin(text_len).
    let s1: String = "function f(s: String) -> Integer = s.length()"
    let p1: IrProgram = lower_source(s1)
    let m1: IrModule = get(p1.modules, 0)!!
    let f1: Function = get(m1.functions, 0)!!
    let entry1: BasicBlock = get(f1.blocks, 0)!!
    // Walk instructions for the CallBuiltin.
    let mutable found_call: Trilean! = false
    let mutable found_builtin: BuiltinName = PrintlnBuiltin(primitive_marker())
    let total1: Integer = length(entry1.instructions)
    let mutable i: Integer = 0
    while i < total1 {
        let inst_opt: Instruction? = get(entry1.instructions, i)
        let inst: Instruction = inst_opt!!
        match inst {
            CallBuiltinInst(cb) => {
                found_call = true
                found_builtin = cb.name
            },
            _ => { },
        }
        i = i + 1
    }
    assert(found_call)
    assert_string_eq(builtin_name_display(found_builtin), "text_len")

    // Test 2: `.unwrap_value("msg")` on a `T~E` receiver →
    // OutcomeUnwrapValue. The message arg is lowered (constant
    // string emitted) but the VM ignores it (E2210 uses hardcoded
    // label). Single block; check for OutcomeUnwrapValue presence.
    let s2: String = "function f(x: Integer~String) -> Integer = x.unwrap_value(\"oops\")"
    let p2: IrProgram = lower_source(s2)
    let m2: IrModule = get(p2.modules, 0)!!
    let f2: Function = get(m2.functions, 0)!!
    let entry2: BasicBlock = get(f2.blocks, 0)!!
    let mutable found_unwrap_v: Trilean! = false
    let total2: Integer = length(entry2.instructions)
    i = 0
    while i < total2 {
        let inst2_opt: Instruction? = get(entry2.instructions, i)
        let inst2: Instruction = inst2_opt!!
        if instruction_opcode_name(inst2) == "OutcomeUnwrapValue" {
            found_unwrap_v = true
        }
        i = i + 1
    }
    assert(found_unwrap_v)

    // Test 3: `.unwrap_error("msg")` → OutcomeUnwrapError.
    let s3: String = "function f(x: Integer~String) -> String = x.unwrap_error(\"oops\")"
    let p3: IrProgram = lower_source(s3)
    let m3: IrModule = get(p3.modules, 0)!!
    let f3: Function = get(m3.functions, 0)!!
    let entry3: BasicBlock = get(f3.blocks, 0)!!
    let mutable found_unwrap_e: Trilean! = false
    let total3: Integer = length(entry3.instructions)
    i = 0
    while i < total3 {
        let inst3_opt: Instruction? = get(entry3.instructions, i)
        let inst3: Instruction = inst3_opt!!
        if instruction_opcode_name(inst3) == "OutcomeUnwrapError" {
            found_unwrap_e = true
        }
        i = i + 1
    }
    assert(found_unwrap_e)

    println("v0.7.11.1d ir_lowerer method-call smoke OK")
}

// ── v0.7.11.1e2 smoke — IfExpr with phi-stitch ───────────────────

public function if_expr_smoke_main() -> Unit = {
    // Test 1: `if cond { 1 } else { 0 }` with plain `if` (Unknown
    // → panic block). Canonical 5-block shape: entry + then + else
    // + merge + if_unknown_panic.
    let s1: String = "function f(cond: Trilean!) -> Integer = if cond { 1 } else { 0 }"
    let p1: IrProgram = lower_source(s1)
    let m1: IrModule = get(p1.modules, 0)!!
    let f1: Function = get(m1.functions, 0)!!
    assert(length(f1.blocks) == 5)

    // Test 2: entry block — last instruction is BrTrilean.
    let entry1: BasicBlock = get(f1.blocks, 0)!!
    let entry_total: Integer = length(entry1.instructions)
    let entry_last: Instruction = get(entry1.instructions, entry_total - 1)!!
    assert_string_eq(instruction_opcode_name(entry_last), "BrTrilean")

    // Test 3: BrTrilean for plain `if` — true_block != unknown_block,
    // unknown_block != false_block (3 distinct targets).
    match entry_last {
        BrTrileanInst(p) => {
            assert(p.true_block.raw != p.unknown_block.raw)
            assert(p.unknown_block.raw != p.false_block.raw)
        },
        _ => { },
    }

    // Test 4: merge block starts with Phi for the if's value, with
    // EXACTLY 2 incoming edges (then-end + else-end). Block order
    // in `f1.blocks` is determined by `start_block` calls in
    // `lower_if_expr`: for plain `if` the sequence is entry (0) →
    // if_unknown_panic (1) → then (2) → else (3) → merge (4).
    let merge1: BasicBlock = get(f1.blocks, 4)!!
    let merge_first: Instruction = get(merge1.instructions, 0)!!
    assert_string_eq(instruction_opcode_name(merge_first), "Phi")
    let phi_count: Integer = match merge_first {
        PhiInst(pp) => length(pp.incoming),
        _ => 0,
    }
    assert(phi_count == 2)

    // Test 5: `if?` form — no panic block, 4-block shape.
    let s2: String = "function f(cond: Trilean) -> Integer = if? cond { 1 } else { 0 }"
    let p2: IrProgram = lower_source(s2)
    let m2: IrModule = get(p2.modules, 0)!!
    let f2: Function = get(m2.functions, 0)!!
    assert(length(f2.blocks) == 4)

    // Test 6: `if?` BrTrilean's unknown_block ≡ false_block (both
    // route to else per ADR-0010 treat_unknown_as_false).
    let entry2: BasicBlock = get(f2.blocks, 0)!!
    let entry2_total: Integer = length(entry2.instructions)
    let entry2_last: Instruction = get(entry2.instructions, entry2_total - 1)!!
    match entry2_last {
        BrTrileanInst(p) => {
            assert(p.unknown_block.raw == p.false_block.raw)
        },
        _ => { },
    }

    println("v0.7.11.1e2 ir_lowerer if-expr smoke OK")
}

// ── v0.7.11.1f2 smoke — MatchExpr ───────────────────────────────

public function match_expr_smoke_main() -> Unit = {
    // Test 1: 2-arm literal match → arm dispatch via Eq + BrTrilean
    // for non-last, unconditional Br for last. Block shape:
    //   entry → test → arm_0_body → arm_1_body → merge
    // 4 spawned blocks (arm_0, test_1, arm_1, merge) + entry = 5
    // total. Arm-0's pattern test uses Eq; non-last so emits
    // BrTrilean. Last arm (wildcard) is unconditional Br.
    let s1: String = "function f(x: Integer) -> Integer = match x { 0 => 100, _ => 0 }"
    let p1: IrProgram = lower_source(s1)
    let m1: IrModule = get(p1.modules, 0)!!
    let f1: Function = get(m1.functions, 0)!!
    assert(length(f1.blocks) == 5)

    // Test 2: entry block ends with BrTrilean (first arm's test
    // for non-last literal pattern).
    let entry1: BasicBlock = get(f1.blocks, 0)!!
    let entry_total: Integer = length(entry1.instructions)
    let entry_last: Instruction = get(entry1.instructions, entry_total - 1)!!
    assert_string_eq(instruction_opcode_name(entry_last), "BrTrilean")

    // Test 3: the merge block (last in vector) starts with Phi
    // carrying EXACTLY arm_count incoming edges.
    let merge1: BasicBlock = get(f1.blocks, length(f1.blocks) - 1)!!
    let merge_first: Instruction = get(merge1.instructions, 0)!!
    assert_string_eq(instruction_opcode_name(merge_first), "Phi")
    let phi_count: Integer = match merge_first {
        PhiInst(pp) => length(pp.incoming),
        _ => 0,
    }
    assert(phi_count == 2)

    // Test 4: outcome arm pattern — `match res { ~+ v => v, ~- _ =>
    // -1, ~0 => 0 }`. Should spawn 3 arm bodies + 2 test blocks +
    // merge + entry = 7 total. Last arm (~0) is unconditional, no
    // separate test block.
    let s2: String = "function f(res: Integer?~String) -> Integer = match res { ~+ v => v, ~- _ => -1, ~0 => 0 }"
    let p2: IrProgram = lower_source(s2)
    let m2: IrModule = get(p2.modules, 0)!!
    let f2: Function = get(m2.functions, 0)!!
    // entry + 3 arm bodies + 2 test blocks (between arms 1/2 and
    // 2/3) + merge = 7.
    assert(length(f2.blocks) == 7)

    // Test 5: outcome match merge has 3 phi incoming.
    let merge2: BasicBlock = get(f2.blocks, length(f2.blocks) - 1)!!
    let merge2_first: Instruction = get(merge2.instructions, 0)!!
    assert_string_eq(instruction_opcode_name(merge2_first), "Phi")
    let phi2_count: Integer = match merge2_first {
        PhiInst(pp) => length(pp.incoming),
        _ => 0,
    }
    assert(phi2_count == 3)

    println("v0.7.11.1f2 ir_lowerer match-expr smoke OK")
}

public function main() -> Unit = {
    // ── ID display ────────────────────────────────────────────────
    assert_string_eq(value_id_display(ValueId { raw: 0 }), "%0")
    assert_string_eq(value_id_display(ValueId { raw: 42 }), "%42")
    assert_string_eq(block_id_display(BlockId { raw: 7 }), "b7")
    assert_string_eq(func_id_display(FuncId { raw: 3 }), "@f3")
    assert_string_eq(const_id_display(ConstId { raw: 99 }), "c99")

    // ── TypeTag construction + display ────────────────────────────
    let a0: TypeTagArena = type_tag_arena_new()
    let r_int: AllocTagResult = alloc_tag_integer(a0)
    assert_string_eq(type_tag_display(r_int.arena, r_int.tag_id), "Integer")

    let r_str: AllocTagResult = alloc_tag_string(r_int.arena)
    assert_string_eq(type_tag_display(r_str.arena, r_str.tag_id), "String")

    let r_unit: AllocTagResult = alloc_tag_unit(r_str.arena)
    assert_string_eq(type_tag_display(r_unit.arena, r_unit.tag_id), "Unit")

    let r_trit: AllocTagResult = alloc_tag_trit(r_unit.arena)
    let r_tri: AllocTagResult = alloc_tag_trilean(r_trit.arena)
    let r_long: AllocTagResult = alloc_tag_long(r_tri.arena)
    let r_tryte: AllocTagResult = alloc_tag_tryte(r_long.arena)
    assert_string_eq(type_tag_display(r_tryte.arena, r_trit.tag_id), "Trit")
    assert_string_eq(type_tag_display(r_tryte.arena, r_tri.tag_id), "Trilean")
    assert_string_eq(type_tag_display(r_tryte.arena, r_long.tag_id), "Long")
    assert_string_eq(type_tag_display(r_tryte.arena, r_tryte.tag_id), "Tryte")

    let r_null_int: AllocTagResult = alloc_tag_nullable(r_tryte.arena, r_int.tag_id)
    assert_string_eq(type_tag_display(r_null_int.arena, r_null_int.tag_id), "Integer?")

    let r_vec_int: AllocTagResult = alloc_tag_vector(r_null_int.arena, r_int.tag_id)
    assert_string_eq(type_tag_display(r_vec_int.arena, r_vec_int.tag_id), "Vector<Integer>")

    let r_map: AllocTagResult = alloc_tag_hashmap(r_vec_int.arena, r_str.tag_id, r_int.tag_id)
    assert_string_eq(type_tag_display(r_map.arena, r_map.tag_id), "HashMap<String, Integer>")

    let r_out_bin: AllocTagResult = alloc_tag_outcome(r_map.arena, r_int.tag_id, r_str.tag_id, false)
    assert_string_eq(type_tag_display(r_out_bin.arena, r_out_bin.tag_id), "Integer~String")
    let r_out_tri: AllocTagResult = alloc_tag_outcome(r_out_bin.arena, r_int.tag_id, r_str.tag_id, true)
    assert_string_eq(type_tag_display(r_out_tri.arena, r_out_tri.tag_id), "Integer?~String")

    // ── Constant + ConstantPool ───────────────────────────────────
    let pool0: ConstantPool = constant_pool_new()
    let int_const: Constant = IntegerConst(ConstantIntegerPayload { value: 42 })
    let i1: InternResult = constant_pool_intern(pool0, int_const)
    assert(i1.id.raw == 0)

    let str_const: Constant = StringConst(ConstantStringPayload { value: "hello" })
    let i2: InternResult = constant_pool_intern(i1.pool, str_const)
    assert(i2.id.raw == 1)

    let null_const: Constant = NullConst(primitive_marker())
    let i3: InternResult = constant_pool_intern(i2.pool, null_const)
    assert(i3.id.raw == 2)
    assert(constant_pool_count(i3.pool) == 3)

    // Constant → TypeTag mapping
    let a1: TypeTagArena = type_tag_arena_new()
    let r_int_ty: AllocTagResult = constant_type_tag(a1, int_const)
    assert_string_eq(type_tag_display(r_int_ty.arena, r_int_ty.tag_id), "Integer")
    let r_null_ty: AllocTagResult = constant_type_tag(r_int_ty.arena, null_const)
    assert_string_eq(type_tag_display(r_null_ty.arena, r_null_ty.tag_id), "Unit?")

    // ── Operand display ───────────────────────────────────────────
    assert_string_eq(operand_display(ValueOp(ValueId { raw: 5 })), "%5")
    assert_string_eq(operand_display(ConstOp(ConstId { raw: 2 })), "c2")

    // ── BuiltinName display ───────────────────────────────────────
    assert_string_eq(builtin_name_display(PrintlnBuiltin(primitive_marker())), "println")
    assert_string_eq(builtin_name_display(VectorPushBuiltin(primitive_marker())), "vector_push")
    assert_string_eq(builtin_name_display(HashMapKeysBuiltin(primitive_marker())), "hashmap_keys")
    assert_string_eq(builtin_name_display(ParseIntegerBuiltin(primitive_marker())), "parse_integer")

    // ── Instruction construction + helpers ────────────────────────
    let v0: ValueId = ValueId { raw: 0 }
    let v1: ValueId = ValueId { raw: 1 }
    let v2: ValueId = ValueId { raw: 2 }
    let v3: ValueId = ValueId { raw: 3 }
    let b0: BlockId = BlockId { raw: 0 }
    let b1: BlockId = BlockId { raw: 1 }
    let c0: ConstId = ConstId { raw: 0 }

    let const_inst: Instruction = ConstInst(InstConstPayload { dest: v0, const_id: c0 })
    assert_string_eq(instruction_opcode_name(const_inst), "Const")
    assert(!instruction_is_terminator(const_inst))
    assert_some_value_id(instruction_destination(const_inst), 0)

    let add_inst: Instruction = AddInst(InstBinaryOpPayload {
        dest: v1,
        lhs: ValueOp(v0),
        rhs: ConstOp(c0),
    })
    assert_string_eq(instruction_opcode_name(add_inst), "Add")
    assert_some_value_id(instruction_destination(add_inst), 1)

    let neg_inst: Instruction = NegInst(InstUnaryOpPayload {
        dest: v2,
        operand: ValueOp(v1),
    })
    assert_string_eq(instruction_opcode_name(neg_inst), "Neg")

    let pow_inst: Instruction = PowInst(InstPowPayload {
        dest: v3,
        base: ValueOp(v0),
        exp: ConstOp(c0),
    })
    assert_string_eq(instruction_opcode_name(pow_inst), "Pow")

    let luk_and_inst: Instruction = LukAndInst(InstBinaryOpPayload {
        dest: v1,
        lhs: ValueOp(v0),
        rhs: ValueOp(v2),
    })
    assert_string_eq(instruction_opcode_name(luk_and_inst), "LukAnd")

    let kleene_implies_inst: Instruction = KleeneImpliesInst(InstBinaryOpPayload {
        dest: v1,
        lhs: ValueOp(v0),
        rhs: ValueOp(v2),
    })
    assert_string_eq(instruction_opcode_name(kleene_implies_inst), "KleeneImplies")

    let eq_inst: Instruction = EqInst(InstBinaryOpPayload {
        dest: v1,
        lhs: ValueOp(v0),
        rhs: ValueOp(v2),
    })
    assert_string_eq(instruction_opcode_name(eq_inst), "Eq")

    let to_int_inst: Instruction = ToIntegerInst(InstUnaryOpPayload {
        dest: v2,
        operand: ValueOp(v1),
    })
    assert_string_eq(instruction_opcode_name(to_int_inst), "ToInteger")

    // ── Struct / Enum / Nullable opcodes ──────────────────────────
    let mutable fields: Vector<Operand> = new()
    fields = push(fields, ValueOp(v0))
    fields = push(fields, ConstOp(c0))
    let struct_new_inst: Instruction = StructNewInst(InstStructNewPayload {
        dest: v1,
        fields: fields,
    })
    assert_string_eq(instruction_opcode_name(struct_new_inst), "StructNew")

    let field_get_inst: Instruction = FieldGetInst(InstFieldGetPayload {
        dest: v2,
        object: ValueOp(v1),
        field_idx: 0,
    })
    assert_string_eq(instruction_opcode_name(field_get_inst), "FieldGet")

    let enum_new_inst: Instruction = EnumNewInst(InstEnumNewPayload {
        dest: v3,
        variant_idx: 1,
        payload: ValueOp(v0),
    })
    assert_string_eq(instruction_opcode_name(enum_new_inst), "EnumNew")

    let enum_tag_inst: Instruction = EnumTagInst(InstEnumTagPayload {
        dest: v1,
        scrutinee: ValueOp(v3),
    })
    assert_string_eq(instruction_opcode_name(enum_tag_inst), "EnumTag")

    let null_wrap_inst: Instruction = NullWrapInst(InstNullWrapPayload {
        dest: v1,
        value: ValueOp(v0),
    })
    assert_string_eq(instruction_opcode_name(null_wrap_inst), "NullWrap")

    let null_check_inst: Instruction = NullCheckInst(InstNullCheckPayload {
        dest: v2,
        nullable: ValueOp(v1),
    })
    assert_string_eq(instruction_opcode_name(null_check_inst), "NullCheck")

    // ── Call opcodes ──────────────────────────────────────────────
    let mutable call_args: Vector<Operand> = new()
    call_args = push(call_args, ValueOp(v0))
    call_args = push(call_args, ConstOp(c0))
    let call_local_inst: Instruction = CallLocalInst(InstCallLocalPayload {
        dest: v1,
        callee: FuncId { raw: 2 },
        args: call_args,
    })
    assert_string_eq(instruction_opcode_name(call_local_inst), "CallLocal")

    let call_local_void: Instruction = CallLocalInst(InstCallLocalPayload {
        dest: ~0,
        callee: FuncId { raw: 5 },
        args: new(),
    })
    // Void call: destination should be `~0`.
    assert_none_value_id(instruction_destination(call_local_void))

    let mutable path_segs: Vector<String> = new()
    path_segs = push(path_segs, "std")
    path_segs = push(path_segs, "io")
    path_segs = push(path_segs, "println")
    let call_cross_inst: Instruction = CallCrossModuleInst(InstCallCrossModulePayload {
        dest: ~0,
        path_segments: path_segs,
        args: new(),
    })
    assert_string_eq(instruction_opcode_name(call_cross_inst), "CallCrossModule")

    let call_builtin_inst: Instruction = CallBuiltinInst(InstCallBuiltinPayload {
        dest: ~0,
        name: PrintlnBuiltin(primitive_marker()),
        args: new(),
    })
    assert_string_eq(instruction_opcode_name(call_builtin_inst), "CallBuiltin")

    // ── Closure opcodes ───────────────────────────────────────────
    let mutable captures: Vector<ValueId> = new()
    captures = push(captures, v0)
    let closure_new_inst: Instruction = ClosureNewInst(InstClosureNewPayload {
        dest: v1,
        lambda: FuncId { raw: 7 },
        captures: captures,
    })
    assert_string_eq(instruction_opcode_name(closure_new_inst), "ClosureNew")

    let closure_call_inst: Instruction = ClosureCallInst(InstClosureCallPayload {
        dest: v2,
        closure: ValueOp(v1),
        args: new(),
    })
    assert_string_eq(instruction_opcode_name(closure_call_inst), "ClosureCall")

    // ── Control-flow terminators ──────────────────────────────────
    let br_inst: Instruction = BrInst(InstBrPayload { target: b1 })
    assert_string_eq(instruction_opcode_name(br_inst), "Br")
    assert(instruction_is_terminator(br_inst))

    let br_if_inst: Instruction = BrIfInst(InstBrIfPayload {
        cond: ValueOp(v0),
        then_block: b0,
        else_block: b1,
    })
    assert(instruction_is_terminator(br_if_inst))

    let br_trilean_inst: Instruction = BrTrileanInst(InstBrTrileanPayload {
        cond: ValueOp(v0),
        true_block: b0,
        unknown_block: b1,
        false_block: b1,
    })
    assert(instruction_is_terminator(br_trilean_inst))
    assert_string_eq(instruction_opcode_name(br_trilean_inst), "BrTrilean")

    let ret_inst: Instruction = RetInst(InstRetPayload { value: ValueOp(v0) })
    assert(instruction_is_terminator(ret_inst))

    let ret_void: Instruction = RetInst(InstRetPayload { value: ~0 })
    assert(instruction_is_terminator(ret_void))

    let unreachable_inst: Instruction = UnreachableInst(primitive_marker())
    assert(instruction_is_terminator(unreachable_inst))

    // ── Phi node ──────────────────────────────────────────────────
    let mutable incoming: Vector<PhiIncoming> = new()
    incoming = push(incoming, PhiIncoming { value: v0, block: b0 })
    incoming = push(incoming, PhiIncoming { value: v1, block: b1 })
    let phi_inst: Instruction = PhiInst(InstPhiPayload { dest: v2, incoming: incoming })
    assert_string_eq(instruction_opcode_name(phi_inst), "Phi")
    assert_some_value_id(instruction_destination(phi_inst), 2)

    // ── Outcome opcodes ───────────────────────────────────────────
    let ocn_pos: Instruction = OutcomeNewPositiveInst(InstOutcomeCtorPayload {
        dest: v0,
        payload: ConstOp(c0),
    })
    assert_string_eq(instruction_opcode_name(ocn_pos), "OutcomeNewPositive")

    let ocn_neg: Instruction = OutcomeNewNegativeInst(InstOutcomeCtorPayload {
        dest: v1,
        payload: ValueOp(v0),
    })
    assert_string_eq(instruction_opcode_name(ocn_neg), "OutcomeNewNegative")

    let ocn_null: Instruction = OutcomeNewNullInst(InstOutcomeNewNullPayload { dest: v2 })
    assert_string_eq(instruction_opcode_name(ocn_null), "OutcomeNewNull")

    let oc_discr: Instruction = OutcomeDiscriminantInst(InstOutcomeUnaryPayload {
        dest: v3,
        source: ValueOp(v0),
    })
    assert_string_eq(instruction_opcode_name(oc_discr), "OutcomeDiscriminant")

    let oc_unwrap_val: Instruction = OutcomeUnwrapValueInst(InstOutcomeUnaryPayload {
        dest: v0,
        source: ValueOp(v1),
    })
    assert_string_eq(instruction_opcode_name(oc_unwrap_val), "OutcomeUnwrapValue")

    let oc_unwrap_err: Instruction = OutcomeUnwrapErrorInst(InstOutcomeUnaryPayload {
        dest: v0,
        source: ValueOp(v1),
    })
    assert_string_eq(instruction_opcode_name(oc_unwrap_err), "OutcomeUnwrapError")

    // ── BasicBlock + terminator detection ─────────────────────────
    let bb0: BasicBlock = basic_block_new(b0, "entry")
    assert(length(bb0.instructions) == 0)
    match basic_block_terminator(bb0) {
        ~0 => assert(true),
        _ => assert(false),
    }
    let bb1: BasicBlock = basic_block_push(bb0, const_inst)
    let bb2: BasicBlock = basic_block_push(bb1, RetInst(InstRetPayload { value: ValueOp(v0) }))
    assert(length(bb2.instructions) == 2)
    match basic_block_terminator(bb2) {
        ~0 => assert(false),
        _ => assert(true),
    }

    // ── Function + well-formedness ────────────────────────────────
    let arena1: TypeTagArena = type_tag_arena_new()
    let ret_tag: AllocTagResult = alloc_tag_integer(arena1)
    let mutable params: Vector<IrFunctionParam> = new()
    params = push(params, IrFunctionParam { name: "x", type_tag_id: ret_tag.tag_id })
    let fn0: Function = function_new(FuncId { raw: 0 }, "identity", params, ret_tag.tag_id)
    assert(length(fn0.blocks) == 0)
    assert(!function_is_well_formed(fn0))
    let fn1: Function = function_push_block(fn0, bb2)
    assert(function_is_well_formed(fn1))

    // ── IrModule + IrProgram ──────────────────────────────────────
    let mutable mod_path: Vector<String> = new()
    mod_path = push(mod_path, "khi")
    let mod0: IrModule = ir_module_new(mod_path)
    let mod1: IrModule = ir_module_push_function(mod0, fn1)
    let mod2: IrModule = ir_module_with_type_arena(mod1, ret_tag.arena)
    assert(length(mod2.functions) == 1)
    assert(length(mod2.type_arena.tags) == 1)

    let prog0: IrProgram = ir_program_new()
    let prog1: IrProgram = ir_program_push_module(prog0, mod2)
    let prog2: IrProgram = ir_program_with_constants(prog1, i3.pool)
    assert(length(prog2.modules) == 1)
    assert(ir_program_function_count(prog2) == 1)
    assert(constant_pool_count(prog2.constants) == 3)

    println("v0.7.8.1 ir_lowerer types smoke OK")
    lower_source_smoke_main()
    call_loop_smoke_main()
    while_phi_smoke_main()
    struct_enum_outcome_smoke_main()
    elvis_smoke_main()
    outcome_default_smoke_main()
    outcome_propagate_smoke_main()
    method_call_smoke_main()
    if_expr_smoke_main()
    match_expr_smoke_main()
}
