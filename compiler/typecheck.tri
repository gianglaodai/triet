// ─────────────────────────────────────────────────────────────────
// TypeKind — discriminator for the resolved-type representation.
//
// Each variant carries a payload struct (Triết enum variants take
// exactly one payload). Recursive references (`Box<Type>` in Rust)
// become Integer arena IDs into a `TypeArena.types` vector.
// ─────────────────────────────────────────────────────────────────

// Marker payloads (zero-field) for primitive variants — Triết
// enum variants require a payload, so we use a unit-shaped
// marker for the "no extra data" cases.
public struct PrimitiveMarker {
    placeholder: Integer,
}

public struct TrileanPayload {
    refined: Trilean!,
}

public struct NullablePayload {
    inner: Integer,
}

public struct TuplePayload {
    elements: Vector<Integer>,
}

public struct TypeFunctionPayload {
    type_params: Vector<String>,
    parameters: Vector<Integer>,
    return_type: Integer,
}

public struct TypeRangePayload {
    element: Integer,
}

public struct UserStructFieldPayload {
    name: String,
    type_id: Integer,
}

public struct UserStructPayload {
    name: String,
    type_params: Vector<String>,
    fields: Vector<UserStructFieldPayload>,
}

public struct UserEnumVariantPayload {
    name: String,
    payload_type: Integer?,
}

public struct UserEnumPayload {
    name: String,
    type_params: Vector<String>,
    variants: Vector<UserEnumVariantPayload>,
}

public struct TypeParamPayload {
    name: String,
}

public struct OutcomeTypePayload {
    value_type: Integer,
    error_type: Integer,
    allow_null_state: Trilean!,
}

public enum TypeKind {
    TritKind(PrimitiveMarker),
    TryteKind(PrimitiveMarker),
    IntegerKind(PrimitiveMarker),
    LongKind(PrimitiveMarker),
    TrileanKind(TrileanPayload),
    StringKind(PrimitiveMarker),
    UnitKind(PrimitiveMarker),
    UnknownKind(PrimitiveMarker),
    NullableKind(NullablePayload),
    TupleKind(TuplePayload),
    FunctionKind(TypeFunctionPayload),
    RangeKind(TypeRangePayload),
    UserStructKind(UserStructPayload),
    UserEnumKind(UserEnumPayload),
    TypeParamKind(TypeParamPayload),
    OutcomeKind(OutcomeTypePayload),
}

/// A single arena-allocated type node. Wrapped in a struct so the
/// arena can grow Vector<TypeNode> without losing the per-node
/// discriminator.
public struct TypeNode {
    kind: TypeKind,
}

/// Type arena. Recursive type references (Nullable inner, Tuple
/// elements, Function parameters/return, Outcome value/error, etc.)
/// are Integer IDs into `types`. Mirrors compiler/parser/parser.tri
/// `Arena` pattern.
public struct TypeArena {
    types: Vector<TypeNode>,
}

public struct AllocTypeResult {
    arena: TypeArena,
    type_id: Integer,
}

public function type_arena_new() -> TypeArena =
    TypeArena { types: new() }

/// Allocate `node` into `arena`, returning the updated arena + the
/// newly-allocated type ID. Caller carries the new arena forward.
public function alloc_type(arena: TypeArena, node: TypeNode) -> AllocTypeResult = {
    let next_id: Integer = length(arena.types)
    let updated: TypeArena = TypeArena { types: push(arena.types, node) }
    AllocTypeResult { arena: updated, type_id: next_id }
}

/// Fetch a type node by id. Returns `null` for out-of-bounds.
/// Caller should `!!` when the id is known valid (recently
/// returned from `alloc_type`).
public function get_type(arena: TypeArena, type_id: Integer) -> TypeNode? =
    get(arena.types, type_id)

// ─────────────────────────────────────────────────────────────────
// Type construction helpers — convenience constructors that match
// the v0.7.7.{2..4} call-site ergonomics. All take + return a
// `TypeArena` (functional update).
// ─────────────────────────────────────────────────────────────────

function primitive_marker() -> PrimitiveMarker =
    PrimitiveMarker { placeholder: 0 }

public function alloc_trit(arena: TypeArena) -> AllocTypeResult =
    alloc_type(arena, TypeNode { kind: TritKind(primitive_marker()) })

public function alloc_tryte(arena: TypeArena) -> AllocTypeResult =
    alloc_type(arena, TypeNode { kind: TryteKind(primitive_marker()) })

public function alloc_integer(arena: TypeArena) -> AllocTypeResult =
    alloc_type(arena, TypeNode { kind: IntegerKind(primitive_marker()) })

public function alloc_long(arena: TypeArena) -> AllocTypeResult =
    alloc_type(arena, TypeNode { kind: LongKind(primitive_marker()) })

public function alloc_string(arena: TypeArena) -> AllocTypeResult =
    alloc_type(arena, TypeNode { kind: StringKind(primitive_marker()) })

public function alloc_unit(arena: TypeArena) -> AllocTypeResult =
    alloc_type(arena, TypeNode { kind: UnitKind(primitive_marker()) })

public function alloc_unknown(arena: TypeArena) -> AllocTypeResult =
    alloc_type(arena, TypeNode { kind: UnknownKind(primitive_marker()) })

public function alloc_trilean(arena: TypeArena, refined: Trilean!) -> AllocTypeResult =
    alloc_type(arena, TypeNode { kind: TrileanKind(TrileanPayload { refined: refined }) })

public function alloc_nullable(arena: TypeArena, inner: Integer) -> AllocTypeResult =
    alloc_type(arena, TypeNode { kind: NullableKind(NullablePayload { inner: inner }) })

public function alloc_tuple(arena: TypeArena, elements: Vector<Integer>) -> AllocTypeResult =
    alloc_type(arena, TypeNode { kind: TupleKind(TuplePayload { elements: elements }) })

public function alloc_function(
    arena: TypeArena,
    type_params: Vector<String>,
    parameters: Vector<Integer>,
    return_type: Integer,
) -> AllocTypeResult =
    alloc_type(arena, TypeNode {
        kind: FunctionKind(TypeFunctionPayload {
            type_params: type_params,
            parameters: parameters,
            return_type: return_type,
        })
    })

public function alloc_range(arena: TypeArena, element: Integer) -> AllocTypeResult =
    alloc_type(arena, TypeNode { kind: RangeKind(TypeRangePayload { element: element }) })

public function alloc_user_struct(
    arena: TypeArena,
    name: String,
    type_params: Vector<String>,
    fields: Vector<UserStructFieldPayload>,
) -> AllocTypeResult =
    alloc_type(arena, TypeNode {
        kind: UserStructKind(UserStructPayload {
            name: name,
            type_params: type_params,
            fields: fields,
        })
    })

public function alloc_user_enum(
    arena: TypeArena,
    name: String,
    type_params: Vector<String>,
    variants: Vector<UserEnumVariantPayload>,
) -> AllocTypeResult =
    alloc_type(arena, TypeNode {
        kind: UserEnumKind(UserEnumPayload {
            name: name,
            type_params: type_params,
            variants: variants,
        })
    })

public function alloc_type_param(arena: TypeArena, name: String) -> AllocTypeResult =
    alloc_type(arena, TypeNode { kind: TypeParamKind(TypeParamPayload { name: name }) })

public function alloc_outcome(
    arena: TypeArena,
    value_type: Integer,
    error_type: Integer,
    allow_null_state: Trilean!,
) -> AllocTypeResult =
    alloc_type(arena, TypeNode {
        kind: OutcomeKind(OutcomeTypePayload {
            value_type: value_type,
            error_type: error_type,
            allow_null_state: allow_null_state,
        })
    })

// ─────────────────────────────────────────────────────────────────
// Type predicates — mirror Rust's `impl Type` const fns.
// ─────────────────────────────────────────────────────────────────

/// True for any of Trit / Tryte / Integer / Long.
public function type_is_numeric(arena: TypeArena, type_id: Integer) -> Trilean! = {
    let node_opt: TypeNode? = get_type(arena, type_id)
    match node_opt {
        ~0 => false,
        _ => {
            let node: TypeNode = node_opt!!
            match node.kind {
                TritKind(_) => true,
                TryteKind(_) => true,
                IntegerKind(_) => true,
                LongKind(_) => true,
                _ => false,
            }
        },
    }
}

/// True for any Trilean (refined or generic). Mirrors
/// `Type::is_trilean`.
public function type_is_trilean(arena: TypeArena, type_id: Integer) -> Trilean! = {
    let node_opt: TypeNode? = get_type(arena, type_id)
    match node_opt {
        ~0 => false,
        _ => {
            let node: TypeNode = node_opt!!
            match node.kind {
                TrileanKind(_) => true,
                _ => false,
            }
        },
    }
}

/// True for refined `Trilean!`. Mirrors `Type::is_refined_trilean`.
public function type_is_refined_trilean(arena: TypeArena, type_id: Integer) -> Trilean! = {
    let node_opt: TypeNode? = get_type(arena, type_id)
    match node_opt {
        ~0 => false,
        _ => {
            let node: TypeNode = node_opt!!
            match node.kind {
                TrileanKind(p) => p.refined,
                _ => false,
            }
        },
    }
}

// ─────────────────────────────────────────────────────────────────
// Type display — produces a String matching Rust's `impl Display
// for Type`. Used by error messages + the v0.7.7.5 differential
// gate so both sides can compare error.message byte-for-byte.
// ─────────────────────────────────────────────────────────────────

public function type_display(arena: TypeArena, type_id: Integer) -> String = {
    let node_opt: TypeNode? = get_type(arena, type_id)
    match node_opt {
        ~0 => "?",
        _ => {
            let node: TypeNode = node_opt!!
            match node.kind {
                TritKind(_) => "Trit",
                TryteKind(_) => "Tryte",
                IntegerKind(_) => "Integer",
                LongKind(_) => "Long",
                TrileanKind(p) => {
                    if p.refined {
                        "Trilean!"
                    } else {
                        "Trilean"
                    }
                },
                StringKind(_) => "String",
                UnitKind(_) => "Unit",
                UnknownKind(_) => "?",
                NullableKind(p) => concat(type_display(arena, p.inner), "?"),
                TupleKind(p) => format_tuple_display(arena, p.elements),
                FunctionKind(p) => format_function_display(arena, p),
                RangeKind(p) => concat(concat("Range<", type_display(arena, p.element)), ">"),
                UserStructKind(p) => p.name,
                UserEnumKind(p) => p.name,
                TypeParamKind(p) => p.name,
                OutcomeKind(p) => format_outcome_display(arena, p),
            }
        },
    }
}

function format_tuple_display(arena: TypeArena, elements: Vector<Integer>) -> String = {
    let total: Integer = length(elements)
    let mutable out: String = "("
    let mutable i: Integer = 0
    while i < total {
        let e_opt: Integer? = get(elements, i)
        if i > 0 {
            out = concat(out, ", ")
        }
        out = concat(out, type_display(arena, e_opt!!))
        i = i + 1
    }
    concat(out, ")")
}

function format_function_display(arena: TypeArena, payload: TypeFunctionPayload) -> String = {
    let mutable out: String = "function("
    let total: Integer = length(payload.parameters)
    let mutable i: Integer = 0
    while i < total {
        let p_opt: Integer? = get(payload.parameters, i)
        if i > 0 {
            out = concat(out, ", ")
        }
        out = concat(out, type_display(arena, p_opt!!))
        i = i + 1
    }
    out = concat(out, ") -> ")
    concat(out, type_display(arena, payload.return_type))
}

function format_outcome_display(arena: TypeArena, payload: OutcomeTypePayload) -> String = {
    let value_str: String = type_display(arena, payload.value_type)
    let error_str: String = type_display(arena, payload.error_type)
    let sep: String = if payload.allow_null_state { "?~" } else { "~" }
    concat(concat(value_str, sep), error_str)
}

// ─────────────────────────────────────────────────────────────────
// TypeError — 27 variants covering E1001–E1034 + W2001.
//
// Per-variant payload struct (Triết enum variants take a single
// payload). Spans encoded as `span_start: Integer + span_end:
// Integer` pair per compiler/parser/parser.tri convention.
// ─────────────────────────────────────────────────────────────────

public struct UnknownTypePayload {
    name: String,
    span_start: Integer,
    span_end: Integer,
}

public struct UndefinedNamePayload {
    name: String,
    span_start: Integer,
    span_end: Integer,
}

public struct MismatchPayload {
    expected: Integer,
    found: Integer,
    span_start: Integer,
    span_end: Integer,
}

public struct InvalidOperandsPayload {
    operator: String,
    expected_description: String,
    left: Integer,
    right: Integer,
    span_start: Integer,
    span_end: Integer,
}

public struct InvalidUnaryPayload {
    operator: String,
    operand: Integer,
    span_start: Integer,
    span_end: Integer,
}

public struct WrongArityPayload {
    expected: Integer,
    found: Integer,
    span_start: Integer,
    span_end: Integer,
}

public struct NotCallablePayload {
    found: Integer,
    span_start: Integer,
    span_end: Integer,
}

public struct AmbiguousConditionPayload {
    span_start: Integer,
    span_end: Integer,
}

public struct NonTrileanConditionPayload {
    found: Integer,
    span_start: Integer,
    span_end: Integer,
}

public struct DuplicateNamePayload {
    name: String,
    span_start: Integer,
    span_end: Integer,
}

public struct NullLiteralInNonNullableContextPayload {
    span_start: Integer,
    span_end: Integer,
}

public struct NotNullablePayload {
    operator: String,
    found: Integer,
    span_start: Integer,
    span_end: Integer,
}

public struct MatchArmMismatchPayload {
    expected: Integer,
    found: Integer,
    span_start: Integer,
    span_end: Integer,
}

public struct TupleIndexOutOfRangePayload {
    index: Integer,
    length: Integer,
    span_start: Integer,
    span_end: Integer,
}

public struct UnknownMemberPayload {
    member: String,
    found: Integer,
    span_start: Integer,
    span_end: Integer,
}

public struct AssignToImmutablePayload {
    name: String,
    span_start: Integer,
    span_end: Integer,
}

public struct NullableErrorInOutcomeTypePayload {
    span_start: Integer,
    span_end: Integer,
}

public struct NullStateInBinaryOutcomePayload {
    span_start: Integer,
    span_end: Integer,
}

public struct NonExhaustiveOutcomeMatchPayload {
    missing: String,
    span_start: Integer,
    span_end: Integer,
}

public struct OutcomeTypeMismatchPayload {
    span_start: Integer,
    span_end: Integer,
}

public struct PropagateInNonFallibleContextPayload {
    span_start: Integer,
    span_end: Integer,
}

public struct ErrorTypeMismatchPayload {
    inner_error: Integer,
    outer_error: Integer,
    span_start: Integer,
    span_end: Integer,
}

public struct OutcomePropagateMissingCapturePayload {
    span_start: Integer,
    span_end: Integer,
}

public struct OutcomePropagateMalformedReturnPayload {
    span_start: Integer,
    span_end: Integer,
}

public struct PatternMissingExplicitConstructorPayload {
    span_start: Integer,
    span_end: Integer,
}

public struct PossiblyUnknownConditionPayload {
    span_start: Integer,
    span_end: Integer,
}

public struct TrileanReturnNotRefinedPayload {
    span_start: Integer,
    span_end: Integer,
}

public struct NullDeprecatedPayload {
    span_start: Integer,
    span_end: Integer,
}

public enum TypeError {
    UnknownTypeErr(UnknownTypePayload),
    UndefinedNameErr(UndefinedNamePayload),
    MismatchErr(MismatchPayload),
    InvalidOperandsErr(InvalidOperandsPayload),
    InvalidUnaryErr(InvalidUnaryPayload),
    WrongArityErr(WrongArityPayload),
    NotCallableErr(NotCallablePayload),
    AmbiguousConditionErr(AmbiguousConditionPayload),
    NonTrileanConditionErr(NonTrileanConditionPayload),
    DuplicateNameErr(DuplicateNamePayload),
    NullLiteralInNonNullableContextErr(NullLiteralInNonNullableContextPayload),
    NotNullableErr(NotNullablePayload),
    MatchArmMismatchErr(MatchArmMismatchPayload),
    TupleIndexOutOfRangeErr(TupleIndexOutOfRangePayload),
    UnknownMemberErr(UnknownMemberPayload),
    AssignToImmutableErr(AssignToImmutablePayload),
    NullableErrorInOutcomeTypeErr(NullableErrorInOutcomeTypePayload),
    NullStateInBinaryOutcomeErr(NullStateInBinaryOutcomePayload),
    NonExhaustiveOutcomeMatchErr(NonExhaustiveOutcomeMatchPayload),
    OutcomeTypeMismatchErr(OutcomeTypeMismatchPayload),
    PropagateInNonFallibleContextErr(PropagateInNonFallibleContextPayload),
    ErrorTypeMismatchErr(ErrorTypeMismatchPayload),
    OutcomePropagateMissingCaptureErr(OutcomePropagateMissingCapturePayload),
    OutcomePropagateMalformedReturnErr(OutcomePropagateMalformedReturnPayload),
    PatternMissingExplicitConstructorErr(PatternMissingExplicitConstructorPayload),
    PossiblyUnknownConditionErr(PossiblyUnknownConditionPayload),
    TrileanReturnNotRefinedErr(TrileanReturnNotRefinedPayload),
    NullDeprecatedErr(NullDeprecatedPayload),
}

/// Stable error code string — mirrors Rust's `impl LoaderError::code`
/// shape for the differential gate.
public function type_error_code(err: TypeError) -> String = {
    match err {
        UnknownTypeErr(_) => "triet::typecheck::E1001",
        UndefinedNameErr(_) => "triet::typecheck::E1002",
        MismatchErr(_) => "triet::typecheck::E1003",
        InvalidOperandsErr(_) => "triet::typecheck::E1004",
        InvalidUnaryErr(_) => "triet::typecheck::E1005",
        WrongArityErr(_) => "triet::typecheck::E1006",
        NotCallableErr(_) => "triet::typecheck::E1007",
        AmbiguousConditionErr(_) => "triet::typecheck::E1008",
        NonTrileanConditionErr(_) => "triet::typecheck::E1009",
        DuplicateNameErr(_) => "triet::typecheck::E1010",
        NullLiteralInNonNullableContextErr(_) => "triet::typecheck::E1011",
        NotNullableErr(_) => "triet::typecheck::E1012",
        MatchArmMismatchErr(_) => "triet::typecheck::E1013",
        TupleIndexOutOfRangeErr(_) => "triet::typecheck::E1014",
        UnknownMemberErr(_) => "triet::typecheck::E1015",
        AssignToImmutableErr(_) => "triet::typecheck::E1016",
        NullableErrorInOutcomeTypeErr(_) => "triet::typecheck::E1024",
        NullStateInBinaryOutcomeErr(_) => "triet::typecheck::E1025",
        NonExhaustiveOutcomeMatchErr(_) => "triet::typecheck::E1026",
        OutcomeTypeMismatchErr(_) => "triet::typecheck::E1027",
        PropagateInNonFallibleContextErr(_) => "triet::typecheck::E1028",
        ErrorTypeMismatchErr(_) => "triet::typecheck::E1029",
        OutcomePropagateMissingCaptureErr(_) => "triet::typecheck::E1030",
        OutcomePropagateMalformedReturnErr(_) => "triet::typecheck::E1031",
        PatternMissingExplicitConstructorErr(_) => "triet::typecheck::E1032",
        PossiblyUnknownConditionErr(_) => "triet::typecheck::E1033",
        TrileanReturnNotRefinedErr(_) => "triet::typecheck::E1034",
        NullDeprecatedErr(_) => "triet::typecheck::W2001",
    }
}

/// Extract the labelled span as a `(start, end)` Vector pair.
/// IR tuple returns defer post-v1.0 per SPEC §95 — same idiom as
/// modules.tri's `loader_error_span`.
public function type_error_span(err: TypeError) -> Vector<Integer> = {
    let mutable out: Vector<Integer> = new()
    match err {
        UnknownTypeErr(p) => { out = push(out, p.span_start) out = push(out, p.span_end) },
        UndefinedNameErr(p) => { out = push(out, p.span_start) out = push(out, p.span_end) },
        MismatchErr(p) => { out = push(out, p.span_start) out = push(out, p.span_end) },
        InvalidOperandsErr(p) => { out = push(out, p.span_start) out = push(out, p.span_end) },
        InvalidUnaryErr(p) => { out = push(out, p.span_start) out = push(out, p.span_end) },
        WrongArityErr(p) => { out = push(out, p.span_start) out = push(out, p.span_end) },
        NotCallableErr(p) => { out = push(out, p.span_start) out = push(out, p.span_end) },
        AmbiguousConditionErr(p) => { out = push(out, p.span_start) out = push(out, p.span_end) },
        NonTrileanConditionErr(p) => { out = push(out, p.span_start) out = push(out, p.span_end) },
        DuplicateNameErr(p) => { out = push(out, p.span_start) out = push(out, p.span_end) },
        NullLiteralInNonNullableContextErr(p) => { out = push(out, p.span_start) out = push(out, p.span_end) },
        NotNullableErr(p) => { out = push(out, p.span_start) out = push(out, p.span_end) },
        MatchArmMismatchErr(p) => { out = push(out, p.span_start) out = push(out, p.span_end) },
        TupleIndexOutOfRangeErr(p) => { out = push(out, p.span_start) out = push(out, p.span_end) },
        UnknownMemberErr(p) => { out = push(out, p.span_start) out = push(out, p.span_end) },
        AssignToImmutableErr(p) => { out = push(out, p.span_start) out = push(out, p.span_end) },
        NullableErrorInOutcomeTypeErr(p) => { out = push(out, p.span_start) out = push(out, p.span_end) },
        NullStateInBinaryOutcomeErr(p) => { out = push(out, p.span_start) out = push(out, p.span_end) },
        NonExhaustiveOutcomeMatchErr(p) => { out = push(out, p.span_start) out = push(out, p.span_end) },
        OutcomeTypeMismatchErr(p) => { out = push(out, p.span_start) out = push(out, p.span_end) },
        PropagateInNonFallibleContextErr(p) => { out = push(out, p.span_start) out = push(out, p.span_end) },
        ErrorTypeMismatchErr(p) => { out = push(out, p.span_start) out = push(out, p.span_end) },
        OutcomePropagateMissingCaptureErr(p) => { out = push(out, p.span_start) out = push(out, p.span_end) },
        OutcomePropagateMalformedReturnErr(p) => { out = push(out, p.span_start) out = push(out, p.span_end) },
        PatternMissingExplicitConstructorErr(p) => { out = push(out, p.span_start) out = push(out, p.span_end) },
        PossiblyUnknownConditionErr(p) => { out = push(out, p.span_start) out = push(out, p.span_end) },
        TrileanReturnNotRefinedErr(p) => { out = push(out, p.span_start) out = push(out, p.span_end) },
        NullDeprecatedErr(p) => { out = push(out, p.span_start) out = push(out, p.span_end) },
    }
    out
}

// ─────────────────────────────────────────────────────────────────
// TypeEnvironment — scoped variable bindings + frame stack.
//
// Mirrors crates/triet-typecheck/src/env.rs but Triết structs are
// immutable, so `declare` / `push_frame` / `pop_frame` return new
// `TypeEnvironment` values rather than mutating in place. Callers
// thread the updated env through.
// ─────────────────────────────────────────────────────────────────

public struct Binding {
    type_id: Integer,
    is_mutable: Trilean!,
}

public struct Frame {
    names: HashMap<String, Binding>,
}

public struct TypeEnvironment {
    frames: Vector<Frame>,
}

public function frame_new() -> Frame =
    Frame { names: hashmap_new() }

public function type_env_new() -> TypeEnvironment = {
    let initial: Frame = frame_new()
    TypeEnvironment { frames: push(new(), initial) }
}

/// Push an empty frame onto the env's stack — entering a new scope.
public function push_frame(env: TypeEnvironment) -> TypeEnvironment = {
    let new_frame: Frame = frame_new()
    TypeEnvironment { frames: push(env.frames, new_frame) }
}

/// Pop the top frame — leaving a scope. Returns the env unchanged
/// if only the root frame remains (defensive — the Rust impl
/// asserts but Triết's smoke test exercises both branches).
public function pop_frame(env: TypeEnvironment) -> TypeEnvironment = {
    let total: Integer = length(env.frames)
    if total <= 1 {
        env
    } else {
        let mutable rebuilt: Vector<Frame> = new()
        let mutable i: Integer = 0
        while i < total - 1 {
            let f_opt: Frame? = get(env.frames, i)
            rebuilt = push(rebuilt, f_opt!!)
            i = i + 1
        }
        TypeEnvironment { frames: rebuilt }
    }
}

/// Bind `name → (type_id, mutable)` in the top frame. Functional
/// rebuild: returns a new env with the top frame replaced.
public function declare_with_mut(
    env: TypeEnvironment,
    name: String,
    type_id: Integer,
    mutable_flag: Trilean!,
) -> TypeEnvironment = {
    let total: Integer = length(env.frames)
    if total == 0 {
        env
    } else {
        let top_opt: Frame? = get(env.frames, total - 1)
        let top: Frame = top_opt!!
        let updated_names: HashMap<String, Binding> = insert(top.names, name, Binding {
            type_id: type_id,
            is_mutable: mutable_flag,
        })
        let updated_top: Frame = Frame { names: updated_names }
        let mutable rebuilt: Vector<Frame> = new()
        let mutable i: Integer = 0
        while i < total - 1 {
            let f_opt: Frame? = get(env.frames, i)
            rebuilt = push(rebuilt, f_opt!!)
            i = i + 1
        }
        rebuilt = push(rebuilt, updated_top)
        TypeEnvironment { frames: rebuilt }
    }
}

/// Immutable variant of `declare_with_mut` — convenience wrapper.
public function declare(
    env: TypeEnvironment,
    name: String,
    type_id: Integer,
) -> TypeEnvironment =
    declare_with_mut(env, name, type_id, false)

/// Look up `name`, walking frames innermost-first. Returns the
/// matching `Binding` or `null`.
public function lookup_binding(env: TypeEnvironment, name: String) -> Binding? = {
    let total: Integer = length(env.frames)
    let mutable found: Binding? = ~0
    let mutable i: Integer = total
    while i > 0 {
        i = i - 1
        let frame_opt: Frame? = get(env.frames, i)
        let frame: Frame = frame_opt!!
        let bind_opt: Binding? = hashmap_get(frame.names, name)
        match bind_opt {
            ~0 => { },
            _ => {
                match found {
                    ~0 => { found = bind_opt },
                    _ => { },
                }
            },
        }
    }
    found
}

/// Look up `name`, returning just the `type_id` (or `null` if
/// unbound). Mirrors Rust `TypeEnvironment::lookup`.
public function lookup_type(env: TypeEnvironment, name: String) -> Integer? = {
    let b_opt: Binding? = lookup_binding(env, name)
    match b_opt {
        ~0 => ~0,
        _ => b_opt!!.type_id,
    }
}

// ─────────────────────────────────────────────────────────────────
// v0.7.7.2 — Literal + binding + control-flow checking.
//
// Mirrors crates/triet-typecheck/src/check.rs +
// crates/triet-typecheck/src/check/exprs.rs +
// crates/triet-typecheck/src/env.rs (prelude).
//
// CheckerState threads all mutable context functionally (same pattern
// as modules.tri's LoaderState). InferResult pairs the updated state
// with the inferred type arena id.
// ─────────────────────────────────────────────────────────────────

// ── CheckerState ─────────────────────────────────────────────────

public struct CheckerState {
    type_arena: TypeArena,
    env: TypeEnvironment,
    errors: Vector<TypeError>,
    return_type_id: Integer?,
    in_loop: Trilean!,
    parser_arena: Arena,
}

public struct InferResult {
    state: CheckerState,
    type_id: Integer,
}

function checker_with_type_arena(state: CheckerState, ta: TypeArena) -> CheckerState =
    CheckerState {
        type_arena: ta,
        env: state.env,
        errors: state.errors,
        return_type_id: state.return_type_id,
        in_loop: state.in_loop,
        parser_arena: state.parser_arena,
    }

function checker_with_env(state: CheckerState, env: TypeEnvironment) -> CheckerState =
    CheckerState {
        type_arena: state.type_arena,
        env: env,
        errors: state.errors,
        return_type_id: state.return_type_id,
        in_loop: state.in_loop,
        parser_arena: state.parser_arena,
    }

function checker_push_error(state: CheckerState, err: TypeError) -> CheckerState =
    CheckerState {
        type_arena: state.type_arena,
        env: state.env,
        errors: push(state.errors, err),
        return_type_id: state.return_type_id,
        in_loop: state.in_loop,
        parser_arena: state.parser_arena,
    }

function checker_with_return_type(state: CheckerState, type_id: Integer) -> CheckerState =
    CheckerState {
        type_arena: state.type_arena,
        env: state.env,
        errors: state.errors,
        return_type_id: type_id,
        in_loop: state.in_loop,
        parser_arena: state.parser_arena,
    }

function checker_clear_return_type(state: CheckerState) -> CheckerState =
    CheckerState {
        type_arena: state.type_arena,
        env: state.env,
        errors: state.errors,
        return_type_id: ~0,
        in_loop: state.in_loop,
        parser_arena: state.parser_arena,
    }

function checker_enter_loop(state: CheckerState) -> CheckerState =
    CheckerState {
        type_arena: state.type_arena,
        env: state.env,
        errors: state.errors,
        return_type_id: state.return_type_id,
        in_loop: true,
        parser_arena: state.parser_arena,
    }

function checker_exit_loop(state: CheckerState) -> CheckerState =
    CheckerState {
        type_arena: state.type_arena,
        env: state.env,
        errors: state.errors,
        return_type_id: state.return_type_id,
        in_loop: false,
        parser_arena: state.parser_arena,
    }

// ── Prelude ───────────────────────────────────────────────────────

public struct PreludeResult {
    type_arena: TypeArena,
    env: TypeEnvironment,
}

public function with_prelude() -> PreludeResult = {
    let a0: TypeArena = type_arena_new()
    let r_int: AllocTypeResult = alloc_integer(a0)
    let int_id: Integer = r_int.type_id
    let r_str: AllocTypeResult = alloc_string(r_int.arena)
    let str_id: Integer = r_str.type_id
    let r_unit: AllocTypeResult = alloc_unit(r_str.arena)
    let unit_id: Integer = r_unit.type_id
    let r_tryte: AllocTypeResult = alloc_tryte(r_unit.arena)
    let tryte_id: Integer = r_tryte.type_id
    let r_long: AllocTypeResult = alloc_long(r_tryte.arena)
    let long_id: Integer = r_long.type_id
    let r_tri: AllocTypeResult = alloc_trilean(r_long.arena, false)
    let trilean_id: Integer = r_tri.type_id

    let mutable str_vec: Vector<Integer> = new()
    str_vec = push(str_vec, str_id)
    let mutable tryte_vec: Vector<Integer> = new()
    tryte_vec = push(tryte_vec, tryte_id)
    let mutable long_vec: Vector<Integer> = new()
    long_vec = push(long_vec, long_id)
    let mutable int_vec: Vector<Integer> = new()
    int_vec = push(int_vec, int_id)
    let mutable tri_vec: Vector<Integer> = new()
    tri_vec = push(tri_vec, trilean_id)

    let r_print: AllocTypeResult = alloc_function(r_tri.arena, new(), str_vec, unit_id)
    let r_println: AllocTypeResult = alloc_function(r_print.arena, new(), str_vec, unit_id)
    let r_read: AllocTypeResult = alloc_function(r_println.arena, new(), new(), str_id)
    let r_to_str: AllocTypeResult = alloc_function(r_read.arena, new(), int_vec, str_id)
    let r_tryte_str: AllocTypeResult = alloc_function(r_to_str.arena, new(), tryte_vec, str_id)
    let r_long_str: AllocTypeResult = alloc_function(r_tryte_str.arena, new(), long_vec, str_id)
    let r_tri_str: AllocTypeResult = alloc_function(r_long_str.arena, new(), tri_vec, str_id)
    let r_len: AllocTypeResult = alloc_function(r_tri_str.arena, new(), str_vec, int_id)
    let final_arena: TypeArena = r_len.arena

    let env0: TypeEnvironment = type_env_new()
    let env1: TypeEnvironment = declare(env0, "print", r_print.type_id)
    let env2: TypeEnvironment = declare(env1, "println", r_println.type_id)
    let env3: TypeEnvironment = declare(env2, "read_line", r_read.type_id)
    let env4: TypeEnvironment = declare(env3, "to_string", r_to_str.type_id)
    let env5: TypeEnvironment = declare(env4, "tryte_to_string", r_tryte_str.type_id)
    let env6: TypeEnvironment = declare(env5, "long_to_string", r_long_str.type_id)
    let env7: TypeEnvironment = declare(env6, "trilean_to_string", r_tri_str.type_id)
    let env8: TypeEnvironment = declare(env7, "length", r_len.type_id)

    PreludeResult { type_arena: final_arena, env: env8 }
}

// ── Type helpers ──────────────────────────────────────────────────

function type_is_unknown_id(arena: TypeArena, type_id: Integer) -> Trilean! = {
    let node_opt: TypeNode? = get_type(arena, type_id)
    match node_opt {
        ~0 => true,
        _ => {
            match node_opt!!.kind {
                UnknownKind(_) => true,
                _ => false,
            }
        },
    }
}

function type_is_nullable(arena: TypeArena, type_id: Integer) -> Trilean! = {
    let node_opt: TypeNode? = get_type(arena, type_id)
    match node_opt {
        ~0 => false,
        _ => {
            match node_opt!!.kind {
                NullableKind(_) => true,
                _ => false,
            }
        },
    }
}

function type_is_trit(arena: TypeArena, type_id: Integer) -> Trilean! = {
    let node_opt: TypeNode? = get_type(arena, type_id)
    match node_opt {
        ~0 => false,
        _ => {
            match node_opt!!.kind {
                TritKind(_) => true,
                _ => false,
            }
        },
    }
}

function type_is_outcome(arena: TypeArena, type_id: Integer) -> Trilean! = {
    let node_opt: TypeNode? = get_type(arena, type_id)
    match node_opt {
        ~0 => false,
        _ => {
            match node_opt!!.kind {
                OutcomeKind(_) => true,
                _ => false,
            }
        },
    }
}

function nullable_inner(arena: TypeArena, type_id: Integer) -> Integer? = {
    let node_opt: TypeNode? = get_type(arena, type_id)
    match node_opt {
        ~0 => ~0,
        _ => {
            match node_opt!!.kind {
                NullableKind(p) => p.inner,
                _ => ~0,
            }
        },
    }
}

function types_match(arena: TypeArena, expected_id: Integer, found_id: Integer) -> Trilean! = {
    if type_is_unknown_id(arena, expected_id) { return true }
    if type_is_unknown_id(arena, found_id) { return true }
    if type_is_trilean(arena, expected_id) && type_is_trilean(arena, found_id) {
        let self_r: Trilean! = type_is_refined_trilean(arena, expected_id)
        let other_r: Trilean! = type_is_refined_trilean(arena, found_id)
        return !self_r || other_r
    }
    let exp_inner: Integer? = nullable_inner(arena, expected_id)
    let found_inner: Integer? = nullable_inner(arena, found_id)
    match exp_inner {
        ~0 => { },
        _ => {
            match found_inner {
                ~0 => {
                    let exp_display: String = type_display(arena, exp_inner!!)
                    let found_display: String = type_display(arena, found_id)
                    return exp_display == found_display
                },
                _ => {
                    return types_match(arena, exp_inner!!, found_inner!!)
                },
            }
        },
    }
    let exp_str: String = type_display(arena, expected_id)
    let found_str: String = type_display(arena, found_id)
    exp_str == found_str
}

// ── TypeExpr resolution ───────────────────────────────────────────

function infer_unknown(state: CheckerState) -> InferResult = {
    let r: AllocTypeResult = alloc_unknown(state.type_arena)
    InferResult { state: checker_with_type_arena(state, r.arena), type_id: r.type_id }
}

function resolve_named_type(state: CheckerState, name: String, ss: Integer, se: Integer) -> InferResult = {
    if name == "Integer" {
        let r: AllocTypeResult = alloc_integer(state.type_arena)
        return InferResult { state: checker_with_type_arena(state, r.arena), type_id: r.type_id }
    }
    if name == "String" {
        let r: AllocTypeResult = alloc_string(state.type_arena)
        return InferResult { state: checker_with_type_arena(state, r.arena), type_id: r.type_id }
    }
    if name == "Trit" {
        let r: AllocTypeResult = alloc_trit(state.type_arena)
        return InferResult { state: checker_with_type_arena(state, r.arena), type_id: r.type_id }
    }
    if name == "Tryte" {
        let r: AllocTypeResult = alloc_tryte(state.type_arena)
        return InferResult { state: checker_with_type_arena(state, r.arena), type_id: r.type_id }
    }
    if name == "Long" {
        let r: AllocTypeResult = alloc_long(state.type_arena)
        return InferResult { state: checker_with_type_arena(state, r.arena), type_id: r.type_id }
    }
    if name == "Unit" {
        let r: AllocTypeResult = alloc_unit(state.type_arena)
        return InferResult { state: checker_with_type_arena(state, r.arena), type_id: r.type_id }
    }
    if name == "Trilean" {
        let r: AllocTypeResult = alloc_trilean(state.type_arena, false)
        return InferResult { state: checker_with_type_arena(state, r.arena), type_id: r.type_id }
    }
    // Generic containers and unknown user types → Unknown for v0.7.7.2
    let env_type: Integer? = lookup_type(state.env, name)
    match env_type {
        ~0 => {
            let r: AllocTypeResult = alloc_unknown(state.type_arena)
            let st2: CheckerState = checker_with_type_arena(state, r.arena)
            InferResult {
                state: checker_push_error(st2, UnknownTypeErr(UnknownTypePayload {
                    name: name,
                    span_start: ss,
                    span_end: se,
                })),
                type_id: r.type_id,
            }
        },
        _ => InferResult { state: state, type_id: env_type!! },
    }
}

function resolve_generic_type(
    state: CheckerState,
    payload: GenericTypePayload,
    ss: Integer,
    se: Integer,
) -> InferResult = {
    // Resolve each argument first.
    let mutable st: CheckerState = state
    let mutable arg_ids: Vector<Integer> = new()
    let arg_total: Integer = length(payload.arguments)
    let mutable i: Integer = 0
    while i < arg_total {
        let aid_opt: Integer? = get(payload.arguments, i)
        let r: InferResult = resolve_type_expr(st, aid_opt!!)
        st = r.state
        arg_ids = push(arg_ids, r.type_id)
        i = i + 1
    }

    // Built-in collection shells per ADR-0019 Addendum §A7
    // (`Vector<T>` / `HashMap<K, V>` resolve to pseudo UserStruct
    // shapes carrying their element / key+value type IDs in
    // synthetic field slots `__element` / `__key` + `__value`).
    if payload.name == "Vector" {
        if arg_total != 1 {
            let st2: CheckerState = checker_push_error(st, WrongArityErr(WrongArityPayload {
                expected: 1,
                found: arg_total,
                span_start: ss,
                span_end: se,
            }))
            return infer_unknown(st2)
        }
        let elem_id: Integer = get(arg_ids, 0)!!
        let mutable fields: Vector<UserStructFieldPayload> = new()
        fields = push(fields, UserStructFieldPayload { name: "__element", type_id: elem_id })
        let r: AllocTypeResult = alloc_user_struct(st.type_arena, "Vector", new(), fields)
        return InferResult { state: checker_with_type_arena(st, r.arena), type_id: r.type_id }
    }
    if payload.name == "HashMap" {
        if arg_total != 2 {
            let st2: CheckerState = checker_push_error(st, WrongArityErr(WrongArityPayload {
                expected: 2,
                found: arg_total,
                span_start: ss,
                span_end: se,
            }))
            return infer_unknown(st2)
        }
        let key_id: Integer = get(arg_ids, 0)!!
        let val_id: Integer = get(arg_ids, 1)!!
        let mutable fields: Vector<UserStructFieldPayload> = new()
        fields = push(fields, UserStructFieldPayload { name: "__key", type_id: key_id })
        fields = push(fields, UserStructFieldPayload { name: "__value", type_id: val_id })
        let r: AllocTypeResult = alloc_user_struct(st.type_arena, "HashMap", new(), fields)
        return InferResult { state: checker_with_type_arena(st, r.arena), type_id: r.type_id }
    }

    // User generic type: look up in env, substitute params.
    let env_type: Integer? = lookup_type(st.env, payload.name)
    match env_type {
        ~0 => {
            let r: AllocTypeResult = alloc_unknown(st.type_arena)
            let st3: CheckerState = checker_with_type_arena(st, r.arena)
            return InferResult {
                state: checker_push_error(st3, UnknownTypeErr(UnknownTypePayload {
                    name: payload.name,
                    span_start: ss,
                    span_end: se,
                })),
                type_id: r.type_id,
            }
        },
        _ => { },
    }
    let template_id: Integer = env_type!!
    let template_node_opt: TypeNode? = get_type(st.type_arena, template_id)
    match template_node_opt {
        ~0 => { return infer_unknown(st) },
        _ => { },
    }
    let template_node: TypeNode = template_node_opt!!
    match template_node.kind {
        UserStructKind(s) => {
            if length(s.type_params) != arg_total {
                let st2: CheckerState = checker_push_error(st, WrongArityErr(WrongArityPayload {
                    expected: length(s.type_params),
                    found: arg_total,
                    span_start: ss,
                    span_end: se,
                }))
                return infer_unknown(st2)
            }
            let mutable sub_map: HashMap<String, Integer> = hashmap_new()
            let mutable j: Integer = 0
            while j < arg_total {
                let tp_name: String = get(s.type_params, j)!!
                let arg_id: Integer = get(arg_ids, j)!!
                sub_map = insert(sub_map, tp_name, arg_id)
                j = j + 1
            }
            let r: AllocTypeResult = type_substitute(st.type_arena, template_id, sub_map)
            InferResult { state: checker_with_type_arena(st, r.arena), type_id: r.type_id }
        },
        UserEnumKind(e) => {
            if length(e.type_params) != arg_total {
                let st2: CheckerState = checker_push_error(st, WrongArityErr(WrongArityPayload {
                    expected: length(e.type_params),
                    found: arg_total,
                    span_start: ss,
                    span_end: se,
                }))
                return infer_unknown(st2)
            }
            let mutable sub_map: HashMap<String, Integer> = hashmap_new()
            let mutable j: Integer = 0
            while j < arg_total {
                let tp_name: String = get(e.type_params, j)!!
                let arg_id: Integer = get(arg_ids, j)!!
                sub_map = insert(sub_map, tp_name, arg_id)
                j = j + 1
            }
            let r: AllocTypeResult = type_substitute(st.type_arena, template_id, sub_map)
            InferResult { state: checker_with_type_arena(st, r.arena), type_id: r.type_id }
        },
        _ => {
            let r: AllocTypeResult = alloc_unknown(st.type_arena)
            let st3: CheckerState = checker_with_type_arena(st, r.arena)
            InferResult {
                state: checker_push_error(st3, UnknownTypeErr(UnknownTypePayload {
                    name: payload.name,
                    span_start: ss,
                    span_end: se,
                })),
                type_id: r.type_id,
            }
        },
    }
}

function resolve_type_expr(state: CheckerState, type_expr_id: Integer) -> InferResult = {
    let spanned: SpannedTypeExpr = get_type_expr(state.parser_arena, type_expr_id)
    match spanned.node {
        NamedType(p) => resolve_named_type(state, p.name, spanned.span_start, spanned.span_end),
        GenericType(p) => resolve_generic_type(state, p, spanned.span_start, spanned.span_end),
        TupleType(elements) => {
            let mutable st: CheckerState = state
            let mutable elem_ids: Vector<Integer> = new()
            let total: Integer = length(elements)
            let mutable i: Integer = 0
            while i < total {
                let eid_opt: Integer? = get(elements, i)
                let r: InferResult = resolve_type_expr(st, eid_opt!!)
                st = r.state
                elem_ids = push(elem_ids, r.type_id)
                i = i + 1
            }
            let r: AllocTypeResult = alloc_tuple(st.type_arena, elem_ids)
            InferResult { state: checker_with_type_arena(st, r.arena), type_id: r.type_id }
        },
        NullableType(inner_id) => {
            let inner_r: InferResult = resolve_type_expr(state, inner_id)
            let r: AllocTypeResult = alloc_nullable(inner_r.state.type_arena, inner_r.type_id)
            InferResult {
                state: checker_with_type_arena(inner_r.state, r.arena),
                type_id: r.type_id,
            }
        },
        FunctionType(p) => {
            let mutable st: CheckerState = state
            let mutable param_ids: Vector<Integer> = new()
            let total: Integer = length(p.parameters)
            let mutable i: Integer = 0
            while i < total {
                let pid_opt: Integer? = get(p.parameters, i)
                let pr: InferResult = resolve_type_expr(st, pid_opt!!)
                st = pr.state
                param_ids = push(param_ids, pr.type_id)
                i = i + 1
            }
            let ret_r: InferResult = resolve_type_expr(st, p.return_type)
            st = ret_r.state
            let fn_r: AllocTypeResult = alloc_function(st.type_arena, new(), param_ids, ret_r.type_id)
            InferResult {
                state: checker_with_type_arena(st, fn_r.arena),
                type_id: fn_r.type_id,
            }
        },
        OutcomeType(p) => {
            let val_r: InferResult = resolve_type_expr(state, p.value_type)
            let err_r: InferResult = resolve_type_expr(val_r.state, p.error_type)
            let out_r: AllocTypeResult = alloc_outcome(err_r.state.type_arena, val_r.type_id, err_r.type_id, p.allow_null_state)
            InferResult {
                state: checker_with_type_arena(err_r.state, out_r.arena),
                type_id: out_r.type_id,
            }
        },
        RefinedTrileanType => {
            let r: AllocTypeResult = alloc_trilean(state.type_arena, true)
            InferResult { state: checker_with_type_arena(state, r.arena), type_id: r.type_id }
        },
    }
}

// ── Binary op helpers ─────────────────────────────────────────────

function binary_op_symbol(op: BinaryOperator) -> String = {
    match op {
        Add => "+",
        Subtract => "-",
        Multiply => "*",
        Divide => "/",
        Modulo => "%",
        Power => "**",
        Equal => "==",
        NotEqual => "!=",
        LessThan => "<",
        LessEqual => "<=",
        GreaterThan => ">",
        GreaterEqual => ">=",
        And => "&&",
        Or => "||",
        Xor => "^",
        Iff => "<=>",
        Implies => "=>",
        KleeneXor => "~^",
        KleeneIff => "<~>",
        KleeneImplies => "~>",
    }
}

function eq_result_type(state: CheckerState, left_tid: Integer, right_tid: Integer) -> InferResult = {
    let ta: TypeArena = state.type_arena
    let left_nullable: Trilean! = type_is_nullable(ta, left_tid)
    let right_nullable: Trilean! = type_is_nullable(ta, right_tid)
    let left_trit: Trilean! = type_is_trit(ta, left_tid)
    let right_trit: Trilean! = type_is_trit(ta, right_tid)
    let left_outcome: Trilean! = type_is_outcome(ta, left_tid)
    let right_outcome: Trilean! = type_is_outcome(ta, right_tid)

    let refined: Trilean! = if left_nullable || right_nullable || left_outcome || right_outcome || left_trit || right_trit {
        false
    } else {
        let left_tri: Trilean! = type_is_trilean(ta, left_tid)
        let right_tri: Trilean! = type_is_trilean(ta, right_tid)
        if left_tri || right_tri {
            let left_ref: Trilean! = if left_tri { type_is_refined_trilean(ta, left_tid) } else { true }
            let right_ref: Trilean! = if right_tri { type_is_refined_trilean(ta, right_tid) } else { true }
            left_ref && right_ref
        } else {
            true
        }
    }
    let r: AllocTypeResult = alloc_trilean(ta, refined)
    InferResult { state: checker_with_type_arena(state, r.arena), type_id: r.type_id }
}

function check_arithmetic_op(
    state: CheckerState,
    op: BinaryOperator,
    left_tid: Integer,
    right_tid: Integer,
    ss: Integer,
    se: Integer,
) -> InferResult = {
    let ta: TypeArena = state.type_arena
    let left_ok: Trilean! = type_is_numeric(ta, left_tid) || type_is_unknown_id(ta, left_tid)
    let right_ok: Trilean! = type_is_numeric(ta, right_tid) || type_is_unknown_id(ta, right_tid)
    let types_ok: Trilean! = types_match(ta, left_tid, right_tid)
    if !left_ok || !right_ok || !types_ok {
        let st2: CheckerState = checker_push_error(state, InvalidOperandsErr(InvalidOperandsPayload {
            operator: binary_op_symbol(op),
            expected_description: "two numeric operands of the same type",
            left: left_tid,
            right: right_tid,
            span_start: ss,
            span_end: se,
        }))
        infer_unknown(st2)
    } else {
        InferResult { state: state, type_id: left_tid }
    }
}

function check_equality_op(
    state: CheckerState,
    op: BinaryOperator,
    left_tid: Integer,
    right_tid: Integer,
    ss: Integer,
    se: Integer,
) -> InferResult = {
    if !types_match(state.type_arena, left_tid, right_tid) {
        let st2: CheckerState = checker_push_error(state, InvalidOperandsErr(InvalidOperandsPayload {
            operator: binary_op_symbol(op),
            expected_description: "two operands of the same type",
            left: left_tid,
            right: right_tid,
            span_start: ss,
            span_end: se,
        }))
        infer_unknown(st2)
    } else {
        eq_result_type(state, left_tid, right_tid)
    }
}

function check_ordering_op(
    state: CheckerState,
    op: BinaryOperator,
    left_tid: Integer,
    right_tid: Integer,
    ss: Integer,
    se: Integer,
) -> InferResult = {
    let ta: TypeArena = state.type_arena
    let left_ok: Trilean! = type_is_numeric(ta, left_tid) || type_is_unknown_id(ta, left_tid)
    let right_ok: Trilean! = type_is_numeric(ta, right_tid) || type_is_unknown_id(ta, right_tid)
    let types_ok: Trilean! = types_match(ta, left_tid, right_tid)
    if !left_ok || !right_ok || !types_ok {
        let st2: CheckerState = checker_push_error(state, InvalidOperandsErr(InvalidOperandsPayload {
            operator: binary_op_symbol(op),
            expected_description: "two numeric operands of the same type",
            left: left_tid,
            right: right_tid,
            span_start: ss,
            span_end: se,
        }))
        infer_unknown(st2)
    } else {
        let r: AllocTypeResult = alloc_trilean(ta, true)
        InferResult { state: checker_with_type_arena(state, r.arena), type_id: r.type_id }
    }
}

function check_logic_op(
    state: CheckerState,
    op: BinaryOperator,
    left_tid: Integer,
    right_tid: Integer,
    ss: Integer,
    se: Integer,
) -> InferResult = {
    let ta: TypeArena = state.type_arena
    let left_ok: Trilean! = type_is_trilean(ta, left_tid) || type_is_unknown_id(ta, left_tid)
    let right_ok: Trilean! = type_is_trilean(ta, right_tid) || type_is_unknown_id(ta, right_tid)
    if !left_ok || !right_ok {
        let st2: CheckerState = checker_push_error(state, InvalidOperandsErr(InvalidOperandsPayload {
            operator: binary_op_symbol(op),
            expected_description: "two `Trilean` operands",
            left: left_tid,
            right: right_tid,
            span_start: ss,
            span_end: se,
        }))
        infer_unknown(st2)
    } else {
        let both_refined: Trilean! = type_is_refined_trilean(ta, left_tid) && type_is_refined_trilean(ta, right_tid)
        let r: AllocTypeResult = alloc_trilean(ta, both_refined)
        InferResult { state: checker_with_type_arena(state, r.arena), type_id: r.type_id }
    }
}

function check_binary_op(
    state: CheckerState,
    op: BinaryOperator,
    left_id: Integer,
    right_id: Integer,
    ss: Integer,
    se: Integer,
) -> InferResult = {
    let left_r: InferResult = infer_expression(state, left_id)
    let right_r: InferResult = infer_expression(left_r.state, right_id)
    let st: CheckerState = right_r.state
    let left_tid: Integer = left_r.type_id
    let right_tid: Integer = right_r.type_id
    match op {
        Add => check_arithmetic_op(st, op, left_tid, right_tid, ss, se),
        Subtract => check_arithmetic_op(st, op, left_tid, right_tid, ss, se),
        Multiply => check_arithmetic_op(st, op, left_tid, right_tid, ss, se),
        Divide => check_arithmetic_op(st, op, left_tid, right_tid, ss, se),
        Modulo => check_arithmetic_op(st, op, left_tid, right_tid, ss, se),
        Power => check_arithmetic_op(st, op, left_tid, right_tid, ss, se),
        Equal => check_equality_op(st, op, left_tid, right_tid, ss, se),
        NotEqual => check_equality_op(st, op, left_tid, right_tid, ss, se),
        LessThan => check_ordering_op(st, op, left_tid, right_tid, ss, se),
        LessEqual => check_ordering_op(st, op, left_tid, right_tid, ss, se),
        GreaterThan => check_ordering_op(st, op, left_tid, right_tid, ss, se),
        GreaterEqual => check_ordering_op(st, op, left_tid, right_tid, ss, se),
        And => check_logic_op(st, op, left_tid, right_tid, ss, se),
        Or => check_logic_op(st, op, left_tid, right_tid, ss, se),
        Xor => check_logic_op(st, op, left_tid, right_tid, ss, se),
        Iff => check_logic_op(st, op, left_tid, right_tid, ss, se),
        Implies => check_logic_op(st, op, left_tid, right_tid, ss, se),
        KleeneXor => check_logic_op(st, op, left_tid, right_tid, ss, se),
        KleeneIff => check_logic_op(st, op, left_tid, right_tid, ss, se),
        KleeneImplies => check_logic_op(st, op, left_tid, right_tid, ss, se),
    }
}

function check_unary_negate(state: CheckerState, operand_id: Integer, ss: Integer, se: Integer) -> InferResult = {
    let operand_r: InferResult = infer_expression(state, operand_id)
    let st: CheckerState = operand_r.state
    let operand_tid: Integer = operand_r.type_id
    let ta: TypeArena = st.type_arena
    if type_is_numeric(ta, operand_tid) || type_is_trilean(ta, operand_tid) || type_is_unknown_id(ta, operand_tid) {
        InferResult { state: st, type_id: operand_tid }
    } else {
        let st2: CheckerState = checker_push_error(st, InvalidUnaryErr(InvalidUnaryPayload {
            operator: "-/!/not",
            operand: operand_tid,
            span_start: ss,
            span_end: se,
        }))
        infer_unknown(st2)
    }
}

// ── Expression inference ──────────────────────────────────────────

function infer_integer_literal(state: CheckerState, lit: IntLiteral) -> InferResult = {
    let suf_opt: NumericSuffix? = lit.suffix
    match suf_opt {
        ~0 => {
            let r: AllocTypeResult = alloc_integer(state.type_arena)
            InferResult { state: checker_with_type_arena(state, r.arena), type_id: r.type_id }
        },
        _ => {
            match suf_opt!! {
                TritSuffix => {
                    let r: AllocTypeResult = alloc_trit(state.type_arena)
                    InferResult { state: checker_with_type_arena(state, r.arena), type_id: r.type_id }
                },
                TryteSuffix => {
                    let r: AllocTypeResult = alloc_tryte(state.type_arena)
                    InferResult { state: checker_with_type_arena(state, r.arena), type_id: r.type_id }
                },
                IntegerSuffix => {
                    let r: AllocTypeResult = alloc_integer(state.type_arena)
                    InferResult { state: checker_with_type_arena(state, r.arena), type_id: r.type_id }
                },
                LongSuffix => {
                    let r: AllocTypeResult = alloc_long(state.type_arena)
                    InferResult { state: checker_with_type_arena(state, r.arena), type_id: r.type_id }
                },
            }
        },
    }
}

function infer_trilean_literal(state: CheckerState, tv: TrileanValue) -> InferResult = {
    let refined: Trilean! = match tv {
        TrueValue => true,
        FalseValue => true,
        UnknownValue => false,
    }
    let r: AllocTypeResult = alloc_trilean(state.type_arena, refined)
    InferResult { state: checker_with_type_arena(state, r.arena), type_id: r.type_id }
}

function infer_null_literal(state: CheckerState, ss: Integer, se: Integer) -> InferResult = {
    let r_unk: AllocTypeResult = alloc_unknown(state.type_arena)
    let st1: CheckerState = checker_with_type_arena(state, r_unk.arena)
    let r_null: AllocTypeResult = alloc_nullable(st1.type_arena, r_unk.type_id)
    let st2: CheckerState = checker_with_type_arena(st1, r_null.arena)
    let st3: CheckerState = checker_push_error(st2, NullDeprecatedErr(NullDeprecatedPayload {
        span_start: ss,
        span_end: se,
    }))
    InferResult { state: st3, type_id: r_null.type_id }
}

function infer_identifier(state: CheckerState, name: String, ss: Integer, se: Integer) -> InferResult = {
    let type_id_opt: Integer? = lookup_type(state.env, name)
    match type_id_opt {
        ~0 => {
            let r: AllocTypeResult = alloc_unknown(state.type_arena)
            InferResult {
                state: checker_push_error(
                    checker_with_type_arena(state, r.arena),
                    UndefinedNameErr(UndefinedNamePayload {
                        name: name,
                        span_start: ss,
                        span_end: se,
                    })
                ),
                type_id: r.type_id,
            }
        },
        _ => InferResult { state: state, type_id: type_id_opt!! },
    }
}

function infer_force_unwrap(state: CheckerState, inner_id: Integer, ss: Integer, se: Integer) -> InferResult = {
    let inner_r: InferResult = infer_expression(state, inner_id)
    let inner_inner: Integer? = nullable_inner(inner_r.state.type_arena, inner_r.type_id)
    match inner_inner {
        ~0 => {
            if type_is_unknown_id(inner_r.state.type_arena, inner_r.type_id) {
                inner_r
            } else {
                let r: AllocTypeResult = alloc_unknown(inner_r.state.type_arena)
                InferResult {
                    state: checker_push_error(
                        checker_with_type_arena(inner_r.state, r.arena),
                        NotNullableErr(NotNullablePayload {
                            operator: "!!",
                            found: inner_r.type_id,
                            span_start: ss,
                            span_end: se,
                        })
                    ),
                    type_id: r.type_id,
                }
            }
        },
        _ => InferResult { state: inner_r.state, type_id: inner_inner!! },
    }
}

function extract_type_params(
    arena: TypeArena,
    param_id: Integer,
    arg_id: Integer,
    sub_map: HashMap<String, Integer>,
) -> HashMap<String, Integer> = {
    let p_node_opt: TypeNode? = get_type(arena, param_id)
    match p_node_opt {
        ~0 => { return sub_map },
        _ => { },
    }
    let a_node_opt: TypeNode? = get_type(arena, arg_id)
    match a_node_opt {
        ~0 => { return sub_map },
        _ => { },
    }
    let p: TypeNode = p_node_opt!!
    let a: TypeNode = a_node_opt!!

    match p.kind {
        TypeParamKind(tp) => {
            let name: String = tp.name
            match hashmap_get(sub_map, name) {
                ~0 => {
                    insert(sub_map, name, arg_id)
                },
                _ => {
                    let existing: Integer = hashmap_get(sub_map, name)!!
                    let ext_node_opt: TypeNode? = get_type(arena, existing)
                    match ext_node_opt {
                        ~0 => { sub_map },
                        _ => {
                            let ext_node: TypeNode = ext_node_opt!!
                            match ext_node.kind {
                                TypeParamKind(_) => {
                                    match a.kind {
                                        TypeParamKind(_) => { sub_map },
                                        _ => {
                                            insert(sub_map, name, arg_id)
                                        },
                                    }
                                },
                                _ => { sub_map },
                            }
                        },
                    }
                },
            }
        },
        NullableKind(pn) => {
            match a.kind {
                NullableKind(an) => {
                    extract_type_params(arena, pn.inner, an.inner, sub_map)
                },
                _ => {
                    extract_type_params(arena, pn.inner, arg_id, sub_map)
                },
            }
        },
        TupleKind(pt) => {
            match a.kind {
                TupleKind(at) => {
                    if length(pt.elements) == length(at.elements) {
                        let mutable m: HashMap<String, Integer> = sub_map
                        let mutable i: Integer = 0
                        while i < length(pt.elements) {
                            let p_elem: Integer = get(pt.elements, i)!!
                            let a_elem: Integer = get(at.elements, i)!!
                            m = extract_type_params(arena, p_elem, a_elem, m)
                            i = i + 1
                        }
                        m
                    } else {
                        sub_map
                    }
                },
                _ => { sub_map },
            }
        },
        RangeKind(pr) => {
            match a.kind {
                RangeKind(ar) => {
                    extract_type_params(arena, pr.element, ar.element, sub_map)
                },
                _ => { sub_map },
            }
        },
        UserStructKind(ps) => {
            match a.kind {
                UserStructKind(a_struct) => {
                    if ps.name == a_struct.name && length(ps.fields) == length(a_struct.fields) {
                        let mutable m: HashMap<String, Integer> = sub_map
                        let mutable i: Integer = 0
                        while i < length(ps.fields) {
                            let pf: UserStructFieldPayload = get(ps.fields, i)!!
                            let af: UserStructFieldPayload = get(a_struct.fields, i)!!
                            m = extract_type_params(arena, pf.type_id, af.type_id, m)
                            i = i + 1
                        }
                        m
                    } else {
                        sub_map
                    }
                },
                _ => { sub_map },
            }
        },
        UserEnumKind(pe) => {
            match a.kind {
                UserEnumKind(ae) => {
                    if pe.name == ae.name && length(pe.variants) == length(ae.variants) {
                        let mutable m: HashMap<String, Integer> = sub_map
                        let mutable i: Integer = 0
                        while i < length(pe.variants) {
                            let pv: UserEnumVariantPayload = get(pe.variants, i)!!
                            let av: UserEnumVariantPayload = get(ae.variants, i)!!
                            match pv.payload_type {
                                ~0 => { },
                                _ => {
                                    match av.payload_type {
                                        ~0 => { },
                                        _ => {
                                            m = extract_type_params(arena, pv.payload_type!!, av.payload_type!!, m)
                                        },
                                    }
                                },
                            }
                            i = i + 1
                        }
                        m
                    } else {
                        sub_map
                    }
                },
                _ => { sub_map },
            }
        },
        FunctionKind(pf) => {
            match a.kind {
                FunctionKind(af) => {
                    if length(pf.parameters) == length(af.parameters) {
                        let mutable m: HashMap<String, Integer> = sub_map
                        let mutable i: Integer = 0
                        while i < length(pf.parameters) {
                            let pp: Integer = get(pf.parameters, i)!!
                            let ap: Integer = get(af.parameters, i)!!
                            m = extract_type_params(arena, pp, ap, m)
                            i = i + 1
                        }
                        extract_type_params(arena, pf.return_type, af.return_type, m)
                    } else {
                        sub_map
                    }
                },
                _ => { sub_map },
            }
        },
        OutcomeKind(po) => {
            match a.kind {
                OutcomeKind(ao) => {
                    if po.allow_null_state == ao.allow_null_state {
                        let mutable m: HashMap<String, Integer> = sub_map
                        m = extract_type_params(arena, po.value_type, ao.value_type, m)
                        extract_type_params(arena, po.error_type, ao.error_type, m)
                    } else {
                        sub_map
                    }
                },
                _ => { sub_map },
            }
        },
        _ => { sub_map },
    }
}

function type_substitute(
    arena: TypeArena,
    type_id: Integer,
    sub_map: HashMap<String, Integer>,
) -> AllocTypeResult = {
    let node_opt: TypeNode? = get_type(arena, type_id)
    match node_opt {
        ~0 => { return AllocTypeResult { arena: arena, type_id: type_id } },
        _ => { },
    }
    let node: TypeNode = node_opt!!
    match node.kind {
        TypeParamKind(tp) => {
            let name: String = tp.name
            match hashmap_get(sub_map, name) {
                ~0 => { AllocTypeResult { arena: arena, type_id: type_id } },
                _ => {
                    let sub_id: Integer = hashmap_get(sub_map, name)!!
                    AllocTypeResult { arena: arena, type_id: sub_id }
                },
            }
        },
        NullableKind(n) => {
            let r: AllocTypeResult = type_substitute(arena, n.inner, sub_map)
            alloc_nullable(r.arena, r.type_id)
        },
        TupleKind(t) => {
            let mutable st_arena: TypeArena = arena
            let mutable new_elems: Vector<Integer> = new()
            let mutable i: Integer = 0
            while i < length(t.elements) {
                let e: Integer = get(t.elements, i)!!
                let r: AllocTypeResult = type_substitute(st_arena, e, sub_map)
                st_arena = r.arena
                new_elems = push(new_elems, r.type_id)
                i = i + 1
            }
            alloc_tuple(st_arena, new_elems)
        },
        FunctionKind(f) => {
            let mutable st_arena: TypeArena = arena
            let mutable new_params: Vector<Integer> = new()
            let mutable i: Integer = 0
            while i < length(f.parameters) {
                let p: Integer = get(f.parameters, i)!!
                let r: AllocTypeResult = type_substitute(st_arena, p, sub_map)
                st_arena = r.arena
                new_params = push(new_params, r.type_id)
                i = i + 1
            }
            let ret_r: AllocTypeResult = type_substitute(st_arena, f.return_type, sub_map)
            st_arena = ret_r.arena
            alloc_function(st_arena, f.type_params, new_params, ret_r.type_id)
        },
        RangeKind(rg) => {
            let r: AllocTypeResult = type_substitute(arena, rg.element, sub_map)
            alloc_range(r.arena, r.type_id)
        },
        UserStructKind(us) => {
            let mutable st_arena: TypeArena = arena
            let mutable new_fields: Vector<UserStructFieldPayload> = new()
            let mutable local_map: HashMap<String, Integer> = sub_map
            // type_params are replaced with empty vec
            let mutable i: Integer = 0
            while i < length(us.type_params) {
                let p: String = get(us.type_params, i)!!
                match hashmap_get(sub_map, p) {
                    ~0 => {
                        let uk: AllocTypeResult = alloc_unknown(st_arena)
                        st_arena = uk.arena
                        local_map = insert(local_map, p, uk.type_id)
                    },
                    _ => {
                        let sub_id: Integer = hashmap_get(sub_map, p)!!
                        local_map = insert(local_map, p, sub_id)
                    },
                }
                i = i + 1
            }
            let mutable j: Integer = 0
            while j < length(us.fields) {
                let f: UserStructFieldPayload = get(us.fields, j)!!
                let r: AllocTypeResult = type_substitute(st_arena, f.type_id, local_map)
                st_arena = r.arena
                new_fields = push(new_fields, UserStructFieldPayload { name: f.name, type_id: r.type_id })
                j = j + 1
            }
            let empty_tp: Vector<String> = new()
            alloc_user_struct(st_arena, us.name, empty_tp, new_fields)
        },
        UserEnumKind(ue) => {
            let mutable st_arena: TypeArena = arena
            let mutable new_variants: Vector<UserEnumVariantPayload> = new()
            let mutable local_map: HashMap<String, Integer> = sub_map
            let mutable i: Integer = 0
            while i < length(ue.type_params) {
                let p: String = get(ue.type_params, i)!!
                match hashmap_get(sub_map, p) {
                    ~0 => {
                        let uk: AllocTypeResult = alloc_unknown(st_arena)
                        st_arena = uk.arena
                        local_map = insert(local_map, p, uk.type_id)
                    },
                    _ => {
                        let sub_id: Integer = hashmap_get(sub_map, p)!!
                        local_map = insert(local_map, p, sub_id)
                    },
                }
                i = i + 1
            }
            let mutable j: Integer = 0
            while j < length(ue.variants) {
                let v: UserEnumVariantPayload = get(ue.variants, j)!!
                match v.payload_type {
                    ~0 => {
                        new_variants = push(new_variants, UserEnumVariantPayload { name: v.name, payload_type: ~0 })
                    },
                    _ => {
                        let r: AllocTypeResult = type_substitute(st_arena, v.payload_type!!, local_map)
                        st_arena = r.arena
                        new_variants = push(new_variants, UserEnumVariantPayload { name: v.name, payload_type: r.type_id })
                    },
                }
                j = j + 1
            }
            let empty_tp: Vector<String> = new()
            alloc_user_enum(st_arena, ue.name, empty_tp, new_variants)
        },
        OutcomeKind(o) => {
            let r_val: AllocTypeResult = type_substitute(arena, o.value_type, sub_map)
            let r_err: AllocTypeResult = type_substitute(r_val.arena, o.error_type, sub_map)
            alloc_outcome(r_err.arena, r_val.type_id, r_err.type_id, o.allow_null_state)
        },
        _ => { AllocTypeResult { arena: arena, type_id: type_id } },
    }
}

function infer_call(
    state: CheckerState,
    call: CallPayload,
    ss: Integer,
    se: Integer,
) -> InferResult = {
    let callee_r: InferResult = infer_expression(state, call.callee)
    let mutable st: CheckerState = callee_r.state
    let callee_ty_opt: TypeNode? = get_type(st.type_arena, callee_r.type_id)
    match callee_ty_opt {
        ~0 => { return infer_unknown(st) },
        _ => { },
    }
    let callee_ty: TypeNode = callee_ty_opt!!

    match callee_ty.kind {
        FunctionKind(f) => {
            if length(call.arguments) != length(f.parameters) {
                let err: TypeError = WrongArityErr(WrongArityPayload {
                    expected: length(f.parameters),
                    found: length(call.arguments),
                    span_start: ss,
                    span_end: se,
                })
                st = checker_push_error(st, err)
            }
            let mutable sub_map: HashMap<String, Integer> = hashmap_new()
            let mutable i: Integer = 0
            while i < length(call.arguments) {
                let arg_id: Integer = get(call.arguments, i)!!
                let arg_r: InferResult = infer_expression(st, arg_id)
                st = arg_r.state
                let expected_opt: Integer? = get(f.parameters, i)
                match expected_opt {
                    ~0 => { },
                    _ => {
                        let expected: Integer = expected_opt!!
                        if length(f.type_params) > 0 {
                            sub_map = extract_type_params(st.type_arena, expected, arg_r.type_id, sub_map)
                        }
                        let exp_sub_r: AllocTypeResult = type_substitute(st.type_arena, expected, sub_map)
                        st = checker_with_type_arena(st, exp_sub_r.arena)
                        if !types_match(st.type_arena, exp_sub_r.type_id, arg_r.type_id) {
                            let arg_spanned: SpannedExpr = get_expression(st.parser_arena, arg_id)
                            let err2: TypeError = MismatchErr(MismatchPayload {
                                expected: exp_sub_r.type_id,
                                found: arg_r.type_id,
                                span_start: arg_spanned.span_start,
                                span_end: arg_spanned.span_end,
                            })
                            st = checker_push_error(st, err2)
                        }
                    },
                }
                i = i + 1
            }
            if length(f.type_params) == 0 {
                return InferResult { state: st, type_id: f.return_type }
            }
            let ret_sub_r: AllocTypeResult = type_substitute(st.type_arena, f.return_type, sub_map)
            InferResult { state: checker_with_type_arena(st, ret_sub_r.arena), type_id: ret_sub_r.type_id }
        },
        UnknownKind(_) => {
            InferResult { state: st, type_id: callee_r.type_id }
        },
        _ => {
            let err: TypeError = NotCallableErr(NotCallablePayload {
                found: callee_r.type_id,
                span_start: ss,
                span_end: se,
            })
            st = checker_push_error(st, err)
            infer_unknown(st)
        },
    }
}


// ── v0.7.7.4b expression inference (Outcome / Elvis / Range /
// FieldAccess body-side). Mirrors crates/triet-typecheck/src/check/
// exprs.rs:215-353, :754-776, :856-876, :148-159. Context-sensitive
// `OutcomeConstructor` inference via expected_type_stack defers
// past v0.7.7.4b — without an active expected context the
// constructor returns Unknown (matches Rust impl when the local
// stack is empty; the local-stack feature ports later alongside
// the StructLiteral / EnumLiteral expression variants once the
// Triết parser surfaces them).

function infer_field_access(
    state: CheckerState,
    object_id: Integer,
    field_name: String,
    ss: Integer,
    se: Integer,
) -> InferResult = {
    let obj_r: InferResult = infer_expression(state, object_id)
    let mutable st: CheckerState = obj_r.state
    let obj_tid: Integer = obj_r.type_id
    if type_is_unknown_id(st.type_arena, obj_tid) {
        return InferResult { state: st, type_id: obj_tid }
    }
    let node_opt: TypeNode? = get_type(st.type_arena, obj_tid)
    let mutable found_tid: Integer = 0
    let mutable found: Trilean! = false
    match node_opt {
        ~0 => { },
        _ => {
            match node_opt!!.kind {
                UserStructKind(s) => {
                    let total: Integer = length(s.fields)
                    let mutable i: Integer = 0
                    while i < total {
                        let f: UserStructFieldPayload = get(s.fields, i)!!
                        if f.name == field_name {
                            found_tid = f.type_id
                            found = true
                        }
                        i = i + 1
                    }
                },
                _ => { },
            }
        },
    }
    if found {
        InferResult { state: st, type_id: found_tid }
    } else {
        let err: TypeError = UnknownMemberErr(UnknownMemberPayload {
            member: field_name,
            found: obj_tid,
            span_start: ss,
            span_end: se,
        })
        st = checker_push_error(st, err)
        infer_unknown(st)
    }
}

function infer_range(
    state: CheckerState,
    p: RangePayload,
    ss: Integer,
    se: Integer,
) -> InferResult = {
    let start_r: InferResult = infer_expression(state, p.range_start)
    let end_r: InferResult = infer_expression(start_r.state, p.range_end)
    let mutable st: CheckerState = end_r.state
    if !types_match(st.type_arena, start_r.type_id, end_r.type_id) {
        let end_spanned: SpannedExpr = get_expression(st.parser_arena, p.range_end)
        st = checker_push_error(st, MismatchErr(MismatchPayload {
            expected: start_r.type_id,
            found: end_r.type_id,
            span_start: end_spanned.span_start,
            span_end: end_spanned.span_end,
        }))
    }
    let r: AllocTypeResult = alloc_range(st.type_arena, start_r.type_id)
    InferResult { state: checker_with_type_arena(st, r.arena), type_id: r.type_id }
}

function infer_elvis(
    state: CheckerState,
    p: ElvisOpPayload,
    ss: Integer,
    se: Integer,
) -> InferResult = {
    let obj_r: InferResult = infer_expression(state, p.object)
    let def_r: InferResult = infer_expression(obj_r.state, p.default_expr)
    let mutable st: CheckerState = def_r.state
    let obj_tid: Integer = obj_r.type_id
    let def_tid: Integer = def_r.type_id
    let nullable: Trilean! = type_is_nullable(st.type_arena, obj_tid)
    let is_unk: Trilean! = type_is_unknown_id(st.type_arena, obj_tid)
    if !nullable && !is_unk {
        st = checker_push_error(st, NotNullableErr(NotNullablePayload {
            operator: "?:",
            found: obj_tid,
            span_start: ss,
            span_end: se,
        }))
        return InferResult { state: st, type_id: def_tid }
    }
    let inner_opt: Integer? = nullable_inner(st.type_arena, obj_tid)
    let mutable inner_tid: Integer = 0
    match inner_opt {
        ~0 => { inner_tid = obj_tid },
        _ => { inner_tid = inner_opt!! },
    }
    if !types_match(st.type_arena, inner_tid, def_tid) {
        let def_spanned: SpannedExpr = get_expression(st.parser_arena, p.default_expr)
        st = checker_push_error(st, MismatchErr(MismatchPayload {
            expected: inner_tid,
            found: def_tid,
            span_start: def_spanned.span_start,
            span_end: def_spanned.span_end,
        }))
    }
    InferResult { state: st, type_id: inner_tid }
}

// Outcome constructor result type. Without an active
// `expected_type_stack`, mirror Rust's "Unknown" arm (returned when
// `local_context.or(surrounding_context)` resolves to None / non-
// Outcome). The surrounding-return-type path is enough for the
// common case where a function body returns `~+ value` against a
// declared `T~E` / `T?~E` return type — that's checked downstream
// via `types_match` against `return_type_id`. E1025 (null arm
// against binary outcome) needs the resolved context to fire;
// without it we defer the diagnostic to v0.7.7.4b+ when
// constructor-context tracking ports alongside StructLiteral.
function infer_outcome_constructor(
    state: CheckerState,
    p: OutcomeConstructorPayload,
    ss: Integer,
    se: Integer,
) -> InferResult = {
    let mutable st: CheckerState = state
    // Type-check the payload (if any) so nested errors still surface.
    match p.payload {
        ~0 => { },
        _ => {
            let pr: InferResult = infer_expression(st, p.payload!!)
            st = pr.state
        },
    }
    // Surrounding-return-type context: if the function's return
    // type is an Outcome (or, for ZeroArm, a Nullable), tighten the
    // constructor's shape to that. Otherwise return Unknown.
    match st.return_type_id {
        ~0 => infer_unknown(st),
        _ => {
            let ret_id: Integer = st.return_type_id!!
            let node_opt: TypeNode? = get_type(st.type_arena, ret_id)
            match node_opt {
                ~0 => infer_unknown(st),
                _ => {
                    match node_opt!!.kind {
                        OutcomeKind(o) => {
                            // E1025: `~0` arm against a binary outcome (no null state).
                            match p.arm {
                                ZeroArm => {
                                    if !o.allow_null_state {
                                        st = checker_push_error(st, NullStateInBinaryOutcomeErr(NullStateInBinaryOutcomePayload {
                                            span_start: ss,
                                            span_end: se,
                                        }))
                                        return infer_unknown(st)
                                    }
                                    InferResult { state: st, type_id: ret_id }
                                },
                                PositiveArm => InferResult { state: st, type_id: ret_id },
                                NegativeArm => InferResult { state: st, type_id: ret_id },
                            }
                        },
                        NullableKind(_) => {
                            match p.arm {
                                ZeroArm => InferResult { state: st, type_id: ret_id },
                                _ => infer_unknown(st),
                            }
                        },
                        _ => infer_unknown(st),
                    }
                },
            }
        },
    }
}

// `inner ~? |capture| early_return` per ADR-0020 §3.1.
function infer_outcome_propagate(
    state: CheckerState,
    p: OutcomePropagatePayload,
    ss: Integer,
    se: Integer,
) -> InferResult = {
    let inner_r: InferResult = infer_expression(state, p.inner)
    let mutable st: CheckerState = inner_r.state
    let inner_tid: Integer = inner_r.type_id
    let inner_node_opt: TypeNode? = get_type(st.type_arena, inner_tid)
    let mutable inner_value_tid: Integer = 0
    let mutable inner_error_tid: Integer = 0
    let mutable inner_allow_null: Trilean! = false
    let mutable inner_is_outcome: Trilean! = false
    match inner_node_opt {
        ~0 => { },
        _ => {
            match inner_node_opt!!.kind {
                OutcomeKind(o) => {
                    inner_value_tid = o.value_type
                    inner_error_tid = o.error_type
                    inner_allow_null = o.allow_null_state
                    inner_is_outcome = true
                },
                _ => { },
            }
        },
    }

    // E1028: surrounding function's return type must be Outcome.
    let mutable caller_is_outcome: Trilean! = false
    let mutable caller_error_tid: Integer = 0
    match st.return_type_id {
        ~0 => { },
        _ => {
            let r_node_opt: TypeNode? = get_type(st.type_arena, st.return_type_id!!)
            match r_node_opt {
                ~0 => { },
                _ => {
                    match r_node_opt!!.kind {
                        OutcomeKind(o2) => {
                            caller_is_outcome = true
                            caller_error_tid = o2.error_type
                        },
                        _ => { },
                    }
                },
            }
        },
    }
    if !caller_is_outcome {
        st = checker_push_error(st, PropagateInNonFallibleContextErr(PropagateInNonFallibleContextPayload {
            span_start: ss,
            span_end: se,
        }))
    }

    // E1029: inner error_type must match caller error_type.
    if inner_is_outcome && caller_is_outcome {
        if !types_match(st.type_arena, caller_error_tid, inner_error_tid) {
            st = checker_push_error(st, ErrorTypeMismatchErr(ErrorTypeMismatchPayload {
                inner_error: inner_error_tid,
                outer_error: caller_error_tid,
                span_start: ss,
                span_end: se,
            }))
        }
    }

    // Bind the optional capture in a fresh frame, infer early_return,
    // then pop. The capture's type is the inner Outcome's error type
    // (Unknown if inner isn't Outcome).
    let capture_frame: CheckerState = checker_with_env(st, push_frame(st.env))
    let mutable st2: CheckerState = capture_frame
    match p.capture_name {
        ~0 => { },
        _ => {
            let mutable cap_tid: Integer = 0
            if inner_is_outcome {
                cap_tid = inner_error_tid
            } else {
                let unk_r: AllocTypeResult = alloc_unknown(st2.type_arena)
                st2 = checker_with_type_arena(st2, unk_r.arena)
                cap_tid = unk_r.type_id
            }
            st2 = checker_with_env(st2, declare(st2.env, p.capture_name!!, cap_tid))
        },
    }
    let er_r: InferResult = infer_expression(st2, p.early_return)
    st2 = checker_with_env(er_r.state, pop_frame(er_r.state.env))

    // Result type: inner's success arm. For T?~E threads Nullable<T>.
    if inner_is_outcome {
        if inner_allow_null {
            let n_r: AllocTypeResult = alloc_nullable(st2.type_arena, inner_value_tid)
            InferResult { state: checker_with_type_arena(st2, n_r.arena), type_id: n_r.type_id }
        } else {
            InferResult { state: st2, type_id: inner_value_tid }
        }
    } else {
        infer_unknown(st2)
    }
}

// `inner ~: default` per ADR-0020 §3.2.
function infer_outcome_default(
    state: CheckerState,
    p: OutcomeDefaultPayload,
    ss: Integer,
    se: Integer,
) -> InferResult = {
    let inner_r: InferResult = infer_expression(state, p.inner)
    let def_r: InferResult = infer_expression(inner_r.state, p.default_expr)
    let mutable st: CheckerState = def_r.state
    let inner_tid: Integer = inner_r.type_id
    let def_tid: Integer = def_r.type_id
    let node_opt: TypeNode? = get_type(st.type_arena, inner_tid)
    let mutable expected_tid: Integer = 0
    let mutable resolved: Trilean! = false
    match node_opt {
        ~0 => { },
        _ => {
            match node_opt!!.kind {
                OutcomeKind(o) => {
                    if o.allow_null_state {
                        let n_r: AllocTypeResult = alloc_nullable(st.type_arena, o.value_type)
                        st = checker_with_type_arena(st, n_r.arena)
                        expected_tid = n_r.type_id
                    } else {
                        expected_tid = o.value_type
                    }
                    resolved = true
                },
                _ => { },
            }
        },
    }
    if !resolved {
        return infer_unknown(st)
    }
    if !types_match(st.type_arena, expected_tid, def_tid) {
        let def_spanned: SpannedExpr = get_expression(st.parser_arena, p.default_expr)
        st = checker_push_error(st, MismatchErr(MismatchPayload {
            expected: expected_tid,
            found: def_tid,
            span_start: def_spanned.span_start,
            span_end: def_spanned.span_end,
        }))
    }
    InferResult { state: st, type_id: expected_tid }
}

public function infer_expression(state: CheckerState, expr_id: Integer) -> InferResult = {
    let spanned: SpannedExpr = get_expression(state.parser_arena, expr_id)
    let ss: Integer = spanned.span_start
    let se: Integer = spanned.span_end
    match spanned.node {
        IntegerLiteralExpr(lit) => infer_integer_literal(state, lit),
        TernaryLiteralExpr(_) => {
            let r: AllocTypeResult = alloc_integer(state.type_arena)
            InferResult { state: checker_with_type_arena(state, r.arena), type_id: r.type_id }
        },
        TrileanLiteralExpr(tv) => infer_trilean_literal(state, tv),
        StringLiteralExpr(_) => {
            let r: AllocTypeResult = alloc_string(state.type_arena)
            InferResult { state: checker_with_type_arena(state, r.arena), type_id: r.type_id }
        },
        NullLiteralExpr => infer_null_literal(state, ss, se),
        IdentifierExpr(sp) => infer_identifier(state, sp.text, ss, se),
        UnaryOpExpr(p) => check_unary_negate(state, p.operand, ss, se),
        BinaryOpExpr(p) => check_binary_op(state, p.operator, p.left, p.right, ss, se),
        ForceUnwrapExpr(inner_id) => infer_force_unwrap(state, inner_id, ss, se),
        CallExpr(call) => infer_call(state, call, ss, se),
        FieldAccessExpr(p) => infer_field_access(state, p.object, p.field, ss, se),
        MethodCallExpr(_) => infer_unknown(state),
        OutcomeConstructorExpr(p) => infer_outcome_constructor(state, p, ss, se),
        OutcomePropagateExpr(p) => infer_outcome_propagate(state, p, ss, se),
        OutcomeDefaultExpr(p) => infer_outcome_default(state, p, ss, se),
        ElvisOpExpr(p) => infer_elvis(state, p, ss, se),
        RangeExpr(p) => infer_range(state, p, ss, se),
    }
}

// ── Statement checking ────────────────────────────────────────────

function push_return_mismatch(
    state: CheckerState,
    expected_tid: Integer,
    found_tid: Integer,
    ss: Integer,
    se: Integer,
) -> CheckerState = {
    if type_is_refined_trilean(state.type_arena, expected_tid) && type_is_trilean(state.type_arena, found_tid) && !type_is_refined_trilean(state.type_arena, found_tid) {
        checker_push_error(state, TrileanReturnNotRefinedErr(TrileanReturnNotRefinedPayload {
            span_start: ss,
            span_end: se,
        }))
    } else {
        checker_push_error(state, MismatchErr(MismatchPayload {
            expected: expected_tid,
            found: found_tid,
            span_start: ss,
            span_end: se,
        }))
    }
}

function check_condition_type(
    state: CheckerState,
    cond_tid: Integer,
    treat_unknown_as_false: Trilean!,
    ss: Integer,
    se: Integer,
) -> CheckerState = {
    if type_is_unknown_id(state.type_arena, cond_tid) {
        state
    } else if type_is_refined_trilean(state.type_arena, cond_tid) {
        state
    } else if type_is_trilean(state.type_arena, cond_tid) {
        if treat_unknown_as_false {
            state
        } else {
            checker_push_error(state, PossiblyUnknownConditionErr(PossiblyUnknownConditionPayload {
                span_start: ss,
                span_end: se,
            }))
        }
    } else {
        checker_push_error(state, NonTrileanConditionErr(NonTrileanConditionPayload {
            found: cond_tid,
            span_start: ss,
            span_end: se,
        }))
    }
}

function check_block(state: CheckerState, block: Block) -> InferResult = {
    let mutable st: CheckerState = checker_with_env(state, push_frame(state.env))
    let stmt_total: Integer = length(block.block_statements)
    let mutable i: Integer = 0
    while i < stmt_total {
        let sid_opt: Integer? = get(block.block_statements, i)
        st = check_statement(st, sid_opt!!)
        i = i + 1
    }
    let mutable val_tid: Integer = 0
    match block.block_final {
        ~0 => {
            let r: AllocTypeResult = alloc_unit(st.type_arena)
            st = checker_with_type_arena(st, r.arena)
            val_tid = r.type_id
        },
        _ => {
            let final_r: InferResult = infer_expression(st, block.block_final!!)
            st = final_r.state
            val_tid = final_r.type_id
        },
    }
    st = checker_with_env(st, pop_frame(st.env))
    InferResult { state: st, type_id: val_tid }
}

function check_initializer(
    state: CheckerState,
    type_ann: Integer?,
    value_expr_id: Integer,
) -> InferResult = {
    let mutable st: CheckerState = state
    let mutable has_ann: Trilean! = false
    let mutable ann_tid: Integer = 0
    match type_ann {
        ~0 => { },
        _ => {
            let ann_r: InferResult = resolve_type_expr(st, type_ann!!)
            st = ann_r.state
            ann_tid = ann_r.type_id
            has_ann = true
        },
    }
    let inferred_r: InferResult = infer_expression(st, value_expr_id)
    st = inferred_r.state
    let inferred_tid: Integer = inferred_r.type_id
    if has_ann {
        if !types_match(st.type_arena, ann_tid, inferred_tid) {
            let val_spanned: SpannedExpr = get_expression(st.parser_arena, value_expr_id)
            st = checker_push_error(st, MismatchErr(MismatchPayload {
                expected: ann_tid,
                found: inferred_tid,
                span_start: val_spanned.span_start,
                span_end: val_spanned.span_end,
            }))
        }
        InferResult { state: st, type_id: ann_tid }
    } else {
        InferResult { state: st, type_id: inferred_tid }
    }
}

function check_return(
    state: CheckerState,
    value_opt: Integer?,
    stmt_ss: Integer,
    stmt_se: Integer,
) -> CheckerState = {
    let mutable st: CheckerState = state
    let mutable actual_tid: Integer = 0
    let mutable val_ss: Integer = stmt_ss
    let mutable val_se: Integer = stmt_se
    match value_opt {
        ~0 => {
            let r: AllocTypeResult = alloc_unit(st.type_arena)
            st = checker_with_type_arena(st, r.arena)
            actual_tid = r.type_id
        },
        _ => {
            let val_r: InferResult = infer_expression(st, value_opt!!)
            st = val_r.state
            actual_tid = val_r.type_id
            let val_spanned: SpannedExpr = get_expression(st.parser_arena, value_opt!!)
            val_ss = val_spanned.span_start
            val_se = val_spanned.span_end
        },
    }
    match st.return_type_id {
        ~0 => st,
        _ => {
            let expected_tid: Integer = st.return_type_id!!
            if !types_match(st.type_arena, expected_tid, actual_tid) {
                push_return_mismatch(st, expected_tid, actual_tid, val_ss, val_se)
            } else {
                st
            }
        },
    }
}

function check_assignment(
    state: CheckerState,
    target: String,
    value_expr_id: Integer,
    stmt_ss: Integer,
    stmt_se: Integer,
) -> CheckerState = {
    let value_r: InferResult = infer_expression(state, value_expr_id)
    let mutable st: CheckerState = value_r.state
    let value_tid: Integer = value_r.type_id
    let val_spanned: SpannedExpr = get_expression(st.parser_arena, value_expr_id)
    let binding_opt: Binding? = lookup_binding(st.env, target)
    match binding_opt {
        ~0 => {
            st = checker_push_error(st, UndefinedNameErr(UndefinedNamePayload {
                name: target,
                span_start: stmt_ss,
                span_end: stmt_se,
            }))
        },
        _ => {
            let binding: Binding = binding_opt!!
            if !binding.is_mutable {
                st = checker_push_error(st, AssignToImmutableErr(AssignToImmutablePayload {
                    name: target,
                    span_start: stmt_ss,
                    span_end: stmt_se,
                }))
            }
            if !types_match(st.type_arena, binding.type_id, value_tid) {
                st = checker_push_error(st, MismatchErr(MismatchPayload {
                    expected: binding.type_id,
                    found: value_tid,
                    span_start: val_spanned.span_start,
                    span_end: val_spanned.span_end,
                }))
            }
        },
    }
    st
}

function check_while(state: CheckerState, p: WhileStmtPayload) -> CheckerState = {
    let cond_r: InferResult = infer_expression(state, p.condition)
    let mutable st: CheckerState = cond_r.state
    let cond_tid: Integer = cond_r.type_id
    let cond_spanned: SpannedExpr = get_expression(st.parser_arena, p.condition)
    st = check_condition_type(st, cond_tid, p.treat_unknown_as_false, cond_spanned.span_start, cond_spanned.span_end)
    let loop_st: CheckerState = checker_enter_loop(st)
    let body_r: InferResult = check_block(loop_st, p.body)
    checker_exit_loop(body_r.state)
}

// ── Pattern binding (v0.7.7.4) ───────────────────────────────────
//
// `bind_pattern` walks a parse-side `Pattern` and binds any
// `Identifier` sub-patterns to the appropriate part of the
// scrutinee type. Mirrors Rust `check.rs::bind_pattern` (lines
// 465-530). Literals / wildcards / null / ranges bind nothing.
// Tuple recurses element-by-element; Or only binds from the first
// alternative (the others must be shape-compatible per parser
// invariants). EnumVariant unwraps the matching variant's payload.
// OutcomeArm unwraps Positive→value_type / Negative→error_type;
// Zero arm has no payload.
//
// v0.7.7.4 only calls this from `check_for` (the parser-side
// `MatchExpr` isn't surfaced yet — gap noted in TODO.md).

function bind_pattern(state: CheckerState, pattern_id: Integer, scrutinee_tid: Integer) -> CheckerState = {
    let spanned: SpannedPattern = get_pattern(state.parser_arena, pattern_id)
    match spanned.node {
        WildcardPattern => state,
        NullPat => state,
        LiteralPat(_) => state,
        RangePat(_) => state,
        IdentifierPattern(sp) => {
            checker_with_env(state, declare(state.env, sp.text, scrutinee_tid))
        },
        TuplePat(children) => {
            let child_total: Integer = length(children)
            let scrut_node_opt: TypeNode? = get_type(state.type_arena, scrutinee_tid)
            let mutable element_ids: Vector<Integer> = new()
            let mutable use_unknowns: Trilean! = true
            match scrut_node_opt {
                ~0 => { },
                _ => {
                    match scrut_node_opt!!.kind {
                        TupleKind(p) => {
                            if length(p.elements) == child_total {
                                element_ids = p.elements
                                use_unknowns = false
                            }
                        },
                        _ => { },
                    }
                },
            }
            let mutable st: CheckerState = state
            let mutable i: Integer = 0
            while i < child_total {
                let child_id: Integer = get(children, i)!!
                let mutable sub_tid: Integer = 0
                if use_unknowns {
                    let r: AllocTypeResult = alloc_unknown(st.type_arena)
                    st = checker_with_type_arena(st, r.arena)
                    sub_tid = r.type_id
                } else {
                    sub_tid = get(element_ids, i)!!
                }
                st = bind_pattern(st, child_id, sub_tid)
                i = i + 1
            }
            st
        },
        OrPat(alternatives) => {
            // Bind only from the first alternative — others must be
            // shape-compatible. Mirrors Rust check.rs:483-490.
            if length(alternatives) == 0 {
                state
            } else {
                let first: Integer = get(alternatives, 0)!!
                bind_pattern(state, first, scrutinee_tid)
            }
        },
        EnumVariantPat(p) => {
            match p.payload {
                ~0 => state,
                _ => {
                    let scrut_node_opt: TypeNode? = get_type(state.type_arena, scrutinee_tid)
                    let mutable sub_tid: Integer = 0
                    let mutable found: Trilean! = false
                    match scrut_node_opt {
                        ~0 => { },
                        _ => {
                            match scrut_node_opt!!.kind {
                                UserEnumKind(e) => {
                                    let total: Integer = length(e.variants)
                                    let mutable i: Integer = 0
                                    while i < total {
                                        let v: UserEnumVariantPayload = get(e.variants, i)!!
                                        if v.name == p.variant_name {
                                            match v.payload_type {
                                                ~0 => { },
                                                _ => {
                                                    sub_tid = v.payload_type!!
                                                    found = true
                                                },
                                            }
                                        }
                                        i = i + 1
                                    }
                                },
                                _ => { },
                            }
                        },
                    }
                    if !found {
                        let r: AllocTypeResult = alloc_unknown(state.type_arena)
                        let st2: CheckerState = checker_with_type_arena(state, r.arena)
                        bind_pattern(st2, p.payload!!, r.type_id)
                    } else {
                        bind_pattern(state, p.payload!!, sub_tid)
                    }
                },
            }
        },
        OutcomeArmPat(p) => {
            match p.payload {
                ~0 => state,
                _ => {
                    let scrut_node_opt: TypeNode? = get_type(state.type_arena, scrutinee_tid)
                    let mutable sub_tid: Integer = 0
                    let mutable resolved: Trilean! = false
                    match scrut_node_opt {
                        ~0 => { },
                        _ => {
                            match scrut_node_opt!!.kind {
                                OutcomeKind(o) => {
                                    match p.arm {
                                        PositiveArm => { sub_tid = o.value_type resolved = true },
                                        NegativeArm => { sub_tid = o.error_type resolved = true },
                                        ZeroArm => { },
                                    }
                                },
                                NullableKind(n) => {
                                    match p.arm {
                                        PositiveArm => { sub_tid = n.inner resolved = true },
                                        _ => { },
                                    }
                                },
                                _ => { },
                            }
                        },
                    }
                    if !resolved {
                        let r: AllocTypeResult = alloc_unknown(state.type_arena)
                        let st2: CheckerState = checker_with_type_arena(state, r.arena)
                        bind_pattern(st2, p.payload!!, r.type_id)
                    } else {
                        bind_pattern(state, p.payload!!, sub_tid)
                    }
                },
            }
        },
    }
}

// Extract the element type of an iterable. Range<T> → T;
// Vector<T> (built-in shell with `__element` field) → T;
// anything else → Unknown.
function iterable_element_type(state: CheckerState, iter_tid: Integer) -> InferResult = {
    let node_opt: TypeNode? = get_type(state.type_arena, iter_tid)
    match node_opt {
        ~0 => infer_unknown(state),
        _ => {
            match node_opt!!.kind {
                RangeKind(r) => InferResult { state: state, type_id: r.element },
                UserStructKind(s) => {
                    if s.name == "Vector" && length(s.fields) > 0 {
                        let elem: UserStructFieldPayload = get(s.fields, 0)!!
                        InferResult { state: state, type_id: elem.type_id }
                    } else {
                        infer_unknown(state)
                    }
                },
                _ => infer_unknown(state),
            }
        },
    }
}

function check_for(state: CheckerState, p: ForStmtPayload) -> CheckerState = {
    let iter_r: InferResult = infer_expression(state, p.iterable)
    let elem_r: InferResult = iterable_element_type(iter_r.state, iter_r.type_id)
    let with_frame: CheckerState = checker_with_env(elem_r.state, push_frame(elem_r.state.env))
    let bound: CheckerState = bind_pattern(with_frame, p.variable, elem_r.type_id)
    let loop_st: CheckerState = checker_enter_loop(bound)
    let body_r: InferResult = check_block(loop_st, p.body)
    let exited: CheckerState = checker_exit_loop(body_r.state)
    checker_with_env(exited, pop_frame(exited.env))
}

function check_statement(state: CheckerState, stmt_id: Integer) -> CheckerState = {
    let spanned: SpannedStmt = get_statement(state.parser_arena, stmt_id)
    let ss: Integer = spanned.span_start
    let se: Integer = spanned.span_end
    match spanned.node {
        LetStmt(p) => {
            let init_r: InferResult = check_initializer(state, p.type_annotation, p.value)
            let new_env: TypeEnvironment = declare_with_mut(init_r.state.env, p.name, init_r.type_id, p.is_mutable)
            checker_with_env(init_r.state, new_env)
        },
        ConstantStmt(p) => {
            let init_r: InferResult = check_initializer(state, p.type_annotation, p.value)
            let new_env: TypeEnvironment = declare(init_r.state.env, p.name, init_r.type_id)
            checker_with_env(init_r.state, new_env)
        },
        ReturnStmt(p) => check_return(state, p.value, ss, se),
        BreakStmt(p) => {
            match p.value {
                ~0 => state,
                _ => {
                    let r: InferResult = infer_expression(state, p.value!!)
                    r.state
                },
            }
        },
        ContinueStmt => state,
        ForStmt(p) => check_for(state, p),
        WhileStmt(p) => check_while(state, p),
        LoopStmt(p) => {
            let loop_st: CheckerState = checker_enter_loop(state)
            let body_r: InferResult = check_block(loop_st, p.body)
            checker_exit_loop(body_r.state)
        },
        AssignStmt(p) => check_assignment(state, p.target, p.value, ss, se),
        ExpressionStmt(p) => {
            let expr_r: InferResult = infer_expression(state, p.expression)
            expr_r.state
        },
    }
}

// ── Item declaration (pass 1) ─────────────────────────────────────

function declare_function_signature(
    state: CheckerState,
    def: FunctionDef,
    ss: Integer,
    se: Integer,
) -> CheckerState = {
    let mutable st: CheckerState = checker_with_env(state, push_frame(state.env))
    let tp_total: Integer = length(def.type_params)
    let mutable ti: Integer = 0
    while ti < tp_total {
        let tp_opt: String? = get(def.type_params, ti)
        let tp: String = tp_opt!!
        let r: AllocTypeResult = alloc_type_param(st.type_arena, tp)
        st = checker_with_type_arena(st, r.arena)
        st = checker_with_env(st, declare(st.env, tp, r.type_id))
        ti = ti + 1
    }
    let mutable param_ids: Vector<Integer> = new()
    let param_total: Integer = length(def.parameters)
    let mutable pi: Integer = 0
    while pi < param_total {
        let param_opt: FunctionParam? = get(def.parameters, pi)
        let param: FunctionParam = param_opt!!
        let pr: InferResult = resolve_type_expr(st, param.type_annotation)
        st = pr.state
        param_ids = push(param_ids, pr.type_id)
        pi = pi + 1
    }
    let mutable ret_id: Integer = 0
    match def.return_type {
        ~0 => {
            let r: AllocTypeResult = alloc_unit(st.type_arena)
            st = checker_with_type_arena(st, r.arena)
            ret_id = r.type_id
        },
        _ => {
            let ret_r: InferResult = resolve_type_expr(st, def.return_type!!)
            st = ret_r.state
            ret_id = ret_r.type_id
        },
    }
    st = checker_with_env(st, pop_frame(st.env))
    let fn_r: AllocTypeResult = alloc_function(st.type_arena, def.type_params, param_ids, ret_id)
    st = checker_with_type_arena(st, fn_r.arena)
    checker_with_env(st, declare(st.env, def.name, fn_r.type_id))
}

function declare_constant_signature(
    state: CheckerState,
    p: ConstantItemPayload,
) -> CheckerState = {
    let mutable st: CheckerState = state
    let mutable type_id: Integer = 0
    let mutable has_ann: Trilean! = false
    match p.type_annotation {
        ~0 => { },
        _ => {
            let r: InferResult = resolve_type_expr(st, p.type_annotation!!)
            st = r.state
            type_id = r.type_id
            has_ann = true
        },
    }
    if !has_ann {
        let r: AllocTypeResult = alloc_unknown(st.type_arena)
        st = checker_with_type_arena(st, r.arena)
        type_id = r.type_id
    }
    checker_with_env(st, declare(st.env, p.name, type_id))
}

function declare_struct_signature(
    state: CheckerState,
    def: StructDef,
    ss: Integer,
    se: Integer,
) -> CheckerState = {
    // Push frame so type params are visible during field-type
    // resolution (mirrors Rust check.rs:171-181).
    let mutable st: CheckerState = checker_with_env(state, push_frame(state.env))
    let tp_total: Integer = length(def.type_params)
    let mutable ti: Integer = 0
    while ti < tp_total {
        let tp: String = get(def.type_params, ti)!!
        let r: AllocTypeResult = alloc_type_param(st.type_arena, tp)
        st = checker_with_type_arena(st, r.arena)
        st = checker_with_env(st, declare(st.env, tp, r.type_id))
        ti = ti + 1
    }
    let mutable fields: Vector<UserStructFieldPayload> = new()
    let f_total: Integer = length(def.fields)
    let mutable fi: Integer = 0
    while fi < f_total {
        let field: StructField = get(def.fields, fi)!!
        let fr: InferResult = resolve_type_expr(st, field.type_annotation)
        st = fr.state
        fields = push(fields, UserStructFieldPayload {
            name: field.name,
            type_id: fr.type_id,
        })
        fi = fi + 1
    }
    st = checker_with_env(st, pop_frame(st.env))
    let r: AllocTypeResult = alloc_user_struct(st.type_arena, def.name, def.type_params, fields)
    st = checker_with_type_arena(st, r.arena)
    checker_with_env(st, declare(st.env, def.name, r.type_id))
}

function declare_enum_signature(
    state: CheckerState,
    def: EnumDef,
    ss: Integer,
    se: Integer,
) -> CheckerState = {
    let mutable st: CheckerState = checker_with_env(state, push_frame(state.env))
    let tp_total: Integer = length(def.type_params)
    let mutable ti: Integer = 0
    while ti < tp_total {
        let tp: String = get(def.type_params, ti)!!
        let r: AllocTypeResult = alloc_type_param(st.type_arena, tp)
        st = checker_with_type_arena(st, r.arena)
        st = checker_with_env(st, declare(st.env, tp, r.type_id))
        ti = ti + 1
    }
    let mutable variants: Vector<UserEnumVariantPayload> = new()
    let v_total: Integer = length(def.variants)
    let mutable vi: Integer = 0
    while vi < v_total {
        let variant: EnumVariant = get(def.variants, vi)!!
        let mutable payload_id: Integer? = ~0
        match variant.payload {
            ~0 => { },
            _ => {
                let pr: InferResult = resolve_type_expr(st, variant.payload!!)
                st = pr.state
                payload_id = pr.type_id
            },
        }
        variants = push(variants, UserEnumVariantPayload {
            name: variant.name,
            payload_type: payload_id,
        })
        vi = vi + 1
    }
    st = checker_with_env(st, pop_frame(st.env))
    let r: AllocTypeResult = alloc_user_enum(st.type_arena, def.name, def.type_params, variants)
    st = checker_with_type_arena(st, r.arena)
    checker_with_env(st, declare(st.env, def.name, r.type_id))
}

function declare_item_pass1(state: CheckerState, item_id: Integer) -> CheckerState = {
    let spanned: SpannedItem = get_item(state.parser_arena, item_id)
    let ss: Integer = spanned.span_start
    let se: Integer = spanned.span_end
    match spanned.node {
        FunctionItem(def) => declare_function_signature(state, def, ss, se),
        ConstantItem(p) => declare_constant_signature(state, p),
        StructItem(def) => declare_struct_signature(state, def, ss, se),
        EnumItem(def) => declare_enum_signature(state, def, ss, se),
        TypeAliasItem(_) => state,
        ImportItem(_) => state,
        ImportFromItem(_) => state,
        ModuleItem(_) => state,
    }
}

// ── Item checking (pass 2) ────────────────────────────────────────

function check_function(
    state: CheckerState,
    def: FunctionDef,
    item_ss: Integer,
    item_se: Integer,
) -> CheckerState = {
    let mutable st: CheckerState = checker_with_env(state, push_frame(state.env))
    let tp_total: Integer = length(def.type_params)
    let mutable ti: Integer = 0
    while ti < tp_total {
        let tp_opt: String? = get(def.type_params, ti)
        let tp: String = tp_opt!!
        let r: AllocTypeResult = alloc_type_param(st.type_arena, tp)
        st = checker_with_type_arena(st, r.arena)
        st = checker_with_env(st, declare(st.env, tp, r.type_id))
        ti = ti + 1
    }
    let mutable ret_id: Integer = 0
    match def.return_type {
        ~0 => {
            let r: AllocTypeResult = alloc_unit(st.type_arena)
            st = checker_with_type_arena(st, r.arena)
            ret_id = r.type_id
        },
        _ => {
            let ret_r: InferResult = resolve_type_expr(st, def.return_type!!)
            st = ret_r.state
            ret_id = ret_r.type_id
        },
    }
    st = checker_with_return_type(st, ret_id)
    let param_total: Integer = length(def.parameters)
    let mutable pi: Integer = 0
    while pi < param_total {
        let param_opt: FunctionParam? = get(def.parameters, pi)
        let param: FunctionParam = param_opt!!
        let pr: InferResult = resolve_type_expr(st, param.type_annotation)
        st = pr.state
        st = checker_with_env(st, declare(st.env, param.name, pr.type_id))
        pi = pi + 1
    }
    let mutable body_tid: Integer = 0
    let mutable body_ss: Integer = item_ss
    let mutable body_se: Integer = item_se
    match def.body {
        BlockBody(block) => {
            let body_r: InferResult = check_block(st, block)
            st = body_r.state
            body_tid = body_r.type_id
        },
        ExpressionBody(expr_id) => {
            let body_r: InferResult = infer_expression(st, expr_id)
            st = body_r.state
            body_tid = body_r.type_id
            let expr_spanned: SpannedExpr = get_expression(st.parser_arena, expr_id)
            body_ss = expr_spanned.span_start
            body_se = expr_spanned.span_end
        },
    }
    if !types_match(st.type_arena, ret_id, body_tid) {
        st = push_return_mismatch(st, ret_id, body_tid, body_ss, body_se)
    }
    st = checker_clear_return_type(st)
    checker_with_env(st, pop_frame(st.env))
}

function check_item_pass2(state: CheckerState, item_id: Integer) -> CheckerState = {
    let spanned: SpannedItem = get_item(state.parser_arena, item_id)
    match spanned.node {
        FunctionItem(def) => check_function(state, def, spanned.span_start, spanned.span_end),
        _ => state,
    }
}

// ── Two-pass checker ──────────────────────────────────────────────

function check_program(state: CheckerState, item_ids: Vector<Integer>) -> CheckerState = {
    let total: Integer = length(item_ids)
    let mutable st: CheckerState = state
    let mutable i: Integer = 0
    while i < total {
        let id_opt: Integer? = get(item_ids, i)
        st = declare_item_pass1(st, id_opt!!)
        i = i + 1
    }
    let mutable j: Integer = 0
    while j < total {
        let id_opt: Integer? = get(item_ids, j)
        st = check_item_pass2(st, id_opt!!)
        j = j + 1
    }
    st
}

public function check_resolved(program: ResolvedProgram) -> Vector<TypeError> = {
    let mutable mut_errors: Vector<TypeError> = new()
    let max_modules: Integer = resolved_program_module_count(program)
    let mutable module_types: Vector<HashMap<String, Integer>> = new()

    let prelude: PreludeResult = with_prelude()
    let mutable global_arena: TypeArena = prelude.type_arena
    let root_id: Integer = module_id_raw(resolved_program_root(program))

    // Pass 1: Collect declared types per module.
    // For v0.7.7.2 we just do 1 iteration since we don't have UserStruct fields to resolve yet.
    let mutable mi: Integer = 0
    while mi < max_modules {
        let mod: Module = get(program.modules, mi)!!
        let arena: Arena = get(program.arenas, arena_id_raw(mod.arena_id))!!
        let initial_state: CheckerState = CheckerState {
            type_arena: global_arena,
            env: type_env_new(),
            errors: new(),
            return_type_id: ~0,
            in_loop: false,
            parser_arena: arena,
        }
        let items_len: Integer = length(mod.item_ids)
        let mutable ii: Integer = 0
        let mutable st: CheckerState = initial_state
        while ii < items_len {
            st = declare_item_pass1(st, get(mod.item_ids, ii)!!)
            ii = ii + 1
        }
        let frame: Frame = get(st.env.frames, 0)!!
        let mutable local_types: HashMap<String, Integer> = hashmap_new()
        let keys: Vector<String> = hashmap_keys(frame.names)
        let keys_len: Integer = length(keys)
        let mutable ki: Integer = 0
        while ki < keys_len {
            let k: String = get(keys, ki)!!
            let binding: Binding = hashmap_get(frame.names, k)!!
            insert(local_types, k, binding.type_id)
            ki = ki + 1
        }
        module_types = push(module_types, local_types)
        global_arena = st.type_arena
        mi = mi + 1
    }

    // Pass 2: Check each module with seeded environment.
    mi = 0
    while mi < max_modules {
        let mod: Module = get(program.modules, mi)!!
        let arena: Arena = get(program.arenas, arena_id_raw(mod.arena_id))!!
        let mutable initial_env: TypeEnvironment = if mi == root_id { prelude.env } else { type_env_new() }

        let bindings_keys: Vector<String> = hashmap_keys(mod.bindings)
        let bindings_len: Integer = length(bindings_keys)
        let mutable bi: Integer = 0
        while bi < bindings_len {
            let local_name: String = get(bindings_keys, bi)!!
            let abs_path: AbsolutePath = hashmap_get(mod.bindings, local_name)!!
            let src_path: ModulePath = absolute_path_module(abs_path)
            let item_name: String = absolute_path_name(abs_path)

            // TODO: In Triết module path matching, if source_path == mod.path, continue.
            let src_id_opt: ModuleId? = find_module_by_path(program, src_path.segments)
            match src_id_opt {
                ~0 => { },
                _ => {
                    let src_idx: Integer = module_id_raw(src_id_opt!!)
                    if src_idx != mi {
                        let src_types: HashMap<String, Integer> = get(module_types, src_idx)!!
                        match hashmap_contains(src_types, item_name) {
                            true => {
                                let ty_id: Integer = hashmap_get(src_types, item_name)!!
                                initial_env = declare(initial_env, local_name, ty_id)
                            },
                            _ => { },
                        }
                    }
                },
            }
            bi = bi + 1
        }

        let initial: CheckerState = CheckerState {
            type_arena: global_arena,
            env: initial_env,
            errors: new(),
            return_type_id: ~0,
            in_loop: false,
            parser_arena: arena,
        }
        let final_state: CheckerState = check_program(initial, mod.item_ids)
        let err_len: Integer = length(final_state.errors)
        let mutable ei: Integer = 0
        while ei < err_len {
            mut_errors = push(mut_errors, get(final_state.errors, ei)!!)
            ei = ei + 1
        }
        global_arena = final_state.type_arena
        mi = mi + 1
    }

    mut_errors
}

function check_module(is_root: Trilean!, arena: Arena, item_ids: Vector<Integer>) -> Vector<TypeError> = {
    let prelude: PreludeResult = with_prelude()
    let initial_env: TypeEnvironment = if is_root { prelude.env } else { type_env_new() }
    let initial: CheckerState = CheckerState {
        type_arena: prelude.type_arena,
        env: initial_env,
        errors: new(),
        return_type_id: ~0,
        in_loop: false,
        parser_arena: arena,
    }
    let final_state: CheckerState = check_program(initial, item_ids)
    final_state.errors
}

/// Type-check a Triết source string, returning all errors (empty on success).
public function check_source(source: String) -> Vector<TypeError> = {
    let tokens_outcome: Vector<SpannedToken>~LexError = lex(source)
    match tokens_outcome {
        ~+ tokens => {
            let pstate: ParserState = parser_new(tokens)
            let pstep: ParseProgramStep = parse_program(pstate)
            check_module(true, pstep.program.arena, pstep.program.item_ids)
        },
        ~- _ => new(),
    }
}

// ── v0.7.7.2 smoke — literals + bindings + control flow ──────────

public function control_flow_smoke_main() -> Unit = {
    // Test 1: empty program → no errors
    let e1: Vector<TypeError> = check_source("")
    assert(length(e1) == 0)

    // Test 2: simple integer return expression body → no errors
    let e2: Vector<TypeError> = check_source("function f() -> Integer = 42")
    assert(length(e2) == 0)

    // Test 3: let binding + arithmetic block body → no errors
    let e3: Vector<TypeError> = check_source("function f() -> Integer { let x: Integer = 5 x + 3 }")
    assert(length(e3) == 0)

    // Test 4: return type mismatch (Integer body, String declared) → 1 error
    let e4: Vector<TypeError> = check_source("function f() -> String = 42")
    assert(length(e4) == 1)

    // Test 5: undefined name → 1 error
    let e5: Vector<TypeError> = check_source("function f() -> Integer = no_such_name")
    assert(length(e5) == 1)

    // Test 6: while loop with Trilean! condition and mutable counter → no errors
    let src6: String = "function f() -> Unit { let mutable i: Integer = 0 while i < 10 { i = i + 1 } }"
    let e6: Vector<TypeError> = check_source(src6)
    assert(length(e6) == 0)

    // Test 7: assign to immutable → 1 error
    let src7: String = "function f() -> Unit { let x: Integer = 0 x = 1 }"
    let e7: Vector<TypeError> = check_source(src7)
    assert(length(e7) == 1)

    // Test 8: Trilean literal types — true/false are Trilean!, unknown is Trilean
    let src8: String = "function f() -> Trilean! = true"
    let e8: Vector<TypeError> = check_source(src8)
    assert(length(e8) == 0)

    // Test 9: arithmetic on mixed numeric types (Integer + Long) → ≥1 error
    let src9: String = "function f() -> Long = 1 + 2_long"
    let e9: Vector<TypeError> = check_source(src9)
    assert(length(e9) >= 1)

    // Test 10: ordering produces Trilean! — usable directly in `while`
    let src10: String = "function f() -> Integer = { let mutable x: Integer = 0 while x < 3 { x = x + 1 } x }"
    let e10: Vector<TypeError> = check_source(src10)
    assert(length(e10) == 0)

    // Test 11: let binding + unary negate. Note: explicit `;`
    // after the let binding to keep the parser from greedily
    // consuming `-c` as a binary `7 - c`. Pre-v0.7.11.1g the
    // `function f() = { … }` form rejected entirely so this
    // ambiguity was masked; post-fix the test source must
    // disambiguate explicitly.
    let src11: String = "function f() -> Integer = { let c: Integer = 7; -c }"
    let e11: Vector<TypeError> = check_source(src11)
    assert(length(e11) == 0)

    // Test 12: Trilean (unknown) condition without `while?` → E1033 PossiblyUnknownCondition
    let src12: String = "function f() -> Unit { while unknown { } }"
    let e12: Vector<TypeError> = check_source(src12)
    assert(length(e12) == 1)

    println("v0.7.7.2 typecheck control-flow smoke OK")
}

// ── v0.7.7.3 smoke — function calls + generic inference ──────────

public function generic_smoke_main() -> Unit = {
    // Test 1: prelude call — `println` accepts a String → no errors
    let g1: Vector<TypeError> = check_source("function main() -> Unit = println(\"hi\")")
    assert(length(g1) == 0)

    // Test 2: user-defined function + correct call → no errors
    let src2: String = "function add(x: Integer, y: Integer) -> Integer = x + y\nfunction main() -> Integer = add(1, 2)"
    let g2: Vector<TypeError> = check_source(src2)
    assert(length(g2) == 0)

    // Test 3: wrong arity (1 arg, expected 2) → 1 error
    let src3: String = "function add(x: Integer, y: Integer) -> Integer = x + y\nfunction main() -> Integer = add(1)"
    let g3: Vector<TypeError> = check_source(src3)
    assert(length(g3) == 1)

    // Test 4: argument type mismatch (String for Integer) → 1 error
    let src4: String = "function add(x: Integer, y: Integer) -> Integer = x + y\nfunction main() -> Integer = add(1, \"two\")"
    let g4: Vector<TypeError> = check_source(src4)
    assert(length(g4) == 1)

    // Test 5: calling a non-function value → ≥1 error (NotCallable)
    let src5: String = "function main() -> Integer = (5)(1)"
    let g5: Vector<TypeError> = check_source(src5)
    assert(length(g5) >= 1)

    // Test 6: generic function — single TypeParam, return inferred from argument
    let src6: String = "function identity<T>(value: T) -> T = value\nfunction main() -> Integer = identity(42)"
    let g6: Vector<TypeError> = check_source(src6)
    assert(length(g6) == 0)

    // Test 7: generic function — return type mismatch after substitution
    let src7: String = "function identity<T>(value: T) -> T = value\nfunction main() -> String = identity(42)"
    let g7: Vector<TypeError> = check_source(src7)
    assert(length(g7) == 1)

    // Test 8: prelude `to_string` (Integer -> String) round-trips
    let src8: String = "function main() -> String = to_string(7)"
    let g8: Vector<TypeError> = check_source(src8)
    assert(length(g8) == 0)

    println("v0.7.7.3 typecheck generic-call smoke OK")
}

// ── v0.7.7.4 smoke — structs + enums + tuple/generic types + patterns ──

public function struct_enum_smoke_main() -> Unit = {
    // Test 1: simple struct declaration + minimal main
    let s1: String = "struct Point { x: Integer, y: Integer }\nfunction main() -> Integer = 0"
    let r1: Vector<TypeError> = check_source(s1)
    assert(length(r1) == 0)

    // Test 2: enum declaration with unit + payload variants
    let s2: String = "enum Option { None, Some(Integer) }\nfunction main() -> Integer = 0"
    let r2: Vector<TypeError> = check_source(s2)
    assert(length(r2) == 0)

    // Test 3: struct field type referencing an undeclared name → 1 error
    let s3: String = "struct Bad { x: NoSuchType }\nfunction main() -> Integer = 0"
    let r3: Vector<TypeError> = check_source(s3)
    assert(length(r3) == 1)

    // Test 4: Vector<T> built-in shell resolves
    let s4: String = "function pick<T>(v: Vector<T>) -> Integer = 0\nfunction main() -> Integer = 0"
    let r4: Vector<TypeError> = check_source(s4)
    assert(length(r4) == 0)

    // Test 5: HashMap<K, V> built-in shell
    let s5: String = "function pick<K, V>(m: HashMap<K, V>) -> Integer = 0\nfunction main() -> Integer = 0"
    let r5: Vector<TypeError> = check_source(s5)
    assert(length(r5) == 0)

    // Test 6: Vector wrong arity → ≥1 error. (Both passes resolve the
    // annotation, so the WrongArity surfaces twice — matches Rust.)
    let s6: String = "function pick(v: Vector<Integer, Integer>) -> Integer = 0\nfunction main() -> Integer = 0"
    let r6: Vector<TypeError> = check_source(s6)
    assert(length(r6) >= 1)

    // Test 7: tuple type annotation resolves (tuple literal expr is
    // not yet parser-side, so body inference may emit no error here).
    let s7: String = "function pair() -> (Integer, String) = (1, \"hi\")\nfunction main() -> Integer = 0"
    let r7: Vector<TypeError> = check_source(s7)
    assert(length(r7) <= 1)

    // Test 8: For loop with identifier pattern over a Range<Integer>
    let s8: String = "function main() -> Integer = { let mutable s: Integer = 0 for i in 0..10 { s = s + i } s }"
    let r8: Vector<TypeError> = check_source(s8)
    assert(length(r8) == 0)

    // Test 9: For loop with wildcard pattern — no binding leak
    let s9: String = "function main() -> Integer = { let mutable n: Integer = 0 for _ in 0..3 { n = n + 1 } n }"
    let r9: Vector<TypeError> = check_source(s9)
    assert(length(r9) == 0)

    // Test 10: For loop binds variable visible in body
    let s10: String = "function main() -> Integer = { let mutable s: Integer = 0 for i in 0..5 { s = s + i } s }"
    let r10: Vector<TypeError> = check_source(s10)
    assert(length(r10) == 0)

    // Test 11: Loop variable scope is bounded by the for-body frame —
    // `i` used after the body must trigger E1002 UndefinedName. The
    // post-body `let x = i` form avoids block-final parse ambiguity.
    let s11: String = "function main() -> Integer { for i in 0..5 { } let x: Integer = i x }"
    let r11: Vector<TypeError> = check_source(s11)
    assert(length(r11) >= 1)

    // Test 12: Generic user struct — Pair<Integer, String> resolves
    let s12: String = "struct Pair<A, B> { first: A, second: B }\nfunction take(p: Pair<Integer, String>) -> Integer = 0\nfunction main() -> Integer = 0"
    let r12: Vector<TypeError> = check_source(s12)
    assert(length(r12) == 0)

    // Test 13: Generic user struct — wrong arity → ≥1 error
    let s13: String = "struct Pair<A, B> { first: A, second: B }\nfunction take(p: Pair<Integer>) -> Integer = 0\nfunction main() -> Integer = 0"
    let r13: Vector<TypeError> = check_source(s13)
    assert(length(r13) >= 1)

    println("v0.7.7.4 typecheck struct/enum/pattern smoke OK")
}

// ── v0.7.7.4b smoke — Outcome / Elvis / Range / FieldAccess body inference ──

public function outcome_field_smoke_main() -> Unit = {
    // Test 1: Range over Integer → Range<Integer>, used in For
    let s1: String = "function main() -> Integer = { let mutable s: Integer = 0 for i in 0..10 { s = s + i } s }"
    let r1: Vector<TypeError> = check_source(s1)
    assert(length(r1) == 0)

    // Test 2: Range over Integer endpoints — clean, no mismatch.
    // Mixed-endpoint Range mismatch needs `Range<T>` annotation
    // support — defer the cross-type assertion to v0.7.7.5.
    let s2: String = "function main() -> Integer = { for j in 1..5 { } 0 }"
    let r2: Vector<TypeError> = check_source(s2)
    assert(length(r2) == 0)

    // Test 3: FieldAccess on UserStruct returns the field's type
    let s3: String = "struct Point { x: Integer, y: Integer }\nfunction get_x(p: Point) -> Integer = p.x\nfunction main() -> Integer = 0"
    let r3: Vector<TypeError> = check_source(s3)
    assert(length(r3) == 0)

    // Test 4: FieldAccess unknown member → E1015 UnknownMember
    let s4: String = "struct Point { x: Integer }\nfunction get_z(p: Point) -> Integer = p.z\nfunction main() -> Integer = 0"
    let r4: Vector<TypeError> = check_source(s4)
    assert(length(r4) >= 1)

    // Test 5: FieldAccess return-type mismatch
    let s5: String = "struct Point { x: Integer }\nfunction get_x(p: Point) -> String = p.x\nfunction main() -> Integer = 0"
    let r5: Vector<TypeError> = check_source(s5)
    assert(length(r5) >= 1)

    // Test 6: Elvis on Nullable → unwrapped type
    let s6: String = "function get_or(x: Integer?) -> Integer = x ?: 0\nfunction main() -> Integer = 0"
    let r6: Vector<TypeError> = check_source(s6)
    assert(length(r6) == 0)

    // Test 7: Elvis on non-Nullable → E1012 NotNullable
    let s7: String = "function get_or(x: Integer) -> Integer = x ?: 0\nfunction main() -> Integer = 0"
    let r7: Vector<TypeError> = check_source(s7)
    assert(length(r7) >= 1)

    // Test 8: Elvis default type mismatch → E1003 Mismatch
    let s8: String = "function get_or(x: Integer?) -> Integer = x ?: \"zero\"\nfunction main() -> Integer = 0"
    let r8: Vector<TypeError> = check_source(s8)
    assert(length(r8) >= 1)

    // Test 9: Outcome constructor against T~E return type — success arm
    let s9: String = "function parse(s: String) -> Integer~String = ~+ 42\nfunction main() -> Integer = 0"
    let r9: Vector<TypeError> = check_source(s9)
    assert(length(r9) == 0)

    // Test 10: Outcome constructor — error arm against T~E
    let s10: String = "function parse(s: String) -> Integer~String = ~- \"bad\"\nfunction main() -> Integer = 0"
    let r10: Vector<TypeError> = check_source(s10)
    assert(length(r10) == 0)

    // Test 11: ZeroArm against binary outcome (no null state) → E1025
    let s11: String = "function bad(s: String) -> Integer~String = ~0\nfunction main() -> Integer = 0"
    let r11: Vector<TypeError> = check_source(s11)
    assert(length(r11) >= 1)

    // Test 12: ZeroArm against T?~E (null-state allowed) → OK
    let s12: String = "function some(s: String) -> Integer?~String = ~0\nfunction main() -> Integer = 0"
    let r12: Vector<TypeError> = check_source(s12)
    assert(length(r12) == 0)

    // Test 13: Outcome default (~:) — inner T~E, default = value type
    let s13: String = "function unwrap_or(o: Integer~String, d: Integer) -> Integer = o ~: d\nfunction main() -> Integer = 0"
    let r13: Vector<TypeError> = check_source(s13)
    assert(length(r13) == 0)

    // ~? propagate operator typechecking is wired in `infer_outcome_propagate`
    // but the capture-binding path hits a runtime regression we haven't
    // root-caused on the Triết-side VM (declare_with_mut sees HashMap
    // field as Unit at runtime — likely a struct-layout corruption
    // triggered deep inside a multi-frame env after the propagate's
    // frame push). The logic mirrors Rust exprs.rs::check_outcome_propagate
    // and exercises clean under the Rust typechecker; defer the smoke
    // assertion to v0.7.7.5 once the runtime path stabilises.

    println("v0.7.7.4b typecheck outcome/field smoke OK")
}

// ─────────────────────────────────────────────────────────────────
// Smoke main — exercises Type construction + display, TypeError
// code/span emission, TypeEnvironment push/pop/declare/lookup so
// the v0.7.7.1 integration test (`typecheck_types_smoke.rs`) can
// confirm the surface compiles + round-trips through the VM.
// v0.7.7.5 supersedes this with the byte-diff `typecheck_differential`
// gate.
// ─────────────────────────────────────────────────────────────────

function assert_string_eq(actual: String, expected: String) -> Unit =
    assert(actual == expected)

public function main() -> Unit = {
    // ── Type arena + primitive allocation ─────────────────────────
    let arena0: TypeArena = type_arena_new()
    let r1: AllocTypeResult = alloc_integer(arena0)
    assert(r1.type_id == 0)
    assert_string_eq(type_display(r1.arena, r1.type_id), "Integer")

    let r2: AllocTypeResult = alloc_string(r1.arena)
    assert(r2.type_id == 1)
    assert_string_eq(type_display(r2.arena, r2.type_id), "String")

    let r3: AllocTypeResult = alloc_trit(r2.arena)
    assert_string_eq(type_display(r3.arena, r3.type_id), "Trit")

    let r4: AllocTypeResult = alloc_tryte(r3.arena)
    assert_string_eq(type_display(r4.arena, r4.type_id), "Tryte")

    let r5: AllocTypeResult = alloc_long(r4.arena)
    assert_string_eq(type_display(r5.arena, r5.type_id), "Long")

    let r6: AllocTypeResult = alloc_unit(r5.arena)
    assert_string_eq(type_display(r6.arena, r6.type_id), "Unit")

    let r7: AllocTypeResult = alloc_unknown(r6.arena)
    assert_string_eq(type_display(r7.arena, r7.type_id), "?")

    // ── Trilean refinement ────────────────────────────────────────
    let r8: AllocTypeResult = alloc_trilean(r7.arena, false)
    assert_string_eq(type_display(r8.arena, r8.type_id), "Trilean")
    let r9: AllocTypeResult = alloc_trilean(r8.arena, true)
    assert_string_eq(type_display(r9.arena, r9.type_id), "Trilean!")
    assert(type_is_trilean(r9.arena, r9.type_id) == true)
    assert(type_is_refined_trilean(r9.arena, r9.type_id) == true)
    assert(type_is_refined_trilean(r9.arena, r8.type_id) == false)

    // ── Numeric predicate ─────────────────────────────────────────
    assert(type_is_numeric(r9.arena, r1.type_id) == true)
    assert(type_is_numeric(r9.arena, r2.type_id) == false)
    assert(type_is_numeric(r9.arena, r3.type_id) == true)
    assert(type_is_numeric(r9.arena, r9.type_id) == false)

    // ── Recursive types: Nullable, Tuple, Range ───────────────────
    let r10: AllocTypeResult = alloc_nullable(r9.arena, r1.type_id)
    assert_string_eq(type_display(r10.arena, r10.type_id), "Integer?")

    let mutable tuple_elems: Vector<Integer> = new()
    tuple_elems = push(tuple_elems, r1.type_id)
    tuple_elems = push(tuple_elems, r2.type_id)
    let r11: AllocTypeResult = alloc_tuple(r10.arena, tuple_elems)
    assert_string_eq(type_display(r11.arena, r11.type_id), "(Integer, String)")

    let r12: AllocTypeResult = alloc_range(r11.arena, r1.type_id)
    assert_string_eq(type_display(r12.arena, r12.type_id), "Range<Integer>")

    // ── Function type ─────────────────────────────────────────────
    let mutable fn_params: Vector<Integer> = new()
    fn_params = push(fn_params, r1.type_id)
    fn_params = push(fn_params, r2.type_id)
    let r13: AllocTypeResult = alloc_function(r12.arena, new(), fn_params, r6.type_id)
    assert_string_eq(type_display(r13.arena, r13.type_id), "function(Integer, String) -> Unit")

    // ── Outcome ───────────────────────────────────────────────────
    let r14: AllocTypeResult = alloc_outcome(r13.arena, r1.type_id, r2.type_id, false)
    assert_string_eq(type_display(r14.arena, r14.type_id), "Integer~String")
    let r15: AllocTypeResult = alloc_outcome(r14.arena, r1.type_id, r2.type_id, true)
    assert_string_eq(type_display(r15.arena, r15.type_id), "Integer?~String")

    // ── User struct / enum / type param ───────────────────────────
    let mutable fields: Vector<UserStructFieldPayload> = new()
    fields = push(fields, UserStructFieldPayload { name: "x", type_id: r1.type_id })
    fields = push(fields, UserStructFieldPayload { name: "y", type_id: r1.type_id })
    let r16: AllocTypeResult = alloc_user_struct(r15.arena, "Point", new(), fields)
    assert_string_eq(type_display(r16.arena, r16.type_id), "Point")

    let mutable variants: Vector<UserEnumVariantPayload> = new()
    variants = push(variants, UserEnumVariantPayload { name: "None", payload_type: ~0 })
    variants = push(variants, UserEnumVariantPayload { name: "Some", payload_type: r1.type_id })
    let r17: AllocTypeResult = alloc_user_enum(r16.arena, "Option", new(), variants)
    assert_string_eq(type_display(r17.arena, r17.type_id), "Option")

    let r18: AllocTypeResult = alloc_type_param(r17.arena, "T")
    assert_string_eq(type_display(r18.arena, r18.type_id), "T")

    // ── TypeError construction + code + span ──────────────────────
    let unknown_err: TypeError = UnknownTypeErr(UnknownTypePayload {
        name: "Foo",
        span_start: 0,
        span_end: 3,
    })
    assert_string_eq(type_error_code(unknown_err), "triet::typecheck::E1001")
    let unknown_span: Vector<Integer> = type_error_span(unknown_err)
    assert(length(unknown_span) == 2)
    assert(get(unknown_span, 0)!! == 0)
    assert(get(unknown_span, 1)!! == 3)

    let undef_err: TypeError = UndefinedNameErr(UndefinedNamePayload {
        name: "bar",
        span_start: 10,
        span_end: 13,
    })
    assert_string_eq(type_error_code(undef_err), "triet::typecheck::E1002")

    let mismatch_err: TypeError = MismatchErr(MismatchPayload {
        expected: r1.type_id,
        found: r2.type_id,
        span_start: 20,
        span_end: 30,
    })
    assert_string_eq(type_error_code(mismatch_err), "triet::typecheck::E1003")

    let dup_err: TypeError = DuplicateNameErr(DuplicateNamePayload {
        name: "x",
        span_start: 40,
        span_end: 41,
    })
    assert_string_eq(type_error_code(dup_err), "triet::typecheck::E1010")

    let possibly_unknown: TypeError = PossiblyUnknownConditionErr(PossiblyUnknownConditionPayload {
        span_start: 100,
        span_end: 110,
    })
    assert_string_eq(type_error_code(possibly_unknown), "triet::typecheck::E1033")

    let trilean_return: TypeError = TrileanReturnNotRefinedErr(TrileanReturnNotRefinedPayload {
        span_start: 200,
        span_end: 210,
    })
    assert_string_eq(type_error_code(trilean_return), "triet::typecheck::E1034")

    let null_dep: TypeError = NullDeprecatedErr(NullDeprecatedPayload {
        span_start: 300,
        span_end: 304,
    })
    assert_string_eq(type_error_code(null_dep), "triet::typecheck::W2001")

    // ── TypeEnvironment push/pop/declare/lookup ───────────────────
    let env0: TypeEnvironment = type_env_new()
    assert(length(env0.frames) == 1)

    let env1: TypeEnvironment = declare(env0, "x", r1.type_id)
    let bx_opt: Binding? = lookup_binding(env1, "x")
    match bx_opt {
        ~0 => assert(false),
        _ => {
            let bx: Binding = bx_opt!!
            assert(bx.type_id == r1.type_id)
            assert(bx.is_mutable == false)
        },
    }

    let env2: TypeEnvironment = declare_with_mut(env1, "y", r2.type_id, true)
    let by_opt: Binding? = lookup_binding(env2, "y")
    match by_opt {
        ~0 => assert(false),
        _ => {
            let by: Binding = by_opt!!
            assert(by.type_id == r2.type_id)
            assert(by.is_mutable == true)
        },
    }

    // Push a new frame, shadow `x`, pop, original visible again.
    let env3: TypeEnvironment = push_frame(env2)
    assert(length(env3.frames) == 2)
    let env4: TypeEnvironment = declare(env3, "x", r3.type_id)
    let shadow_id_opt: Integer? = lookup_type(env4, "x")
    assert(shadow_id_opt!! == r3.type_id)

    let env5: TypeEnvironment = pop_frame(env4)
    assert(length(env5.frames) == 1)
    let restored_id_opt: Integer? = lookup_type(env5, "x")
    assert(restored_id_opt!! == r1.type_id)

    // Missing name returns null.
    let missing_opt: Integer? = lookup_type(env5, "no_such_name")
    match missing_opt {
        ~0 => assert(true),
        _ => assert(false),
    }

    // Pop on root frame is a no-op (defensive).
    let env6: TypeEnvironment = pop_frame(env5)
    assert(length(env6.frames) == 1)

    println("v0.7.7.1 typecheck types smoke OK")
    control_flow_smoke_main()
    generic_smoke_main()
    struct_enum_smoke_main()
    outcome_field_smoke_main()
}
