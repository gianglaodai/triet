function test_half_adder() {
    banner("Half Adder")

    println("a  b  | sum carry")
    println("T  T  |  F    T")
    println("T  F  |  T    F")
    println("U  U  |  U    U")

    println(f"  T+T sum={format_trilean(half_sum(true, true))} carry={format_trilean(half_carry(true, true))}")
    println(f"  T+F sum={format_trilean(half_sum(true, false))} carry={format_trilean(half_carry(true, false))}")
    println(f"  U+U sum={format_trilean(half_sum(unknown, unknown))} carry={format_trilean(half_carry(unknown, unknown))}")
    println("  Half adder: OK")
}

function test_full_adder() {
    banner("Full Adder")

    // 1 + 1 + 0 = 2 → sum=false, carry=true
    // check(full_sum(true, true, false) == false)
    // check(full_carry(true, true, false) == true)

    // 1 + 0 + 0 = 1
    // check(full_sum(true, false, false) == true)
    // check(full_carry(true, false, false) == false)

    // U + U + F = U
    // check(full_sum(unknown, unknown, false) == unknown)
    println("  Full adder: OK")
}

