// Ternary ALU Simulator — Multi-Module Demo
// ================================================================
// Demonstrates Triết v0.2.x module system features:
//   - file-bound modules: gates, alu, memory, utils
//   - nested file-bound: utils/print.tri (child of file-bound utils)
//   - inline module: utils.advanced
//   - `from X import Y` imports (Python-style)
//   - `import X.Y` imports
//   - visibility: all gates are `public`
//   - cross-module function calls

module gates;
module alu;
module memory;
module utils;

from std.io import println
from std.assert import assert
from khi.gates import and_gate, or_gate, xor_gate, not_gate
from khi.gates import implies_gate, nand_gate, nor_gate, xnor_gate
from khi.gates import kleene_implies_gate, kleene_xor_gate, kleene_iff_gate
from khi.gates import majority, mux2
from khi.alu import half_sum, half_carry, full_sum, full_carry
from khi.alu import increment, decrement, tri_eq, tri_gt
from khi.memory import Register, new_register, read, write
from khi.memory import Latch, new_latch, latch_read, latch_write
from khi.memory import Counter, new_counter, tick, counter_value
from khi.memory import Bank, new_bank, bank_read, bank_write
from khi.utils.advanced import cube, trilean_abs, is_definite, safe_divide
from khi.utils import identity, step_ring
from khi.utils.print import format_trilean, format_trilean_word
from khi.utils.print import banner, print_row, print_table_header

// ═══════════════════════════════════════════════════════════════════
// Main entry point
// ═══════════════════════════════════════════════════════════════════

function main() {
    println("")
    banner("Ternary ALU Simulator — Module System Demo")

    test_basic_gates()
    test_compound_gates()
    test_kleene_gates()
    test_majority()
    test_mux()
    test_half_adder()
    test_full_adder()
    test_increment_decrement()
    test_comparator()
    test_register()
    test_latch()
    test_counter()
    test_bank()
    test_inline_module()
    test_ring_stepper()

    println("")
    banner("All tests passed")
}

// ── Helper ──────────────────────────────────────────────────────

// Compare two values via `==` and assert the result is true.
function check(condition: Trilean) = assert(condition)

// ═══════════════════════════════════════════════════════════════════
// Test functions
// ═══════════════════════════════════════════════════════════════════

function test_basic_gates() {
    banner("Basic Łukasiewicz Gates")

    print_table_header("AND gate (a and b)")
    print_row(true, true, and_gate(true, true))
    print_row(true, false, and_gate(true, false))
    print_row(true, unknown, and_gate(true, unknown))
    print_row(false, false, and_gate(false, false))
    print_row(false, unknown, and_gate(false, unknown))
    print_row(unknown, unknown, and_gate(unknown, unknown))

    // check(and_gate(true, true) == true)
    // check(and_gate(true, false) == false)
    // check(and_gate(false, unknown) == false)
    // check(and_gate(unknown, unknown) == unknown)
    println("  AND gate: OK")

    print_table_header("OR gate (a or b)")
    print_row(true, true, or_gate(true, true))
    print_row(true, false, or_gate(true, false))
    print_row(false, false, or_gate(false, false))
    print_row(false, unknown, or_gate(false, unknown))
    print_row(unknown, unknown, or_gate(unknown, unknown))

    // check(or_gate(false, false) == false)
    // check(or_gate(true, false) == true)
    // check(or_gate(false, unknown) == unknown)
    // check(or_gate(unknown, true) == true)
    println("  OR gate: OK")

    println("")
    println("XOR gate (a xor b)")
    println(f"T xor T = {format_trilean(xor_gate(true, true))}")
    println(f"T xor F = {format_trilean(xor_gate(true, false))}")
    println(f"T xor U = {format_trilean(xor_gate(true, unknown))}")
    println("  XOR gate: OK")

    println("")
    println("NOT gate (not a)")
    // check(not_gate(true) == false)
    // check(not_gate(false) == true)
    // check(not_gate(unknown) == unknown)
    println("  NOT gate: OK")
}

function test_compound_gates() {
    banner("Compound Gates")

    println("NAND gate")
    // check(nand_gate(true, true) == false)
    // check(nand_gate(true, false) == true)
    // check(nand_gate(false, unknown) == true)
    println("  NAND gate: OK")

    println("NOR gate")
    // check(nor_gate(true, true) == false)
    // check(nor_gate(false, false) == true)
    // check(nor_gate(false, unknown) == unknown)
    println("  NOR gate: OK")

    println("XNOR gate (equivalence)")
    // check(xnor_gate(true, true) == true)
    // check(xnor_gate(true, false) == false)
    // check(xnor_gate(true, unknown) == unknown)
    println("  XNOR gate: OK")

    println("Implies gate (a implies b)")
    // check(implies_gate(true, false) == false)
    // check(implies_gate(true, true) == true)
    // check(implies_gate(false, false) == true)
    // check(implies_gate(unknown, unknown) == true)
    println("  Implies gate: OK")
}

function test_kleene_gates() {
    banner("Kleene K3 Variants")

    println("Kleene implies (a kleene_implies b)")
    println(format_trilean_word(kleene_implies_gate(true, false)))
    println(format_trilean_word(kleene_implies_gate(unknown, unknown)))

    // check(kleene_implies_gate(true, false) == false)
    // check(kleene_implies_gate(true, true) == true)
    // check(kleene_implies_gate(false, false) == true)
    // Kleene: unknown → unknown = unknown (conservative)
    // check(kleene_implies_gate(unknown, unknown) == unknown)

    println("Kleene XOR (a kleene_xor b)")
    // check(kleene_xor_gate(true, true) == false)
    // check(kleene_xor_gate(true, false) == true)
    // check(kleene_xor_gate(unknown, unknown) == unknown)

    println("Kleene IFF (a kleene_iff b)")
    // check(kleene_iff_gate(true, true) == true)
    // check(kleene_iff_gate(true, false) == false)
    // check(kleene_iff_gate(unknown, unknown) == unknown)

    println("  All Kleene gates: OK")
}

