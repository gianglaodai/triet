function test_register() {
    banner("Register (single-Trilean storage)")

    let r1 = new_register(false)
    // check(read(r1) == false)
    println("  Initial value: OK")

    let r2 = write(r1, true)
    // check(read(r2) == true)
    println("  After write: OK")

    let r3 = write(r2, unknown)
    // check(read(r3) == unknown)
    println("  After second write: OK")

    // Original register unchanged (functional style)
    // check(read(r1) == false)
    println("  Functional semantics: OK")
}

function test_latch() {
    banner("Latch (gated register)")

    let lt = new_latch(false)
    // check(latch_read(lt) == false)

    // Write disabled — should hold old value
    let lt2 = latch_write(lt, true, false)
    // check(latch_read(lt2) == false)
    println("  Hold on disable: OK")

    // Write enabled — should capture new value
    let lt3 = latch_write(lt2, true, true)
    // check(latch_read(lt3) == true)
    println("  Capture on enable: OK")
}

function test_counter() {
    banner("Ring Counter")

    let c = new_counter(false, 9)
    // check(counter_value(c) == false)

    let c1 = tick(c)
    // check(counter_value(c1) == unknown)

    let c2 = tick(c1)
    // check(counter_value(c2) == true)

    let c3 = tick(c2)
    // check(counter_value(c3) == false)
    println("  Counter ring: OK")

    // Counter wraps every 3 ticks (full ring cycle)
    let c4 = tick(tick(tick(c)))
    // check(counter_value(c4) == false)
    println("  Counter wrap: OK")
}

function test_bank() {
    banner("Register Bank (3-register file)")

    let bank = new_bank()
    // check(bank_read(bank, 0) == false)
    // check(bank_read(bank, 1) == unknown)
    // check(bank_read(bank, 2) == true)
    println("  Initial values: OK")

    let bank2 = bank_write(bank, 0, true)
    // check(bank_read(bank2, 0) == true)
    // Other registers unchanged
    // check(bank_read(bank2, 1) == unknown)
    println("  Bank write: OK")
}

