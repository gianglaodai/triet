// FizzBuzz trong Triết — minh họa pattern matching trên tuple
// và phép modulo balanced ternary `%%`.

fn fizzbuzz(n: Integer) -> String =
    match (n %% 3, n %% 5) {
        (0, 0) => "FizzBuzz",
        (0, _) => "Fizz",
        (_, 0) => "Buzz",
        _      => to_string(n),
    }

fn main() {
    for i in 1..=15 {
        println(fizzbuzz(i))
    }
}
